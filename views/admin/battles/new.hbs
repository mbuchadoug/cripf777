<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Create Battle</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <style>
    body{font-family:system-ui;background:#0b0b0b;color:#fff;margin:0}
    .wrap{max-width:900px;margin:34px auto;padding:0 18px}
    a{color:#FFB800;text-decoration:none;font-weight:800}
    .card{background:#141414;border:1px solid #222;border-radius:14px;padding:18px;margin-top:16px}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    @media(max-width:720px){ .row{grid-template-columns:1fr} }
    label{display:block;font-weight:800;margin-bottom:6px}
    input,select,textarea{width:100%;padding:12px;border-radius:12px;border:1px solid #2a2a2a;background:#0f0f0f;color:#fff}
    textarea{min-height:80px}
    .btn{display:inline-block;background:#FFB800;color:#000;padding:12px 18px;border-radius:12px;font-weight:900;border:none;cursor:pointer}
    .muted{color:#9aa3ad}
    .err{color:#ff6b6b;font-weight:800}
  </style>
</head>
<body>
  <div class="wrap">
    <a href="/admin/battles">← Back to Battles</a>

    <div class="card">
      <h2 style="margin:0 0 6px;">Create Battle</h2>
      <div class="muted">Times should be in ISO format (or HTML datetime-local will generate valid values).</div>

      {{#if errors.length}}
        <div style="margin-top:12px;">
          {{#each errors}}
            <div class="err">• {{this}}</div>
          {{/each}}
        </div>
      {{/if}}

      <form method="POST" action="/admin/battles" style="margin-top:14px;">
        <div class="row">
          <div>
            <label>Title</label>
            <input name="title" value="{{form.title}}" placeholder="Daily Math Blitz" required />
          </div>
          <div>
            <label>Category</label>
            <input name="category" value="{{form.category}}" placeholder="math" required />
          </div>
        </div>

        <div class="row" style="margin-top:12px;">
          <div>
            <label>Opens At</label>
            <input type="datetime-local" name="opensAt" value="{{form.opensAt}}" required />
          </div>
          <div>
            <label>Locks At</label>
            <input type="datetime-local" name="locksAt" value="{{form.locksAt}}" required />
          </div>
        </div>

        <div class="row" style="margin-top:12px;">
          <div>
            <label>Ends At</label>
            <input type="datetime-local" name="endsAt" value="{{form.endsAt}}" required />
          </div>
          <div>
            <label>Duration (minutes)</label>
            <input type="number" name="durationMinutes" value="{{form.durationMinutes}}" min="1" max="60" />
          </div>
        </div>

        <div class="row" style="margin-top:12px;">
          <div>
            <label>Question Count</label>
            <input type="number" name="questionCount" value="{{form.questionCount}}" min="3" max="50" />
          </div>
          <div>
            <label>Min Entries</label>
            <input type="number" name="minEntries" value="{{form.minEntries}}" min="2" max="200000" />
          </div>
        </div>

        <div class="row" style="margin-top:12px;">
          <div>
            <label>Entry Fee (cents)</label>
            <input type="number" name="entryFeeCents" value="{{form.entryFeeCents}}" min="0" max="50000" />
          </div>
          <div>
            <label>Platform Fee (%)</label>
            <input type="number" name="platformFeePct" value="{{form.platformFeePct}}" min="0" max="90" />
          </div>
        </div>

    
    
    
              <div class="row" style="margin-top:12px;">
            <div>
              <label>Question Source</label>
              <select name="quizSource">
                <option value="mixed" selected>mixed (bank + AI fallback)</option>
                <option value="bank">bank only</option>
                <option value="ai">AI quizzes only</option>
              </select>
            </div>
            <div class="muted" style="align-self:end;">
              bank = Question collection • ai = AIQuiz collection
            </div>
          </div>
    
            <label>Topics (comma separated)</label>
              <input name="topics" value="{{form.topics}}" placeholder="fractions, algebra" />
            </div>
          </div>
        </div>

        <div style="margin-top:14px;">
          <button class="btn" type="submit">Create Battle</button>
        </div>
      </form>
    </div>
  </div>

<script>
  (function(){
    // Fix difficulty selection after validation error
    const desiredDiff = "{{form.difficulty}}";
    if (desiredDiff) {
      const sel = document.querySelector('select[name="difficulty"]');
      if (sel) {
        for (const opt of sel.options) opt.selected = (opt.value === desiredDiff);
      }
    }

    // Fix source selection after validation error
    const desiredSource = "{{form.quizSource}}";
    if (desiredSource) {
      const sel2 = document.querySelector('select[name="quizSource"]');
      if (sel2) {
        for (const opt of sel2.options) opt.selected = (opt.value === desiredSource);
      }
    }
  })();
</script>

</body>
</html>