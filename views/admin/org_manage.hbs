<!-- ════════════════════════════
     SCRIPTS
════════════════════════════ -->
<script>
/* ── Global helpers ── */
const ORG = '{{org.slug}}';

function api(url, method, body) {
  return fetch(url, {
    method: method || 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: body ? JSON.stringify(body) : undefined
  }).then(r => r.json().then(d => ({ ok: r.ok, status: r.status, data: d })));
}

function toast(id, ok, msg) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = msg;
  el.className = 'result-toast ' + (ok ? 'ok' : 'err');
  el.style.display = 'block';
  if (ok) setTimeout(() => { el.style.display = 'none'; }, 6000);
}

function formToObj(form) {
  const fd = new FormData(form);
  const obj = {};
  for (const [k, v] of fd.entries()) {
    if (obj[k] !== undefined) {
      if (!Array.isArray(obj[k])) obj[k] = [obj[k]];
      obj[k].push(v);
    } else {
      obj[k] = v;
    }
  }
  return obj;
}

/* ── Sidebar open / close (mobile) ── */
function openSidebar() {
  const sb = document.getElementById('sidebar');
  const ov = document.getElementById('sb-overlay');
  if (sb) sb.classList.add('sb-open');
  if (ov) ov.classList.add('show');
  document.body.style.overflow = 'hidden';
}

function closeSidebar() {
  const sb = document.getElementById('sidebar');
  const ov = document.getElementById('sb-overlay');
  if (sb) sb.classList.remove('sb-open');
  if (ov) ov.classList.remove('show');
  document.body.style.overflow = '';
}

/* Desktop sidebar toggle - collapses/expands without overlay */
function toggleSidebarDesktop() {
  if (window.innerWidth <= 768) {
    // On mobile, use the drawer open/close
    const sb = document.getElementById('sidebar');
    if (sb && sb.classList.contains('sb-open')) closeSidebar();
    else openSidebar();
    return;
  }
  // Desktop: toggle collapsed class on shell
  document.body.classList.toggle('sidebar-collapsed');
  const btn = document.getElementById('sb-toggle-btn');
  const isCollapsed = document.body.classList.contains('sidebar-collapsed');
  if (btn) btn.title = isCollapsed ? 'Show navigation' : 'Hide navigation';
}

/* Reset drawer when resizing to desktop */
window.addEventListener('resize', () => {
  if (window.innerWidth > 768) closeSidebar();
});

/* ── Page navigation ── */
function gotoPage(id, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sb-item').forEach(b => b.classList.remove('active'));
  const el = document.getElementById('page-' + id);
  if (el) el.classList.add('active');
  if (btn) btn.classList.add('active');
  const sub = document.getElementById('page-sub');
  if (sub && btn) sub.textContent = btn.querySelector('.sb-ic')?.nextSibling?.textContent?.trim() || '';
  // Close sidebar on mobile after navigation
  if (window.innerWidth <= 768) closeSidebar();
  // Sync bottom nav active state
  syncBottomNav(id);
  // Scroll main area to top
  const ma = document.querySelector('.main-area');
  if (ma) ma.scrollTo({ top:0, behavior:'smooth' });
}

/* ── Bottom nav sync ── */
function syncBottomNav(pageId) {
  document.querySelectorAll('.mbn-item').forEach(b => {
    b.classList.toggle('active', b.dataset.page === pageId);
  });
}

/* ── Member tabs ── */
function switchMTab(id, btn) {
  document.querySelectorAll('.m-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.m-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id)?.classList.add('active');
  btn.classList.add('active');
}

/* ── Member search ── */
function filterMembers(q) {
  const term = q.toLowerCase();
  document.querySelectorAll('.mem-row').forEach(row => {
    const text = row.innerText.toLowerCase();
    row.style.display = term ? (text.includes(term) ? '' : 'none') : '';
  });
}

/* ── Activate account ── */
async function activateUser(userId, btn) {
  if (!confirm('Activate this account to full access (paid)?')) return;
  const orig = btn.textContent;
  btn.textContent = '…'; btn.disabled = true;
  const r = await api(`/admin/orgs/${ORG}/members/${userId}/activate`, 'POST');
  if (r.ok) {
    btn.textContent = '✓ Active';
    btn.className = 'btn-activate active';
    btn.disabled = false;
    // update the status badge in the same row
    const row = btn.closest('tr');
    if (row) {
      const badge = row.querySelector('.badge-trial');
      if (badge) { badge.className = 'badge badge-paid'; badge.textContent = '✓ Active'; }
    }
  } else {
    btn.textContent = orig; btn.disabled = false;
    alert('Activation failed: ' + (r.data.error || 'unknown'));
  }
}

/* ── Member action (promote/demote/remove) ── */
async function memberAction(btn, slug, userId, action, role) {
  const labels = { remove: 'Remove this member?', promote: `Promote to ${role||'manager'}?`, demote: 'Demote to employee?' };
  if (!confirm(labels[action] || 'Confirm?')) return;
  const r = await api(`/admin/orgs/${slug}/members/${userId}`, 'POST', { action, role });
  const fb = document.getElementById('memberFeedback');
  if (r.ok) {
    if (action === 'remove') { btn.closest('tr')?.remove(); }
    if (fb) { fb.innerHTML = '<span style="color:var(--emerald)">✓ Done</span>'; setTimeout(() => fb.innerHTML='', 3000); }
  } else {
    if (fb) { fb.innerHTML = '<span style="color:var(--rose)">✗ ' + (r.data.error||'Failed') + '</span>'; }
  }
}

/* ── Modal helpers ── */
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
// Close on backdrop click
document.querySelectorAll('.modal-overlay').forEach(ov => {
  ov.addEventListener('click', e => { if (e.target === ov) closeModal(ov.id); });
});



/* ── Create User modal ── */
function openCreateUserModal() {
  const box = document.getElementById('createUserResult');
  if (box) {
    box.style.display = 'none';
    box.innerHTML = '';
    box.className = 'result-toast';
  }
  openModal('createUserModal');
}

function closeCreateUserModal() {
  closeModal('createUserModal');
}

(function wireCreateUserForm() {
  const form = document.getElementById('createUserForm');
  if (!form || form.dataset.wired === '1') return;
  form.dataset.wired = '1';

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    const firstName = (form.firstName?.value || '').trim();
    const lastName  = (form.lastName?.value  || '').trim();
    const email     = (form.email?.value     || '').trim();
    const role      = (form.role?.value      || '').trim();

    const box = document.getElementById('createUserResult');

    if (!firstName || !lastName || !role) {
      box.className = 'result-toast err';
      box.style.display = 'block';
      box.textContent = 'First name, last name, and role are required';
      return;
    }

    const r = await api(`/admin/orgs/${ORG}/members/add`, 'POST', {
      firstName,
      lastName,
      email,
      role
    });

    if (!r.ok) {
      box.className = 'result-toast err';
      box.style.display = 'block';
      box.textContent = '✗ ' + (r.data?.error || 'Failed to create user');
      return;
    }

    box.className = 'result-toast ok';
    box.style.display = 'block';
    box.innerHTML = `
      ✅ User created successfully<br><br>
      <strong>Username:</strong> ${r.data.username}<br>
      <strong>Password:</strong> ${r.data.tempPassword}<br>
      <strong>Login:</strong> ${r.data.loginUrl || '/auth/school'}
    `;

    form.reset();

    setTimeout(() => {
      window.location.reload();
    }, 1200);
  });
})();
/* ── Assign modal ── */
function openAssignModal(uid, name) {
  document.getElementById('assignModal-uid').value = uid;
  document.getElementById('assignModal-sub').textContent = 'Assigning to: ' + name;
  document.getElementById('assignModal-result').style.display = 'none';
  openModal('assignModal');
}

async function doAssignModal() {
  const uid       = document.getElementById('assignModal-uid').value;
  const passageId = document.getElementById('assignModal-passage').value;
  const module    = document.getElementById('assignModal-module').value;
  const count     = document.getElementById('assignModal-count').value;
  const duration  = document.getElementById('assignModal-duration').value;

  const body = { modules: [module], userIds: [uid], count, durationMinutes: duration };
  if (passageId) body.passageId = passageId;

  const r = await api(`/admin/orgs/${ORG}/assign-quiz`, 'POST', body);
  if (r.ok) {
    toast('assignModal-result', true, '✅ Quiz assigned successfully!');
    setTimeout(() => closeModal('assignModal'), 1800);
  } else {
    toast('assignModal-result', false, '✗ ' + (r.data.error || 'Failed'));
  }
}

/* ── Credential modal - three tabs: view, change-password, edit-username ── */

// State kept in module scope so tabs can share it
let _credData = null;

function switchCredTab(tab, btn) {
  document.querySelectorAll('.cred-modal-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.cred-ctab-pane').forEach(p => p.style.display = 'none');
  btn.classList.add('active');
  document.getElementById('ctab-' + tab).style.display = 'block';
}

// Called from every "🔑 Creds" button in the member tables
async function openCredModal(uid, name, role) {
  // Reset modal to loading state
  document.getElementById('credModal-uid').value   = uid;
  document.getElementById('credModal-role').value  = role;
  document.getElementById('credModal-sub').textContent = name;
  document.getElementById('credModal-loading').style.display  = 'block';
  document.getElementById('credModal-content').style.display  = 'none';
  document.getElementById('credModal-result').style.display   = 'none';
  document.getElementById('credModal-pw-result') && (document.getElementById('credModal-pw-result').style.display = 'none');
  document.getElementById('credModal-user-result') && (document.getElementById('credModal-user-result').style.display = 'none');
  // Reset to view tab
  switchCredTab('view', document.querySelector('.cred-modal-tab[data-ctab="view"]'));
  openModal('credModal');

  // Fetch current credentials from backend
  try {
    const r = await fetch(`/admin/orgs/${ORG}/members/${uid}/credentials`, { method: 'GET' });
    const data = await r.json();
    _credData = data;

    document.getElementById('credModal-loading').style.display = 'none';
    document.getElementById('credModal-content').style.display = 'block';

    // Pre-fill username field in edit tab
    if (document.getElementById('credModal-username')) {
      document.getElementById('credModal-username').value = data.username || '';
    }

    // Build the info display
    renderCredInfo(data);

  } catch (e) {
    document.getElementById('credModal-loading').textContent = '✗ Failed to load credentials. Check network.';
  }
}

function renderCredInfo(data) {
  const container = document.getElementById('credModal-info');

  function row(label, value, canCopy) {
    const hasVal = value && String(value).trim();
    return `
      <div class="cred-info-row">
        <div class="ci-label">${label}</div>
        <div class="ci-val ${hasVal ? '' : 'none'}">${hasVal ? escHtml(value) : 'Not set'}</div>
        ${hasVal && canCopy ? `<button class="ci-copy" onclick="clipCopy('${escAttr(value)}','${escAttr(label)}')">Copy</button>` : ''}
      </div>`;
  }

  const pwStatus = data.hasPassword
    ? `<span class="cred-status-has">● Password is set</span>${data.needsPasswordSetup ? ' <span style="font-size:11.5px;color:var(--amber)">(user should change it)</span>' : ''}`
    : `<span class="cred-status-none">○ No password - user cannot log in yet</span>`;

  container.innerHTML = `
    ${row('Username', data.username, true)}
    ${data.studentId ? row('Student ID', data.studentId, true) : ''}
    ${data.teacherId ? row('Teacher ID', data.teacherId, true) : ''}
    ${data.adminId   ? row('Admin ID',   data.adminId,   true) : ''}
    ${data.email     ? row('Email',      data.email,     true) : ''}
    <div class="cred-info-row">
      <div class="ci-label">Password</div>
      <div style="flex:1">${pwStatus}</div>
    </div>
    ${data.lastLogin ? row('Last Login', new Date(data.lastLogin).toLocaleString(), false) : ''}
  `;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escAttr(s) {
  return String(s).replace(/'/g,"\\'");
}

function clipCopy(val, label) {
  navigator.clipboard?.writeText(val)
    .then(() => toast('credModal-result', true, `✅ ${label} copied to clipboard`))
    .catch(() => toast('credModal-result', false, 'Copy failed - please copy manually: ' + val));
}

function copyCredentials() {
  if (!_credData) return;
  const lines = [
    `Name: ${(_credData.firstName||'')+' '+(_credData.lastName||'')}`.trim(),
    _credData.username  ? `Username:   ${_credData.username}`  : null,
    _credData.studentId ? `Student ID: ${_credData.studentId}` : null,
    _credData.teacherId ? `Teacher ID: ${_credData.teacherId}` : null,
    _credData.adminId   ? `Admin ID:   ${_credData.adminId}`   : null,
    _credData.email     ? `Email:      ${_credData.email}`     : null,
    `Login URL:  /auth/school`,
  ].filter(Boolean);
  navigator.clipboard?.writeText(lines.join('\n'))
    .then(() => toast('credModal-result', true, '✅ Credentials copied to clipboard'))
    .catch(() => alert(lines.join('\n')));
}

function genModalPw() {
  const name = _credData
    ? (_credData.firstName || 'User')
    : document.getElementById('credModal-sub').textContent.split(' ')[0] || 'User';
  const first = name.replace(/[^a-zA-Z]/g, '');
  const pin = String(Math.floor(1000 + Math.random() * 9000));
  const pw = first + pin + '!';
  document.getElementById('credModal-password').value = pw;
  // Show strength
  updatePwStrength(pw);
}

function updatePwStrength(val) {
  const fill = document.getElementById('credModal-pw-fill');
  if (!fill) return;
  let score = 0;
  if (val.length >= 8)  score++;
  if (val.length >= 12) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const cols = ['#e2e8f0','#ef4444','#f97316','#eab308','#22c55e','#16a34a'];
  const pcts = ['0%','20%','40%','60%','80%','100%'];
  fill.style.width = pcts[score];
  fill.style.background = cols[score];
}

// Wire password strength to input
document.addEventListener('DOMContentLoaded', () => {
  const pwInp = document.getElementById('credModal-password');
  if (pwInp) pwInp.addEventListener('input', e => updatePwStrength(e.target.value));
});

async function doChangePassword() {
  const uid      = document.getElementById('credModal-uid').value;
  const password = document.getElementById('credModal-password').value.trim();
  if (!password || password.length < 8) {
    return toast('credModal-pw-result', false, 'Password must be at least 8 characters');
  }
  const r = await api(`/admin/orgs/${ORG}/users/${uid}/password`, 'POST', { password });
  if (r.ok) {
    toast('credModal-pw-result', true, '✅ Password changed successfully');
    document.getElementById('credModal-password').value = '';
    document.getElementById('credModal-pw-fill').style.width = '0';
    // Refresh the info panel
    if (_credData) {
      _credData.hasPassword = true;
      _credData.needsPasswordSetup = false;
      renderCredInfo(_credData);
    }
  } else {
    toast('credModal-pw-result', false, '✗ ' + (r.data.error || 'Failed'));
  }
}

async function doChangeUsername() {
  const uid      = document.getElementById('credModal-uid').value;
  const username = document.getElementById('credModal-username').value.trim();
  // We call the credentials endpoint with the new username and a dummy password-keep flow.
  // Since the credentials endpoint requires a password, we use the unified endpoint differently:
  // We post JUST the username update by sending password="" and relying on the server
  // to keep the existing password if we use a dedicated username-only endpoint.
  // Use the existing credentials endpoint but pass generateUsername=false and no password change.
  // Actually: easiest is to call GET creds → get current hash presence,
  // then POST /members/:id/credentials with username + a sentinel.
  // Since we can't get the raw password back, we instead send the username update only
  // via a new approach: POST /admin/orgs/:slug/members/:userId/username
  // But that route doesn't exist yet. For now use the credentials route with a temp password
  // only if no password exists, otherwise just update username via a direct mongo update.
  // ── Simplest safe approach: dedicated username-change call ──
  const r = await api(`/admin/orgs/${ORG}/members/${uid}/username`, 'POST', { username: username || undefined, generate: !username });
  if (r.ok) {
    toast('credModal-user-result', true, `✅ Username updated to: ${r.data.username}`);
    if (_credData) { _credData.username = r.data.username; renderCredInfo(_credData); }
    document.getElementById('credModal-username').value = r.data.username;
  } else {
    toast('credModal-user-result', false, '✗ ' + (r.data.error || 'Failed'));
  }
}

// Legacy: kept for backward compat if anything still calls doIssueCredModal
function doIssueCredModal() {
