/* ── Credentials page ── */
function genTempPw() {
  const sel = document.getElementById('cred-member');
  const name = sel.options[sel.selectedIndex]?.dataset?.name || 'User';
  const first = (name.split(' ')[0]||'User').replace(/[^a-zA-Z]/g,'');
  const pin = String(Math.floor(1000+Math.random()*9000));
  document.getElementById('cred-password').value = first + pin + '!';
}

async function issueSingleCredentials() {
  const uid      = document.getElementById('cred-member').value;
  const username = document.getElementById('cred-username').value.trim();
  const password = document.getElementById('cred-password').value.trim();
  const genUser  = document.getElementById('cred-gen-user').checked;
  if (!uid)      return toast('cred-result', false, 'Select a member');
  if (!password || password.length < 8) return toast('cred-result', false, 'Password must be ≥ 8 characters');
  const r = await api(`/admin/orgs/${ORG}/members/${uid}/credentials`, 'POST', { username: username||undefined, password, generateUsername: genUser });
  if (r.ok) {
    toast('cred-result', true, `✅ Credentials issued. Username: ${r.data.username}`);
    document.getElementById('cred-username').value = '';
    document.getElementById('cred-password').value = '';
  } else {
    toast('cred-result', false, '✗ ' + (r.data.error || 'Failed'));
  }
}

async function bulkGenCreds() {
  if (!confirm('Generate credentials for all members without a password?')) return;
  toast('bulk-cred-result', true, '⏳ Generating…');
  const r = await api(`/admin/orgs/${ORG}/credentials/bulk-generate`, 'POST');
  if (!r.ok) return toast('bulk-cred-result', false, '✗ ' + (r.data.error || 'Failed'));
  toast('bulk-cred-result', true, `✅ Issued ${r.data.issued} credentials. ${r.data.skipped} already had passwords.`);
  if (r.data.credentials?.length) {
    window._bulkCreds = r.data.credentials;
    const tbody = document.getElementById('bulk-cred-tbody');
    tbody.innerHTML = '';
    r.data.credentials.forEach(c => {
      const tr = document.createElement('tr');
      tr.innerHTML = `<td>${c.name}</td><td>${c.role}</td><td class="mono">${c.username}</td><td style="font-family:'Courier New',monospace;font-size:12px">${c.tempPassword}</td><td><button class="btn btn-xs btn-o" onclick="navigator.clipboard.writeText('Username: ${c.username}  Password: ${c.tempPassword}').then(()=>alert('Copied!'))">Copy</button></td>`;
      tbody.appendChild(tr);
    });
    document.getElementById('bulk-cred-table').classList.remove('hidden');
  }
}

function exportCreds() {
  const creds = window._bulkCreds || [];
  if (!creds.length) return;
  const rows = [['Name','Email','Role','Username','Temp Password']];
  creds.forEach(c => rows.push([c.name, c.email, c.role, c.username, c.tempPassword]));
  const csv = rows.map(r => r.map(v => '"' + String(v).replace(/"/g,'""') + '"').join(',')).join('\n');
  const a = Object.assign(document.createElement('a'), { href: URL.createObjectURL(new Blob([csv],{type:'text/csv'})), download: `creds_${Date.now()}.csv` });
  a.click();
}

function copyAllCreds() {
  const creds = window._bulkCreds || [];
  const text = creds.map(c => `${c.name} | @${c.username} | ${c.tempPassword}`).join('\n');
  navigator.clipboard?.writeText(text).then(() => alert('All credentials copied!'));
}

