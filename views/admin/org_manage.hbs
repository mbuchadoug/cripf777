/* ── Assign quiz form ── */
(function () {
  const assignForm = document.getElementById('assignForm');
  if (!assignForm) return;

  const targetRole  = document.getElementById('targetRole');
  const gradeWrap   = document.getElementById('gradeWrap');
  const specificWrap = document.getElementById('specificWrap');

  if (targetRole) {
    targetRole.addEventListener('change', () => {
      const v = targetRole.value;
      if (gradeWrap)    gradeWrap.style.display    = (v === 'student') ? 'block' : 'none';
      if (specificWrap) specificWrap.style.display  = (v === 'specific') ? 'block' : 'none';
    });
  }

  function selectAll(checked) {
    document.querySelectorAll('#userPickList input[type=checkbox]').forEach(cb => cb.checked = checked);
  }
  window.selectAll = selectAll;

  assignForm.addEventListener('submit', async ev => {
    ev.preventDefault();
    const btn = document.getElementById('assignBtn');
    btn.textContent = 'Assigning…'; btn.disabled = true;

    const role = targetRole?.value || 'specific';
    const modulesSel = document.getElementById('modules');
    const modules = modulesSel ? Array.from(modulesSel.selectedOptions).map(o => o.value) : [];
    const passageId = document.getElementById('passageSelect')?.value || null;
    const count = document.getElementById('count')?.value || 20;
    const durationMinutes = document.getElementById('durationMinutes')?.value || 30;

    const body = { modules, count, durationMinutes };
    if (passageId) body.passageId = passageId;

    if (role === 'specific') {
      const checked = Array.from(document.querySelectorAll('#userPickList input[type=checkbox]:checked')).map(cb => cb.value);
      if (!checked.length) { btn.textContent='📋 Assign Quiz'; btn.disabled=false; toast('assignResult',false,'Please select at least one user'); return; }
      body.userIds = checked;
    } else {
      body.targetRole = role;
      if (role === 'student') body.grade = document.getElementById('gradeSelect')?.value;
    }

    const r = await api(`/admin/orgs/${ORG}/assign-quiz`, 'POST', body);
    btn.textContent = '📋 Assign Quiz'; btn.disabled = false;
    toast('assignResult', r.ok, r.ok ? `✅ Assigned to ${r.data.assigned?.length || 0} user(s)!` : ('✗ ' + (r.data.error || 'Failed')));
  });
})();

/* ── Bulk assign form ── */
(function () {
  const form = document.getElementById('bulkAssignForm');
  if (!form) return;
  const bulkTargetType = document.getElementById('bulkTargetType');
  const bulkUserWrap   = document.getElementById('bulkUserWrap');
  if (bulkTargetType) {
    bulkTargetType.addEventListener('change', () => {
      bulkUserWrap?.classList.toggle('hidden', bulkTargetType.value !== 'specific');
    });
  }
  form.addEventListener('submit', async ev => {
    ev.preventDefault();
    const fd = new FormData(form);
    const targetType = fd.get('targetType');
    const durationMinutes = parseInt(fd.get('durationMinutes')) || 30;
    const previewOnly = fd.get('previewOnly') === '1';
    const payload = { targetType, durationMinutes, previewOnly };
    if (targetType === 'specific') {
      payload.userIds = Array.from(document.querySelectorAll('#bulkUserPick input:checked')).map(c => c.value);
      if (!payload.userIds.length) { toast('bulkAssignResult', false, 'Select at least one user'); return; }
    }
    toast('bulkAssignResult', true, '⏳ Processing…');
    const r = await api(`/admin/orgs/cripfcnt-school/bulk-assign-all`, 'POST', payload);
    if (!r.ok) { toast('bulkAssignResult', false, '✗ ' + (r.data.error || 'Failed')); return; }
    const d = r.data;
    if (d.preview) {
      toast('bulkAssignResult', true, `📊 Preview: ${d.usersCount} users × ${d.quizzesCount} quizzes = ${d.totalInstances} instances (~${Math.ceil(d.totalInstances*d.durationMinutes/60)}h per user). Uncheck Preview to create.`);
    } else {
      toast('bulkAssignResult', true, `✅ Created ${d.totalCreated} exam instances for ${d.usersCount} users. ${d.errors?.length||0} errors.`);
    }
  });
})();

/* ── Create passage AJAX ── */
(function () {
