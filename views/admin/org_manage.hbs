{{!-- admin/org_manage.hbs - Professional Admin Panel --}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{org.name}} · Admin Panel</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* ═══ TOKENS ═══ */
    :root {
      --ink:        #0f172a;
      --ink-soft:   #334155;
      --ink-muted:  #64748b;
      --ink-faint:  #94a3b8;
      --canvas:     #f1f5f9;
      --surface:    #ffffff;
      --surface-2:  #f8fafc;
      --border:     #e2e8f0;
      --border-soft:#f1f5f9;

      --blue:       #2563eb;
      --blue-dk:    #1d4ed8;
      --blue-bg:    #eff6ff;
      --blue-ring:  rgba(37,99,235,.15);

      --emerald:    #059669;
      --emerald-bg: #ecfdf5;
      --amber:      #d97706;
      --amber-bg:   #fffbeb;
      --rose:       #e11d48;
      --rose-bg:    #fff1f2;
      --violet:     #7c3aed;
      --violet-bg:  #f5f3ff;
      --cyan:       #0891b2;
      --cyan-bg:    #ecfeff;
      --orange:     #ea580c;
      --orange-bg:  #fff7ed;

      --nav-w:   240px;
      --hdr-h:   64px;
      --r:       10px;
      --r-lg:    14px;
      --sx:      0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
      --s:       0 4px 16px rgba(0,0,0,.07),0 1px 3px rgba(0,0,0,.04);
      --slg:     0 10px 40px rgba(0,0,0,.1);
      --font:    'Inter',system-ui,-apple-system,sans-serif;
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { font-family:var(--font); background:var(--canvas); color:var(--ink); font-size:14px; line-height:1.6; -webkit-font-smoothing:antialiased; }
    a { text-decoration:none; color:inherit; }
    input,select,textarea,button { font-family:var(--font); }
    button { cursor:pointer; }

    /* ═══ LAYOUT ═══ */
    .shell { display:flex; min-height:100vh; }

    /* ═══ SIDEBAR ═══ */
    .sidebar {
      width:var(--nav-w); flex-shrink:0;
      position:fixed; top:0; left:0; bottom:0;
      background:var(--ink); z-index:200;
      display:flex; flex-direction:column;
      overflow-y:auto;
    }

    .sb-brand {
      padding:20px 20px 16px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }
    .sb-brand-name {
      font-size:16px; font-weight:800;
      color:#fff; letter-spacing:-.3px;
    }
    .sb-brand-name em { color:#fbbf24; font-style:normal; }
    .sb-brand-sub {
      font-size:11px; color:rgba(255,255,255,.45);
      margin-top:2px; font-weight:500;
      text-transform:uppercase; letter-spacing:.5px;
    }

    .sb-section {
      padding:14px 12px 6px;
      font-size:9.5px; font-weight:700;
      text-transform:uppercase; letter-spacing:.8px;
      color:rgba(255,255,255,.3);
    }

    .sb-item {
      display:flex; align-items:center; gap:10px;
      padding:9px 14px;
      font-size:13px; font-weight:500;
      color:rgba(255,255,255,.65);
      border-radius:8px; margin:1px 8px;
      transition:all .12s; border:none; background:none;
      width:calc(100% - 16px); text-align:left;
    }
    .sb-item:hover { background:rgba(255,255,255,.08); color:#fff; }
    .sb-item.active {
      background:var(--blue); color:#fff; font-weight:600;
    }
    .sb-item .sb-ic { font-size:15px; width:18px; text-align:center; flex-shrink:0; }
    .sb-item .sb-badge {
      margin-left:auto; background:rgba(255,255,255,.2);
      color:#fff; border-radius:999px;
      font-size:10px; font-weight:700;
      padding:1px 7px; min-width:20px; text-align:center;
    }
    .sb-item.active .sb-badge { background:rgba(255,255,255,.3); }

    .sb-footer {
      margin-top:auto;
      padding:14px 12px;
      border-top:1px solid rgba(255,255,255,.06);
    }
    .sb-footer a {
      display:flex; align-items:center; gap:8px;
      font-size:12.5px; color:rgba(255,255,255,.4);
      padding:6px 8px; border-radius:6px; transition:all .12s;
    }
    .sb-footer a:hover { color:#fff; background:rgba(255,255,255,.07); }

    /* ═══ MAIN AREA ═══ */
    .main-area {
      margin-left:var(--nav-w);
      flex:1; display:flex; flex-direction:column; min-height:100vh;
    }

    /* ═══ TOP HEADER ═══ */
    .top-hdr {
      position:sticky; top:0; z-index:100;
      height:var(--hdr-h);
      background:rgba(255,255,255,.95);
      backdrop-filter:blur(12px);
      border-bottom:1px solid var(--border);
      display:flex; align-items:center;
      padding:0 28px; gap:14px;
    }
    .hdr-title { font-size:17px; font-weight:800; color:var(--ink); }
    .hdr-sub   { font-size:12.5px; color:var(--ink-muted); margin-left:2px; }
    .hdr-sp    { flex:1; }

    .hdr-badge {
      display:inline-flex; align-items:center; gap:5px;
      padding:5px 12px; border-radius:999px;
      font-size:11px; font-weight:700;
    }
    .hdr-badge.school { background:#ffe4e6; color:#be123c; }
    .hdr-badge.home   { background:#dcfce7; color:#15803d; }
    .hdr-badge.other  { background:var(--blue-bg); color:var(--blue-dk); }

    /* ═══ PAGE BODY ═══ */
    .page { padding:28px; display:none; flex-direction:column; gap:22px; overflow-x:hidden; box-sizing:border-box; width:100%; }
    .page.active { display:flex; }

    /* ═══ STAT CARDS ═══ */
    .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }
    .stat-card {
      background:var(--surface); border:1px solid var(--border);
      border-radius:var(--r-lg); padding:18px 20px;
      box-shadow:var(--sx); display:flex; align-items:center; gap:14px;
    }
    .stat-ic {
      width:44px; height:44px; border-radius:var(--r);
      display:flex; align-items:center; justify-content:center;
      font-size:20px; flex-shrink:0;
    }
    .stat-val { font-size:26px; font-weight:800; color:var(--ink); line-height:1; }
    .stat-lbl { font-size:12px; color:var(--ink-muted); margin-top:2px; font-weight:500; }

    /* ═══ SECTION CARD ═══ */
    .card {
      background:var(--surface); border:1px solid var(--border);
      border-radius:var(--r-lg); overflow:hidden; box-shadow:var(--sx);
    }
    .card-hdr {
      padding:16px 22px; border-bottom:1px solid var(--border);
      display:flex; align-items:center; gap:10px; flex-wrap:wrap;
    }
    .card-hdr-title { font-size:14.5px; font-weight:700; color:var(--ink); }
    .card-hdr-sub   { font-size:12.5px; color:var(--ink-muted); }
    .card-hdr-sp    { flex:1; }
    .card-body      { padding:22px; }
    .card-body.tight { padding:0; }

    /* ═══ MEMBER TABLE ═══ */
    .m-tabs { display:flex; gap:2px; padding:14px 22px 0; border-bottom:1px solid var(--border); }
    .m-tab {
      padding:8px 16px; font-size:12.5px; font-weight:600;
      color:var(--ink-muted); border:none; background:none;
      border-bottom:2px solid transparent; cursor:pointer;
      font-family:var(--font); transition:all .12s;
    }
    .m-tab:hover { color:var(--ink); }
    .m-tab.active { color:var(--blue); border-bottom-color:var(--blue); }

    .m-search {
      padding:12px 22px;
      border-bottom:1px solid var(--border-soft);
    }
    .m-search input {
      width:100%; padding:9px 14px;
      border:1.5px solid var(--border); border-radius:var(--r);
      font-size:13px; color:var(--ink); outline:none;
      transition:border-color .14s;
    }
    .m-search input:focus { border-color:var(--blue); box-shadow:0 0 0 3px var(--blue-ring); }

    .m-pane { display:none; }
    .m-pane.active { display:block; }

    .mem-table { width:100%; border-collapse:collapse; font-size:13px; }
    .mem-table th {
      text-align:left; padding:10px 16px;
      font-size:10.5px; font-weight:700; text-transform:uppercase;
      letter-spacing:.5px; color:var(--ink-muted);
      background:var(--surface-2); border-bottom:1px solid var(--border);
      position:sticky; top:0; z-index:2;
    }
    .mem-table td { padding:11px 16px; border-bottom:1px solid var(--border-soft); vertical-align:middle; }
    .mem-table tr:last-child td { border-bottom:none; }
    .mem-table tr:hover td { background:#fafbfc; }

    .avatar {
      width:32px; height:32px; border-radius:50%;
      background:var(--blue); color:#fff;
      display:inline-flex; align-items:center; justify-content:center;
      font-size:12px; font-weight:700; flex-shrink:0; margin-right:8px;
    }
    .user-name  { font-weight:600; color:var(--ink); }
    .user-email { font-size:11.5px; color:var(--ink-muted); margin-top:1px; }
    .user-id    { font-size:10.5px; color:var(--ink-faint); font-family:'Courier New',monospace; }

    /* ═══ BADGES ═══ */
    .badge {
      display:inline-flex; align-items:center; gap:3px;
      padding:2px 8px; border-radius:999px;
      font-size:10.5px; font-weight:700;
      text-transform:uppercase; letter-spacing:.3px; white-space:nowrap;
    }
    .badge-trial   { background:#fef3c7; color:#92400e; }
    .badge-paid    { background:var(--emerald-bg); color:#065f46; }
    .badge-student { background:var(--blue-bg); color:var(--blue-dk); }
    .badge-teacher { background:var(--cyan-bg); color:var(--cyan); }
    .badge-staff   { background:var(--violet-bg); color:var(--violet); }
    .badge-admin   { background:#fef3c7; color:#92400e; }
    .badge-manager { background:var(--orange-bg); color:var(--orange); }
    .badge-active  { background:var(--emerald-bg); color:#065f46; }
    .badge-inactive{ background:var(--canvas); color:var(--ink-muted); border:1px solid var(--border); }

    /* ═══ BUTTONS ═══ */
    .btn {
      display:inline-flex; align-items:center; justify-content:center; gap:5px;
      padding:8px 15px; border-radius:var(--r);
      font-size:12.5px; font-weight:600; font-family:var(--font);
      border:none; cursor:pointer; transition:all .14s;
      white-space:nowrap; line-height:1;
    }
    .btn-sm { padding:5px 10px; font-size:11.5px; border-radius:7px; }
    .btn-xs { padding:3px 8px; font-size:11px; border-radius:6px; }
    .btn-p  { background:var(--blue); color:#fff; box-shadow:0 2px 6px rgba(37,99,235,.22); }
    .btn-p:hover { background:var(--blue-dk); box-shadow:0 4px 12px rgba(37,99,235,.35); }
    .btn-o  { background:transparent; border:1.5px solid var(--border); color:var(--ink-soft); }
    .btn-o:hover { border-color:var(--blue); color:var(--blue); }
    .btn-g  { background:var(--emerald); color:#fff; }
    .btn-g:hover { background:#047857; }
    .btn-r  { background:var(--rose-bg); color:var(--rose); border:1px solid transparent; }
    .btn-r:hover { background:var(--rose); color:#fff; }
    .btn-a  { background:var(--amber-bg); color:var(--amber); border:1px solid transparent; }
    .btn-a:hover { background:var(--amber); color:#fff; }
    .btn-full { width:100%; }

    .btn-activate {
      background:var(--emerald-bg); color:var(--emerald);
      border:1px solid rgba(5,150,105,.25);
      font-size:11px; padding:4px 10px; border-radius:6px; font-weight:700;
    }
    .btn-activate:hover { background:var(--emerald); color:#fff; }
    .btn-activate.active {
      background:#dcfce7; color:#15803d; cursor:default;
    }

    /* ═══ FORM ELEMENTS ═══ */
    .fld { display:flex; flex-direction:column; gap:5px; }
    .fld label { font-size:12px; font-weight:600; color:var(--ink-soft); }
    .fld input, .fld select, .fld textarea {
      padding:9px 12px; border:1.5px solid var(--border);
      border-radius:var(--r); font-size:13.5px; color:var(--ink);
      outline:none; transition:border-color .14s, box-shadow .14s;
      background:#fff; width:100%;
    }
    .fld input:focus, .fld select:focus, .fld textarea:focus {
      border-color:var(--blue); box-shadow:0 0 0 3px var(--blue-ring);
    }
    .fld .hint { font-size:11.5px; color:var(--ink-muted); }

    .form-grid { display:grid; gap:16px; }
    .form-grid-2 { grid-template-columns:1fr 1fr; }
    .form-grid-3 { grid-template-columns:1fr 1fr 1fr; }
    .col-full    { grid-column:1/-1; }

    /* ═══ ACTION ROW IN TABLE ═══ */
    .act-row { display:flex; gap:5px; align-items:center; flex-wrap:wrap; }

    /* ═══ RESULT TOAST ═══ */
    .result-toast {
      display:none; padding:11px 14px; border-radius:var(--r);
      font-size:13px; font-weight:500; margin-top:12px;
    }
    .result-toast.ok  { background:var(--emerald-bg); color:#065f46; border:1px solid #a7f3d0; }
    .result-toast.err { background:var(--rose-bg); color:var(--rose); border:1px solid #fecdd3; }

    /* ═══ DROPZONE (CSV upload) ═══ */
    .dropzone {
      border:2px dashed var(--border); border-radius:var(--r-lg);
      padding:24px; text-align:center; cursor:pointer;
      transition:all .14s; color:var(--ink-muted); font-size:13px;
    }
    .dropzone:hover, .dropzone.drag { border-color:var(--blue); background:var(--blue-bg); color:var(--blue); }
    .dropzone input[type=file] { display:none; }
    .dropzone .dz-icon { font-size:28px; margin-bottom:6px; }

    /* ═══ MODAL ═══ */
    .modal-overlay {
      display:none; position:fixed; inset:0; z-index:900;
      background:rgba(15,23,42,.45); backdrop-filter:blur(3px);
      align-items:center; justify-content:center; padding:24px;
    }
    .modal-overlay.open { display:flex; }
    .modal {
      background:var(--surface); border-radius:18px;
      box-shadow:var(--slg); width:100%; max-width:520px;
      max-height:90vh; overflow-y:auto; padding:28px;
    }
    .modal-title {
      font-size:17px; font-weight:800; color:var(--ink);
      margin-bottom:5px;
    }
    .modal-sub { font-size:13px; color:var(--ink-muted); margin-bottom:22px; }
    .modal-actions { display:flex; gap:8px; margin-top:22px; justify-content:flex-end; }

    /* ═══ INVITE LINK BOX ═══ */
    .invite-link-box {
      background:var(--blue-bg); border:1px solid #bfdbfe;
      border-radius:var(--r); padding:12px 14px; margin-top:12px;
      display:none;
    }
    .invite-link-box .link-inp {
      width:100%; padding:8px 10px; border:1px solid #93c5fd;
      border-radius:7px; font-size:13px; background:#fff; margin-top:6px;
      color:var(--ink);
    }

    /* ═══ QUIZ ASSIGN PANEL ═══ */
    .user-select-list {
      max-height:200px; overflow-y:auto;
      border:1.5px solid var(--border); border-radius:var(--r);
      padding:4px;
    }
    .user-check {
      display:flex; align-items:center; gap:9px;
      padding:7px 10px; border-radius:7px; cursor:pointer;
      transition:background .1s;
    }
    .user-check:hover { background:var(--canvas); }
    .user-check input { accent-color:var(--blue); width:15px; height:15px; cursor:pointer; flex-shrink:0; }
    .user-check .uc-name { font-size:13px; font-weight:500; color:var(--ink); }
    .user-check .uc-meta { font-size:11px; color:var(--ink-muted); }

    /* ═══ BULK IMPORT ═══ */
    .import-card {
      border:1px solid var(--border); border-radius:var(--r-lg);
      overflow:hidden;
    }
    .import-hdr { background:var(--surface-2); padding:13px 18px; border-bottom:1px solid var(--border); display:flex; gap:10px; align-items:center; }
    .import-hdr-title { font-size:13px; font-weight:700; color:var(--ink); }
    .import-body { padding:16px 18px; }

    /* ═══ RULE TABLE ═══ */
    .rule-t { width:100%; border-collapse:collapse; font-size:12.5px; }
    .rule-t th { background:var(--surface-2); padding:9px 14px; font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.4px; color:var(--ink-muted); border-bottom:1px solid var(--border); text-align:left; }
    .rule-t td { padding:10px 14px; border-bottom:1px solid var(--border-soft); vertical-align:middle; }
    .rule-t tr:last-child td { border-bottom:none; }
    .rule-t tr:hover td { background:#fafbfc; }

    /* ═══ SCROLLABLE TABLE WRAP ═══ */
    .table-wrap { overflow-y:auto; max-height:480px; }
    .table-wrap thead th { position:sticky; top:0; z-index:2; }

    /* ═══ ALERT BANNER ═══ */
    .alert { padding:12px 16px; border-radius:var(--r); font-size:13px; display:flex; align-items:flex-start; gap:9px; }
    .alert-warn { background:var(--amber-bg); color:#92400e; border:1px solid #fcd34d; }
    .alert-info { background:var(--blue-bg); color:#1e40af; border:1px solid #93c5fd; }

    /* ═══ SCROLLABLE MEMBERS ═══ */
    .scroll-wrap { max-height:500px; overflow-y:auto; }

    /* ═══ UTIL ═══ */
    .hidden { display:none !important; }
    .gap-8  { display:flex; flex-direction:column; gap:8px; }
    .gap-12 { display:flex; flex-direction:column; gap:12px; }
    .flex-row { display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
    .mt-4 { margin-top:4px; }
    .mt-8 { margin-top:8px; }
    .mt-16 { margin-top:16px; }
    .mono { font-family:'Courier New',monospace; font-size:11.5px; color:var(--blue); font-weight:600; }
    .sep { height:1px; background:var(--border); margin:4px 0; }




    /* ─── CLOSE BUTTON: hidden on desktop (sidebar always visible there) ─── */
    #sb-close-btn { display:none; }
    @media(max-width:768px) {
      #sb-close-btn { display:flex; }
    }

    /* ─── DESKTOP SIDEBAR TOGGLE ─── */
    /* When sidebar is collapsed on desktop */
    .sidebar-collapsed .sidebar {
      transform:translateX(-100%);
      transition:transform .22s cubic-bezier(.4,0,.2,1);
    }
    .sidebar-collapsed .main-area {
      margin-left:0;
      transition:margin-left .22s cubic-bezier(.4,0,.2,1);
    }
    .sidebar { transition:transform .22s cubic-bezier(.4,0,.2,1); }
    .main-area { transition:margin-left .22s cubic-bezier(.4,0,.2,1); }
    /* Desktop toggle button in header */
    #sb-toggle-btn {
      display:flex; align-items:center; justify-content:center;
      width:36px; height:36px; flex-shrink:0;
      border:1.5px solid var(--border); border-radius:8px;
      background:var(--surface); cursor:pointer;
      color:var(--ink-soft); font-size:16px;
      transition:all .14s;
    }
    #sb-toggle-btn:hover { border-color:var(--blue); color:var(--blue); background:var(--blue-bg); }

    /* ─── HAMBURGER BUTTON ─── */
    .mob-hamburger {
      display:none; flex-direction:column; justify-content:center;
      align-items:center; gap:5px;
      width:40px; height:40px; flex-shrink:0;
      border:none; background:transparent; cursor:pointer; padding:0;
      border-radius:8px; transition:background .15s;
    }
    .mob-hamburger:hover { background:var(--border); }
    .mob-hamburger span {
      display:block; width:20px; height:2px;
      background:var(--ink); border-radius:2px; transition:all .2s;
    }

    /* ─── SIDEBAR OVERLAY (mobile) ─── */
    #sb-overlay {
      display:none; position:fixed; inset:0; z-index:190;
      background:rgba(15,23,42,.55); backdrop-filter:blur(2px);
    }
    #sb-overlay.show { display:block; }

    /* ─── MOBILE BOTTOM NAV ─── */
    .mob-bottom-nav {
      display:none; position:fixed; bottom:0; left:0; right:0;
      z-index:180; background:var(--surface);
      border-top:1px solid var(--border);
      box-shadow:0 -4px 20px rgba(0,0,0,.08);
      padding-bottom:env(safe-area-inset-bottom,0);
    }
    .mob-bottom-nav-row {
      display:flex; align-items:stretch;
    }
    .mbn-item {
      flex:1; display:flex; flex-direction:column; align-items:center;
      justify-content:center; padding:10px 4px 8px;
      border:none; background:none; cursor:pointer;
      font-family:var(--font); font-size:10px; font-weight:600;
      color:var(--ink-muted); gap:3px; transition:color .12s;
      -webkit-tap-highlight-color:transparent;
    }
    .mbn-item .mbn-ic { font-size:19px; line-height:1; }
    .mbn-item.active { color:var(--blue); }

    /* ─── RESPONSIVE 1100px ─── */
    @media(max-width:1100px) {
      .stats-row { grid-template-columns:repeat(2,1fr); }
      .form-grid-3 { grid-template-columns:1fr 1fr; }
    }

    /* ─── RESPONSIVE 768px - tablet/mobile ─── */
    @media(max-width:768px) {

      /* Sidebar: hidden off-screen by default, slides in as drawer */
      .sidebar {
        transform:translateX(-100%);
        transition:transform .26s cubic-bezier(.4,0,.2,1);
        width:260px;
        box-shadow:none;
        z-index:200;
      }
      .sidebar.sb-open {
        transform:translateX(0);
        box-shadow:8px 0 32px rgba(0,0,0,.25);
      }

      /* Main area fills full width */
      .main-area { margin-left:0; }

      /* Show hamburger */
      .mob-hamburger { display:flex; }

      /* Show bottom nav */
      .mob-bottom-nav { display:block; }

      /* Extra bottom padding so content clears the bottom nav */
      .page { padding-bottom:80px; }

      /* Header tighter */
      .top-hdr { padding:0 14px; gap:10px; }
      .hdr-title { font-size:15px; }
      .hdr-sub { display:none; }
      /* Hide badge + header buttons on mobile - space is precious */
      .hdr-right-items { display:none; }

      /* Stats 2×2 */
      .stats-row { grid-template-columns:repeat(2,1fr); gap:10px; }
      .stat-card { padding:14px 14px; gap:10px; }
      .stat-val { font-size:22px; }
      .stat-ic { width:38px; height:38px; font-size:17px; }

      /* Page padding smaller */
      .page { padding:16px 14px; gap:16px; padding-bottom:80px; }

      /* Card padding smaller */
      .card-hdr { padding:13px 16px; }
      .card-body { padding:16px; }

      /* Member tabs: scrollable strip */
      .m-tabs {
        overflow-x:auto; flex-wrap:nowrap;
        -webkit-overflow-scrolling:touch;
        scrollbar-width:none; padding:12px 14px 0;
      }
      .m-tabs::-webkit-scrollbar { display:none; }
      .m-tab { white-space:nowrap; padding:8px 12px; font-size:12px; }
      .m-search { padding:10px 14px; }

      /* Tables: horizontal scroll */
      .table-wrap, .scroll-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; }

      /* Hide less-important table columns */
      .col-hide-sm { display:none !important; }

      /* Form grids collapse */
      .form-grid-2 { grid-template-columns:1fr; gap:12px; }
      .form-grid-3 { grid-template-columns:1fr; gap:12px; }
      .col-full { grid-column:auto; }

      /* Quick-action buttons: 2-column grid */
      .flex-row.qa { display:grid !important; grid-template-columns:1fr 1fr; gap:8px; }
      .flex-row.qa .btn { justify-content:flex-start; }

      /* Modals: full-width, slide up from bottom */
      .modal-overlay { padding:0; align-items:flex-end; }
      .modal {
        border-radius:18px 18px 0 0;
        max-height:88vh; padding:22px 18px 24px;
      }

      /* Cred info rows */
      .cred-info-row { flex-wrap:wrap; gap:6px; padding:9px 12px; }
      .cred-info-row .ci-label { min-width:80px; font-size:10px; }
      .cred-info-row .ci-val { font-size:13px; }

      /* Dropzone */
      .dropzone { padding:18px; }

      /* Alert */
      .alert { font-size:12.5px; }
    }

    /* ─── RESPONSIVE 480px - small phones ─── */
    @media(max-width:480px) {
      .page { padding:12px 10px; gap:12px; padding-bottom:76px; }
      .stats-row { gap:8px; }
      .stat-card { padding:12px; gap:8px; }
      .stat-val { font-size:20px; }
      .card-hdr { padding:11px 12px; }
      .card-body { padding:12px; }

      /* On very narrow screens hide ID/Status columns too */
      .col-hide-xs { display:none !important; }

      /* Action buttons: icon only, no labels */
      .act-lbl { display:none; }
      .act-row { gap:3px; }

      .modal { padding:18px 14px 22px; }
    }

    /* ─── RESPONSIVE 360px - smallest phones ─── */
    @media(max-width:360px) {
      .stats-row { grid-template-columns:1fr; }
      .page { padding:10px 8px; padding-bottom:74px; }
    }
    /* ═══ CREDENTIAL MODAL TABS ═══ */
    .cred-modal-tab.active { color:var(--blue) !important; border-bottom-color:var(--blue) !important; }

    /* ═══ CREDENTIAL INFO GRID ═══ */
    .cred-info-row {
      display:flex; align-items:flex-start; gap:12px;
      padding:10px 14px;
      background:var(--surface-2); border:1px solid var(--border);
      border-radius:var(--r); font-size:13px;
    }
    .cred-info-row .ci-label {
      font-size:11px; font-weight:700; text-transform:uppercase;
      letter-spacing:.5px; color:var(--ink-muted);
      min-width:110px; flex-shrink:0; padding-top:1px;
    }
    .cred-info-row .ci-val {
      font-weight:600; color:var(--ink); font-family:'Courier New',monospace;
      font-size:14px; word-break:break-all;
    }
    .cred-info-row .ci-val.none {
      color:var(--ink-faint); font-family:var(--font);
      font-size:13px; font-weight:400; font-style:italic;
    }
    .cred-info-row .ci-copy {
      margin-left:auto; flex-shrink:0;
      padding:2px 8px; font-size:11px; background:var(--blue-bg);
      color:var(--blue); border:1px solid #bfdbfe; border-radius:5px;
      cursor:pointer; font-family:var(--font); font-weight:600;
    }
    .cred-info-row .ci-copy:hover { background:#dbeafe; }
    .cred-status-has  { color:var(--emerald); font-weight:600; font-size:12.5px; }
    .cred-status-none { color:var(--ink-faint); font-size:12.5px; }



    /* ═══════════════════════════════════════════════════
       CLASSIFICATION MANAGER - Grid-based, zero overflow
    ═══════════════════════════════════════════════════ */

    /* The classify page: standard page padding */
    #page-classify {
      padding:24px;
      box-sizing:border-box;
    }

    /* Wrapper card - full width of its flex-column parent */
    #clf-card {
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--r-lg);
      box-shadow:var(--sx);
      overflow:hidden;
      /* width is 100% because it's a block element in a flex column */
    }

    /* The two-column shell uses CSS Grid - EXACT sizes, no ambiguity */
    .clf-shell {
      display:grid;
      grid-template-columns:160px 1fr; /* sidebar=fixed, main=ALL remaining */
      grid-template-rows:1fr;
      height:72vh;
      min-height:440px;
      max-height:820px;
      overflow:hidden;
    }

    /* LEFT SIDEBAR: grid cell, exactly 160px, scrolls vertically */
    .clf-sidebar {
      grid-column:1;
      background:var(--surface-2);
      border-right:1px solid var(--border);
      overflow-y:auto;
      overflow-x:hidden;
    }

    /* RIGHT MAIN: grid cell, gets ALL remaining width, clips content */
    .clf-main {
      grid-column:2;
      display:flex;
      flex-direction:column;
      overflow:hidden;
      min-width:0; /* belt-and-suspenders for any nested flex */
    }

    /* TOOLBAR: search bar row */
    .clf-toolbar {
      flex-shrink:0;
      display:flex;
      gap:8px;
      align-items:center;
      padding:10px 12px;
      border-bottom:1px solid var(--border);
      background:var(--surface);
      flex-wrap:wrap;
    }
    .clf-toolbar input {
      flex:1;
      min-width:0;
      padding:8px 28px 8px 10px;
      border:1.5px solid var(--border);
      border-radius:var(--r);
      font-size:13px;
      font-family:var(--font);
      outline:none;
      transition:border-color .14s;
    }
    .clf-toolbar input:focus {
      border-color:var(--blue);
      box-shadow:0 0 0 3px var(--blue-ring);
    }

    /* QUIZ LIST: vertically scrollable, never horizontal */
    .clf-list {
      flex:1;
      overflow-y:auto;
      overflow-x:hidden;
      -webkit-overflow-scrolling:touch;
    }

    /* QUIZ ROW
       Three children: [chk][info flex:1 min-width:0][actions flex-shrink:0]
       The info section MUST have min-width:0 - this is what makes text truncate
       instead of pushing the Edit button off screen. */
    .clf-row {
      display:flex;
      align-items:center;
      gap:8px;
      padding:10px 12px;
      border-bottom:1px solid var(--border-soft);
      transition:background .1s;
    }
    .clf-row:hover    { background:var(--surface-2); }
    .clf-row.selected { background:var(--blue-bg); }

    /* Checkbox column */
    .clf-row-chk { flex-shrink:0; }

    /* Info column: MUST have min-width:0 for ellipsis to work in flex */
    .clf-row-info { flex:1; min-width:0; }

    .clf-row-title {
      font-size:13px; font-weight:500; color:var(--ink);
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .clf-row-meta {
      font-size:11px; color:var(--ink-muted);
      margin-top:2px; display:flex; gap:4px; flex-wrap:wrap; align-items:center;
    }

    /* Edit button column: NEVER shrinks - always fully visible */
    .clf-row-actions { flex-shrink:0; }

    .clf-edit-btn {
      display:inline-flex; align-items:center; gap:3px;
      padding:5px 11px; border-radius:6px;
      font-size:11.5px; font-weight:600; font-family:var(--font);
      border:1.5px solid var(--border); background:var(--surface);
      color:var(--blue); cursor:pointer; white-space:nowrap;
      transition:all .12s;
    }
    .clf-edit-btn:hover {
      border-color:var(--blue); background:var(--blue-bg);
    }

    /* Sidebar section labels */
    .clf-sb-section {
      padding:10px 12px 4px;
      font-size:9.5px;
      font-weight:700;
      color:var(--ink-faint);
      letter-spacing:.06em;
      text-transform:uppercase;
    }

    /* Sidebar filter buttons */
    .clf-filter {
      display:flex;
      align-items:center;
      gap:6px;
      padding:7px 10px;
      font-size:11.5px;
      color:var(--ink-soft);
      cursor:pointer;
      border:none;
      background:none;
      width:100%;
      text-align:left;
      transition:background .1s;
      box-sizing:border-box;
      overflow:hidden; /* prevent filter from expanding sidebar */
    }
    .clf-filter:hover  { background:rgba(0,0,0,.04); }
    .clf-filter.active { color:var(--blue); background:var(--blue-bg); font-weight:600; }
    /* Label text inside filter - truncates if too long */
    .clf-fi {
      flex:1;
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .clf-filter-count  {
      flex-shrink:0;
      font-size:10px;
      font-weight:700;
      color:var(--ink-faint);
      background:var(--canvas);
      padding:1px 5px;
      border-radius:99px;
    }
    .clf-filter.active .clf-filter-count { background:var(--blue-bg); color:var(--blue); }

    /* Pillar colour dot */
    .clf-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

    /* Badges */
    .clf-badge {
      font-size:10px; font-weight:600;
      padding:1px 6px; border-radius:99px;
      white-space:nowrap; flex-shrink:0;
    }
    .clf-badge-cat  { background:var(--violet-bg); color:var(--violet); }
    .clf-badge-none { background:var(--canvas); color:var(--ink-faint); border:1px solid var(--border); }
    .clf-badge-lock { background:var(--amber-bg); color:var(--amber); }
    .clf-badge-oos  { background:var(--rose-bg); color:var(--rose); }
    .clf-badge-conf { background:var(--emerald-bg); color:var(--emerald); }

    /* BULK ACTION BAR: fixed at bottom of clf-main */
    .clf-bulk-bar {
      display:none;
      flex-shrink:0;
      align-items:center;
      gap:8px;
      padding:9px 12px;
      background:var(--blue-bg);
      border-top:1px solid #bfdbfe;
      flex-wrap:wrap;
      width:100%;
      box-sizing:border-box;
    }
    .clf-bulk-bar.visible { display:flex; }
    .clf-bulk-label {
      font-size:12px; font-weight:700; color:var(--blue); white-space:nowrap;
    }
    .clf-bulk-bar select {
      font-size:12px; padding:5px 8px;
      border:1.5px solid var(--border);
      border-radius:var(--r);
      font-family:var(--font);
    }

    /* CLASSIFICATION SLIDE-IN PANEL */
    .clf-panel-overlay {
      position:fixed; inset:0;
      background:rgba(0,0,0,.4);
      z-index:500; display:none;
    }
    .clf-panel-overlay.open { display:block; }
    .clf-panel {
      position:fixed; top:0; right:0;
      width:440px; max-width:100vw; height:100vh;
      background:var(--surface); box-shadow:var(--slg);
      z-index:501; display:flex; flex-direction:column;
      transform:translateX(100%);
      transition:transform .22s cubic-bezier(.4,0,.2,1);
    }
    .clf-panel.open { transform:translateX(0); }
    .clf-panel-hdr {
      padding:18px 22px 14px;
      border-bottom:1px solid var(--border);
      flex-shrink:0;
    }
    .clf-panel-title { font-size:16px; font-weight:700; color:var(--ink); }
    .clf-panel-sub {
      font-size:12px; color:var(--ink-muted); margin-top:3px;
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .clf-panel-body { flex:1; overflow-y:auto; padding:18px 22px; }
    .clf-panel-footer {
      padding:14px 22px;
      border-top:1px solid var(--border);
      display:flex; gap:10px; flex-shrink:0;
      background:var(--surface-2);
    }

    /* Pillar → Category buttons in panel */
    .clf-pillar-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px; }
    .clf-cat-list    { display:grid; grid-template-columns:1fr; gap:5px; margin-bottom:14px; }
    .clf-cat-btn {
      padding:8px 11px;
      border:1.5px solid var(--border); border-radius:var(--r);
      font-size:12.5px; font-family:var(--font);
      color:var(--ink-soft); background:var(--surface);
      text-align:left; cursor:pointer; transition:all .12s;
    }
    .clf-cat-btn:hover    { border-color:var(--blue); color:var(--blue); background:var(--blue-bg); }
    .clf-cat-btn.selected { border-color:var(--blue); color:var(--blue); background:var(--blue-bg); font-weight:600; }

    /* Loading / empty state */
    .clf-loading {
      display:flex; align-items:center; justify-content:center;
      padding:48px 20px; color:var(--ink-muted); font-size:13px;
      gap:10px; flex-direction:column; text-align:center;
    }

    /* ─── TABLET / MOBILE ≤ 768px ───────────────────────
       Grid switches to single column.
       Sidebar becomes a horizontal scrollable pill strip. */
    @media (max-width:768px) {
      #page-classify { padding:12px; }

      .clf-shell {
        grid-template-columns:1fr;  /* single column */
        grid-template-rows:auto 1fr;
        height:auto;
        max-height:none;
      }
      .clf-sidebar {
        grid-column:1; grid-row:1;
        display:flex; flex-direction:row;
        overflow-x:auto; overflow-y:hidden;
        -webkit-overflow-scrolling:touch;
        scrollbar-width:none;
        padding:6px 8px; gap:4px;
        border-right:none; border-bottom:1px solid var(--border);
        height:auto;
      }
      .clf-sidebar::-webkit-scrollbar { display:none; }
      .clf-main {
        grid-column:1; grid-row:2;
        max-height:60vh;
      }
      .clf-sb-section { display:none; }
      .clf-filter {
        flex-shrink:0; white-space:nowrap; width:auto;
        padding:5px 10px; border-radius:99px;
        border:1.5px solid var(--border); font-size:11px;
        overflow:visible;
      }
      .clf-filter.active { border-color:var(--blue); background:var(--blue-bg); }
      .clf-fi { white-space:nowrap; }
      .clf-filter-count { font-size:9.5px; }
      .clf-list { max-height:52vh; }
      .clf-row { padding:9px 10px; gap:6px; }
      .clf-row-title { font-size:12px; }
      .clf-row-meta { font-size:10px; }
      .clf-edit-btn { padding:5px 8px; font-size:11px; }
      .clf-bulk-bar { flex-wrap:wrap; gap:6px; }
    }

    /* ─── SMALL PHONES ≤ 480px ─────────────────────── */
    @media (max-width:480px) {
      #page-classify { padding:8px; }
      .clf-row-chk { display:none; }
      .clf-row { padding:8px 8px; gap:5px; }
      .clf-row-title { font-size:11.5px; }
    }
  </style>
</head>
<body data-org-slug="{{org.slug}}">

{{> navbar}}

<div class="shell">

  <!-- ══════════════════════════════════════
       SIDEBAR
  ══════════════════════════════════════ -->
  <aside class="sidebar" id="sidebar">
    <div class="sb-brand" style="display:flex;align-items:center;justify-content:space-between;padding:20px 16px 16px">
      <div>
        <div class="sb-brand-name">CRIPF<em>Cnt</em></div>
        <div class="sb-brand-sub">Admin Console</div>
      </div>
      <!-- Close button - only visible on mobile -->
      <button id="sb-close-btn" onclick="closeSidebar()"
        style="display:flex;align-items:center;justify-content:center;
               width:32px;height:32px;border:none;border-radius:7px;
               background:rgba(255,255,255,.1);color:#fff;font-size:18px;
               cursor:pointer;flex-shrink:0;transition:background .12s"
        aria-label="Close menu">✕</button>
    </div>

    <div class="sb-section">Overview</div>
    <button class="sb-item active" data-page="overview" onclick="gotoPage('overview',this)">
      <span class="sb-ic">🏠</span> Dashboard
    </button>

    <div class="sb-section">People</div>
    <button class="sb-item" data-page="members" onclick="gotoPage('members',this)">
      <span class="sb-ic">👥</span> Members
      <span class="sb-badge" id="sb-total-members">
        {{groups.staff.length}}
      </span>
    </button>
    <button class="sb-item" data-page="invites" onclick="gotoPage('invites',this)">
      <span class="sb-ic">✉️</span> Invites
      <span class="sb-badge">{{invites.length}}</span>
    </button>
    <button class="sb-item" data-page="credentials" onclick="gotoPage('credentials',this)">
      <span class="sb-ic">🔑</span> Credentials
    </button>

    {{#unless isHomeSchool}}
    <div class="sb-section">Assessments</div>
    <button class="sb-item" data-page="assign" onclick="gotoPage('assign',this)">
      <span class="sb-ic">📋</span> Assign Quiz
    </button>
    {{#if (eq org.slug "cripfcnt-school")}}
    <button class="sb-item" data-page="bulk" onclick="gotoPage('bulk',this)">
      <span class="sb-ic">📦</span> Bulk Assign
    </button>
    {{/if}}
    <button class="sb-item" data-page="passages" onclick="gotoPage('passages',this)">
      <span class="sb-ic">📝</span> Create Passage
    </button>
    {{/unless}}

  {{#if (eq org.type "school")}}
    <div class="sb-section">Import</div>
    {{#unless isHomeSchool}}
    <button class="sb-item" data-page="import" onclick="gotoPage('import',this)">
      <span class="sb-ic">⬆️</span> Import CSV
    </button>
    {{/unless}}
    {{/if}}

    {{#if (or isHomeSchool isCripSchool)}}
    <div class="sb-section">Rules</div>
    <button class="sb-item" data-page="rules" onclick="gotoPage('rules',this)">
      <span class="sb-ic">⚙️</span> Quiz Rules
      <span class="sb-badge">{{quizRules.length}}</span>
    </button>
    {{/if}}

    {{#if (or isHomeSchool isCripSchool)}}
    <div class="sb-section">Categories</div>
    <button class="sb-item" data-page="classify" onclick="gotoPage('classify',this)">
      <span class="sb-ic">🏷️</span> Classify Quizzes
      {{#if unclassifiedCount}}<span class="sb-badge" style="background:var(--rose)">{{unclassifiedCount}}</span>{{/if}}
    </button>
    {{/if}}



    <div class="sb-section">Reports</div>
    <button class="sb-item" data-page="reports" onclick="gotoPage('reports',this)">
      <span class="sb-ic">📊</span> Reports
    </button>

    <div class="sb-footer">
      {{#if isHomeSchool}}
      <a href="/admin/finance">💰 Finance Dashboard</a>
      <a href="/parent/dashboard">👁 Parent View</a>
      {{/if}}
      <a href="/org/{{org.slug}}/dashboard">← Back to Dashboard</a>
    </div>
  </aside>

  <!-- ══════════════════════════════════════
       MAIN AREA
  ══════════════════════════════════════ -->
  <div class="main-area">

    <header class="top-hdr">
      <!-- Hamburger: only visible on mobile -->
      <button class="mob-hamburger" id="mob-hamburger-btn"
              onclick="openSidebar()" aria-label="Open navigation menu">
        <span></span><span></span><span></span>
      </button>

      <!-- Desktop sidebar toggle - always visible, collapses/expands the nav -->
      <button id="sb-toggle-btn" onclick="toggleSidebarDesktop()" title="Toggle navigation" aria-label="Toggle sidebar">
        ☰
      </button>
      <div style="min-width:0;overflow:hidden">
        <div class="hdr-title" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{org.name}}</div>
        <div class="hdr-sub" id="page-sub">Overview</div>
      </div>
      <div class="hdr-sp"></div>

      <!-- These items hide on mobile (via .hdr-right-items) -->
      <div class="hdr-right-items" style="display:flex;align-items:center;gap:10px">
        {{#if isCripSchool}}
          <span class="hdr-badge school">🏫 cripfcnt-school</span>
        {{else if isHomeSchool}}
          <span class="hdr-badge home">🏠 cripfcnt-home</span>
        {{else}}
          <span class="hdr-badge other">🏢 {{org.slug}}</span>
        {{/if}}
        <a href="/admin/orgs/{{org.slug}}/attempts" class="btn btn-o btn-sm">📊 Attempts</a>
        <a href="/admin/orgs/{{org.slug}}/reports/attempts.csv" class="btn btn-o btn-sm">⬇ CSV</a>
      </div>
    </header>


<!-- ════════════════════════════
         PAGE: CLASSIFY QUIZZES
    ════════════════════════════ -->
    {{#if (or isHomeSchool isCripSchool)}}
    <section class="page" id="page-classify">
      <div id="clf-card">
        <!-- Card header -->
        <div class="card-hdr">
          <div style="flex:1;min-width:0">
            <div class="card-hdr-title">🏷️ Quiz Classification Manager</div>
            <div class="card-hdr-sub">
              <span id="clf-status-badge">Assign or reassign quizzes to pillars and categories</span>
            </div>
          </div>
          <button class="btn btn-o btn-sm" onclick="clfReload()">↻ Refresh</button>
        </div>

        <!-- clf-shell sits directly in card - no card-body padding around it -->
        <div class="clf-shell">

          <!-- ── LEFT: Pillar filter sidebar (FIXED - never scrolls with list) ── -->
          <div class="clf-sidebar">
            <div class="clf-sb-section">Show</div>
            <button class="clf-filter active" id="clf-f-all" onclick="clfSetFilter('all')">
              <span class="clf-fi">📋 All</span>
              <span class="clf-filter-count" id="clf-count-all">-</span>
            </button>
            <button class="clf-filter" id="clf-f-unclassified" onclick="clfSetFilter('unclassified')">
              <span class="clf-fi">⚠️ Unclassified</span>
              <span class="clf-filter-count" id="clf-count-unclassified" style="background:var(--rose-bg);color:var(--rose)">{{unclassifiedCount}}</span>
            </button>
            <button class="clf-filter" id="clf-f-locked" onclick="clfSetFilter('locked')">
              <span class="clf-fi">🔒 Locked</span>
              <span class="clf-filter-count" id="clf-count-locked">-</span>
            </button>
            <div class="clf-sb-section">Pillar</div>
            <button class="clf-filter" onclick="clfSetFilter('pillar','consciousness')">
              <span class="clf-dot" style="background:#7c3aed"></span>
              <span class="clf-fi">Consciousness</span>
              <span class="clf-filter-count" id="clf-p-consciousness">-</span>
            </button>
            <button class="clf-filter" onclick="clfSetFilter('pillar','responsibility')">
              <span class="clf-dot" style="background:#0d9488"></span>
              <span class="clf-fi">Responsibility</span>
              <span class="clf-filter-count" id="clf-p-responsibility">-</span>
            </button>
            <button class="clf-filter" onclick="clfSetFilter('pillar','interpretation')">
              <span class="clf-dot" style="background:#4f46e5"></span>
              <span class="clf-fi">Interprete</span>
              <span class="clf-filter-count" id="clf-p-interpretation">-</span>
            </button>
            <button class="clf-filter" onclick="clfSetFilter('pillar','purpose')">
              <span class="clf-dot" style="background:#d97706"></span>
              <span class="clf-fi">Purpose</span>
              <span class="clf-filter-count" id="clf-p-purpose">-</span>
            </button>
            <button class="clf-filter" onclick="clfSetFilter('pillar','frequencies')">
              <span class="clf-dot" style="background:#e11d48"></span>
              <span class="clf-fi">Frequencies</span>
              <span class="clf-filter-count" id="clf-p-frequencies">-</span>
            </button>
            <button class="clf-filter" onclick="clfSetFilter('pillar','civilization')">
              <span class="clf-dot" style="background:#059669"></span>
              <span class="clf-fi">Civilization</span>
              <span class="clf-filter-count" id="clf-p-civilization">-</span>
            </button>
            <button class="clf-filter" onclick="clfSetFilter('pillar','negotiation')">
              <span class="clf-dot" style="background:#ea580c"></span>
              <span class="clf-fi">Negotiation</span>
              <span class="clf-filter-count" id="clf-p-negotiation">-</span>
            </button>
            <button class="clf-filter" onclick="clfSetFilter('pillar','technology')">
              <span class="clf-dot" style="background:#2563eb"></span>
              <span class="clf-fi">Technology</span>
              <span class="clf-filter-count" id="clf-p-technology">-</span>
            </button>
          </div>

          <!-- ── RIGHT: Toolbar + scrollable list + bulk bar ── -->
          <div class="clf-main">

            <!-- Toolbar: always visible, never scrolls -->
            <div class="clf-toolbar">
              <!-- Search wrapper with inline clear button -->
              <div style="flex:1;min-width:120px;position:relative;display:flex">
                <input type="text" id="clf-search"
                  placeholder="🔍  Search quiz titles…"
                  oninput="clfSearch(this.value)"
                  onkeydown="if(event.key==='Enter'){event.preventDefault();clfSearchNow();}">
                <button id="clf-search-clear" onclick="clfSearchClear()" title="Clear search"
                  style="display:none;position:absolute;right:8px;top:50%;transform:translateY(-50%);
                  border:none;background:none;cursor:pointer;font-size:13px;
                  color:var(--ink-muted);line-height:1;padding:2px 4px">✕</button>
              </div>
              <!-- Select-all checkbox -->
              <label style="display:flex;align-items:center;gap:5px;font-size:12.5px;
                color:var(--ink-muted);cursor:pointer;white-space:nowrap;flex-shrink:0">
                <input type="checkbox" id="clf-select-all" onchange="clfToggleAll(this.checked)"
                  style="accent-color:var(--blue);width:14px;height:14px">
                All
              </label>
              <button class="btn btn-o btn-sm" onclick="clfClearSelection()"
                id="clf-clear-btn" style="display:none;flex-shrink:0">✕ Clear</button>
            </div>

            <!-- THE ONLY SCROLLING ELEMENT: quiz list -->
            <div class="clf-list" id="clf-list">
              <div class="clf-loading">⏳ Loading quizzes…</div>
            </div>

            <!-- Bulk action bar: visible only when quizzes are selected -->
            <div class="clf-bulk-bar" id="clf-bulk-bar">
              <span class="clf-bulk-label" id="clf-bulk-label">0 selected</span>
              <select id="clf-bulk-pillar" onchange="clfBulkPillarChange()">
                <option value="">- Pillar -</option>
                <option value="consciousness">Consciousness</option>
                <option value="responsibility">Responsibility</option>
                <option value="interpretation">Interpretation</option>
                <option value="purpose">Purpose</option>
                <option value="frequencies">Frequencies</option>
                <option value="civilization">Civilization</option>
                <option value="negotiation">Negotiation</option>
                <option value="technology">Technology</option>
              </select>
              <select id="clf-bulk-category" disabled>
                <option value="">- Category -</option>
              </select>
              <button class="btn btn-p btn-sm" onclick="clfBulkApply()"
                id="clf-bulk-apply-btn" disabled style="flex-shrink:0">Apply</button>
              <span id="clf-bulk-result" style="font-size:12px;color:var(--emerald)"></span>
            </div>

          </div><!-- /clf-main -->
        </div><!-- /clf-shell -->
      </div><!-- /card -->
    </section>
    {{/if}}

    <!-- ── CLASSIFICATION PANEL (right slide-in) ── -->
    <div class="clf-panel-overlay" id="clfOverlay" onclick="clfClosePanel()"></div>
    <div class="clf-panel" id="clfPanel">
      <div class="clf-panel-hdr">
        <div class="clf-panel-title">🏷️ Classify Quiz</div>
        <div class="clf-panel-sub" id="clf-panel-sub">-</div>
      </div>
      <div class="clf-panel-body">
        <input type="hidden" id="clf-panel-quizId">
        <div class="fld" style="margin-bottom:18px">
          <label style="font-size:12px;font-weight:700;color:var(--ink-muted);margin-bottom:8px;display:block">1. SELECT PILLAR</label>
          <div class="clf-pillar-grid" id="clf-pillar-grid"></div>
        </div>
        <div class="fld" style="margin-bottom:18px" id="clf-cat-section">
          <label style="font-size:12px;font-weight:700;color:var(--ink-muted);margin-bottom:8px;display:block">2. SELECT CATEGORY</label>
          <div class="clf-cat-list" id="clf-cat-list"></div>
        </div>
        <div class="fld" id="clf-series-section" style="display:none;margin-bottom:18px">
          <label style="font-size:12px;font-weight:700;color:var(--ink-muted);margin-bottom:8px;display:block">3. SERIES SLUG <span style="font-weight:400;color:var(--ink-faint)">(optional)</span></label>
          <input type="text" id="clf-panel-series" placeholder="e.g. governance-foundations" style="width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--r);font-size:13px;font-family:var(--font)">
          <div style="font-size:11.5px;color:var(--ink-faint);margin-top:4px">Lowercase slugs only. Leave blank to keep current series.</div>
        </div>
        <div style="padding:12px 14px;background:var(--surface-2);border-radius:var(--r);font-size:12.5px;color:var(--ink-muted);border:1px solid var(--border)">
          <strong style="color:var(--ink)">🔒 Manual Lock</strong><br>
          Saving will lock this quiz against future AI re-categorisation. Unlock by unchecking below.
          <label style="display:flex;align-items:center;gap:8px;margin-top:8px;cursor:pointer">
            <input type="checkbox" id="clf-panel-lock" checked>
            <span style="font-size:12.5px;font-weight:500">Lock this classification</span>
          </label>
        </div>
        <div id="clf-panel-result" style="margin-top:14px;font-size:13px"></div>
      </div>
      <div class="clf-panel-footer">
        <button class="btn btn-o" onclick="clfClosePanel()">Cancel</button>
        <button class="btn btn-p" id="clf-panel-save-btn" onclick="clfSave()" disabled>Save Classification</button>
      </div>
    </div>

   
