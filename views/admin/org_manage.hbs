                      <button class="btn-activate" onclick="activateUser('{{this.user._id}}',this)">✓ Activate</button>
                      {{else}}
                      <span class="btn-activate active">✓ Active</span>
                      {{/if}}
                      <button class="btn btn-xs btn-o" onclick="openAssignModal('{{this.user._id}}','{{this.user.firstName}} {{this.user.lastName}}')">📋 Assign</button>
                      <button class="btn btn-xs btn-o" onclick="openCredModal('{{this.user._id}}','{{this.user.firstName}} {{this.user.lastName}}','employee')">🔑 Creds</button>
                      <button class="btn btn-xs btn-a" onclick="memberAction(this,'{{../org.slug}}','{{this.user._id}}','promote','manager')">↑ Mgr</button>
                      <button class="btn btn-xs btn-r" onclick="memberAction(this,'{{../org.slug}}','{{this.user._id}}','remove')">✕</button>
                    </div>
                  </td>
                </tr>
                {{/if}}
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>

        <!-- ADMINS -->
        {{#if groups.admins.length}}
        <div class="m-pane" id="m-admins">
          <div class="scroll-wrap">
            <table class="mem-table">
              <thead><tr><th>Admin</th><th class="col-hide-xs">Username</th><th class="col-hide-sm">Role</th><th>Actions</th></tr></thead>
              <tbody>
                {{#each groups.admins}}
                {{#if this.user}}
                <tr class="mem-row" data-uid="{{this.user._id}}">
                  <td>
                    <div style="display:flex;align-items:center">
                      <div class="avatar" style="background:var(--amber)">{{#if this.user.firstName}}{{substring this.user.firstName 0 1}}{{else}}A{{/if}}</div>
                      <div>
                        <div class="user-name">{{this.user.firstName}} {{this.user.lastName}}</div>
                        <div class="user-email">{{this.user.email}}</div>
                      </div>
                    </div>
                  </td>
                  <td>{{#if this.user.username}}<div class="mono">@{{this.user.username}}</div>{{else}}<span style="color:var(--ink-faint);font-size:12px">None</span>{{/if}}</td>
                  <td><span class="badge badge-admin">{{this.role}}</span></td>
                  <td>
                    <div class="act-row">
                      <button class="btn btn-xs btn-o" onclick="openAssignModal('{{this.user._id}}','{{this.user.firstName}} {{this.user.lastName}}')">📋 Assign</button>
                      <button class="btn btn-xs btn-o" onclick="openCredModal('{{this.user._id}}','{{this.user.firstName}} {{this.user.lastName}}','admin')">🔑 Creds</button>
                      <button class="btn btn-xs btn-a" onclick="memberAction(this,'{{../org.slug}}','{{this.user._id}}','demote')">↓ Demote</button>
                      <button class="btn btn-xs btn-r" onclick="memberAction(this,'{{../org.slug}}','{{this.user._id}}','remove')">✕</button>
                    </div>
                  </td>
                </tr>
                {{/if}}
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>
        {{/if}}

        <div id="memberFeedback" style="padding:10px 22px;"></div>
      </div>
    </section>

    <!-- ════════════════════════════
         PAGE: INVITES
    ════════════════════════════ -->
    <section class="page" id="page-invites">
      <div class="card">
        <div class="card-hdr">
          <div class="card-hdr-title">Send Invite</div>
          <div class="card-hdr-sub">Invite someone to join {{org.name}} via email link</div>
        </div>
        <div class="card-body">
          <form data-ajax="invite" method="post" action="/admin/orgs/{{org.slug}}/invite">
            <div class="form-grid form-grid-3" style="align-items:end">
              <div class="fld col-full" style="grid-column:span 2">
                <label>Email Address</label>
                <input name="email" type="email" placeholder="colleague@example.com" required>
              </div>
              <div class="fld">
                <label>Role</label>
                <select name="role">
                  <option value="employee">Employee</option>
                  <option value="manager">Manager</option>
                </select>
              </div>
            </div>
            <div style="margin-top:14px">
              <button type="submit" class="btn btn-p">✉️ Send Invite</button>
            </div>
          </form>
          <div id="inviteFeedback" class="result-toast" style="display:none"></div>
          <div class="invite-link-box" id="inviteLinkBox">
            <div style="font-size:12px;font-weight:700;color:#1e40af">📋 Invite Link (send via WhatsApp)</div>
            <input type="text" class="link-inp" id="inviteLinkInp" readonly onclick="this.select()">
            <div style="margin-top:8px;display:flex;gap:8px">
              <button class="btn btn-o btn-sm" onclick="copyInviteLink()">📋 Copy Link</button>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-hdr">
          <div class="card-hdr-title">Existing Invites</div>
          <div class="card-hdr-sub">{{invites.length}} invites sent</div>
        </div>
        <div class="card-body tight">
          <div class="table-wrap">
            <table class="mem-table">
              <thead><tr><th>Email</th><th>Role</th><th>Status</th><th>Token</th><th>Created</th></tr></thead>
              <tbody>
                {{#each invites}}
                <tr>
                  <td><strong>{{this.email}}</strong></td>
                  <td><span class="badge badge-staff">{{this.role}}</span></td>
                  <td>{{#if this.used}}<span class="badge badge-paid">Used</span>{{else}}<span class="badge badge-trial">Pending</span>{{/if}}</td>
                  <td><code style="font-size:11px;color:var(--ink-muted)">{{this.token}}</code></td>
                  <td style="color:var(--ink-muted);font-size:12px">{{this.createdAt}}</td>
                </tr>
                {{else}}
                <tr><td colspan="5" style="text-align:center;color:var(--ink-faint);padding:24px">No invites yet</td></tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════
         PAGE: CREDENTIALS
    ════════════════════════════ -->
    <section class="page" id="page-credentials">
      <div class="card">
        <div class="card-hdr">
          <div>
            <div class="card-hdr-title">🔑 Issue Credentials</div>
            <div class="card-hdr-sub">Set username and password for any member so they can log in at /auth/school</div>
          </div>
        </div>
        <div class="card-body">
          <div class="form-grid form-grid-2" style="gap:14px">
            <div class="fld">
              <label>Select Member</label>
              <select id="cred-member" class="cred-input">
                <option value="">- select -</option>
                {{#each groups.staff}}<option value="{{this.user._id}}" data-name="{{this.user.firstName}} {{this.user.lastName}}">👤 {{this.user.firstName}} {{this.user.lastName}} {{#if this.user.email}}({{this.user.email}}){{/if}}</option>{{/each}}
                {{#each groups.teachers}}<option value="{{this.user._id}}" data-name="{{this.user.firstName}} {{this.user.lastName}}">📖 {{this.user.firstName}} {{this.user.lastName}} {{#if this.user.email}}({{this.user.email}}){{/if}}</option>{{/each}}
                {{#each groups.students}}<option value="{{this.user._id}}" data-name="{{this.user.firstName}} {{this.user.lastName}}">🎓 {{this.user.firstName}} {{this.user.lastName}} {{#if this.user.studentId}}({{this.user.studentId}}){{/if}}</option>{{/each}}
                {{#each groups.admins}}<option value="{{this.user._id}}" data-name="{{this.user.firstName}} {{this.user.lastName}}">⭐ {{this.user.firstName}} {{this.user.lastName}} {{#if this.user.email}}({{this.user.email}}){{/if}}</option>{{/each}}
              </select>
            </div>
            <div class="fld">
              <label>Username <span style="font-weight:400;color:var(--ink-muted)">(blank = auto-generate)</span></label>
              <input type="text" id="cred-username" placeholder="e.g. johsmi2048" autocomplete="off">
            </div>
            <div class="fld">
              <label>Password</label>
              <input type="text" id="cred-password" placeholder="Min 8 characters" autocomplete="new-password">
            </div>
            <div style="display:flex;align-items:flex-end;gap:8px">
              <button class="btn btn-p" style="flex:1" onclick="issueSingleCredentials()">Issue Credentials</button>
              <button class="btn btn-o" onclick="genTempPw()" title="Auto-generate a password">🎲</button>
            </div>
          </div>
          <label style="display:flex;align-items:center;gap:8px;margin-top:12px;font-size:13px;cursor:pointer">
            <input type="checkbox" id="cred-gen-user" checked style="accent-color:var(--blue);width:15px;height:15px">
            Auto-generate username if left blank
          </label>
          <div class="result-toast" id="cred-result"></div>
        </div>
      </div>

      <div class="card">
        <div class="card-hdr">
          <div>
            <div class="card-hdr-title">⚡ Bulk Generate Credentials</div>
            <div class="card-hdr-sub">Issue temp username + password to every member without a password. Existing passwords are never overwritten.</div>
          </div>
        </div>
        <div class="card-body">
          <button class="btn btn-p" onclick="bulkGenCreds()">⚡ Generate for All Without Password</button>
          <div class="result-toast" id="bulk-cred-result"></div>
          <div id="bulk-cred-table" class="hidden" style="margin-top:16px">
            <div class="flex-row" style="margin-bottom:10px">
              <strong style="font-size:13px">Generated Credentials</strong>
              <button class="btn btn-o btn-sm" onclick="exportCreds()">⬇ CSV</button>
              <button class="btn btn-o btn-sm" onclick="copyAllCreds()">📋 Copy All</button>
            </div>
            <div class="table-wrap" style="max-height:280px">
              <table class="mem-table" id="bulk-cred-tbl">
                <thead><tr><th>Name</th><th>Role</th><th>Username</th><th>Temp Password</th><th></th></tr></thead>
                <tbody id="bulk-cred-tbody"></tbody>
              </table>
            </div>
            <p style="font-size:11.5px;color:var(--ink-muted);margin-top:8px">⚠️ Passwords shown once only - export before closing.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════
         PAGE: ASSIGN QUIZ
    ════════════════════════════ -->
    {{#unless isHomeSchool}}
    <section class="page" id="page-assign">
      <div class="card">
        <div class="card-hdr">
          <div class="card-hdr-title">📋 Assign Quiz to Specific Accounts</div>
          <div class="card-hdr-sub">Choose individuals or groups and assign a quiz or passage</div>
        </div>
        <div class="card-body">
          <form id="assignForm" method="post" action="/admin/orgs/{{org.slug}}/assign-quiz">
            <div class="form-grid form-grid-2" style="gap:16px">

              {{#if (eq org.type "school")}}
              <div class="fld">
                <label>Assign to Role</label>
                <select id="targetRole" name="targetRole">
                  <option value="student">Students (by grade)</option>
                  <option value="teacher">Teachers (all)</option>
                  <option value="specific">Specific Users (select below)</option>
                </select>
              </div>
              <div class="fld" id="gradeWrap">
                <label>Grade</label>
                <select id="gradeSelect" name="grade">
                  <option value="">- select grade -</option>
                  <option value="0">Grade 0</option><option value="1">Grade 1</option><option value="2">Grade 2</option><option value="3">Grade 3</option><option value="4">Grade 4</option><option value="5">Grade 5</option><option value="6">Grade 6</option><option value="7">Grade 7</option><option value="8">Grade 8</option><option value="9">Grade 9</option><option value="10">Grade 10</option><option value="11">Grade 11</option><option value="12">Grade 12</option><option value="13">Grade 13</option>
                </select>
              </div>
              {{/if}}

              <div class="fld col-full" id="specificWrap" {{#unless (eq org.type "school")}}style="display:block"{{else}}style="display:none"{{/unless}}>
                <label>Select Specific Users</label>
                <div class="user-select-list" id="userPickList">
                  {{#each groups.staff}}
                    {{#if this.user}}
                    <label class="user-check">
                      <input type="checkbox" name="userIds" value="{{this.user._id}}">
                      <div>
                        <div class="uc-name">{{this.user.firstName}} {{this.user.lastName}}</div>
                        <div class="uc-meta">{{this.user.email}} · Employee</div>
                      </div>
                    </label>
                    {{/if}}
                  {{/each}}
                  {{#each groups.teachers}}
                    {{#if this.user}}
                    <label class="user-check">
                      <input type="checkbox" name="userIds" value="{{this.user._id}}">
                      <div>
                        <div class="uc-name">{{this.user.firstName}} {{this.user.lastName}}</div>
                        <div class="uc-meta">{{this.user.email}} · Teacher</div>
                      </div>
                    </label>
                    {{/if}}
                  {{/each}}
                  {{#each groups.admins}}
                    {{#if this.user}}
                    <label class="user-check">
                      <input type="checkbox" name="userIds" value="{{this.user._id}}">
                      <div>
                        <div class="uc-name">{{this.user.firstName}} {{this.user.lastName}}</div>
                        <div class="uc-meta">{{this.user.email}} · Admin</div>
                      </div>
                    </label>
                    {{/if}}
                  {{/each}}
                </div>
                <div style="margin-top:6px;display:flex;gap:8px">
                  <button type="button" class="btn btn-o btn-sm" onclick="selectAll(true)">Select All</button>
                  <button type="button" class="btn btn-o btn-sm" onclick="selectAll(false)">Clear</button>
                </div>
              </div>

              <div class="fld">
                <label>Module</label>
                <select id="modules" name="modules" multiple size="5">
                  {{#each modules}}<option value="{{this.slug}}">{{this.title}}</option>{{/each}}
                </select>
                <div class="hint">Hold Ctrl/Cmd for multiple</div>
              </div>

              <div class="fld">
                <label>Passage / Quiz <span style="font-weight:400">(optional - overrides module sampling)</span></label>
                <select id="passageSelect" name="passageId">
                  <option value="">- No passage (random from module) -</option>
                  {{#each passages}}
                  <option value="{{this._id}}" data-child-count="{{this.childCount}}" data-module="{{this.module}}">
                    {{this.title}} ({{this.childCount}} q)
                  </option>
                  {{/each}}
                </select>
              </div>

              <div class="fld">
                <label>Question Count</label>
                <input type="number" id="count" name="count" min="1" max="100" value="20">
              </div>
              <div class="fld">
                <label>Duration (minutes)</label>
                <input type="number" id="durationMinutes" name="durationMinutes" min="1" max="300" value="30">
              </div>
            </div>

            <div style="margin-top:20px;display:flex;gap:10px">
              <button type="submit" class="btn btn-p" id="assignBtn">📋 Assign Quiz</button>
            </div>
          </form>
          <div class="result-toast" id="assignResult"></div>
        </div>
      </div>
    </section>
    {{/unless}}

    <!-- ════════════════════════════
         PAGE: BULK ASSIGN
    ════════════════════════════ -->
    {{#if (eq org.slug "cripfcnt-school")}}
    <section class="page" id="page-bulk">
      <div class="alert alert-warn">
        <span>⚠️</span>
        <div><strong>Large Operation:</strong> This creates one exam instance per user per quiz. With {{passages.length}} quizzes and {{groups.staff.length}} staff members, that's up to <strong>{{math passages.length "*" groups.staff.length}}</strong> instances. Use Preview first.</div>
      </div>

      <div class="card">
        <div class="card-hdr">
          <div class="card-hdr-title">📦 Bulk Assign All Quizzes</div>
          <div class="card-hdr-sub">Assign all {{passages.length}} quizzes to selected or all members at once</div>
        </div>
        <div class="card-body">
          <form id="bulkAssignForm">
            <div class="form-grid form-grid-2" style="gap:16px">
              <div class="fld">
                <label>Assign to</label>
                <select id="bulkTargetType" name="targetType">
                  <option value="all">All Members ({{groups.staff.length}} staff)</option>
                  <option value="specific">Specific Users</option>
                </select>
              </div>
              <div class="fld">
                <label>Duration per quiz (minutes)</label>
                <input name="durationMinutes" type="number" min="5" max="300" value="30">
              </div>
              <div class="fld col-full hidden" id="bulkUserWrap">
                <label>Select Users</label>
                <div class="user-select-list" id="bulkUserPick">
                  {{#each groups.staff}}{{#if this.user}}<label class="user-check"><input type="checkbox" name="bulkUserIds" value="{{this.user._id}}"><div><div class="uc-name">{{this.user.displayName}} {{this.user.firstName}}</div><div class="uc-meta">{{this.user.email}}</div></div></label>{{/if}}{{/each}}
                </div>
              </div>
            </div>
            <label style="display:flex;align-items:center;gap:8px;margin-top:14px;font-size:13px;cursor:pointer">
              <input type="checkbox" id="previewOnly" name="previewOnly" value="1" checked style="accent-color:var(--blue);width:15px;height:15px">
              Preview only (calculate without creating)
            </label>
            <div style="margin-top:16px;display:flex;gap:10px">
              <button type="submit" class="btn btn-g">📦 Bulk Assign All Quizzes</button>
              <button type="button" class="btn btn-o" onclick="document.getElementById('bulkAssignForm').reset();document.getElementById('previewOnly').checked=true;document.getElementById('bulkAssignResult').style.display='none'">Reset</button>
            </div>
          </form>
          <div class="result-toast" id="bulkAssignResult"></div>
        </div>
      </div>
    </section>
    {{/if}}

    <!-- ════════════════════════════
         PAGE: CREATE PASSAGE
    ════════════════════════════ -->
    {{#unless isHomeSchool}}
    <section class="page" id="page-passages">
      <div class="card">
        <div class="card-hdr">
          <div class="card-hdr-title">📝 Create Passage Quiz</div>
          <div class="card-hdr-sub">Paste a reading passage and its questions - saves as a comprehension quiz for this org</div>
        </div>
        <div class="card-body">
          <form id="createPassageForm" method="post" action="/admin/orgs/{{org.slug}}/passages">
            <div class="form-grid form-grid-2" style="gap:16px">
              <div class="fld">
                <label>Title</label>
                <input id="passageTitle" name="title" placeholder="Short descriptive title" required>
              </div>
              <div class="fld">
                <label>Module</label>
                <select id="passageModule" name="module" required>
                  {{#each modules}}<option value="{{this.slug}}">{{this.title}} ({{this.slug}})</option>{{/each}}
                </select>
              </div>
              <div class="fld col-full">
                <label>Passage Text</label>
                <textarea id="passageText" name="passage" rows="6" placeholder="Paste the reading passage here…" required style="resize:vertical"></textarea>
              </div>
              <div class="fld col-full">
                <label>Child Questions</label>
                <textarea id="passageQuestions" name="questions" rows="10" placeholder="Question 1&#10;a) Option&#10;b) Option&#10;Correct Answer: a&#10;&#10;Question 2…" required style="resize:vertical;font-family:'Courier New',monospace;font-size:12.5px"></textarea>
                <div class="hint">Separate questions with a blank line. Format: question text → choices (a/b/c/d) → Correct Answer: a</div>
              </div>
            </div>
            <div style="margin-top:16px">
              <button type="submit" class="btn btn-p">Create Passage Quiz</button>
            </div>
          </form>
          <div class="result-toast" id="createPassageResult"></div>
        </div>
      </div>
    </section>
    {{/unless}}

    <!-- ════════════════════════════
         PAGE: IMPORT
    ════════════════════════════ -->
    {{#if (eq org.type "school")}}
    {{#unless isHomeSchool}}
    <section class="page" id="page-import">
      <div class="form-grid" style="gap:16px">

        <div class="import-card">
          <div class="import-hdr"><span>🎓</span><div class="import-hdr-title">Import Students</div></div>
          <div class="import-body">
            <p style="font-size:12.5px;color:var(--ink-muted);margin-bottom:12px">Required columns: <code>studentId, firstName, lastName, grade</code></p>
            <form method="POST" action="/admin/orgs/{{org.slug}}/import-students" enctype="multipart/form-data">
              <label class="dropzone" id="dz-students" ondragover="this.classList.add('drag')" ondragleave="this.classList.remove('drag')" onclick="this.querySelector('input').click()">
                <input type="file" name="csv" accept=".csv" required onchange="handleFile(this,'dz-students')">
                <div class="dz-icon">📄</div>
                <div>Click or drag a CSV file here</div>
              </label>
              <button type="submit" class="btn btn-p btn-full" style="margin-top:10px">Upload Students</button>
            </form>
          </div>
        </div>

        <div class="import-card">
          <div class="import-hdr"><span>📖</span><div class="import-hdr-title">Import Teachers</div></div>
          <div class="import-body">
            <p style="font-size:12.5px;color:var(--ink-muted);margin-bottom:12px">Required columns: <code>email, firstName, lastName</code></p>
            <form method="POST" action="/admin/orgs/{{org.slug}}/import-teachers" enctype="multipart/form-data">
              <label class="dropzone" id="dz-teachers" onclick="this.querySelector('input').click()">
                <input type="file" name="csv" accept=".csv" required onchange="handleFile(this,'dz-teachers')">
                <div class="dz-icon">📄</div>
                <div>Click or drag a CSV file here</div>
              </label>
              <button type="submit" class="btn btn-p btn-full" style="margin-top:10px">Upload Teachers</button>
            </form>
          </div>
        </div>

        <div class="import-card">
          <div class="import-hdr"><span>⭐</span><div class="import-hdr-title">Import School Admins</div></div>
          <div class="import-body">
            <p style="font-size:12.5px;color:var(--ink-muted);margin-bottom:12px">Required columns: <code>adminId, firstName, lastName, role</code></p>
            <form method="POST" action="/admin/orgs/{{org.slug}}/import-admins" enctype="multipart/form-data">
              <label class="dropzone" id="dz-admins" onclick="this.querySelector('input').click()">
                <input type="file" name="csv" accept=".csv" required onchange="handleFile(this,'dz-admins')">
                <div class="dz-icon">📄</div>
                <div>Click or drag a CSV file here</div>
              </label>
              <button type="submit" class="btn btn-p btn-full" style="margin-top:10px">Upload Admins</button>
            </form>
          </div>
        </div>

      </div>
    </section>
    {{/unless}}
    {{/if}}

    <!-- ════════════════════════════
         PAGE: QUIZ RULES
    ════════════════════════════ -->
    {{#if (or isHomeSchool isCripSchool)}}
    <section class="page" id="page-rules">
      <!-- Create form -->
      <div class="card">
        <div class="card-hdr"><div class="card-hdr-title">➕ Create New Rule</div></div>
        <div class="card-body">
          <form method="POST" action="/admin/orgs/{{org.slug}}/quiz-rules">
            <div class="form-grid form-grid-3" style="gap:14px">
              {{#if isHomeSchool}}
              <div class="fld">
                <label>Grade</label>
                <select name="grade" required>
                  <option value="0">Grade 0</option><option value="1">Grade 1</option><option value="2">Grade 2</option><option value="3">Grade 3</option><option value="4">Grade 4</option><option value="5">Grade 5</option><option value="6">Grade 6</option><option value="7">Grade 7</option><option value="8">Grade 8</option><option value="9">Grade 9</option><option value="10">Grade 10</option><option value="11">Grade 11</option><option value="12">Grade 12</option><option value="13">Grade 13</option>
                </select>
              </div>
              <div class="fld">
                <label>Subject</label>
                <select name="subject">
                  <option value="math">Math</option><option value="english">English</option><option value="science">Science</option>
                  <option value="computerstudies">Computer Studies</option><option value="responsibility">Responsibility</option>
