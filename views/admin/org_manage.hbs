document.addEventListener('DOMContentLoaded', () => {
  const active = document.querySelector('.sb-item.active');
  const sub = document.getElementById('page-sub');
  if (active && sub) sub.textContent = active.textContent.trim().replace(/^\S+\s*/,'');

  // Set initial active state on bottom nav
  const initialPage = document.querySelector('.page.active')?.id?.replace('page-','') || 'overview';
  syncBottomNav(initialPage);

  // Mirror col-hide-* classes from <th> to corresponding <td> cells
  // so mobile column hiding works without Handlebars each-row duplication
  document.querySelectorAll('.mem-table').forEach(tbl => {
    const ths = Array.from(tbl.querySelectorAll('thead th'));
    ths.forEach((th, i) => {
      const cls = [];
      if (th.classList.contains('col-hide-sm')) cls.push('col-hide-sm');
      if (th.classList.contains('col-hide-xs')) cls.push('col-hide-xs');
      if (cls.length) {
        tbl.querySelectorAll('tbody tr').forEach(tr => {
          const td = tr.cells[i];
          if (td) td.classList.add(...cls);
        });
      }
    });
  });
});
