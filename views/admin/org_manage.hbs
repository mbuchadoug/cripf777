<script>
/* ── Swipe right on main area to open sidebar (mobile UX) ── */
(function () {
  let startX = 0;
  const main = document.querySelector('.main-area');
  if (!main) return;
  main.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive:true });
  main.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - startX;
    if (dx > 60 && startX < 40 && window.innerWidth <= 768) openSidebar();
  }, { passive:true });
  // Swipe left on open sidebar to close
  const sb = document.getElementById('sidebar');
  if (sb) {
    sb.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive:true });
    sb.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - startX;
      if (dx < -50 && window.innerWidth <= 768) closeSidebar();
    }, { passive:true });
  }
})();

// ═══════════════════════════════════════════════════════════════════
//  CLASSIFICATION MANAGER
// ═══════════════════════════════════════════════════════════════════
(function() {
  const ORG_SLUG = '{{org.slug}}';
  const BASE     = `/admin/orgs/${ORG_SLUG}/classify`;

  // Full pillar→category map (mirrors backend + AI script)
  const PILLARS = {
    consciousness:  { label:'Consciousness',  color:'#7c3aed', cats:['consciousness-studies','philosophical-inquiry','systems-thinking','critical-thinking','psychology','education','communication'] },
    responsibility: { label:'Responsibility', color:'#0d9488', cats:['governance','institutional-accountability','public-sector-ethics','rule-of-law','financial-accountability','structural-responsibility','social-contract','administration'] },
    interpretation: { label:'Interpretation', color:'#4f46e5', cats:['interpretive-frameworks','language-recalibration','media-literacy','strategic-communication','narrative-framing','research-methodology'] },
    purpose:        { label:'Purpose',        color:'#d97706', cats:['strategic-leadership','change-management','policy-implementation','community-leadership','crisis-management','motivation','organisational-development','human-resources'] },
    frequencies:    { label:'Frequencies',    color:'#e11d48', cats:['frequencies-and-influence','social-development','institutional-reform','performance-metrics'] },
    civilization:   { label:'Civilization',   color:'#059669', cats:['civilisation-theory','social-justice','human-rights','economic-justice','environmental-governance','electoral-systems','public-policy','law'] },
    negotiation:    { label:'Negotiation',    color:'#ea580c', cats:['conflict-resolution','negotiation-dynamics','diplomacy','finance','strategy'] },
    technology:     { label:'Technology',     color:'#2563eb', cats:['technology-governance','digital-ethics','ai-governance','risk-and-compliance','innovation'] }
  };
  const CAT_TO_PILLAR = {};
  for (const [p, d] of Object.entries(PILLARS)) d.cats.forEach(c => CAT_TO_PILLAR[c] = p);
  function toLabel(slug) { return slug.replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase()); }

  // ── State ──
  let _quizzes  = [];        // current list
  let _totalAll = 0;         // total count from server (unfiltered)
  let _counts   = {};        // category → count from server
  let _selected = new Set(); // selected quiz IDs
  let _filter   = 'all';
  let _filterVal = null;
  let _search   = '';
  let _searchTimer = null;

  // ── Panel state ──
  let _panelQuizId  = null;
  let _panelPillar  = null;
  let _panelCategory = null;

  // ── Init: load when page becomes visible ──
  const origGotoPage = window.gotoPage;
  window.gotoPage = function(page, el) {
    origGotoPage && origGotoPage(page, el);
    if (page === 'classify') {
      // Small delay so the section is visible before measuring height
      setTimeout(() => {
        clfSetShellHeight();
        clfReload();
      }, 30);
    }
  };

  // Set clf-shell height to use available viewport height
  function clfSetShellHeight() {
    const shell = document.querySelector('.clf-shell');
    if (!shell) return;
    if (window.innerWidth <= 768) {
      shell.style.height = '';
      return;
    }
    const rect = shell.getBoundingClientRect();
    const available = window.innerHeight - rect.top - 28;
    const clamped = Math.max(420, Math.min(available, 820));
    shell.style.height = clamped + 'px';
  }
  window.addEventListener('resize', () => {
    clearTimeout(window._clfResizeTimer);
    window._clfResizeTimer = setTimeout(clfSetShellHeight, 60);
  });

  // ── Public API (called by inline onclick) ──
  window.clfReload        = clfReload;
  window.clfSetShellHeight = clfSetShellHeight;
  window.clfSetFilter     = clfSetFilter;
  window.clfSearch        = clfSearchDebounce;
  window.clfSearchNow     = clfSearchNow;
  window.clfSearchClear   = clfSearchClear;
  window.clfToggleAll     = clfToggleAll;
  window.clfClearSelection= clfClearSelection;
  window.clfBulkPillarChange = clfBulkPillarChange;
  window.clfBulkApply     = clfBulkApply;
  window.clfOpenPanel     = clfOpenPanel;
  window.clfClosePanel    = clfClosePanel;
  window.clfSave          = clfSave;
  window.clfSelectPillar  = clfSelectPillar;
  window.clfSelectCat     = clfSelectCat;
  window.clfToggleRow     = clfToggleRow;

  // ── Load quizzes from server ──
  async function clfReload() {
    const params = new URLSearchParams();
    if (_filter === 'unclassified') params.set('unclassified', '1');
    else if (_filter === 'pillar')  params.set('pillar', _filterVal);
    else if (_filter === 'category') params.set('category', _filterVal);
    if (_search) params.set('q', _search);

    const list = document.getElementById('clf-list');
    list.innerHTML = '<div class="clf-loading">⏳ Loading…</div>';

    try {
      const r    = await fetch(`${BASE}/quizzes?${params}`);
      const data = await r.json();
      if (!data.ok) throw new Error(data.error);

      _quizzes   = data.quizzes;
      _totalAll  = data.total;   // full unfiltered count from server
      _counts    = data.counts;
      _selected.clear();
      updateSidebarCounts();
      renderList();
      updateBulkBar();

      // Show result count / search feedback
      const badge = document.getElementById('clf-status-badge');
      if (badge) {
        if (_search) {
          const n = _quizzes.length;
          badge.style.color = n === 0 ? 'var(--rose)' : n === _totalAll ? 'var(--amber)' : 'var(--emerald)';
          badge.textContent = n === 0
            ? `No results for "${_search}"`
            : n === _totalAll
            ? `⚠ ${n} results - all quizzes match, search may not be filtering`
            : `${n} result${n !== 1 ? 's' : ''} for "${_search}"`;
        } else {
          badge.style.color = 'var(--ink-muted)';
          badge.textContent = `${_totalAll} total quiz${_totalAll !== 1 ? 'zes' : ''}`;
        }
      }
    } catch (e) {
      list.innerHTML = `<div class="clf-loading" style="color:var(--rose)">⚠ ${e.message}</div>`;
    }
  }

  function updateSidebarCounts() {
    // Total - always from server total, not current filtered list
    document.getElementById('clf-count-all').textContent = _totalAll || _quizzes.length;
    // Unclassified + locked - derive from server _counts (none key = unclassified)
    const unclassifiedTotal = (_counts['__none__'] || 0) + (_counts[''] || 0)
      + (_counts['null'] || 0) + (_counts['out-of-scope'] || 0);
    document.getElementById('clf-count-unclassified').textContent = unclassifiedTotal || 
      _quizzes.filter(q => !q.category || q.category === 'out-of-scope').length;
    document.getElementById('clf-count-locked').textContent =
      _quizzes.filter(q => q.isLocked).length;

    // Per-pillar counts from server _counts (full corpus, not filtered list)
    const pillarTotals = {};
    for (const [cat, count] of Object.entries(_counts)) {
      const p = CAT_TO_PILLAR[cat];
      if (p) pillarTotals[p] = (pillarTotals[p] || 0) + count;
    }
    for (const p of Object.keys(PILLARS)) {
      const el = document.getElementById(`clf-p-${p}`);
      if (el) el.textContent = pillarTotals[p] || 0;
    }
  }

  function renderList() {
    const list = document.getElementById('clf-list');
    if (!_quizzes.length) {
      if (_search) {
        list.innerHTML = `<div class="clf-loading" style="flex-direction:column;gap:8px">
          <span style="font-size:18px">🔍</span>
          <span>No quizzes found for <strong>"${escHtml(_search)}"</strong></span>
          <span style="font-size:12px;color:var(--ink-faint)">Try a shorter search term or part of the title</span>
          <button class="btn btn-o btn-sm" style="margin-top:4px" onclick="clfSearchClear()">Clear Search</button>
        </div>`;
      } else {
        list.innerHTML = '<div class="clf-loading">No quizzes match this filter.</div>';
      }
      return;
    }

    // Server already applied all filters; client-side only needed for locked
    // (unclassified is handled server-side via ?unclassified=1)
    let items = _quizzes;
    if (_filter === 'locked') items = _quizzes.filter(q => q.isLocked);

    list.innerHTML = items.map(q => {
      const catBadge = q.category && q.category !== 'out-of-scope'
        ? `<span class="clf-badge clf-badge-cat">${toLabel(q.category)}</span>`
        : q.category === 'out-of-scope'
        ? `<span class="clf-badge clf-badge-oos">Out of scope</span>`
        : `<span class="clf-badge clf-badge-none">Unclassified</span>`;
      const lockBadge = q.isLocked ? `<span class="clf-badge clf-badge-lock">🔒</span>` : '';
      const confBadge = q.confidence != null ? `<span class="clf-badge clf-badge-conf">${(q.confidence*100).toFixed(0)}%</span>` : '';
      const pillarDot = q.pillar && PILLARS[q.pillar]
        ? `<span class="clf-dot" style="background:${PILLARS[q.pillar].color};display:inline-block;margin-right:3px"></span>`
        : '';
      const isChecked = _selected.has(q.id) ? 'checked' : '';

      return `<div class="clf-row${_selected.has(q.id)?' selected':''}" id="clfrow-${q.id}">
        <div class="clf-row-chk">
          <input type="checkbox" ${isChecked} onchange="clfToggleRow('${q.id}',this.checked)"
            style="accent-color:var(--blue);width:14px;height:14px;cursor:pointer">
        </div>
        <div class="clf-row-info">
          <div class="clf-row-title">${escHtml(q.title)}</div>
          <div class="clf-row-meta">
            ${pillarDot}${q.pillar ? `<span style="font-weight:500">${toLabel(q.pillar)}</span>` : ''}
            ${q.pillar && (q.category || lockBadge) ? '<span style="color:var(--border)">·</span>' : ''}
            ${catBadge} ${lockBadge}
            ${q.series ? `<span style="color:var(--ink-faint);font-size:10.5px">· ${escHtml(q.series)}</span>` : ''}
          </div>
        </div>
        <div class="clf-row-actions">
          <button class="clf-edit-btn"
            onclick="clfOpenPanel('${q.id}','${escAttr(q.title)}','${q.pillar||''}','${q.category||''}','${q.series||''}')">
            ✏️ <span class="act-lbl">Edit</span>
          </button>
        </div>
      </div>`;
    }).join('');
  }

  // ── Filter controls ──
  function clfSetFilter(type, val) {
    _filter   = type;
    _filterVal = val || null;
    _selected.clear();
    document.querySelectorAll('.clf-filter').forEach(b => b.classList.remove('active'));
    if (type === 'all') document.getElementById('clf-f-all')?.classList.add('active');
    else if (type === 'unclassified') document.getElementById('clf-f-unclassified')?.classList.add('active');
    else if (type === 'locked') document.getElementById('clf-f-locked')?.classList.add('active');
    clfReload();
  }

  // ── Search ──
  function clfSearchDebounce(val) {
    _search = val.trim();
    // Show/hide clear button
    const clearBtn = document.getElementById('clf-search-clear');
    if (clearBtn) clearBtn.style.display = _search ? 'block' : 'none';
    clearTimeout(_searchTimer);
    _searchTimer = setTimeout(clfReload, 500); // 500ms debounce - avoids mid-word hits
  }

  // Immediate search on Enter key
  function clfSearchNow() {
    clearTimeout(_searchTimer);
    const inp = document.getElementById('clf-search');
    if (inp) _search = inp.value.trim();
    const clearBtn = document.getElementById('clf-search-clear');
    if (clearBtn) clearBtn.style.display = _search ? 'block' : 'none';
    clfReload();
  }

  // Clear search
  function clfSearchClear() {
    const inp = document.getElementById('clf-search');
    if (inp) inp.value = '';
    _search = '';
    const clearBtn = document.getElementById('clf-search-clear');
    if (clearBtn) clearBtn.style.display = 'none';
    clfReload();
  }

  // ── Selection ──
  function clfToggleRow(id, checked) {
    if (checked) _selected.add(id); else _selected.delete(id);
    const row = document.getElementById(`clfrow-${id}`);
    if (row) row.classList.toggle('selected', checked);
    updateBulkBar();
  }
  function clfToggleAll(checked) {
    // Server already filtered for unclassified/pillar; client only filters locked
    let items = _quizzes;
    if (_filter === 'locked') items = _quizzes.filter(q => q.isLocked);
    items.forEach(q => {
      if (checked) _selected.add(q.id); else _selected.delete(q.id);
      const row = document.getElementById(`clfrow-${q.id}`);
      if (row) row.classList.toggle('selected', checked);
      const chk = row?.querySelector('input[type=checkbox]');
      if (chk) chk.checked = checked;
    });
    updateBulkBar();
  }
  function clfClearSelection() {
    _selected.clear();
    document.querySelectorAll('.clf-row').forEach(r => r.classList.remove('selected'));
    document.querySelectorAll('.clf-row input[type=checkbox]').forEach(c => c.checked = false);
    document.getElementById('clf-select-all').checked = false;
    updateBulkBar();
  }
  function updateBulkBar() {
    const bar = document.getElementById('clf-bulk-bar');
    const n   = _selected.size;
    bar.classList.toggle('visible', n > 0);
    document.getElementById('clf-bulk-label').textContent = `${n} quiz${n !== 1 ? 'zes' : ''} selected`;
    document.getElementById('clf-clear-btn').style.display = n > 0 ? '' : 'none';
    document.getElementById('clf-bulk-result').textContent = '';
  }

  // ── Bulk apply ──
  function clfBulkPillarChange() {
    const p = document.getElementById('clf-bulk-pillar').value;
    const catSel = document.getElementById('clf-bulk-category');
    catSel.innerHTML = '<option value="">- Select Category -</option>';
    catSel.disabled  = !p;
    document.getElementById('clf-bulk-apply-btn').disabled = true;
    if (p && PILLARS[p]) {
      PILLARS[p].cats.forEach(c => {
        const o = document.createElement('option');
        o.value = c; o.textContent = toLabel(c);
        catSel.appendChild(o);
      });
    }
    catSel.onchange = () => {
      document.getElementById('clf-bulk-apply-btn').disabled = !catSel.value;
    };
  }

  async function clfBulkApply() {
    const category = document.getElementById('clf-bulk-category').value;
    if (!category || !_selected.size) return;
    const btn = document.getElementById('clf-bulk-apply-btn');
    const res = document.getElementById('clf-bulk-result');
    btn.disabled = true; btn.textContent = 'Saving…';
    try {
      const r = await fetch(`${BASE}/bulk`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quizIds: [..._selected], category })
      });
      const data = await r.json();
      if (!data.ok) throw new Error(data.error);
      res.style.color = 'var(--emerald)';
      res.textContent = `✓ ${data.modified} quiz${data.modified !== 1 ? 'zes' : ''} → ${toLabel(category)}`;
      clfClearSelection();
      await clfReload();
    } catch (e) {
      res.style.color = 'var(--rose)';
      res.textContent = `✗ ${e.message}`;
    } finally {
      btn.disabled = false; btn.textContent = 'Apply to Selected';
    }
  }

  // ── Classification Panel ──
  function clfOpenPanel(id, title, pillar, category, series) {
    _panelQuizId   = id;
    _panelPillar   = pillar || null;
    _panelCategory = category || null;

    document.getElementById('clf-panel-quizId').value = id;
    document.getElementById('clf-panel-sub').textContent = title;
    document.getElementById('clf-panel-series').value = series || '';
    document.getElementById('clf-panel-result').innerHTML = '';

    // Render pillar grid
    const grid = document.getElementById('clf-pillar-grid');
    grid.innerHTML = Object.entries(PILLARS).map(([slug, d]) =>
      `<button class="clf-cat-btn${pillar===slug?' selected':''}" onclick="clfSelectPillar('${slug}')"
        style="${pillar===slug?`border-color:${d.color};color:${d.color};background:${d.color}15`:''}"
      ><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${d.color};margin-right:6px"></span>${d.label}</button>`
    ).join('');

    // Pre-select category if existing
    if (pillar && PILLARS[pillar]) {
      _renderCatList(pillar, category);
      document.getElementById('clf-cat-section').style.display = '';
      document.getElementById('clf-series-section').style.display = '';
    } else {
      document.getElementById('clf-cat-section').style.display = 'none';
      document.getElementById('clf-series-section').style.display = 'none';
    }

    // Save button state
    document.getElementById('clf-panel-save-btn').disabled = !(pillar && category);

    document.getElementById('clfOverlay').classList.add('open');
    document.getElementById('clfPanel').classList.add('open');
  }

  function clfClosePanel() {
    document.getElementById('clfOverlay').classList.remove('open');
    document.getElementById('clfPanel').classList.remove('open');
  }

  function clfSelectPillar(slug) {
    _panelPillar   = slug;
    _panelCategory = null;
    // Highlight selected pillar button
    document.querySelectorAll('#clf-pillar-grid .clf-cat-btn').forEach(b => {
      const isSel = b.textContent.trim().toLowerCase().startsWith(PILLARS[slug].label.toLowerCase());
      b.classList.toggle('selected', b.onclick?.toString().includes(`'${slug}'`));
    });
    // Re-render grid with highlight
    const grid = document.getElementById('clf-pillar-grid');
    grid.innerHTML = Object.entries(PILLARS).map(([s, d]) =>
      `<button class="clf-cat-btn${slug===s?' selected':''}" onclick="clfSelectPillar('${s}')"
        style="${slug===s?`border-color:${d.color};color:${d.color};background:${d.color}15`:''}"
      ><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${d.color};margin-right:6px"></span>${d.label}</button>`
    ).join('');
    _renderCatList(slug, null);
    document.getElementById('clf-cat-section').style.display = '';
    document.getElementById('clf-series-section').style.display = '';
    document.getElementById('clf-panel-save-btn').disabled = true;
  }

  function _renderCatList(pillar, selectedCat) {
    const catList = document.getElementById('clf-cat-list');
    const color   = PILLARS[pillar]?.color || 'var(--blue)';
    catList.innerHTML = (PILLARS[pillar]?.cats || []).map(cat =>
      `<button class="clf-cat-btn${cat===selectedCat?' selected':''}" onclick="clfSelectCat('${cat}')"
        style="${cat===selectedCat?`border-color:${color};color:${color};background:${color}15`:''}"
      >${toLabel(cat)}</button>`
    ).join('');
  }

  function clfSelectCat(cat) {
    _panelCategory = cat;
    _renderCatList(_panelPillar, cat);
    document.getElementById('clf-panel-save-btn').disabled = false;
  }

  async function clfSave() {
    if (!_panelQuizId || !_panelCategory) return;
    const btn    = document.getElementById('clf-panel-save-btn');
    const result = document.getElementById('clf-panel-result');
    const series = document.getElementById('clf-panel-series').value.trim().toLowerCase().replace(/\s+/g,'-') || undefined;
    const lock   = document.getElementById('clf-panel-lock').checked;

    btn.disabled = true; btn.textContent = 'Saving…';
    result.innerHTML = '';

    try {
      const r = await fetch(`${BASE}/quiz/${_panelQuizId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category: _panelCategory, series, lock })
      });
      const data = await r.json();
      if (!data.ok) throw new Error(data.error);

      result.innerHTML = `<span style="color:var(--emerald);font-weight:600">✓ Saved → ${toLabel(data.pillar)} / ${toLabel(data.category)}</span>`;
      setTimeout(() => { clfClosePanel(); clfReload(); }, 800);
    } catch (e) {
      result.innerHTML = `<span style="color:var(--rose)">✗ ${e.message}</span>`;
    } finally {
      btn.disabled = false; btn.textContent = 'Save Classification';
    }
  }

  // ── Utilities ──
  function escHtml(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function escAttr(s) { return String(s||'').replace(/'/g,"\\'"); }


  function openCreateUserModal() {
  document.getElementById('createUserModal').classList.add('open');
}

function closeCreateUserModal() {
  document.getElementById('createUserModal').classList.remove('open');
}

document.getElementById('createUserForm').addEventListener('submit', async function(e) {
  e.preventDefault();

  const form = new FormData(this);
  const data = Object.fromEntries(form.entries());

  const orgSlug = document.body.dataset.orgSlug;

  const res = await fetch(`/admin/orgs/${orgSlug}/members/add`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  });

  const result = await res.json();

  const box = document.getElementById('createUserResult');

  if (result.ok) {
    box.className = 'result-toast ok';
    box.style.display = 'block';

    box.innerHTML = `
      ✅ User Created<br><br>
      Username: <strong>${result.username}</strong><br>
      Password: <strong>${result.tempPassword}</strong><br>
      Login: /auth/school
    `;

    this.reset();
  } else {
    box.className = 'result-toast err';
    box.style.display = 'block';
    box.textContent = result.error || 'Failed to create user';
  }
});
})();
</script>

