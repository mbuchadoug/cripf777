<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Attempt Review</title>
  <style>
    body{font-family:system-ui,Arial,sans-serif;background:#f3f4f6;margin:0;padding:24px;}
    .wrap{max-width:1000px;margin:0 auto;}
    .card{background:#fff;border-radius:12px;padding:18px 20px;box-shadow:0 2px 10px rgba(0,0,0,.08);margin-bottom:12px;}
    .meta{color:#6b7280;font-size:13px;margin-top:4px;}
    .q{border:1px solid #e5e7eb;border-radius:12px;padding:14px 16px;margin-top:10px;}
    .ok{background:#dcfce7;color:#166534;font-weight:900;padding:4px 10px;border-radius:999px;display:inline-block;}
    .bad{background:#fee2e2;color:#991b1b;font-weight:900;padding:4px 10px;border-radius:999px;display:inline-block;}
    a{color:#6366f1;text-decoration:none;font-weight:900;}
  </style>
</head>
<body>
  <div class="wrap">

    <div class="card">
      <a href="/teacher/campaign/{{campaign._id}}">Back to Campaign</a>
      <div style="font-weight:900;font-size:18px;margin-top:8px;">{{quizTitle}}</div>
      <div class="meta">
        Student: <b>{{participant.name}}</b> · Grade {{participant.grade}} · {{participant.school}}
      </div>
      <div class="meta">
        Score: <b>{{attempt.percentage}}%</b> ({{attempt.score}} / {{attempt.maxScore}})
      </div>
    </div>

    {{#if passage}}
      <div class="card">
        <div style="font-weight:900;">Passage</div>
        <div style="white-space:pre-wrap;margin-top:8px;color:#111827;">{{passage}}</div>
      </div>
    {{/if}}

    <div class="card">
      <div style="font-weight:900;">Review</div>

      {{#each review}}
        <div class="q">
          <div style="font-weight:900;">Q{{number}}. {{text}}</div>

          {{#if choices.length}}
            <div style="margin-top:10px;">
              <div style="font-weight:800;font-size:13px;color:#111827;margin-bottom:6px;">Choices</div>
              <ul style="margin:0;padding-left:18px;color:#374151;">
                {{#each choices}}
                  <li><b>{{label}})</b> {{text}}</li>
                {{/each}}
              </ul>
            </div>
          {{/if}}

          <div style="margin-top:10px;">
            {{#if correct}}
              <div class="ok">✅ Correct</div>
            {{else}}
              <div class="bad">❌ Wrong</div>
            {{/if}}

            <div style="margin-top:6px;color:#374151;">
              Selected:
              <b>{{selectedLabel}}) {{selectedText}}</b>
            </div>

            {{#unless correct}}
              <div style="margin-top:6px;color:#111827;">
                Correct:
                <b>{{correctLabel}}) {{correctText}}</b>
              </div>
            {{/unless}}
          </div>

          {{#if solutionText}}
            <div style="margin-top:10px;padding:10px 12px;border-radius:10px;background:#f9fafb;border:1px solid #e5e7eb;">
              <div style="font-weight:900;color:#111827;margin-bottom:4px;">Solution</div>
              <div style="color:#374151;">{{solutionText}}</div>
            </div>
          {{/if}}
        </div>
      {{/each}}

      {{#unless review.length}}
        <div class="meta">No answers recorded for this attempt.</div>
      {{/unless}}
    </div>

  </div>
</body>
</html>