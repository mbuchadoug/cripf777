    <!-- ============================== -->
    <!-- TAB: QUIZ LIBRARY (SYSTEM)     -->
    <!-- ============================== -->
    <div id="tab-library" class="tab-panel">
      <div class="page-header">
        <h2>Quiz Library</h2>
        <p>Pre-made quizzes from CRIPFCnt : assign directly to your students</p>
      </div>

      {{#if systemQuizzes.length}}
        <div class="section-card">
          <div class="section-body">
            <div id="libraryContent">
              {{!-- Group by subject, rendered via JS below --}}
            </div>
          </div>
        </div>

        <script>
          // Group system quizzes by subject for organized display
          (function() {
            const quizzes = {{{json systemQuizzes}}};
            const isPaidTeacher = {{#if isPaid}}true{{else}}false{{/if}};
            const container = document.getElementById('libraryContent');
            if (!quizzes || !quizzes.length) return;

            const grouped = {};
            quizzes.forEach(q => {
              const subj = q.subject || q.module || 'general';
              if (!grouped[subj]) grouped[subj] = [];
              grouped[subj].push(q);
            });

            const subjectIcons = {
              math: '🔢', english: '📖', science: '🔬',
              responsibility: '🤝', social_studies: '🌍'
            };

            let html = '';
            Object.keys(grouped).sort().forEach(subj => {
              const list = grouped[subj];
              const icon = subjectIcons[subj] || '📋';
              html += '<div class="level-section">';
              html += '<h4>' + icon + ' ' + subj.charAt(0).toUpperCase() + subj.slice(1).replace('_', ' ') + ' (' + list.length + ')</h4>';
              html += '<div class="quiz-grid">';
              list.forEach(q => {
                html += '<div class="quiz-card">';
                html += '<div class="quiz-title">' + (q.quizTitle || 'Untitled Quiz') + '</div>';
                html += '<div class="quiz-tags">';
                html += '<span class="tag ' + subj + '">' + subj + '</span>';
                if (q.grade) html += '<span class="tag">Grade ' + q.grade + '</span>';
                if (q.quizType) html += '<span class="tag">' + q.quizType + '</span>';
                html += '</div>';
               html += '<div class="quiz-meta">' + (q.questionCount || '?') + ' questions · ' + (q.durationMinutes || 30) + ' min</div>';
             html += '<div class="actions">';

if (isPaidTeacher) {
  html += '<a href="/teacher/library-quiz/' + q._id + '/preview" class="btn btn-outline">Preview</a>';
} else {
  html += '<a href="/teacher/pricing?locked=library_preview" class="btn btn-outline">🔒 Preview (Upgrade)</a>';
}

html += '<button class="btn btn-success" onclick="openAssignLibrary(\'' + q._id + '\', \'' + (q.quizTitle || '').replace(/'/g, "\\'") + '\')">Assign</button>';
html += '</div>';
                html += '</div>';
              });
              html += '</div></div>';
            });

            container.innerHTML = html;
          })();
        </script>
      {{else}}
        <div class="section-card">
          <div class="empty-state">
            <div class="empty-icon">📖</div>
            <p>No library quizzes available for your selected school levels yet.</p>
            <a href="/teacher/setup" class="btn btn-outline" style="margin-top:12px;">Change School Levels</a>
          </div>
        </div>
      {{/if}}
    </div>

