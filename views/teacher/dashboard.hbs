<!-- TOAST -->
<div id="toast" class="toast"></div>

<script>
  // ==============================
  // MOBILE SIDEBAR TOGGLE (FIXED)
  // ==============================
  const sidebar = document.getElementById('sidebar');
  const menuBtn = document.getElementById('mobileMenuBtn');
  const closeBtn = document.getElementById('sidebarClose');
  const backdrop = document.getElementById('sidebarBackdrop');

  function openSidebar() {
    sidebar.classList.add('open');
    backdrop.classList.add('active');
    menuBtn.style.display = 'none';
  }

  function closeSidebar() {
    sidebar.classList.remove('open');
    backdrop.classList.remove('active');
    // Show menu button again after transition
    setTimeout(() => {
      if (window.innerWidth <= 1024) {
        menuBtn.style.display = 'block';
      }
    }, 300);
  }

  menuBtn.addEventListener('click', openSidebar);
  closeBtn.addEventListener('click', closeSidebar);
  backdrop.addEventListener('click', closeSidebar);

  // ==============================
  // TAB SWITCHING
  // ==============================
  function showTab(tabId, clickedNav) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item[data-tab]').forEach(n => n.classList.remove('active'));

    const panel = document.getElementById('tab-' + tabId);
    if (panel) panel.classList.add('active');

    if (clickedNav) {
      clickedNav.classList.add('active');
    } else {
      const navBtn = document.querySelector('.nav-item[data-tab="' + tabId + '"]');
      if (navBtn) navBtn.classList.add('active');
    }

    // Close sidebar on mobile after tab switch
    if (window.innerWidth <= 1024) closeSidebar();
  }

  // ==============================
  // MODAL
  // ==============================
function openModal(id) {
  document.getElementById(id).classList.add('active');
}

function closeModal(id) {
  document.getElementById(id).classList.remove('active');
}

/* ✅ NEW: Switch Upload Modal Tabs */
function switchUploadTab(which) {
  const jsonForm = document.querySelector('form[data-upload-tab="json"]');
  const textForm = document.querySelector('form[data-upload-tab="text"]');
  const jsonBtn = document.getElementById('tabJsonBtn');
  const textBtn = document.getElementById('tabTextBtn');

  if (!jsonForm || !textForm) return;

  if (which === 'text') {
    jsonForm.style.display = 'none';
    textForm.style.display = 'block';
    jsonBtn.classList.remove('btn-primary'); jsonBtn.classList.add('btn-outline');
    textBtn.classList.remove('btn-outline'); textBtn.classList.add('btn-primary');
  } else {
    textForm.style.display = 'none';
    jsonForm.style.display = 'block';
    textBtn.classList.remove('btn-primary'); textBtn.classList.add('btn-outline');
    jsonBtn.classList.remove('btn-outline'); jsonBtn.classList.add('btn-primary');
  }
}




  function openAssignSingle(quizId, title) {
    document.getElementById('assignSingleQuizId').value = quizId;
    document.getElementById('assignSingleTitle').textContent = title;
    openModal('assignSingleModal');
  }

  // Close modals on backdrop click
  document.querySelectorAll('.modal-overlay').forEach(m => {
    m.addEventListener('click', e => {
      if (e.target === m) m.classList.remove('active');
    });
  });

  // ==============================
  // TOAST
  // ==============================
  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast ' + type + ' show';
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  // ==============================
  // GENERATE AI QUIZ
  // ==============================
  document.getElementById('generateForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    const origText = btn.textContent;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Generating...';
    const data = Object.fromEntries(new FormData(e.target));
    try {
      const r = await fetch('/teacher/generate-quiz', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await r.json();
      if (result.success) { showToast('Quiz generated!'); setTimeout(() => location.reload(), 800); }
      else { showToast(result.error, 'error'); btn.disabled = false; btn.textContent = origText; }
    } catch { showToast('Failed', 'error'); btn.disabled = false; btn.textContent = origText; }
  });

  // ==============================
  // UPLOAD QUIZ
  // ==============================
  document.getElementById('uploadForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Uploading...';
    try {
      const r = await fetch('/teacher/upload-quiz', { method: 'POST', body: new FormData(e.target) });
      const result = await r.json();
      if (result.success) { showToast(`Uploaded! ${result.questionCount} questions.`); setTimeout(() => location.reload(), 800); }
      else { showToast(result.error, 'error'); btn.disabled = false; btn.textContent = 'Upload Quiz'; }
    } catch { showToast('Upload failed', 'error'); btn.disabled = false; btn.textContent = 'Upload Quiz'; }
  });


// ==============================
// UPLOAD QUIZ (PLAIN TEXT) ✅ NEW
// ==============================
document.getElementById('uploadTextForm').addEventListener('submit', async e => {
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  const origText = btn.textContent;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Uploading...';

  try {
    const plainText = new FormData(e.target).get('plainText');

    const r = await fetch('/teacher/upload-quiz-text', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ plainText })
    });

    const result = await r.json();

    if (result.success) {
      showToast(`Uploaded! ${result.questionCount} questions.`);
      setTimeout(() => location.reload(), 800);
    } else {
      showToast(result.error || 'Upload failed', 'error');
      btn.disabled = false;
      btn.textContent = origText;
    }
  } catch {
    showToast('Upload failed', 'error');
    btn.disabled = false;
    btn.textContent = origText;
  }
});

  // ==============================
  // UPLOAD MATERIAL
  // ==============================
 // ==============================
  // UPLOAD MATERIAL
  // ==============================
  document.getElementById('materialForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    const origText = btn.textContent;
    btn.disabled = true; 
    btn.innerHTML = '<span class="spinner"></span> Uploading...';
    
    try {
      const formData = new FormData(e.target);
      
      // Get selected student IDs (only for individual assignment)
      const assignType = formData.get('assignmentType');
      if (assignType === 'individual') {
        const checkboxes = e.target.querySelectorAll('input[name="studentIds"]:checked');
        formData.delete('studentIds'); // Clear existing
        checkboxes.forEach(cb => formData.append('studentIds', cb.value));
      }
      
      const r = await fetch('/teacher/upload-material', { 
        method: 'POST', 
        body: formData 
      });
      
      const result = await r.json();
      
      if (result.success) { 
        if (result.isVideo) {
          showToast('Video uploaded! Processing in background...'); 
        } else {
          showToast('Material uploaded successfully!'); 
        }
        closeModal('materialModal'); 
        e.target.reset();
        setTimeout(() => window.location.href = '/teacher/materials', 1000);
      } else { 
        showToast(result.error, 'error'); 
        btn.disabled = false; 
        btn.textContent = origText; 
      }
    } catch (err) { 
      console.error('Upload error:', err);
      showToast('Upload failed: ' + err.message, 'error'); 
      btn.disabled = false; 
      btn.textContent = origText; 
    }
  });

  // ==============================
  // ASSIGN SINGLE QUIZ
  // ==============================
  document.getElementById('assignSingleForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Assigning...';
    const fd = new FormData(e.target);
    const studentIds = fd.getAll('studentIds[]');
    const quizId = fd.get('quizId');
    if (!studentIds.length) { showToast('Select students', 'error'); btn.disabled = false; btn.textContent = 'Assign'; return; }
    try {
      const r = await fetch('/teacher/assign-quiz', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quizId, studentIds })
      });
      const result = await r.json();
      if (result.success) { showToast(`Assigned to ${result.assigned} student(s)`); setTimeout(() => location.reload(), 800); }
      else { showToast(result.error, 'error'); btn.disabled = false; btn.textContent = 'Assign'; }
    } catch { showToast('Failed', 'error'); btn.disabled = false; btn.textContent = 'Assign'; }
  });

  // ==============================
  // BULK ASSIGN
  // ==============================
  document.getElementById('bulkAssignForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Assigning...';
    const fd = new FormData(e.target);
    const quizIds = fd.getAll('quizIds'); const studentIds = fd.getAll('studentIds');
    const durationMinutes = fd.get('durationMinutes');
    if (!quizIds.length || !studentIds.length) { showToast('Select quizzes and students', 'error'); btn.disabled = false; btn.textContent = 'Assign Selected'; return; }
    try {
      const r = await fetch('/teacher/bulk-assign', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quizIds, studentIds, durationMinutes: Number(durationMinutes) })
      });
      const result = await r.json();
      if (result.success) { showToast(`${result.assigned} assigned, ${result.skipped} skipped`); }
      else { showToast(result.error, 'error'); }
    } catch { showToast('Failed', 'error'); }
    btn.disabled = false; btn.textContent = 'Assign Selected';
  });

  // ==============================
  // GENERATE REPORT
  // ==============================
  document.getElementById('reportForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Generating...';
    const fd = new FormData(e.target);
    const studentIds = fd.getAll('studentIds');
    if (!studentIds.length) { showToast('Select students', 'error'); btn.disabled = false; btn.textContent = '📈 Generate Report'; return; }
    try {
      const r = await fetch('/teacher/generate-report', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ studentIds, subject: fd.get('subject'), dateFrom: fd.get('dateFrom'), dateTo: fd.get('dateTo'), teacherNotes: fd.get('teacherNotes') })
      });
      const result = await r.json();
      if (result.success) { showToast('Report generated!'); document.getElementById('reportResult').style.display = 'block'; document.getElementById('reportDownload').href = result.reportUrl; }
      else { showToast(result.error, 'error'); }
    } catch { showToast('Failed', 'error'); }
    btn.disabled = false; btn.textContent = '📈 Generate Report';
  });



  // ==============================
  // ASSIGN LIBRARY QUIZ
  // ==============================
  function openAssignLibrary(ruleId, title) {
    document.getElementById('assignLibraryRuleId').value = ruleId;
    document.getElementById('assignLibraryTitle').textContent = title;
    openModal('assignLibraryModal');
  }

  document.getElementById('assignLibraryForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Assigning...';
    const fd = new FormData(e.target);
    const studentIds = fd.getAll('studentIds[]');
    const ruleId = fd.get('ruleId');
    const durationMinutes = fd.get('durationMinutes');
    if (!studentIds.length) { showToast('Select students', 'error'); btn.disabled = false; btn.textContent = 'Assign'; return; }
    try {
      const r = await fetch('/teacher/assign-library-quiz', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ruleId, studentIds, durationMinutes: Number(durationMinutes) })
      });
      const result = await r.json();
      if (result.success) { showToast(`Assigned to ${result.assigned} student(s), ${result.skipped} skipped`); closeModal('assignLibraryModal'); }
      else { showToast(result.error, 'error'); }
    } catch { showToast('Failed', 'error'); }
    btn.disabled = false; btn.textContent = 'Assign';
  });



  // ==============================
// CREATE PUBLIC CAMPAIGN
// ==============================

document.getElementById('createCampaignForm')?.addEventListener('submit', async function(e) {
  e.preventDefault();

  const btn = this.querySelector('button');
  const original = btn.innerHTML;

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Creating...';

  const data = Object.fromEntries(new FormData(this));

  try {
    const res = await fetch('/teacher/campaigns', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });

    const result = await res.json();

    if (result.success) {
      document.getElementById('campaignResult').innerHTML =
        `<div style="margin-top:10px;">
          <strong>Campaign Created!</strong><br>
          Share this link:<br>
          <a href="${result.shareUrl}" target="_blank">${result.shareUrl}</a>
        </div>`;

      this.reset();
      showToast('Campaign created successfully!');
    } else {
      showToast(result.error || 'Failed', 'error');
    }

  } catch {
    showToast('Server error', 'error');
  }

  btn.disabled = false;
  btn.innerHTML = original;
});

</script>

