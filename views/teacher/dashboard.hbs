<!-- UPLOAD MATERIAL MODAL -->
<div id="materialModal" class="modal-overlay">
  <div class="modal-box">
    <h2>Upload Learning Material</h2>
    <form id="materialForm" enctype="multipart/form-data">
      <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" required placeholder="e.g., Chapter 5 Notes">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Subject</label>
          <select name="subject" required>
            <option value="">Select...</option>
            <option value="math">Mathematics</option>
            <option value="english">English</option>
            <option value="science">Science</option>
            <option value="social_studies">Social Studies</option>
          </select>
        </div>
        <div class="form-group">
          <label>Grade</label>
          <select name="grade" required>
            <option value="">Select...</option>
            {{#each schoolLevels}}
              {{#if (eq this "junior")}}
                <option value="1">Grade 1</option><option value="2">Grade 2</option>
                <option value="3">Grade 3</option><option value="4">Grade 4</option>
                <option value="5">Grade 5</option><option value="6">Grade 6</option>
                <option value="7">Grade 7</option>
              {{/if}}
              {{#if (eq this "high")}}
                <option value="8">Grade 8</option><option value="9">Grade 9</option>
                <option value="10">Grade 10</option><option value="11">Grade 11</option>
                <option value="12">Grade 12</option><option value="13">Grade 13</option>
              {{/if}}
            {{/each}}
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="3" placeholder="Brief description..."></textarea>
      </div>
      <div class="form-group">
        <label>Upload File (PDF, DOCX, MP3, MP4, Images - Max 500MB)</label>
        <input type="file" name="materialFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.mp3,.mp4,.jpg,.png,.gif">
        <div style="font-size:11px;color:var(--ink-muted);margin-top:4px;">
          Supported: PDF (50MB), DOCX (25MB), MP4 (500MB), MP3 (50MB), Images (10MB)
        </div>
      </div>
      <div class="form-group">
        <label>Assignment Type</label>
        <select name="assignmentType" id="assignmentType" onchange="toggleStudentList()">
          <option value="individual">Individual Students</option>
          <option value="grade">All Students in This Grade</option>
          <option value="all">All My Students</option>
        </select>
      </div>
      <div class="form-group" id="studentListGroup">
        <label>Select Students</label>
        <div class="checkbox-list">
          {{#each students}}
            <label class="checkbox-item">
              <input type="checkbox" name="studentIds" value="{{_id}}">
              <span>{{firstName}} {{lastName}} (Grade {{grade}})</span>
            </label>
          {{/each}}
        </div>
      </div>
      <div class="form-group">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
          <input type="checkbox" name="allowDownload" value="true" checked>
          <span>Allow students to download this file</span>
        </label>
      </div>
      <div style="display:flex;gap:10px;margin-top:20px;">
        <button type="submit" class="btn btn-primary" style="flex:1;">Upload Material</button>
        <button type="button" class="btn btn-outline" onclick="closeModal('materialModal')">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function toggleStudentList() {
  const assignType = document.getElementById('assignmentType').value;
  const studentList = document.getElementById('studentListGroup');
  
  if (assignType === 'individual') {
    studentList.style.display = 'block';
  } else {
    studentList.style.display = 'none';
  }
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', toggleStudentList);
</script>

