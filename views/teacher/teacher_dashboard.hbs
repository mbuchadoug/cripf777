<!-- TOAST -->
<div id="toast" class="toast"></div>

<script>
  // ==============================
  // TAB SWITCHING
  // ==============================
  function showTab(tabId) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    
    const panel = document.getElementById('tab-' + tabId);
    if (panel) panel.classList.add('active');
    
    event?.target?.closest?.('.nav-item')?.classList.add('active');
  }

  // ==============================
  // MODAL
  // ==============================
  function openModal(id) {
    document.getElementById(id).classList.add('active');
  }

  function closeModal(id) {
    document.getElementById(id).classList.remove('active');
  }

  function openAssignSingle(quizId, title) {
    document.getElementById('assignSingleQuizId').value = quizId;
    document.getElementById('assignSingleTitle').textContent = title;
    openModal('assignSingleModal');
  }

  // Close modals on backdrop click
  document.querySelectorAll('.modal-overlay').forEach(m => {
    m.addEventListener('click', e => {
      if (e.target === m) m.classList.remove('active');
    });
  });

  // ==============================
  // TOAST
  // ==============================
  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast ' + type + ' show';
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  // ==============================
  // GENERATE AI QUIZ
  // ==============================
  document.getElementById('generateForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    const origText = btn.textContent;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Generating...';

    const data = Object.fromEntries(new FormData(e.target));
    try {
      const r = await fetch('/teacher/generate-quiz', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await r.json();
      if (result.success) {
        showToast('Quiz generated successfully!');
        setTimeout(() => location.reload(), 800);
      } else {
        showToast(result.error, 'error');
        btn.disabled = false;
        btn.textContent = origText;
      }
    } catch {
      showToast('Failed to generate quiz', 'error');
      btn.disabled = false;
      btn.textContent = origText;
    }
  });

  // ==============================
  // UPLOAD QUIZ
  // ==============================
  document.getElementById('uploadForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Uploading...';

    const formData = new FormData(e.target);
    try {
      const r = await fetch('/teacher/upload-quiz', {
        method: 'POST',
        body: formData
      });
      const result = await r.json();
      if (result.success) {
        showToast(`Quiz uploaded! ${result.questionCount} questions.`);
        setTimeout(() => location.reload(), 800);
      } else {
        showToast(result.error, 'error');
        btn.disabled = false;
        btn.textContent = 'Upload Quiz';
      }
    } catch {
      showToast('Upload failed', 'error');
      btn.disabled = false;
      btn.textContent = 'Upload Quiz';
    }
  });

  // ==============================
  // UPLOAD MATERIAL
  // ==============================
  document.getElementById('materialForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Uploading...';

    const formData = new FormData(e.target);
    try {
      const r = await fetch('/teacher/upload-material', { method: 'POST', body: formData });
      const result = await r.json();
      if (result.success) {
        showToast('Material uploaded!');
        closeModal('materialModal');
        btn.disabled = false;
        btn.textContent = 'Upload Material';
      } else {
        showToast(result.error, 'error');
        btn.disabled = false;
        btn.textContent = 'Upload Material';
      }
    } catch {
      showToast('Upload failed', 'error');
      btn.disabled = false;
      btn.textContent = 'Upload Material';
    }
  });

  // ==============================
  // ASSIGN SINGLE QUIZ
  // ==============================
  document.getElementById('assignSingleForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Assigning...';

    const fd = new FormData(e.target);
    const studentIds = fd.getAll('studentIds[]');
    const quizId = fd.get('quizId');

    if (!studentIds.length) {
      showToast('Select at least one student', 'error');
      btn.disabled = false;
      btn.textContent = 'Assign';
      return;
    }

    try {
      const r = await fetch('/teacher/assign-quiz', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quizId, studentIds })
      });
      const result = await r.json();
      if (result.success) {
        showToast(`Assigned to ${result.assigned} student(s)`);
        setTimeout(() => location.reload(), 800);
      } else {
        showToast(result.error, 'error');
        btn.disabled = false;
        btn.textContent = 'Assign';
      }
    } catch {
      showToast('Assign failed', 'error');
      btn.disabled = false;
      btn.textContent = 'Assign';
    }
  });

  // ==============================
  // BULK ASSIGN
  // ==============================
  document.getElementById('bulkAssignForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Assigning...';

    const fd = new FormData(e.target);
    const quizIds = fd.getAll('quizIds');
    const studentIds = fd.getAll('studentIds');
    const durationMinutes = fd.get('durationMinutes');

    if (!quizIds.length || !studentIds.length) {
      showToast('Select quizzes and students', 'error');
      btn.disabled = false;
      btn.textContent = 'Assign Selected';
      return;
    }

    try {
      const r = await fetch('/teacher/bulk-assign', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quizIds, studentIds, durationMinutes: Number(durationMinutes) })
      });
      const result = await r.json();
      if (result.success) {
        showToast(`${result.assigned} assignments created, ${result.skipped} skipped`);
      } else {
        showToast(result.error, 'error');
      }
    } catch {
      showToast('Bulk assign failed', 'error');
    }
    btn.disabled = false;
    btn.textContent = 'Assign Selected';
  });

  // ==============================
  // GENERATE REPORT
  // ==============================
  document.getElementById('reportForm').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Generating report...';

    const fd = new FormData(e.target);
    const studentIds = fd.getAll('studentIds');
    
    if (!studentIds.length) {
      showToast('Select at least one student', 'error');
      btn.disabled = false;
      btn.textContent = '📈 Generate Report';
      return;
    }

    try {
      const r = await fetch('/teacher/generate-report', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          studentIds,
          subject: fd.get('subject'),
          dateFrom: fd.get('dateFrom'),
          dateTo: fd.get('dateTo'),
          teacherNotes: fd.get('teacherNotes')
        })
      });
      const result = await r.json();
      if (result.success) {
        showToast('Report generated!');
        document.getElementById('reportResult').style.display = 'block';
        document.getElementById('reportDownload').href = result.reportUrl;
      } else {
        showToast(result.error, 'error');
      }
    } catch {
      showToast('Report generation failed', 'error');
    }
    btn.disabled = false;
    btn.textContent = '📈 Generate Report';
  });
</script>

</body>
</html>
