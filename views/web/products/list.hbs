<!-- Page Header -->
<div class="page-header">
  <div>
    <div class="page-title">Products & Services</div>
    <div class="page-subtitle">Manage your product catalogue</div>
  </div>

  <div class="page-actions">
    <button onclick="showAddProductModal()" class="btn btn-primary">
      <i class="fas fa-plus"></i> Add Product
    </button>
  </div>
</div>

<!-- Filters / Search -->
<div class="filters-bar">
  <form method="GET" style="display:flex; gap:12px; width:100%; flex-wrap:wrap; align-items:flex-end;">
    <div class="filter-group" style="min-width:260px; flex:1;">
      <div class="filter-label">Search</div>
      <input
        type="text"
        name="search"
        placeholder="Search products…"
        value="{{search}}"
        class="form-input"
      />
    </div>

    <div style="display:flex; gap:10px;">
      <button type="submit" class="btn btn-ghost">
        <i class="fas fa-search"></i> Search
      </button>

      {{#if search}}
        <a href="/web/products" class="btn btn-ghost">
          <i class="fas fa-times"></i> Clear
        </a>
      {{/if}}
    </div>
  </form>
</div>

<!-- Products Grid -->
{{#if products.length}}
  <div class="grid-3">
    {{#each products}}
      <div class="card">
        <div class="card-header">
          <div style="min-width:0;">
            <div class="card-title" style="gap:10px;">
              <i class="fas fa-box"></i>
              <span style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{this.name}}</span>
            </div>

            <div style="margin-top:8px;">
              {{#if this.branchId}}
                <span class="badge badge-amber">Branch</span>
              {{else}}
                <span class="badge badge-green">Global</span>
              {{/if}}
            </div>
          </div>

          <div class="td-actions">
            <button class="btn btn-ghost btn-sm btn-icon" onclick="editProduct('{{this._id}}')" title="Edit">
              <i class="fas fa-edit"></i>
            </button>
            <button class="btn btn-danger btn-sm btn-icon" onclick="deleteProduct('{{this._id}}')" title="Delete">
              <i class="fas fa-trash"></i>
            </button>
          </div>
        </div>

        <div class="card-body">
          {{#if this.description}}
            <div style="color: var(--muted); font-size:13px; line-height:1.6; margin-bottom:14px;">
              {{this.description}}
            </div>
          {{else}}
            <div style="color: var(--muted-2); font-size:12px; margin-bottom:14px;">
              No description
            </div>
          {{/if}}

          <div style="display:flex; align-items:flex-end; justify-content:space-between;">
            <div style="color: var(--muted-2); font-size:12px;">Unit Price</div>
            <div class="stat-value" style="font-size:18px;">
              {{../user.currency}} {{this.unitPrice}}
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="card">
    <div class="card-body">
      <div class="empty-state">
        <i class="fas fa-box-open"></i>
        <h3>No products found</h3>
        <p>Add your first product to start creating invoices faster.</p>
        <button onclick="showAddProductModal()" class="btn btn-primary">
          <i class="fas fa-plus"></i> Add Product
        </button>
      </div>
    </div>
  </div>
{{/if}}

<!-- Pagination -->
{{#if (gt pagination.totalPages 1)}}
  <div class="pagination">
    {{#if pagination.hasPrev}}
      <a href="?page={{math pagination.currentPage '-' 1}}{{#if search}}&search={{search}}{{/if}}">
        <i class="fas fa-chevron-left" style="font-size:10px;"></i>
      </a>
    {{/if}}

    <div class="page-info">
      Page {{pagination.currentPage}} of {{pagination.totalPages}}
    </div>

    {{#if pagination.hasNext}}
      <a href="?page={{math pagination.currentPage '+' 1}}{{#if search}}&search={{search}}{{/if}}">
        <i class="fas fa-chevron-right" style="font-size:10px;"></i>
      </a>
    {{/if}}
  </div>
{{/if}}

<!-- Modal (uses your existing modal classes) -->
<div id="productModal" class="modal-backdrop">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title"><i class="fas fa-box"></i> <span id="modalTitle">Add Product</span></div>
      <button class="modal-close" onclick="hideProductModal()"><i class="fas fa-times"></i></button>
    </div>

    <form id="productForm">
      <div class="modal-body">
        <input type="hidden" id="productId">

        {{#if isOwner}}
          <div class="form-group">
            <label class="form-label">Branch</label>
            <select id="productBranch" class="form-select">
              <option value="">Global (All Branches)</option>
              {{#each branches}}
                <option value="{{this._id}}">{{this.name}}</option>
              {{/each}}
            </select>
            <div class="form-hint">Global products are visible to all branches.</div>
          </div>
        {{else}}
          <input type="hidden" id="productBranch" value="">
        {{/if}}

        <div class="form-group">
          <label class="form-label">Product Name</label>
          <input type="text" id="productName" class="form-input" placeholder="e.g. Coke 500ml" required>
        </div>

        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea id="productDescription" class="form-textarea" placeholder="Optional"></textarea>
        </div>

        <div class="form-group">
          <label class="form-label">Unit Price ({{user.currency}})</label>
          <input type="number" id="productPrice" min="0" step="0.01" class="form-input" placeholder="0.00" required>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="hideProductModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" id="saveBtn">
          <span id="submitBtnText"><i class="fas fa-check"></i> Save</span>
          <span id="submitBtnLoader" class="hidden"><span class="spinner"></span> Saving…</span>
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const products = {{{json products}}};

  // modal open/close using your open class
  function showAddProductModal() {
    document.getElementById('modalTitle').textContent = 'Add Product';
    document.getElementById('productForm').reset();
    document.getElementById('productId').value = '';

    const branchEl = document.getElementById('productBranch');
    if (branchEl) branchEl.value = '';

    document.getElementById('productModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function hideProductModal() {
    document.getElementById('productModal').classList.remove('open');
    document.body.style.overflow = '';
  }

  function editProduct(productId) {
    const product = products.find(p => String(p._id) === String(productId));
    if (!product) return;

    document.getElementById('modalTitle').textContent = 'Edit Product';
    document.getElementById('productId').value = product._id;
    document.getElementById('productName').value = product.name || '';
    document.getElementById('productDescription').value = product.description || '';
    document.getElementById('productPrice').value = product.unitPrice ?? 0;

    const branchEl = document.getElementById('productBranch');
    if (branchEl) branchEl.value = product.branchId || '';

    document.getElementById('productModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  document.getElementById('productForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const productId = document.getElementById('productId').value;
    const name = document.getElementById('productName').value;
    const description = document.getElementById('productDescription').value;
    const unitPrice = document.getElementById('productPrice').value;
    const branchId = document.getElementById('productBranch')?.value || '';

    const btnText = document.getElementById('submitBtnText');
    const btnLoader = document.getElementById('submitBtnLoader');
    const saveBtn = document.getElementById('saveBtn');

    btnText.classList.add('hidden');
    btnLoader.classList.remove('hidden');
    saveBtn.disabled = true;

    try {
      const url = productId ? `/web/products/${productId}` : '/web/products/create';
      const method = productId ? 'PUT' : 'POST';

      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, description, unitPrice, branchId })
      });

      if (response.ok) {
        window.location.reload();
      } else {
        const data = await response.json().catch(()=>({}));
        alert(data.error || 'Failed to save product');
      }
    } catch (err) {
      console.error(err);
      alert('Failed to save product');
    } finally {
      btnText.classList.remove('hidden');
      btnLoader.classList.add('hidden');
      saveBtn.disabled = false;
    }
  });

  async function deleteProduct(productId) {
    if (!confirm('Are you sure you want to delete this product?')) return;

    try {
      const response = await fetch(`/web/products/${productId}`, { method: 'DELETE' });
      if (response.ok) window.location.reload();
      else {
        const data = await response.json().catch(()=>({}));
        alert(data.error || 'Failed to delete product');
      }
    } catch (err) {
      console.error(err);
      alert('Failed to delete product');
    }
  }
</script>