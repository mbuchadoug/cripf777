<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800 mb-2">Products & Services</h1>
    <p class="text-sm text-gray-600">Manage your product catalogue</p>
  </div>
  <button onclick="showAddProductModal()" class="mt-4 sm:mt-0 inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 active:scale-95">
    <i class="fas fa-plus mr-2"></i>
    Add Product
  </button>
</div>

<!-- Search Bar -->
<div class="bg-white rounded-xl shadow-sm p-4 mb-6">
  <form method="GET" class="flex items-center space-x-4">
    <div class="flex-1">
      <input 
        type="text" 
        name="search" 
        placeholder="Search products..."
        value="{{search}}"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
      >
    </div>
    <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
      <i class="fas fa-search"></i>
    </button>
    {{#if search}}
      <a href="/web/products" class="px-4 py-2 text-gray-600 hover:text-gray-800">
        <i class="fas fa-times"></i>
      </a>
    {{/if}}
  </form>
</div>

<!-- Products Grid (Desktop & Tablet) -->
<div class="hidden sm:grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
  {{#each products}}
    <div class="bg-white rounded-xl shadow-sm p-6 hover:shadow-md transition-shadow">
      <div class="flex items-start justify-between mb-4">
        <div class="flex-1 min-w-0">
         <h3 class="font-semibold text-gray-800 text-lg truncate">{{this.name}}</h3>
{{#if this.branchId}}
  <div class="text-xs text-gray-500 mt-1">Branch item</div>
{{else}}
  <div class="text-xs text-green-600 mt-1">Global</div>
{{/if}}
          {{#if this.description}}
            <p class="text-sm text-gray-500 mt-1 line-clamp-2">{{this.description}}</p>
          {{/if}}
        </div>
        <div class="ml-3 flex space-x-2">
          <button onclick="editProduct('{{this._id}}')" class="text-blue-600 hover:text-blue-700" title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button onclick="deleteProduct('{{this._id}}')" class="text-red-600 hover:text-red-700" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
      
      <div class="flex items-center justify-between pt-4 border-t">
        <span class="text-sm text-gray-600">Unit Price</span>
        <span class="text-2xl font-bold text-blue-600">{{../user.currency}} {{this.unitPrice}}</span>
      </div>
    </div>
  {{else}}
    <div class="col-span-full bg-white rounded-xl shadow-sm p-12 text-center">
      <i class="fas fa-box-open text-4xl text-gray-300 mb-4"></i>
      <p class="text-gray-500 mb-4">No products found</p>
      <button onclick="showAddProductModal()" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        <i class="fas fa-plus mr-2"></i> Add Your First Product
      </button>
    </div>
  {{/each}}
</div>

<!-- Products List (Mobile) -->
<div class="sm:hidden space-y-4">
  {{#each products}}
    <div class="bg-white rounded-xl shadow-sm p-4">
      <div class="flex items-start justify-between mb-3">
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-gray-800 truncate">{{this.name}}</h3>
          {{#if this.description}}
            <p class="text-xs text-gray-500 mt-1 line-clamp-2">{{this.description}}</p>
          {{/if}}
        </div>
      </div>
      
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm text-gray-600">Price</span>
        <span class="text-xl font-bold text-blue-600">{{../user.currency}} {{this.unitPrice}}</span>
      </div>
      
      <div class="flex space-x-2 pt-3 border-t">
        <button onclick="editProduct('{{this._id}}')" class="flex-1 py-2 text-blue-600 hover:bg-blue-50 rounded-lg">
          <i class="fas fa-edit mr-1"></i> Edit
        </button>
        <button onclick="deleteProduct('{{this._id}}')" class="flex-1 py-2 text-red-600 hover:bg-red-50 rounded-lg">
          <i class="fas fa-trash mr-1"></i> Delete
        </button>
      </div>
    </div>
  {{else}}
    <div class="bg-white rounded-xl shadow-sm p-12 text-center">
      <i class="fas fa-box-open text-4xl text-gray-300 mb-4"></i>
      <p class="text-gray-500 mb-4">No products found</p>
      <button onclick="showAddProductModal()" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        Add Product
      </button>
    </div>
  {{/each}}
</div>

<!-- Pagination -->
{{#if (gt pagination.totalPages 1)}}
  <div class="flex items-center justify-center space-x-2 mt-6">
    {{#if pagination.hasPrev}}
      <a href="?page={{math pagination.currentPage '-' 1}}{{#if search}}&search={{search}}{{/if}}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
        <i class="fas fa-chevron-left"></i>
      </a>
    {{/if}}
    
    <span class="px-4 py-2 text-sm text-gray-600">
      Page {{pagination.currentPage}} of {{pagination.totalPages}}
    </span>
    
    {{#if pagination.hasNext}}
      <a href="?page={{math pagination.currentPage '+' 1}}{{#if search}}&search={{search}}{{/if}}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
        <i class="fas fa-chevron-right"></i>
      </a>
    {{/if}}
  </div>
{{/if}}

<!-- Add/Edit Product Modal -->
<div id="productModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center p-4">
  <div class="bg-white rounded-xl shadow-xl max-w-lg w-full p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 id="modalTitle" class="text-lg font-semibold text-gray-800">Add Product</h3>
      <button onclick="hideProductModal()" class="text-gray-400 hover:text-gray-600">
        <i class="fas fa-times"></i>
      </button>
    </div>
    
    <form id="productForm" class="space-y-4">
    <input type="hidden" id="productId">

{{#if isOwner}}
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-2">
      Branch *
    </label>
    <select
      id="productBranch"
      class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
    >
      <option value="">Global (All Branches)</option>
      {{#each branches}}
        <option value="{{this._id}}">{{this.name}}</option>
      {{/each}}
    </select>
    <p class="text-xs text-gray-500 mt-1">
      Global products are visible to all branches.
    </p>
  </div>
{{else}}
  <!-- staff/employee branch is enforced server-side -->
  <input type="hidden" id="productBranch" value="">
{{/if}}
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Product Name *
        </label>
        <input 
          type="text" 
          id="productName" 
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" 
          required
        >
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Description
        </label>
        <textarea 
          id="productDescription" 
          rows="3"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
        ></textarea>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Unit Price * ({{user.currency}})
        </label>
        <input 
          type="number" 
          id="productPrice" 
          min="0" 
          step="0.01"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" 
          required
        >
      </div>
      
      <div class="flex space-x-3 pt-4">
        <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
          <span id="submitBtnText">
            <i class="fas fa-check mr-2"></i> Save Product
          </span>
          <span id="submitBtnLoader" class="hidden">
            <i class="fas fa-spinner fa-spin mr-2"></i> Saving...
          </span>
        </button>
        <button type="button" onclick="hideProductModal()" class="flex-1 border border-gray-300 py-2 rounded-lg hover:bg-gray-50">
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const products = {{{json products}}};
  
  // Show add product modal
function showAddProductModal() {
  document.getElementById('modalTitle').textContent = 'Add Product';
  document.getElementById('productForm').reset();
  document.getElementById('productId').value = '';

  // ✅ reset branch dropdown (owners)
  const branchEl = document.getElementById('productBranch');
  if (branchEl) branchEl.value = '';

  document.getElementById('productModal').classList.remove('hidden');
  document.getElementById('productModal').classList.add('flex');
}
  // Hide modal
  function hideProductModal() {
    document.getElementById('productModal').classList.add('hidden');
    document.getElementById('productModal').classList.remove('flex');
  }
  
  // Edit product
  function editProduct(productId) {
    const product = products.find(p => p._id === productId);
    if (!product) return;
    
    document.getElementById('modalTitle').textContent = 'Edit Product';
    document.getElementById('productId').value = product._id;
    document.getElementById('productName').value = product.name;
    document.getElementById('productDescription').value = product.description || '';
    document.getElementById('productPrice').value = product.unitPrice;

    // ✅ set branch dropdown (owners)
const branchEl = document.getElementById('productBranch');
if (branchEl) branchEl.value = product.branchId || '';
    
    document.getElementById('productModal').classList.remove('hidden');
    document.getElementById('productModal').classList.add('flex');
  }
  
  // Submit form
  document.getElementById('productForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const productId = document.getElementById('productId').value;
    const name = document.getElementById('productName').value;
    const description = document.getElementById('productDescription').value;
    const unitPrice = document.getElementById('productPrice').value;

    const branchId = document.getElementById('productBranch')?.value || '';
    
    const btnText = document.getElementById('submitBtnText');
    const btnLoader = document.getElementById('submitBtnLoader');
    
    btnText.classList.add('hidden');
    btnLoader.classList.remove('hidden');
    
    try {
      const url = productId ? `/web/products/${productId}` : '/web/products/create';
      const method = productId ? 'PUT' : 'POST';
      
      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
       body: JSON.stringify({ name, description, unitPrice, branchId })
      });
      
      if (response.ok) {
        window.location.reload();
      } else {
        const data = await response.json();
        alert(data.error || 'Failed to save product');
        btnText.classList.remove('hidden');
        btnLoader.classList.add('hidden');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Failed to save product');
      btnText.classList.remove('hidden');
      btnLoader.classList.add('hidden');
    }
  });
  
  // Delete product
  async function deleteProduct(productId) {
    if (!confirm('Are you sure you want to delete this product?')) {
      return;
    }
    
    try {
      const response = await fetch(`/web/products/${productId}`, {
        method: 'DELETE'
      });
      
      if (response.ok) {
        window.location.reload();
      } else {
        const data = await response.json();
        alert(data.error || 'Failed to delete product');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Failed to delete product');
    }
  }
</script>