<div class="page-header">
  <div>
    <div class="page-title">Record Expense</div>
    <div class="page-subtitle">Save a business expense (and optionally generate a PDF receipt)</div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="grid-2">
      <div class="form-group">
        <label class="form-label">Amount ({{business.currency}})</label>
        <input id="amount" class="form-input" type="number" min="0" placeholder="0.00" />
      </div>

      <div class="form-group">
        <label class="form-label">Payment Method</label>
        <select id="method" class="form-select">
          <option>Cash</option>
          <option>EcoCash</option>
          <option>Bank Transfer</option>
          <option>Card</option>
          <option>Other</option>
        </select>
      </div>
    </div>

    <div class="grid-2">
      <div class="form-group">
        <label class="form-label">Category</label>
        <input id="category" class="form-input" placeholder="Fuel / Rent / Salaries / Airtime…" />
      </div>

      <div class="form-group">
        <label class="form-label">Description</label>
        <input id="description" class="form-input" placeholder="What was this for?" />
      </div>
    </div>

    <div style="display:flex;gap:10px;justify-content:flex-end">
      <a href="/web/expenses" class="btn btn-ghost"><i class="fas fa-arrow-left"></i> Cancel</a>
      <button class="btn btn-primary" id="saveBtn" onclick="saveExpense()"><i class="fas fa-check"></i> Save Expense</button>
    </div>
  </div>
</div>

<script>
  async function saveExpense() {
    const btn = document.getElementById("saveBtn");
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Saving…';

    const amount = Number(document.getElementById("amount").value || 0);
    const method = document.getElementById("method").value;
    const category = document.getElementById("category").value.trim();
    const description = document.getElementById("description").value.trim();

    if (!amount || amount <= 0 || !category || !description) {
      showToast("Amount, category and description are required", "error");
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-check"></i> Save Expense';
      return;
    }

    try {
      const r = await fetch("/web/expenses/create", {
        method: "POST",
        headers: { "Content-Type":"application/json" },
        body: JSON.stringify({ amount, method, category, description })
      });
      const d = await r.json();
      if (r.ok) {
        showToast("Expense saved", "success");
        if (d.receiptUrl) window.open(d.receiptUrl, "_blank");
        setTimeout(()=>window.location.href="/web/expenses", 500);
      } else {
        showToast(d.error || "Failed to save expense", "error");
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-check"></i> Save Expense';
      }
    } catch {
      showToast("Failed to save expense", "error");
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-check"></i> Save Expense';
    }
  }
</script>