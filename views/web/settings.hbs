<div class="page-header">
  <div>
    <div class="page-title">Settings</div>
    <div class="page-subtitle">Manage your business profile - changes apply instantly across WhatsApp and web.</div>
  </div>
</div>

{{#if saved}}
<div class="alert alert-success" id="savedAlert">
  <i class="fas fa-check-circle"></i>
  {{#if (eq saved "general")}}Business profile saved successfully.
  {{else if (eq saved "prefixes")}}Document prefixes updated.
  {{else if (eq saved "logo")}}Logo updated successfully.
  {{else}}Settings saved.{{/if}}
</div>
{{/if}}

{{#if error}}
<div class="alert alert-error">
  <i class="fas fa-exclamation-circle"></i>
  {{#if (eq error "invalid_currency")}}Invalid currency selected.
  {{else if (eq error "save_failed")}}Failed to save. Please try again.
  {{else if (eq error "upload_failed")}}Logo upload failed. Check file type and size.
  {{else if (eq error "no_file")}}No file selected.
  {{else if (eq error "remove_failed")}}Failed to remove logo.
  {{else}}Something went wrong. Please try again.{{/if}}
</div>
{{/if}}

<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; align-items:start;">

  <!-- ══ LEFT: BUSINESS PROFILE ══════════════════════════════════════════════ -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-building"></i> Business Profile</div>
    </div>
    <div class="card-body">
      <form method="POST" action="/web/settings/general">

        <div class="form-group">
          <label class="form-label">Business Name</label>
          <input type="text" name="name" class="form-input"
            value="{{business.name}}" placeholder="Your Business Name" required>
        </div>

        <div class="form-group">
          <label class="form-label">Currency</label>
          <select name="currency" class="form-select">
            <option value="USD" {{#if (eq business.currency "USD")}}selected{{/if}}>USD - US Dollar ($)</option>
            <option value="ZWL" {{#if (eq business.currency "ZWL")}}selected{{/if}}>ZWL - Zimbabwe Dollar (Z$)</option>
            <option value="ZIG" {{#if (eq business.currency "ZIG")}}selected{{/if}}>ZIG - Zimbabwe Gold</option>
            <option value="ZAR" {{#if (eq business.currency "ZAR")}}selected{{/if}}>ZAR - South African Rand (R)</option>
            <option value="GBP" {{#if (eq business.currency "GBP")}}selected{{/if}}>GBP - British Pound (£)</option>
            <option value="EUR" {{#if (eq business.currency "EUR")}}selected{{/if}}>EUR - Euro (€)</option>
          </select>
          <div class="form-hint">Used on all invoices, quotes and receipts - same as WhatsApp.</div>
        </div>

        <div class="form-group">
          <label class="form-label">Payment Terms (days)</label>
          <div class="form-prefix-wrap">
            <span class="form-prefix">days</span>
            <input type="number" name="paymentTermsDays" class="form-input form-input-pl"
              value="{{business.paymentTermsDays}}" min="0" max="365" placeholder="30">
          </div>
          <div class="form-hint">e.g. 30 = payment due within 30 days of invoice date.</div>
        </div>

        <div class="form-group">
          <label class="form-label">Business Address</label>
          <textarea name="address" class="form-textarea" rows="3"
            placeholder="e.g. 123 Samora Machel Ave, Harare">{{business.address}}</textarea>
          <div class="form-hint">Printed on all documents.</div>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%">
          <i class="fas fa-save"></i> Save Profile
        </button>

      </form>
    </div>
  </div>

  <!-- ══ RIGHT COLUMN ════════════════════════════════════════════════════════ -->
  <div style="display:flex; flex-direction:column; gap:20px;">

    <!-- LOGO ────────────────────────────────────────────────────────────────── -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-image"></i> Business Logo</div>
        {{#if business.logoUrl}}
        <span class="badge badge-green">Active</span>
        {{else}}
        <span class="badge badge-muted">Not set</span>
        {{/if}}
      </div>
      <div class="card-body">

        {{#if business.logoUrl}}
        <!-- Current logo preview -->
        <div style="text-align:center; margin-bottom:16px; padding:16px;
          background:var(--navy-3); border-radius:10px; border:1px solid var(--border);">
          <img src="{{business.logoUrl}}" alt="Your Logo"
            style="max-height:90px; max-width:100%; object-fit:contain;">
        </div>
        <form method="POST" action="/web/settings/logo/remove" style="margin-bottom:16px;">
          <button type="submit" class="btn btn-danger btn-sm" style="width:100%"
            onclick="return confirm('Remove your business logo?')">
            <i class="fas fa-trash-alt"></i> Remove Logo
          </button>
        </form>
        <div class="divider"></div>
        <p style="font-size:11px; color:var(--muted-2); margin-bottom:12px;">Upload a new image to replace:</p>
        {{else}}
        <div style="text-align:center; padding:24px; background:var(--navy-3);
          border-radius:10px; border:1px dashed var(--border); margin-bottom:16px;">
          <i class="fas fa-image" style="font-size:32px; color:var(--muted-2); margin-bottom:8px; display:block;"></i>
          <p style="font-size:12px; color:var(--muted-2);">No logo uploaded yet</p>
        </div>
        {{/if}}

        <form method="POST" action="/web/settings/logo" enctype="multipart/form-data">
          <div class="form-group" style="margin-bottom:12px;">
            <label class="form-label">{{#if business.logoUrl}}Replace Logo{{else}}Upload Logo{{/if}}</label>
            <input type="file" name="logo" accept="image/jpeg,image/png,image/webp"
              class="form-input" style="padding:8px;" required>
            <div class="form-hint">JPG, PNG or WebP · Max 5MB · Appears on all documents.</div>
          </div>
          <button type="submit" class="btn btn-primary btn-sm" style="width:100%">
            <i class="fas fa-upload"></i> Upload Logo
          </button>
        </form>

      </div>
    </div>

    <!-- DOCUMENT PREFIXES ───────────────────────────────────────────────────── -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-hashtag"></i> Document Prefixes</div>
      </div>
      <div class="card-body">
        <p style="font-size:12px; color:var(--muted); margin-bottom:16px; line-height:1.6;">
          These prefix your document numbers - e.g.
          <span style="font-family:'DM Mono',monospace; color:var(--amber)">
            {{business.invoicePrefix}}-000001
          </span>
        </p>
        <form method="POST" action="/web/settings/prefixes">
          <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; margin-bottom:16px;">

            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label">Invoice</label>
              <input type="text" name="invoicePrefix" class="form-input prefix-input"
                value="{{business.invoicePrefix}}" placeholder="INV" maxlength="6"
                style="font-family:'DM Mono',monospace; text-transform:uppercase;">
            </div>

            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label">Quote</label>
              <input type="text" name="quotePrefix" class="form-input prefix-input"
                value="{{business.quotePrefix}}" placeholder="QT" maxlength="6"
                style="font-family:'DM Mono',monospace; text-transform:uppercase;">
            </div>

            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label">Receipt</label>
              <input type="text" name="receiptPrefix" class="form-input prefix-input"
                value="{{business.receiptPrefix}}" placeholder="RCP" maxlength="6"
                style="font-family:'DM Mono',monospace; text-transform:uppercase;">
            </div>

          </div>
          <div class="form-hint" style="margin-bottom:14px;">Max 6 characters. Letters only recommended.</div>
          <button type="submit" class="btn btn-primary btn-sm" style="width:100%">
            <i class="fas fa-save"></i> Save Prefixes
          </button>
        </form>
      </div>
    </div>

    <!-- PACKAGE INFO (read-only) ────────────────────────────────────────────── -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-crown"></i> Current Package</div>
      </div>
      <div class="card-body">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
          <div>
            <div style="font-family:'Syne',sans-serif; font-size:18px; font-weight:800;
              color:var(--amber); text-transform:uppercase;">
              {{business.package}}
            </div>
            <div style="font-size:11px; color:var(--muted-2); margin-top:3px;">
              Status:
              <span style="color:{{#if (eq business.subscriptionStatus 'active')}}var(--green)
                {{else}}var(--red){{/if}}; font-weight:600; text-transform:capitalize;">
                {{business.subscriptionStatus}}
              </span>
            </div>
          </div>
          <div class="pkg-pill">
            <i class="fas fa-crown" style="font-size:8px"></i> {{business.package}}
          </div>
        </div>
        {{#if business.subscriptionEndsAt}}
        <div style="font-size:12px; color:var(--muted); padding:10px; background:var(--navy-3);
          border-radius:8px; border:1px solid var(--border);">
          <i class="fas fa-calendar-alt" style="color:var(--amber); margin-right:6px;"></i>
          Next renewal: <strong style="color:var(--white);">{{business.subscriptionEndsAt}}</strong>
        </div>
        {{/if}}
        <a href="/web/subscription" class="btn btn-ghost btn-sm" style="width:100%; margin-top:12px; text-align:center;">
          <i class="fas fa-arrow-up"></i> Manage Subscription
        </a>
      </div>
    </div>

  </div><!-- end right column -->
</div>

<script>
  // Auto-dismiss success alert after 4s
  const savedAlert = document.getElementById('savedAlert');
  if (savedAlert) {
    setTimeout(() => {
      savedAlert.style.cssText += 'opacity:0;transition:opacity 0.4s';
      setTimeout(() => savedAlert.remove(), 400);
    }, 4000);
  }

  // Force uppercase as user types in prefix fields
  document.querySelectorAll('.prefix-input').forEach(input => {
    input.addEventListener('input', function() {
      const pos = this.selectionStart;
      this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
      this.setSelectionRange(pos, pos);
    });
  });
</script>

<style>
  @media (max-width: 900px) {
    .settings-grid { grid-template-columns: 1fr !important; }
  }
</style>