<div class="page-header">
  <div>
    <div class="page-title">Subscription</div>
    <div class="page-subtitle">Manage your ZimQuote plan - payments via EcoCash, receipt sent to your WhatsApp.</div>
  </div>
</div>

<!-- ── ALERTS ──────────────────────────────────────────────────────────────── -->
{{#if success}}
<div class="alert alert-success" id="topAlert">
  <i class="fas fa-check-circle"></i> Payment confirmed! Your plan has been upgraded.
</div>
{{/if}}

{{#if pending}}
<div class="alert alert-info" id="topAlert" data-pending="true">
  <i class="fas fa-spinner fa-spin"></i>
  <span>
    Payment of <strong>{{amount}} USD</strong> for <strong>{{plan}}</strong> initiated.
    Check your phone and enter your EcoCash PIN.
    This page will update automatically.
  </span>
</div>
{{/if}}

{{#if error}}
<div class="alert alert-error" id="topAlert">
  <i class="fas fa-exclamation-circle"></i>
  {{#if (eq error "invalid_phone")}}Invalid EcoCash number. Use format: 0772123456
  {{else if (eq error "invalid_plan")}}Invalid plan selected.
  {{else if (eq error "paynow_failed")}}EcoCash payment initiation failed. Please try again.
  {{else if (eq error "server_error")}}Server error. Please try again.
  {{else}}Something went wrong. Please try again.{{/if}}
</div>
{{/if}}

<!-- ── CURRENT STATUS ────────────────────────────────────────────────────────── -->
<div class="card" style="margin-bottom:20px;">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-info-circle"></i> Current Plan</div>
    {{#if isActive}}
    <span class="badge badge-green">Active</span>
    {{else}}
    <span class="badge badge-red">Inactive</span>
    {{/if}}
  </div>
  <div class="card-body">
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">

      <div style="text-align:center; padding:16px; background:var(--navy-3);
        border-radius:10px; border:1px solid var(--border);">
        <div style="font-size:11px; color:var(--muted-2); text-transform:uppercase;
          letter-spacing:0.7px; margin-bottom:6px;">Package</div>
        <div style="font-family:'Syne',sans-serif; font-size:20px; font-weight:800;
          color:var(--amber); text-transform:uppercase;">{{business.package}}</div>
      </div>

      <div style="text-align:center; padding:16px; background:var(--navy-3);
        border-radius:10px; border:1px solid var(--border);">
        <div style="font-size:11px; color:var(--muted-2); text-transform:uppercase;
          letter-spacing:0.7px; margin-bottom:6px;">Status</div>
        <div style="font-family:'Syne',sans-serif; font-size:20px; font-weight:800;
          color:{{#if isActive}}var(--green){{else}}var(--red){{/if}}; text-transform:capitalize;">
          {{business.subscriptionStatus}}
        </div>
      </div>

      <div style="text-align:center; padding:16px; background:var(--navy-3);
        border-radius:10px; border:1px solid var(--border);">
        <div style="font-size:11px; color:var(--muted-2); text-transform:uppercase;
          letter-spacing:0.7px; margin-bottom:6px;">
          {{#if isActive}}Next Renewal{{else}}Expired{{/if}}
        </div>
        {{#if endsAt}}
        <div style="font-family:'DM Mono',monospace; font-size:14px; font-weight:500;
          color:var(--white);">{{endsAt}}</div>
        {{#if isActive}}
        <div style="font-size:11px; color:var(--amber); margin-top:4px;">
          {{daysLeft}} days left
        </div>
        {{/if}}
        {{else}}
        <div style="font-size:13px; color:var(--muted-2);">-</div>
        {{/if}}
      </div>

    </div>
  </div>
</div>

<!-- ── PLANS GRID ─────────────────────────────────────────────────────────── -->
<div style="margin-bottom:20px;">
  <h3 style="font-family:'Syne',sans-serif; font-size:16px; font-weight:800;
    color:var(--white); margin-bottom:16px;">
    Choose a Plan
  </h3>
  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">

    {{#each plans}}
    <div class="card" style="position:relative; {{#if (eq this.key ../business.package)}}
      border-color:var(--amber);{{/if}}">

      {{#if (eq this.key ../business.package)}}
      <div style="position:absolute; top:-1px; right:16px; background:var(--amber);
        color:var(--navy); font-family:'Syne',sans-serif; font-size:9px; font-weight:800;
        letter-spacing:1px; padding:3px 10px; border-radius:0 0 6px 6px;">
        CURRENT
      </div>
      {{/if}}

      <div class="card-body" style="text-align:center; padding:24px 20px;">
        <div style="font-family:'Syne',sans-serif; font-size:18px; font-weight:800;
          color:var(--white); margin-bottom:4px; text-transform:uppercase;">
          {{this.name}}
        </div>
        <div style="font-family:'DM Mono',monospace; font-size:28px; font-weight:500;
          color:var(--amber); margin-bottom:4px;">
          ${{this.price}}
        </div>
        <div style="font-size:11px; color:var(--muted-2); margin-bottom:20px;">
          per {{this.durationDays}} days · {{this.currency}}
        </div>

        <button class="btn btn-primary" style="width:100%;"
          onclick="openPayModal('{{this.key}}', '{{this.name}}', {{this.price}})">
          {{#if (eq this.key ../business.package)}}
          <i class="fas fa-redo"></i> Renew
          {{else}}
          <i class="fas fa-arrow-up"></i> Upgrade
          {{/if}}
        </button>
      </div>
    </div>
    {{/each}}

  </div>
</div>

<!-- ── PAYMENT HISTORY ───────────────────────────────────────────────────── -->
<div class="card">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-history"></i> Payment History</div>
  </div>
  {{#if payments.length}}
  <div style="overflow-x:auto;">
    <table class="data-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Package</th>
          <th>Amount</th>
          <th>Reference</th>
          <th>Status</th>
          <th>Receipt</th>
        </tr>
      </thead>
      <tbody>
        {{#each payments}}
        <tr>
          <td class="td-mono" style="font-size:11px;">
            {{#if this.paidAt}}{{this.paidAt}}{{else}}{{this.createdAt}}{{/if}}
          </td>
          <td><span style="text-transform:uppercase; font-weight:600; color:var(--amber);">
            {{this.packageKey}}
          </span></td>
          <td class="td-mono">{{this.amount}} {{this.currency}}</td>
          <td class="td-mono" style="font-size:10px; color:var(--muted-2);">
            {{this.reference}}
          </td>
          <td>
            {{#if (eq this.status "paid")}}
            <span class="badge badge-green">Paid</span>
            {{else if (eq this.status "pending")}}
            <span class="badge badge-amber">Pending</span>
            {{else if (eq this.status "failed")}}
            <span class="badge badge-red">Failed</span>
            {{else}}
            <span class="badge badge-muted">{{this.status}}</span>
            {{/if}}
          </td>
          <td>
            {{#if this.receiptUrl}}
            <a href="{{this.receiptUrl}}" target="_blank" class="btn btn-ghost btn-sm">
              <i class="fas fa-download"></i> PDF
            </a>
            {{else}}
            <span style="font-size:11px; color:var(--muted-2);">-</span>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state">
    <i class="fas fa-receipt"></i>
    <h3>No payments yet</h3>
    <p>Your payment history will appear here after your first subscription.</p>
  </div>
  {{/if}}
</div>

<!-- ══ PAYMENT MODAL ═════════════════════════════════════════════════════════ -->
<div class="modal-backdrop" id="payModal">
  <div class="modal" style="max-width:420px;">
    <div class="modal-header">
      <div class="modal-title"><i class="fas fa-mobile-alt"></i> EcoCash Payment</div>
      <button class="modal-close" onclick="closeModal('payModal')">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">

      <div style="background:var(--amber-g); border:1px solid var(--amber-b);
        border-radius:10px; padding:16px; margin-bottom:20px; text-align:center;">
        <div id="modalPlanName" style="font-family:'Syne',sans-serif; font-size:16px;
          font-weight:800; color:var(--amber);"></div>
        <div id="modalPlanPrice" style="font-family:'DM Mono',monospace; font-size:24px;
          font-weight:500; color:var(--white); margin-top:4px;"></div>
        <div style="font-size:11px; color:var(--muted); margin-top:4px;">per 30 days · USD</div>
      </div>

      <form method="POST" action="/web/subscription/pay" id="payForm">
        <input type="hidden" name="planKey" id="modalPlanKey">

        <div class="form-group">
          <label class="form-label">EcoCash Number</label>
          <div class="form-prefix-wrap">
            <span class="form-prefix">📱</span>
            <input type="text" name="ecocashPhone" class="form-input form-input-pl"
              placeholder="0772123456" maxlength="12" required
              style="font-family:'DM Mono',monospace; letter-spacing:1px;">
          </div>
          <div class="form-hint">
            Enter the EcoCash number to charge. Format: 0772123456<br>
            You will receive a PIN prompt on that phone.
          </div>
        </div>

        <div style="background:var(--navy-3); border:1px solid var(--border);
          border-radius:9px; padding:14px; margin-bottom:18px; font-size:12px;
          color:var(--muted); line-height:1.7;">
          <i class="fas fa-info-circle" style="color:var(--amber); margin-right:6px;"></i>
          After clicking <strong style="color:var(--white);">Pay Now</strong>, you will receive
          an EcoCash prompt on your phone. Enter your PIN to confirm.
          A receipt PDF will be sent to your WhatsApp automatically.
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%;" id="payBtn">
          <i class="fas fa-lock"></i> Pay Now via EcoCash
        </button>
      </form>
    </div>
  </div>
</div>

<script>
// ── Open modal with plan details ───────────────────────────────────────────
function openPayModal(planKey, planName, planPrice) {
  document.getElementById('modalPlanKey').value   = planKey;
  document.getElementById('modalPlanName').textContent = planName + ' Package';
  document.getElementById('modalPlanPrice').textContent = '$' + planPrice;
  openModal('payModal');
}

// ── Prevent double-submit ──────────────────────────────────────────────────
document.getElementById('payForm')?.addEventListener('submit', function() {
  const btn = document.getElementById('payBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Processing...';
});

// ── Auto-dismiss success alert after 5s ───────────────────────────────────
const topAlert = document.getElementById('topAlert');
if (topAlert && !topAlert.dataset.pending) {
  setTimeout(() => {
    topAlert.style.cssText += 'opacity:0;transition:opacity 0.4s';
    setTimeout(() => topAlert.remove(), 400);
  }, 5000);
}

// ── Poll for payment confirmation if pending ───────────────────────────────
// We grab the latest pending reference from the payment history table
(function() {
  if (!topAlert?.dataset.pending) return;

  // Find the most recent pending payment reference from the table
  const rows = document.querySelectorAll('.data-table tbody tr');
  let pendingRef = null;

  for (const row of rows) {
    const statusCell = row.querySelector('.badge-amber');
    if (statusCell) {
      // Reference is in 4th td
      const cells = row.querySelectorAll('td');
      if (cells[3]) {
        pendingRef = cells[3].textContent.trim();
        break;
      }
    }
  }

  if (!pendingRef) return;

  let pollCount = 0;
  const MAX_POLLS = 36; // 3 minutes

  const pollInterval = setInterval(async () => {
    pollCount++;
    try {
      const res = await fetch(`/web/subscription/status/${encodeURIComponent(pendingRef)}`);
      const data = await res.json();

      if (data.status === 'paid') {
        clearInterval(pollInterval);
        window.location.href = '/web/subscription?success=1';
      } else if (data.status === 'failed' || data.status === 'cancelled') {
        clearInterval(pollInterval);
        window.location.href = '/web/subscription?error=payment_failed';
      }
    } catch(e) {
      console.warn('Poll error:', e);
    }

    if (pollCount >= MAX_POLLS) {
      clearInterval(pollInterval);
      if (topAlert) {
        topAlert.innerHTML = `<i class="fas fa-exclamation-circle"></i>
          Payment timed out. If you confirmed the PIN, check back shortly or
          <a href="/web/subscription" style="color:inherit;text-decoration:underline">refresh</a>.`;
        topAlert.className = 'alert alert-error';
      }
    }
  }, 5000);
})();
</script>

<style>
@media (max-width: 768px) {
  .plans-grid { grid-template-columns: 1fr !important; }
}
</style>