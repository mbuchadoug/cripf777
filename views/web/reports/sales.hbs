<div class="page-header">
  <div>
    <div class="page-title">Reports</div>
    <div class="page-subtitle">Sales, expenses and collections overview</div>
  </div>
  <div class="page-actions">
    <button class="btn btn-ghost" onclick="exportReport()"><i class="fas fa-download"></i> Export</button>
  </div>
</div>

<!-- Filters -->
<div class="filters-bar no-print">
  <form method="GET" style="display:contents">
    <div class="filter-group" style="min-width:160px">
      <label class="filter-label">Period</label>
      <select name="period" class="form-select" onchange="this.form.submit()" style="padding:9px 12px;font-size:13px;">
        <option value="today"     {{#if (eq filters.period 'today')}}selected{{/if}}>Today</option>
        <option value="week"      {{#if (eq filters.period 'week')}}selected{{/if}}>Last 7 days</option>
        <option value="month"     {{#if (eq filters.period 'month')}}selected{{/if}}>This month</option>
        <option value="lastmonth" {{#if (eq filters.period 'lastmonth')}}selected{{/if}}>Last month</option>
        <option value="year"      {{#if (eq filters.period 'year')}}selected{{/if}}>This year</option>
      </select>
    </div>

    <div class="filter-group">
      <label class="filter-label">From</label>
      <input type="date" name="startDate" class="form-input" value="{{filters.startDate}}" style="padding:9px 12px;font-size:13px;">
    </div>

    <div class="filter-group">
      <label class="filter-label">To</label>
      <input type="date" name="endDate" class="form-input" value="{{filters.endDate}}" style="padding:9px 12px;font-size:13px;">
    </div>

    {{#if isOwner}}
      <div class="filter-group">
        <label class="filter-label">Branch</label>
        <select name="branchFilter" class="form-select" onchange="this.form.submit()" style="padding:9px 12px;font-size:13px;">
          <option value="">All Branches</option>
          {{#each branches}}
            <option value="{{this._id}}" {{#if (eq ../filters.branchFilter this._id)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
    {{/if}}

    <div style="display:flex;gap:8px;align-items:flex-end;padding-bottom:1px">
      <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-filter"></i> Apply</button>
      <a href="/web/reports" class="btn btn-ghost btn-sm"><i class="fas fa-redo"></i> Reset</a>
    </div>
  </form>
</div>

<!-- Summary -->
<div class="grid-4" style="margin-bottom:18px;">
  <div class="stat-card amber">
    <div class="stat-icon amber"><i class="fas fa-file-invoice-dollar"></i></div>
    <div class="stat-value">{{user.currency}} {{summary.totalRevenue}}</div>
    <div class="stat-label">Invoiced</div>
  </div>

  <div class="stat-card green">
    <div class="stat-icon green"><i class="fas fa-hand-holding-dollar"></i></div>
    <div class="stat-value">{{user.currency}} {{summary.totalCollected}}</div>
    <div class="stat-label">Collected</div>
  </div>

  <div class="stat-card red">
    <div class="stat-icon red"><i class="fas fa-arrow-trend-down"></i></div>
    <div class="stat-value">{{user.currency}} {{summary.totalExpenses}}</div>
    <div class="stat-label">Expenses</div>
  </div>

  <div class="stat-card blue">
    <div class="stat-icon blue"><i class="fas fa-chart-line"></i></div>
    <div class="stat-value">{{user.currency}} {{summary.netProfit}}</div>
    <div class="stat-label">Net (Collected - Expenses)</div>
  </div>
</div>

<div class="grid-2" style="margin-bottom:18px;">
  <!-- Sales breakdown -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-file-invoice"></i> Invoice Status</div>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Status</th>
            <th style="text-align:right">Count</th>
            <th style="text-align:right">Total</th>
            <th style="text-align:right">Paid</th>
            <th style="text-align:right">Balance</th>
          </tr>
        </thead>
        <tbody>
          {{#each salesData}}
            <tr style="cursor:default">
              <td>
                {{#if (eq this._id 'paid')}}<span class="badge badge-green">Paid</span>{{/if}}
                {{#if (eq this._id 'partial')}}<span class="badge badge-amber">Partial</span>{{/if}}
                {{#if (eq this._id 'unpaid')}}<span class="badge badge-red">Unpaid</span>{{/if}}
              </td>
              <td style="text-align:right"><span class="td-mono">{{this.count}}</span></td>
              <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.total}}</span></td>
              <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.paid}}</span></td>
              <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.balance}}</span></td>
            </tr>
          {{else}}
            <tr><td colspan="5"><div class="empty-state" style="padding:26px 10px"><p>No invoice data for this period.</p></div></td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Payments breakdown -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-money-bill-wave"></i> Payments by Method</div>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Method</th>
            <th style="text-align:right">Count</th>
            <th style="text-align:right">Total</th>
          </tr>
        </thead>
        <tbody>
          {{#each paymentData}}
            <tr style="cursor:default">
              <td><span class="td-primary">{{this._id}}</span></td>
              <td style="text-align:right"><span class="td-mono">{{this.count}}</span></td>
              <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.total}}</span></td>
            </tr>
          {{else}}
            <tr><td colspan="3"><div class="empty-state" style="padding:26px 10px"><p>No payments recorded.</p></div></td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Expenses breakdown -->
<div class="card" style="margin-bottom:18px;">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-arrow-trend-down"></i> Expenses by Category</div>
  </div>
  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Category</th>
          <th style="text-align:right">Count</th>
          <th style="text-align:right">Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each expenseData}}
          <tr style="cursor:default">
            <td><span class="td-primary">{{#if this._id}}{{this._id}}{{else}}Uncategorized{{/if}}</span></td>
            <td style="text-align:right"><span class="td-mono">{{this.count}}</span></td>
            <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.total}}</span></td>
          </tr>
        {{else}}
          <tr><td colspan="3"><div class="empty-state" style="padding:26px 10px"><p>No expenses in this period.</p></div></td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<!-- Branch breakdown (owner only + no branchFilter) -->
{{#if (and isOwner (not filters.branchFilter))}}
  <div class="card" style="margin-bottom:18px;">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-code-branch"></i> Branch Performance</div>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Branch</th>
            <th style="text-align:right">Revenue</th>
            <th style="text-align:right">Collected</th>
            <th style="text-align:right">Expenses</th>
            <th style="text-align:right">Profit</th>
          </tr>
        </thead>
        <tbody>
          {{#each branchBreakdown}}
            <tr style="cursor:default">
              <td><span class="td-primary">{{this.name}}</span></td>
              <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.revenue}}</span></td>
              <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.collected}}</span></td>
              <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.expenses}}</span></td>
              <td style="text-align:right"><span class="td-primary td-mono">{{../user.currency}} {{this.profit}}</span></td>
            </tr>
          {{else}}
            <tr><td colspan="5"><div class="empty-state" style="padding:26px 10px"><p>No branch data.</p></div></td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
{{/if}}

<!-- Activity log -->
<div class="card">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-list"></i> Activity Log</div>
  </div>

  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Invoice</th>
          <th>Client</th>
          <th>Status</th>
          <th style="text-align:right">Total</th>
          <th style="text-align:right">Paid</th>
          <th style="text-align:right">Balance</th>
          <th>Created By</th>
          {{#if isOwner}}<th>Branch</th>{{/if}}
        </tr>
      </thead>
      <tbody>
        {{#each activityLog}}
          <tr onclick="window.location.href='/web/invoices/{{this._id}}'">
            <td><span class="td-mono" style="font-size:12px">{{formatDate this.createdAt}}</span></td>
            <td><span class="td-primary td-mono">{{this.number}}</span></td>
            <td>{{this.clientName}}</td>
            <td>
              {{#if (eq this.status 'paid')}}<span class="badge badge-green">Paid</span>{{/if}}
              {{#if (eq this.status 'partial')}}<span class="badge badge-amber">Partial</span>{{/if}}
              {{#if (eq this.status 'unpaid')}}<span class="badge badge-red">Unpaid</span>{{/if}}
            </td>
            <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.total}}</span></td>
            <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.amountPaid}}</span></td>
            <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.balance}}</span></td>
            <td><span class="td-mono">{{#if this.createdBy}}{{this.createdBy}}{{else}}—{{/if}}</span></td>
            {{#if ../isOwner}}<td>{{this.branchName}}</td>{{/if}}
          </tr>
        {{else}}
          <tr>
            <td colspan="{{#if isOwner}}9{{else}}8{{/if}}">
              <div class="empty-state">
                <i class="fas fa-list"></i>
                <h3>No activity</h3>
                <p>No invoices recorded for the selected period.</p>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<script>
  async function exportReport() {
    try {
      const params = new URLSearchParams(window.location.search);
      const r = await fetch('/web/reports/export?' + params.toString());
      const d = await r.json();
      if (!r.ok) return showToast(d.error || 'Export failed', 'error');

      // Simple JSON download (you can do CSV client-side if you want)
      const blob = new Blob([JSON.stringify(d.rows || [], null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'reports-export.json';
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      showToast('Exported', 'success');
    } catch {
      showToast('Export failed', 'error');
    }
  }
</script>