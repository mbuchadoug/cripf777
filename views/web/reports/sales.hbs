<div class="page-header">
  <div>
    <div class="page-title">Reports</div>
    <div class="page-subtitle">Detailed analysis across sales, expenses, receivables and branch performance</div>
  </div>
  <a href="/web/reports/export?period={{filters.period}}&branchFilter={{filters.branchFilter}}" class="btn btn-ghost btn-sm">
    <i class="fas fa-download"></i> Export CSV
  </a>
</div>

<!-- ══ FILTERS ════════════════════════════════════════════════════════════════ -->
<div class="card" style="margin-bottom:22px">
  <div class="card-body" style="padding:16px 20px">
    <form method="GET" action="/web/reports" style="display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap">

      <div class="form-group" style="margin-bottom:0;min-width:130px">
        <label class="form-label">Period</label>
        <select name="period" class="form-select" onchange="this.form.submit()">
          <option value="today"     {{#if (eq filters.period "today")}}selected{{/if}}>Today</option>
          <option value="week"      {{#if (eq filters.period "week")}}selected{{/if}}>This Week</option>
          <option value="month"     {{#if (eq filters.period "month")}}selected{{/if}}>This Month</option>
          <option value="lastmonth" {{#if (eq filters.period "lastmonth")}}selected{{/if}}>Last Month</option>
          <option value="year"      {{#if (eq filters.period "year")}}selected{{/if}}>This Year</option>
          <option value="custom"    {{#if (eq filters.period "custom")}}selected{{/if}}>Custom Range</option>
        </select>
      </div>

      <div class="form-group" style="margin-bottom:0">
        <label class="form-label">From</label>
        <input type="date" name="startDate" class="form-input" value="{{filters.startDate}}" style="width:150px">
      </div>
      <div class="form-group" style="margin-bottom:0">
        <label class="form-label">To</label>
        <input type="date" name="endDate" class="form-input" value="{{filters.endDate}}" style="width:150px">
      </div>

      {{#if isOwner}}
      <div class="form-group" style="margin-bottom:0;min-width:150px">
        <label class="form-label">Branch</label>
        <select name="branchFilter" class="form-select">
          <option value="">All Branches</option>
          {{#each branches}}
          <option value="{{this._id}}" {{#if (eq ../filters.branchFilter (toString this._id))}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}

      <button type="submit" class="btn btn-primary btn-sm" style="margin-bottom:0">
        <i class="fas fa-filter"></i> Apply
      </button>
    </form>
  </div>
</div>

<!-- ══ SUMMARY KPI CARDS ══════════════════════════════════════════════════════ -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:22px">

  <!-- Total Revenue -->
  <div class="card kpi-card">
    <div class="card-body" style="padding:18px 20px">
      <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px">Total Revenue</div>
      <div style="font-family:'DM Mono',monospace;font-size:20px;font-weight:700;color:var(--white)">{{user.currency}} {{summary.totalRevenue}}</div>
      <div style="font-size:11px;color:var(--muted-2);margin-top:4px">
        {{summary.invoiceCount}} invoices · {{summary.receiptCount}} direct sales
      </div>
    </div>
  </div>

  <!-- Cash Received -->
  <div class="card kpi-card">
    <div class="card-body" style="padding:18px 20px">
      <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px">Cash Received</div>
      <div style="font-family:'DM Mono',monospace;font-size:20px;font-weight:700;color:var(--green)">{{user.currency}} {{summary.cashReceived}}</div>
      <div style="font-size:11px;color:var(--muted-2);margin-top:4px">
        {{summary.collectionRate}}% invoice collection · {{summary.profitMargin}}% margin
      </div>
    </div>
  </div>

  <!-- Total Expenses -->
  <div class="card kpi-card">
    <div class="card-body" style="padding:18px 20px">
      <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px">Total Expenses</div>
      <div style="font-family:'DM Mono',monospace;font-size:20px;font-weight:700;color:var(--red)">{{user.currency}} {{summary.spent}}</div>
      <div style="font-size:11px;color:var(--muted-2);margin-top:4px">{{summary.expenseCount}} transactions</div>
    </div>
  </div>

  <!-- Net Profit -->
  <div class="card kpi-card">
    <div class="card-body" style="padding:18px 20px">
      <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px">Net Profit</div>
      <div style="font-family:'DM Mono',monospace;font-size:20px;font-weight:700;
        {{#if (gt summary.netProfit 0)}}color:var(--green){{else}}color:var(--red){{/if}}">
        {{user.currency}} {{summary.netProfit}}
      </div>
      <div style="font-size:11px;color:var(--muted-2);margin-top:4px">Cash received − expenses</div>
    </div>
  </div>

</div>

<!-- ══ CASH BREAKDOWN + PERIOD COMPARISON ════════════════════════════════════ -->
<div class="grid-2" style="margin-bottom:22px">

  <!-- Cash received breakdown -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-sack-dollar"></i> Cash Breakdown</div>
    </div>
    <div class="card-body" style="padding:18px 20px;display:grid;gap:10px">

      <!-- Invoice payments row -->
      <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border:1px solid var(--border);border-radius:9px">
        <div>
          <div style="font-size:13px;font-weight:600;color:var(--white)">Invoice Payments</div>
          <div style="font-size:11px;color:var(--muted-2)">{{summary.paymentCount}} payments collected on invoices</div>
        </div>
        <span style="font-family:'DM Mono',monospace;font-weight:600;color:var(--green)">{{user.currency}} {{summary.paymentCash}}</span>
      </div>

      <!-- Direct sales / receipts row -->
      <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border:1px solid var(--border);border-radius:9px">
        <div>
          <div style="font-size:13px;font-weight:600;color:var(--white)">Direct Sales <span style="font-size:10px;font-weight:500;color:var(--blue);background:rgba(88,166,255,0.1);padding:2px 6px;border-radius:4px;margin-left:4px">Receipts</span></div>
          <div style="font-size:11px;color:var(--muted-2)">{{summary.receiptCount}} direct cash sales — instantly paid in full</div>
        </div>
        <span style="font-family:'DM Mono',monospace;font-weight:600;color:var(--green)">{{user.currency}} {{summary.receiptCash}}</span>
      </div>

      <!-- Total cash in -->
      <div style="display:flex;justify-content:space-between;align-items:center;padding:13px 14px;background:rgba(63,185,80,0.06);border:1px solid rgba(63,185,80,0.2);border-radius:9px">
        <span style="font-size:14px;font-weight:700;color:var(--white)">Total Cash In</span>
        <span style="font-family:'DM Mono',monospace;font-size:16px;font-weight:700;color:var(--green)">{{user.currency}} {{summary.cashReceived}}</span>
      </div>

      <div style="display:flex;justify-content:space-between;padding:8px 4px">
        <span style="font-size:12px;color:var(--muted-2)">Invoice collection rate</span>
        <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;
          {{#if (gt summary.collectionRate 70)}}color:var(--green)
          {{else if (gt summary.collectionRate 40)}}color:var(--amber)
          {{else}}color:var(--red){{/if}}">{{summary.collectionRate}}%
          <span style="font-weight:400;color:var(--muted-2);font-size:10px"> (invoices only)</span>
        </span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:8px 4px;border-top:1px solid var(--border)">
        <span style="font-size:12px;color:var(--muted-2)">Profit margin</span>
        <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--blue)">{{summary.profitMargin}}%</span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:8px 4px;border-top:1px solid var(--border)">
        <span style="font-size:12px;color:var(--muted-2)">Avg invoice value</span>
        <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--white)">{{user.currency}} {{summary.avgSale}}</span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:8px 4px;border-top:1px solid var(--border)">
        <span style="font-size:12px;color:var(--muted-2)">Outstanding receivable</span>
        <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--amber)">{{user.currency}} {{summary.outstanding}}</span>
      </div>
    </div>
  </div>

  <!-- Period comparison -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-arrows-left-right"></i> vs Previous Period</div>
    </div>
    <div class="card-body" style="padding:18px 20px">
      <div style="display:grid;gap:4px">

        <div style="display:flex;align-items:center;gap:6px;padding:11px 0;border-bottom:1px solid var(--border)">
          <span style="font-size:12px;color:var(--muted-2);flex:1;min-width:80px">Invoiced</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;color:var(--muted-2);min-width:90px">{{user.currency}} {{prev.invoiced}}</span>
          <span style="color:var(--muted-2);font-size:11px">→</span>
          <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--white);min-width:90px">{{user.currency}} {{summary.invoiced}}</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600;min-width:52px;text-align:right;
            {{#if (gt growth.revenue 0)}}color:var(--green){{else if (lt growth.revenue 0)}}color:var(--red){{else}}color:var(--muted-2){{/if}}">
            {{#if (gt growth.revenue 0)}}↑{{else if (lt growth.revenue 0)}}↓{{/if}} {{growth.revenue}}%
          </span>
        </div>

        <div style="display:flex;align-items:center;gap:6px;padding:11px 0;border-bottom:1px solid var(--border)">
          <span style="font-size:12px;color:var(--muted-2);flex:1;min-width:80px">Cash In</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;color:var(--muted-2);min-width:90px">{{user.currency}} {{prev.cashReceived}}</span>
          <span style="color:var(--muted-2);font-size:11px">→</span>
          <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--white);min-width:90px">{{user.currency}} {{summary.cashReceived}}</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600;min-width:52px;text-align:right;
            {{#if (gt growth.cash 0)}}color:var(--green){{else if (lt growth.cash 0)}}color:var(--red){{else}}color:var(--muted-2){{/if}}">
            {{#if (gt growth.cash 0)}}↑{{else if (lt growth.cash 0)}}↓{{/if}} {{growth.cash}}%
          </span>
        </div>

        <div style="display:flex;align-items:center;gap:6px;padding:11px 0;border-bottom:1px solid var(--border)">
          <span style="font-size:12px;color:var(--muted-2);flex:1;min-width:80px">Expenses</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;color:var(--muted-2);min-width:90px">{{user.currency}} {{prev.spent}}</span>
          <span style="color:var(--muted-2);font-size:11px">→</span>
          <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--white);min-width:90px">{{user.currency}} {{summary.spent}}</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600;min-width:52px;text-align:right;
            {{#if (lt growth.expenses 0)}}color:var(--green){{else if (gt growth.expenses 0)}}color:var(--red){{else}}color:var(--muted-2){{/if}}">
            {{#if (gt growth.expenses 0)}}↑{{else if (lt growth.expenses 0)}}↓{{/if}} {{growth.expenses}}%
          </span>
        </div>

        <div style="display:flex;align-items:center;gap:6px;padding:11px 0">
          <span style="font-size:12px;color:var(--muted-2);flex:1;min-width:80px">Net Profit</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;color:var(--muted-2);min-width:90px">{{user.currency}} {{prev.netProfit}}</span>
          <span style="color:var(--muted-2);font-size:11px">→</span>
          <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;
            {{#if (gt summary.netProfit 0)}}color:var(--green){{else}}color:var(--red){{/if}};min-width:90px">{{user.currency}} {{summary.netProfit}}</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600;min-width:52px;text-align:right;
            {{#if (gt growth.profit 0)}}color:var(--green){{else if (lt growth.profit 0)}}color:var(--red){{else}}color:var(--muted-2){{/if}}">
            {{#if (gt growth.profit 0)}}↑{{else if (lt growth.profit 0)}}↓{{/if}} {{growth.profit}}%
          </span>
        </div>

      </div>
    </div>
  </div>

</div>

<!-- ══ INVOICE STATUS + PAYMENT METHODS ══════════════════════════════════════ -->
<div class="grid-2" style="margin-bottom:22px">

  <!-- Invoice status breakdown — invoices only, receipts always paid separately -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-file-invoice"></i> Invoice Status</div>
      <span style="font-size:11px;color:var(--muted-2)">Excludes direct sales (receipts)</span>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Status</th>
            <th style="text-align:right">Count</th>
            <th style="text-align:right">Billed</th>
            <th style="text-align:right">Collected</th>
            <th style="text-align:right">Balance</th>
          </tr>
        </thead>
        <tbody>
          {{#each salesData}}
          <tr style="cursor:default">
            <td>
              <span class="badge {{#if (eq this._id 'paid')}}badge-green{{else if (eq this._id 'partial')}}badge-amber{{else}}badge-red{{/if}}">
                {{this._id}}
              </span>
            </td>
            <td style="text-align:right"><span class="td-mono">{{this.count}}</span></td>
            <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.total}}</span></td>
            <td style="text-align:right"><span class="td-mono" style="color:var(--green)">{{../user.currency}} {{this.paid}}</span></td>
            <td style="text-align:right"><span class="td-mono" style="{{#if (gt this.balance 0)}}color:var(--red){{else}}color:var(--muted-2){{/if}}">{{../user.currency}} {{this.balance}}</span></td>
          </tr>
          {{else}}
          <tr><td colspan="5"><div class="empty-state" style="padding:20px"><i class="fas fa-file-invoice"></i><p>No invoices in this period</p></div></td></tr>
          {{/each}}
          {{#if summary.receiptCount}}
          <tr style="background:rgba(88,166,255,0.04);cursor:default">
            <td>
              <span class="badge badge-blue">receipt</span>
            </td>
            <td style="text-align:right"><span class="td-mono">{{summary.receiptCount}}</span></td>
            <td style="text-align:right"><span class="td-mono">{{user.currency}} {{summary.receiptCash}}</span></td>
            <td style="text-align:right"><span class="td-mono" style="color:var(--green)">{{user.currency}} {{summary.receiptCash}}</span></td>
            <td style="text-align:right"><span class="td-mono" style="color:var(--muted-2)">—</span></td>
          </tr>
          {{/if}}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Payment methods -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-credit-card"></i> Payment Methods</div>
      <span style="font-size:11px;color:var(--muted-2)">Invoice payments only</span>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr><th>Method</th><th style="text-align:right">Count</th><th style="text-align:right">Total</th></tr>
        </thead>
        <tbody>
          {{#each paymentData}}
          <tr style="cursor:default">
            <td class="td-primary">{{this._id}}</td>
            <td style="text-align:right"><span class="td-mono">{{this.count}}</span></td>
            <td style="text-align:right"><span class="td-mono td-primary">{{../user.currency}} {{this.total}}</span></td>
          </tr>
          {{else}}
          <tr><td colspan="3"><div class="empty-state" style="padding:20px"><i class="fas fa-credit-card"></i><p>No invoice payments recorded</p></div></td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ══ EXPENSE BREAKDOWN ══════════════════════════════════════════════════════ -->
<div class="card" style="margin-bottom:22px">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-wallet"></i> Expense Breakdown by Category</div>
    <span style="font-size:12px;color:var(--muted-2)">Total: {{user.currency}} {{summary.spent}}</span>
  </div>
  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr><th>Category</th><th style="text-align:right">Count</th><th style="text-align:right">Total</th><th style="text-align:right">% of Spend</th></tr>
      </thead>
      <tbody>
        {{#each expenseData}}
        <tr style="cursor:default">
          <td class="td-primary">{{this._id}}</td>
          <td style="text-align:right"><span class="td-mono">{{this.count}}</span></td>
          <td style="text-align:right"><span class="td-mono td-primary">{{../user.currency}} {{this.total}}</span></td>
          <td style="text-align:right">
            <div style="display:flex;align-items:center;justify-content:flex-end;gap:8px">
              <div style="width:60px;height:4px;border-radius:2px;background:var(--border);overflow:hidden">
                <div style="width:{{this.percentage}}%;height:100%;background:var(--red);border-radius:2px"></div>
              </div>
              <span class="td-mono" style="color:var(--red);min-width:32px">{{this.percentage}}%</span>
            </div>
          </td>
        </tr>
        {{else}}
        <tr><td colspan="4"><div class="empty-state" style="padding:20px"><i class="fas fa-wallet"></i><p>No expenses in this period</p></div></td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<!-- ══ TOP PRODUCTS + TOP CUSTOMERS ══════════════════════════════════════════ -->
<div class="grid-2" style="margin-bottom:22px">

  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-boxes-stacked"></i> Top Products / Services</div>
      <span style="font-size:11px;color:var(--muted-2)">Invoices + receipts</span>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr><th>Product / Service</th><th style="text-align:right">Units</th><th style="text-align:right">Revenue</th></tr>
        </thead>
        <tbody>
          {{#each topProducts}}
          <tr style="cursor:default">
            <td class="td-primary">{{this.name}}</td>
            <td style="text-align:right"><span class="td-mono">{{this.qty}}</span></td>
            <td style="text-align:right"><span class="td-mono td-primary">{{../user.currency}} {{this.revenue}}</span></td>
          </tr>
          {{else}}
          <tr><td colspan="3"><div class="empty-state" style="padding:20px"><i class="fas fa-boxes-stacked"></i><p>No product data</p></div></td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-trophy"></i> Top Customers</div>
      <span style="font-size:11px;color:var(--muted-2)">Invoices + receipts</span>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr><th>Rank</th><th>Client</th><th style="text-align:right">Total Spent</th></tr>
        </thead>
        <tbody>
          {{#each topCustomers}}
          <tr style="cursor:default">
            <td><span style="font-family:'DM Mono',monospace;font-size:12px;color:var(--amber)">#{{addOne @index}}</span></td>
            <td class="td-primary">{{this.name}}</td>
            <td style="text-align:right"><span class="td-mono td-primary">{{../user.currency}} {{this.amount}}</span></td>
          </tr>
          {{else}}
          <tr><td colspan="3"><div class="empty-state" style="padding:20px"><i class="fas fa-users"></i><p>No customer data</p></div></td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ══ OVERDUE ANALYSIS + PERIOD HIGHLIGHTS ══════════════════════════════════ -->
<div class="grid-2" style="margin-bottom:22px">

  <!-- Outstanding receivables — invoices only, receipts can't be overdue -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-triangle-exclamation"></i> Outstanding Receivables</div>
      <span style="font-size:11px;color:var(--muted-2)">Terms: {{termsDays}} days · invoices only</span>
    </div>
    <div class="card-body" style="padding:16px 20px">

      {{#if overdueList.length}}
      <div style="margin-bottom:16px">
        <div style="font-size:10px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px">
          Overdue ({{overdueList.length}}) — {{user.currency}} {{totalOverdue}}
        </div>
        {{#each overdueList}}
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 10px;border-radius:7px;background:rgba(248,81,73,0.05);margin-bottom:4px;border:1px solid rgba(248,81,73,0.1)">
          <span style="font-family:'DM Mono',monospace;font-size:12px;color:var(--red)">{{this.number}}</span>
          <span style="font-size:11px;color:var(--muted-2)">{{this.ageDays}}d overdue</span>
          <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--white)">{{../user.currency}} {{this.balance}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if currentList.length}}
      <div>
        <div style="font-size:10px;font-weight:700;color:var(--amber);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px">
          Within Terms ({{currentList.length}})
        </div>
        {{#each currentList}}
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 10px;border-radius:7px;background:rgba(245,158,11,0.04);margin-bottom:4px;border:1px solid rgba(245,158,11,0.1)">
          <span style="font-family:'DM Mono',monospace;font-size:12px;color:var(--amber)">{{this.number}}</span>
          <span style="font-size:11px;color:var(--muted-2)">{{this.ageDays}}d old</span>
          <span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--white)">{{../user.currency}} {{this.balance}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#unless overdueList.length}}{{#unless currentList.length}}
      <div class="empty-state" style="padding:24px">
        <i class="fas fa-check-circle" style="color:var(--green)"></i>
        <p>All invoices settled — no outstanding balances</p>
      </div>
      {{/unless}}{{/unless}}

    </div>
  </div>

  <!-- Period highlights -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-calendar-day"></i> Period Highlights</div>
    </div>
    <div class="card-body" style="padding:18px 20px;display:grid;gap:14px">

      {{#if bestDay}}
      <div style="padding:12px 14px;border:1px solid rgba(63,185,80,0.25);border-radius:9px;background:rgba(63,185,80,0.04)">
        <div style="font-size:10px;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:4px">Best Day</div>
        <div style="font-family:'DM Mono',monospace;font-size:13px;color:var(--green);font-weight:600">
          {{bestDay.date}} — {{user.currency}} {{bestDay.amount}}
        </div>
      </div>
      {{/if}}

      {{#if worstDay}}
      <div style="padding:12px 14px;border:1px solid var(--border);border-radius:9px">
        <div style="font-size:10px;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:4px">Slowest Day</div>
        <div style="font-family:'DM Mono',monospace;font-size:13px;color:var(--muted);font-weight:600">
          {{worstDay.date}} — {{user.currency}} {{worstDay.amount}}
        </div>
      </div>
      {{/if}}

      {{#if topInvoices.length}}
      <div>
        <div style="font-size:10px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:10px">
          Largest Invoices
        </div>
        {{#each topInvoices}}
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)">
          <span style="font-family:'DM Mono',monospace;font-size:12px;color:var(--amber)">{{this.number}}</span>
          <span class="badge {{#if (eq this.status 'paid')}}badge-green{{else if (eq this.status 'partial')}}badge-amber{{else}}badge-red{{/if}}" style="font-size:10px">
            {{this.status}}
          </span>
          <span style="font-family:'DM Mono',monospace;font-size:13px;font-weight:600;color:var(--white)">{{../user.currency}} {{this.total}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}

    </div>
  </div>

</div>

<!-- ══ BRANCH BREAKDOWN (owner only) ══════════════════════════════════════════ -->
{{#if isOwner}}
{{#if branchBreakdown.length}}
<div class="card" style="margin-bottom:22px">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-code-branch"></i> Branch Breakdown</div>
    <span style="font-size:11px;color:var(--muted-2)">Collected = invoice payments + direct sales</span>
  </div>
  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Branch</th>
          <th style="text-align:right">Invoiced</th>
          <th style="text-align:right">Collected</th>
          <th style="text-align:right">Direct Sales</th>
          <th style="text-align:right">Expenses</th>
          <th style="text-align:right">Net Profit</th>
          <th style="text-align:right">Outstanding</th>
          <th style="text-align:right">Invoices</th>
        </tr>
      </thead>
      <tbody>
        {{#each branchBreakdown}}
        <tr style="cursor:default">
          <td class="td-primary">{{this.branchName}}</td>
          <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.revenue}}</span></td>
          <td style="text-align:right"><span class="td-mono" style="color:var(--green)">{{../user.currency}} {{this.collected}}</span></td>
          <td style="text-align:right"><span class="td-mono" style="color:var(--blue)">{{../user.currency}} {{this.rcptCash}}</span></td>
          <td style="text-align:right"><span class="td-mono" style="color:var(--red)">{{../user.currency}} {{this.spent}}</span></td>
          <td style="text-align:right">
            <span class="td-mono" style="{{#if (gt this.profit 0)}}color:var(--green){{else if (lt this.profit 0)}}color:var(--red){{else}}color:var(--muted-2){{/if}}">
              {{../user.currency}} {{this.profit}}
            </span>
          </td>
          <td style="text-align:right"><span class="td-mono" style="color:var(--amber)">{{../user.currency}} {{this.outstanding}}</span></td>
          <td style="text-align:right"><span class="td-mono">{{this.count}}</span></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
{{/if}}
{{/if}}

<!-- ══ ACTIVITY LOG ═══════════════════════════════════════════════════════════ -->
<div class="card">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-list-ul"></i> Sales & Invoice Activity</div>
    <span style="font-size:12px;color:var(--muted-2)">Last {{activityLog.length}} in period</span>
  </div>

  {{#if activityLog.length}}
  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Number</th>
          <th>Type</th>
          <th>Client</th>
          {{#if isOwner}}<th>Branch</th>{{/if}}
          <th style="text-align:right">Total</th>
          <th style="text-align:right">Balance</th>
          <th>Status</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        {{#each activityLog}}
        <tr onclick="location.href='/web/{{#if (eq this.type 'receipt')}}receipts{{else}}invoices{{/if}}/{{this._id}}'" style="cursor:pointer">
          <td><span class="td-mono" style="color:var(--amber)">{{this.number}}</span></td>
          <td>
            <span class="badge {{#if (eq this.type 'receipt')}}badge-blue{{else}}badge-default{{/if}}" style="font-size:10px;text-transform:capitalize">
              {{this.type}}
            </span>
          </td>
          <td class="td-primary">{{this.clientName}}</td>
          {{#if ../isOwner}}<td><span style="font-size:12px;color:var(--muted)">{{this.branchName}}</span></td>{{/if}}
          <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.total}}</span></td>
          <td style="text-align:right">
            <span class="td-mono" style="{{#if (gt this.balance 0)}}color:var(--red){{else}}color:var(--muted-2){{/if}}">
              {{#if (eq this.type 'receipt')}}—{{else}}{{../user.currency}} {{this.balance}}{{/if}}
            </span>
          </td>
          <td>
            <span class="badge {{#if (eq this.status 'paid')}}badge-green{{else if (eq this.status 'partial')}}badge-amber{{else}}badge-red{{/if}}">
              {{this.status}}
            </span>
          </td>
          <td style="font-size:11px;color:var(--muted-2)">{{this.createdAt}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="empty-state">
    <i class="fas fa-list-ul"></i>
    <h3>No activity in this period</h3>
    <p>Try changing your date filter.</p>
  </div>
  {{/if}}
</div>
