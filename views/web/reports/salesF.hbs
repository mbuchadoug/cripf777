<!-- Page Header -->
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-800 mb-2">Sales Reports</h1>
  <p class="text-sm text-gray-600">Analyze your business performance</p>
</div>

<!-- Filters -->
<div class="bg-white rounded-xl shadow-sm p-6 mb-6">
  <form method="GET" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Start Date</label>
      <input 
        type="date" 
        name="startDate" 
        value="{{filters.startDate}}"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
      >
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">End Date</label>
      <input 
        type="date" 
        name="endDate" 
        value="{{filters.endDate}}"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
      >
    </div>
    
    {{#if (eq user.role 'owner')}}
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Branch</label>
        <select name="branchFilter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
          <option value="">All Branches</option>
          <!-- Branches will be populated here -->
        </select>
      </div>
    {{/if}}
    
    <div class="flex items-end space-x-2">
      <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
        Apply
      </button>
      <a href="/web/reports" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
        <i class="fas fa-redo"></i>
      </a>
    </div>
    
  </form>
</div>

<!-- Sales Summary -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
  
  {{#each salesData}}
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-medium text-gray-600 uppercase">{{this._id}} Invoices</h3>
        <span class="inline-block px-3 py-1 text-xs font-medium rounded-full {{#if (eq this._id 'paid')}}bg-green-100 text-green-800{{else if (eq this._id 'partial')}}bg-yellow-100 text-yellow-800{{else}}bg-red-100 text-red-800{{/if}}">
          {{this.count}}
        </span>
      </div>
      
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-gray-600">Total:</span>
          <span class="font-semibold">{{../user.currency}} {{this.total}}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-600">Paid:</span>
          <span class="text-green-600">{{../user.currency}} {{this.paid}}</span>
        </div>
        {{#if (gt this.balance 0)}}
          <div class="flex justify-between">
            <span class="text-gray-600">Balance:</span>
            <span class="text-red-600">{{../user.currency}} {{this.balance}}</span>
          </div>
        {{/if}}
      </div>
    </div>
  {{/each}}
  
</div>

<!-- Expenses Summary -->
{{#if expenseData.length}}
  <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Expenses by Category</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {{#each expenseData}}
        <div class="border border-gray-200 rounded-lg p-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-800">{{this._id}}</span>
            <span class="text-sm text-gray-500">{{this.count}} items</span>
          </div>
          <p class="text-xl font-bold text-red-600 mt-2">{{../user.currency}} {{this.total}}</p>
        </div>
      {{/each}}
    </div>
  </div>
{{/if}}

<!-- Payment Methods -->
{{#if paymentData.length}}
  <div class="bg-white rounded-xl shadow-sm p-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Payments by Method</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {{#each paymentData}}
        <div class="border border-gray-200 rounded-lg p-4 text-center">
          <i class="fas {{#if (eq this._id 'Cash')}}fa-money-bill-wave{{else if (eq this._id 'Bank')}}fa-university{{else if (eq this._id 'EcoCash')}}fa-mobile-alt{{else}}fa-credit-card{{/if}} text-2xl text-blue-600 mb-2"></i>
          <p class="text-sm font-medium text-gray-800">{{this._id}}</p>
          <p class="text-xs text-gray-500">{{this.count}} transactions</p>
          <p class="text-lg font-bold text-green-600 mt-2">{{../user.currency}} {{this.total}}</p>
        </div>
      {{/each}}
    </div>
  </div>
{{/if}}

<!-- Export Options -->
<div class="mt-6 flex justify-center space-x-4 no-print">
  <button onclick="window.print()" class="px-6 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
    <i class="fas fa-print mr-2"></i> Print Report
  </button>
  <button onclick="exportToCSV()" class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
    <i class="fas fa-file-excel mr-2"></i> Export to CSV
  </button>
</div>

<script>
  function exportToCSV() {
    // Simple CSV export
    alert('CSV export feature coming soon!');
  }
</script>