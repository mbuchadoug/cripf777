<div class="page-header">
  <div>
    <div class="page-title">Reports & Analytics</div>
    <div class="page-subtitle">Sales, expenses and collections overview</div>
  </div>
  <div class="page-actions">
    <button class="btn btn-ghost" onclick="exportReport()">
      <i class="fas fa-download"></i> Export Data
    </button>
  </div>
</div>

<!-- Filters -->
<div class="card" style="margin-bottom:20px">
  <div class="card-body" style="padding:18px 20px">
    <form method="GET" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap">
      <div class="filter-group" style="min-width:160px">
        <label class="filter-label">Period</label>
        <select name="period" class="form-select" onchange="this.form.submit()" style="padding:9px 12px;font-size:13px;">
          <option value="today"     {{#if (eq filters.period 'today')}}selected{{/if}}>Today</option>
          <option value="week"      {{#if (eq filters.period 'week')}}selected{{/if}}>Last 7 days</option>
          <option value="month"     {{#if (eq filters.period 'month')}}selected{{/if}}>This month</option>
          <option value="lastmonth" {{#if (eq filters.period 'lastmonth')}}selected{{/if}}>Last month</option>
          <option value="year"      {{#if (eq filters.period 'year')}}selected{{/if}}>This year</option>
        </select>
      </div>

      <div class="filter-group">
        <label class="filter-label">From</label>
        <input type="date" name="startDate" class="form-input" value="{{filters.startDate}}" style="padding:9px 12px;font-size:13px;">
      </div>

      <div class="filter-group">
        <label class="filter-label">To</label>
        <input type="date" name="endDate" class="form-input" value="{{filters.endDate}}" style="padding:9px 12px;font-size:13px;">
      </div>

      {{#if isOwner}}
        <div class="filter-group" style="min-width:180px">
          <label class="filter-label">Branch</label>
          <select name="branchFilter" class="form-select" onchange="this.form.submit()" style="padding:9px 12px;font-size:13px;">
            <option value="">All Branches</option>
            {{#each branches}}
              <option value="{{this._id}}" {{#if (eq ../filters.branchFilter this._id)}}selected{{/if}}>{{this.name}}</option>
            {{/each}}
          </select>
        </div>
      {{/if}}

      <div style="display:flex;gap:8px;margin-left:auto">
        <button type="submit" class="btn btn-primary btn-sm">
          <i class="fas fa-filter"></i> Apply
        </button>
        <a href="/web/reports" class="btn btn-ghost btn-sm">
          <i class="fas fa-redo"></i> Reset
        </a>
      </div>
    </form>
  </div>
</div>

<!-- Summary Cards -->
<div class="grid-4" style="margin-bottom:22px">
  
  <div class="card" style="background:linear-gradient(135deg, rgba(245,158,11,0.08) 0%, rgba(245,158,11,0.02) 100%);border-color:rgba(245,158,11,0.2)">
    <div class="card-body" style="padding:20px 22px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px">
        <div style="width:48px;height:48px;border-radius:12px;background:var(--amber-g);border:1px solid var(--amber-b);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="fas fa-file-invoice-dollar" style="color:var(--amber);font-size:20px"></i>
        </div>
        <div style="flex:1;min-width:0">
          <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px">
            Total Invoiced
          </div>
          <div style="font-family:'DM Mono',monospace;font-size:24px;font-weight:500;color:var(--amber);overflow:hidden;text-overflow:ellipsis">
            {{user.currency}} {{summary.totalRevenue}}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="background:linear-gradient(135deg, rgba(34,197,94,0.08) 0%, rgba(34,197,94,0.02) 100%);border-color:rgba(34,197,94,0.2)">
    <div class="card-body" style="padding:20px 22px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px">
        <div style="width:48px;height:48px;border-radius:12px;background:var(--green-g);border:1px solid var(--green-b);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="fas fa-hand-holding-dollar" style="color:var(--green);font-size:20px"></i>
        </div>
        <div style="flex:1;min-width:0">
          <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px">
            Total Collected
          </div>
          <div style="font-family:'DM Mono',monospace;font-size:24px;font-weight:500;color:var(--green);overflow:hidden;text-overflow:ellipsis">
            {{user.currency}} {{summary.totalCollected}}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="background:linear-gradient(135deg, rgba(239,68,68,0.08) 0%, rgba(239,68,68,0.02) 100%);border-color:rgba(239,68,68,0.2)">
    <div class="card-body" style="padding:20px 22px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px">
        <div style="width:48px;height:48px;border-radius:12px;background:var(--red-g);border:1px solid var(--red-b);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="fas fa-arrow-trend-down" style="color:var(--red);font-size:20px"></i>
        </div>
        <div style="flex:1;min-width:0">
          <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px">
            Total Expenses
          </div>
          <div style="font-family:'DM Mono',monospace;font-size:24px;font-weight:500;color:var(--red);overflow:hidden;text-overflow:ellipsis">
            {{user.currency}} {{summary.totalExpenses}}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="background:linear-gradient(135deg, rgba(59,130,246,0.08) 0%, rgba(59,130,246,0.02) 100%);border-color:rgba(59,130,246,0.2)">
    <div class="card-body" style="padding:20px 22px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px">
        <div style="width:48px;height:48px;border-radius:12px;background:var(--blue-g);border:1px solid var(--blue-b);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="fas fa-chart-line" style="color:var(--blue);font-size:20px"></i>
        </div>
        <div style="flex:1;min-width:0">
          <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px">
            Net Profit
          </div>
          <div style="font-family:'DM Mono',monospace;font-size:24px;font-weight:500;color:var(--blue);overflow:hidden;text-overflow:ellipsis">
            {{user.currency}} {{summary.netProfit}}
          </div>
        </div>
      </div>
      <div style="font-size:11px;color:var(--muted-2)">Collected − Expenses</div>
    </div>
  </div>

</div>

<!-- Two Column Grid -->
<div class="grid-2" style="margin-bottom:22px">
  
  <!-- Sales breakdown -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-file-invoice"></i> Invoice Status Breakdown</div>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Status</th>
            <th style="text-align:right">Count</th>
            <th style="text-align:right">Total</th>
            <th style="text-align:right">Paid</th>
            <th style="text-align:right">Balance</th>
          </tr>
        </thead>
        <tbody>
          {{#each salesData}}
            <tr style="cursor:default">
              <td>
                {{#if (eq this._id 'paid')}}
                  <span class="badge badge-green">Paid</span>
                {{/if}}
                {{#if (eq this._id 'partial')}}
                  <span class="badge badge-amber">Partial</span>
                {{/if}}
                {{#if (eq this._id 'unpaid')}}
                  <span class="badge badge-red">Unpaid</span>
                {{/if}}
              </td>
              <td style="text-align:right">
                <span class="td-mono">{{this.count}}</span>
              </td>
              <td style="text-align:right">
                <span class="td-mono td-primary">{{../user.currency}} {{this.total}}</span>
              </td>
              <td style="text-align:right">
                <span class="td-mono" style="color:var(--green)">{{../user.currency}} {{this.paid}}</span>
              </td>
              <td style="text-align:right">
                <span class="td-mono" style="color:var(--red)">{{../user.currency}} {{this.balance}}</span>
              </td>
            </tr>
          {{else}}
            <tr>
              <td colspan="5">
                <div class="empty-state" style="padding:32px 20px">
                  <i class="fas fa-file-invoice"></i>
                  <p>No invoice data for this period.</p>
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Payments breakdown -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-money-bill-wave"></i> Payments by Method</div>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Payment Method</th>
            <th style="text-align:right">Count</th>
            <th style="text-align:right">Total Amount</th>
          </tr>
        </thead>
        <tbody>
          {{#each paymentData}}
            <tr style="cursor:default">
              <td>
                <div style="display:flex;align-items:center;gap:8px">
                  {{#if (eq this._id 'Cash')}}
                    <i class="fas fa-money-bill-wave" style="color:var(--green);font-size:14px"></i>
                  {{else if (eq this._id 'Bank')}}
                    <i class="fas fa-building-columns" style="color:var(--blue);font-size:14px"></i>
                  {{else if (eq this._id 'EcoCash')}}
                    <i class="fas fa-mobile-screen" style="color:var(--amber);font-size:14px"></i>
                  {{else}}
                    <i class="fas fa-credit-card" style="color:var(--muted);font-size:14px"></i>
                  {{/if}}
                  <span class="td-primary">{{this._id}}</span>
                </div>
              </td>
              <td style="text-align:right">
                <span class="td-mono">{{this.count}}</span>
              </td>
              <td style="text-align:right">
                <span class="td-mono td-primary">{{../user.currency}} {{this.total}}</span>
              </td>
            </tr>
          {{else}}
            <tr>
              <td colspan="3">
                <div class="empty-state" style="padding:32px 20px">
                  <i class="fas fa-money-bill-wave"></i>
                  <p>No payments recorded for this period.</p>
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- Expenses breakdown -->
<div class="card" style="margin-bottom:22px">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-arrow-trend-down"></i> Expenses by Category</div>
  </div>
  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Category</th>
          <th style="text-align:right">Transaction Count</th>
          <th style="text-align:right">Total Amount</th>
          <th style="text-align:right">% of Total Expenses</th>
        </tr>
      </thead>
      <tbody>
        {{#each expenseData}}
          <tr style="cursor:default">
            <td>
              <span class="td-primary">{{#if this._id}}{{this._id}}{{else}}Uncategorized{{/if}}</span>
            </td>
            <td style="text-align:right">
              <span class="td-mono">{{this.count}}</span>
            </td>
            <td style="text-align:right">
              <span class="td-mono td-primary">{{../user.currency}} {{this.total}}</span>
            </td>
            <td style="text-align:right">
              <div style="display:flex;align-items:center;justify-content:flex-end;gap:10px">
                <div style="width:80px;height:6px;background:var(--surface-2);border-radius:3px;overflow:hidden">
                  <div style="width:{{this.percentage}}%;height:100%;background:var(--amber);border-radius:3px"></div>
                </div>
                <span class="td-mono" style="font-size:12px;color:var(--muted)">{{this.percentage}}%</span>
              </div>
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="4">
              <div class="empty-state" style="padding:32px 20px">
                <i class="fas fa-arrow-trend-down"></i>
                <p>No expenses recorded for this period.</p>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<!-- Branch breakdown (owner only + no branchFilter) -->
{{#if (and isOwner (not filters.branchFilter))}}
  <div class="card" style="margin-bottom:22px">
    <div class="card-header">
      <div class="card-title"><i class="fas fa-code-branch"></i> Branch Performance Comparison</div>
    </div>
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Branch Name</th>
            <th style="text-align:right">Revenue</th>
            <th style="text-align:right">Collected</th>
            <th style="text-align:right">Expenses</th>
            <th style="text-align:right">Net Profit</th>
          </tr>
        </thead>
        <tbody>
          {{#each branchBreakdown}}
            <tr style="cursor:default">
              <td>
                <div style="display:flex;align-items:center;gap:8px">
                  <i class="fas fa-building" style="color:var(--blue);font-size:14px"></i>
                  <span class="td-primary">{{this.name}}</span>
                </div>
              </td>
              <td style="text-align:right">
                <span class="td-mono">{{../user.currency}} {{this.revenue}}</span>
              </td>
              <td style="text-align:right">
                <span class="td-mono" style="color:var(--green)">{{../user.currency}} {{this.collected}}</span>
              </td>
              <td style="text-align:right">
                <span class="td-mono" style="color:var(--red)">{{../user.currency}} {{this.expenses}}</span>
              </td>
              <td style="text-align:right">
                <span class="td-primary td-mono" style="font-weight:600;{{#if (gt this.profit 0)}}color:var(--green){{else}}color:var(--red){{/if}}">
                  {{../user.currency}} {{this.profit}}
                </span>
              </td>
            </tr>
          {{else}}
            <tr>
              <td colspan="5">
                <div class="empty-state" style="padding:32px 20px">
                  <i class="fas fa-code-branch"></i>
                  <p>No branch data available.</p>
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
{{/if}}

<!-- Activity log -->
<div class="card">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-clock-rotate-left"></i> Recent Activity</div>
  </div>

  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Invoice #</th>
          <th>Client</th>
          <th>Status</th>
          <th style="text-align:right">Total</th>
          <th style="text-align:right">Paid</th>
          <th style="text-align:right">Balance</th>
          <th>Created By</th>
          {{#if isOwner}}<th>Branch</th>{{/if}}
        </tr>
      </thead>
      <tbody>
        {{#each activityLog}}
          <tr onclick="window.location.href='/web/invoices/{{this._id}}'" style="cursor:pointer">
            <td>
              <span class="td-mono" style="font-size:12px">{{formatDate this.createdAt}}</span>
            </td>
            <td>
              <span class="td-primary td-mono">{{this.number}}</span>
            </td>
            <td>
              <span class="td-primary">{{this.clientName}}</span>
            </td>
            <td>
              {{#if (eq this.status 'paid')}}
                <span class="badge badge-green">Paid</span>
              {{/if}}
              {{#if (eq this.status 'partial')}}
                <span class="badge badge-amber">Partial</span>
              {{/if}}
              {{#if (eq this.status 'unpaid')}}
                <span class="badge badge-red">Unpaid</span>
              {{/if}}
            </td>
            <td style="text-align:right">
              <span class="td-mono">{{../user.currency}} {{this.total}}</span>
            </td>
            <td style="text-align:right">
              <span class="td-mono" style="color:var(--green)">{{../user.currency}} {{this.amountPaid}}</span>
            </td>
            <td style="text-align:right">
              <span class="td-mono" style="color:var(--red)">{{../user.currency}} {{this.balance}}</span>
            </td>
            <td>
              <span class="td-mono" style="font-size:12px">{{#if this.createdBy}}{{this.createdBy}}{{else}}—{{/if}}</span>
            </td>
            {{#if ../isOwner}}
              <td>
                <span style="font-size:12px;color:var(--muted)">{{this.branchName}}</span>
              </td>
            {{/if}}
          </tr>
        {{else}}
          <tr>
            <td colspan="{{#if isOwner}}9{{else}}8{{/if}}">
              <div class="empty-state">
                <i class="fas fa-list"></i>
                <h3>No Activity Found</h3>
                <p>No invoices recorded for the selected period.</p>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<script>
  async function exportReport() {
    const btn = event.target.closest('button');
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Exporting...';
    
    try {
      const params = new URLSearchParams(window.location.search);
      const r = await fetch('/web/reports/export?' + params.toString());
      const d = await r.json();
      
      if (!r.ok) {
        showToast(d.error || 'Export failed', 'error');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
        return;
      }

      // Create CSV export
      const rows = d.rows || [];
      if (!rows.length) {
        showToast('No data to export', 'info');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
        return;
      }

      // Convert to CSV
      const headers = Object.keys(rows[0]).join(',');
      const csv = [headers, ...rows.map(row => Object.values(row).join(','))].join('\n');
      
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `report-${new Date().toISOString().split('T')[0]}.csv`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      
      showToast('Report exported successfully', 'success');
    } catch (err) {
      console.error('Export error:', err);
      showToast('Export failed', 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalHTML;
    }
  }
</script>