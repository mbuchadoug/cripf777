{{!-- views/web/users/activity.hbs --}}

<div class="flex items-center gap-3 mb-6">
  <a href="/web/users" class="text-gray-400 hover:text-gray-600">
    <i class="fas fa-arrow-left"></i>
  </a>
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Activity Log</h1>
    <p class="text-sm text-gray-500 mt-0.5 font-mono">{{member.phone}}</p>
  </div>
</div>

{{!-- Member Info --}}
<div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 mb-6">
  <div class="flex items-center gap-4">
    <div class="w-12 h-12 rounded-full flex items-center justify-center
      {{#if (eq member.role 'manager')}}bg-blue-100{{else}}bg-gray-100{{/if}}">
      <i class="fas fa-user
        {{#if (eq member.role 'manager')}}text-blue-600{{else}}text-gray-400{{/if}}"></i>
    </div>
    <div>
      <p class="font-mono text-sm text-gray-800">{{member.phone}}</p>
      <div class="flex items-center gap-2 mt-1">
        <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium capitalize
          {{#if (eq member.role 'manager')}}bg-blue-100 text-blue-700{{else}}bg-gray-100 text-gray-600{{/if}}">
          {{member.role}}
        </span>
        {{#if member.branchName}}
        <span class="text-xs text-gray-400">· {{member.branchName}}</span>
        {{/if}}
        {{#if member.locked}}
        <span class="inline-flex items-center gap-1 text-xs text-red-600">
          <i class="fas fa-lock"></i> Locked
        </span>
        {{/if}}
      </div>
    </div>
  </div>
</div>

{{!-- Invoices Created --}}
<div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 mb-6">
  <h2 class="font-semibold text-gray-800 mb-4">
    Invoices & Documents Created
    <span class="ml-2 text-xs text-gray-400 font-normal">(last 50)</span>
  </h2>

  {{#if invoices.length}}
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="border-b border-gray-100">
        <tr>
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase">Number</th>
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase">Client</th>
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase">Type</th>
          <th class="text-right pb-3 text-xs font-semibold text-gray-500 uppercase">Amount</th>
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase">Status</th>
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        {{#each invoices}}
        <tr class="hover:bg-gray-50">
          <td class="py-3">
            <a href="/web/invoices/{{this._id}}" class="text-blue-600 hover:underline font-mono text-xs">
              {{this.number}}
            </a>
          </td>
          <td class="py-3 text-gray-700">{{this.clientName}}</td>
          <td class="py-3">
            <span class="text-xs capitalize text-gray-500">{{this.type}}</span>
          </td>
          <td class="py-3 text-right font-medium text-gray-900">{{this.total}}</td>
          <td class="py-3">
            <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium
              {{#if (eq this.status 'paid')}}bg-green-100 text-green-700
              {{else if (eq this.status 'partial')}}bg-amber-100 text-amber-700
              {{else}}bg-red-100 text-red-700{{/if}}">
              {{this.status}}
            </span>
          </td>
          <td class="py-3 text-xs text-gray-400">{{formatDate this.createdAt}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <p class="text-sm text-gray-400 text-center py-8">No invoices created yet</p>
  {{/if}}
</div>

{{!-- Expenses Created --}}
<div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
  <h2 class="font-semibold text-gray-800 mb-4">
    Expenses Recorded
    <span class="ml-2 text-xs text-gray-400 font-normal">(last 50)</span>
  </h2>

  {{#if expenses.length}}
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="border-b border-gray-100">
        <tr>
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase">Category</th>
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase">Description</th>
          <th class="text-right pb-3 text-xs font-semibold text-gray-500 uppercase">Amount</th>
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        {{#each expenses}}
        <tr class="hover:bg-gray-50">
          <td class="py-3 text-gray-700">{{this.category}}</td>
          <td class="py-3 text-gray-500 text-xs">{{this.description}}</td>
          <td class="py-3 text-right font-medium text-red-500">{{this.amount}}</td>
          <td class="py-3 text-xs text-gray-400">{{formatDate this.createdAt}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <p class="text-sm text-gray-400 text-center py-8">No expenses recorded yet</p>
  {{/if}}
</div>
