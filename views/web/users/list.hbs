{{!-- views/web/clients/list.hbs --}}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Clients</h1>
    <p class="text-sm text-gray-500 mt-1">Manage your customer database</p>
  </div>
  <button onclick="showModal('addModal')"
    class="mt-4 sm:mt-0 inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
    <i class="fas fa-plus"></i> Add Client
  </button>
</div>

{{!-- Search --}}
<div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 mb-6">
  <form method="GET" class="flex items-center gap-3">
    <div class="flex-1 relative">
      <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
      <input type="text" name="search" placeholder="Search by name or phone…"
        value="{{search}}"
        class="w-full pl-9 pr-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
    </div>
    <button type="submit"
      class="px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700">
      Search
    </button>
    {{#if search}}
    <a href="/web/clients" class="px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-500 hover:bg-gray-50">
      <i class="fas fa-times"></i>
    </a>
    {{/if}}
  </form>
</div>

{{!-- Client List --}}
<div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden mb-6">
  {{#if clients.length}}
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="border-b border-gray-100 bg-gray-50">
        <tr>
          <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Name</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Phone</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide hidden sm:table-cell">Added</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Added By</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        {{#each clients}}
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-5 py-3.5">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                <span class="text-xs font-bold text-blue-600">
                  {{#if this.name}}{{substr this.name 0 1}}{{else}}?{{/if}}
                </span>
              </div>
              <span class="font-medium text-gray-800">
                {{#if this.name}}{{this.name}}{{else}}—{{/if}}
              </span>
            </div>
          </td>
          <td class="px-5 py-3.5 text-gray-600 font-mono text-xs">{{this.phone}}</td>
          <td class="px-5 py-3.5 text-gray-400 text-xs hidden sm:table-cell">{{formatDate this.createdAt}}</td>
          <td class="px-5 py-3.5 text-gray-400 font-mono text-xs hidden md:table-cell">
            {{#if this.createdBy}}{{this.createdBy}}{{else}}<span class="text-gray-300">—</span>{{/if}}
          </td>
          <td class="px-5 py-3.5">
            <div class="flex items-center justify-end gap-2">
              <a href="/web/clients/{{this._id}}"
                class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-blue-600 border border-blue-200 rounded-lg hover:bg-blue-50">
                <i class="fas fa-eye"></i> View
              </a>
              {{#if (or (eq ../user.role 'owner') (eq ../user.role 'manager'))}}
              <button onclick="openEditClient('{{this._id}}','{{escapeJs this.name}}','{{this.phone}}')"
                class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50">
                <i class="fas fa-edit"></i>
              </button>
              {{/if}}
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="text-center py-16">
    <div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <i class="fas fa-users text-gray-400 text-xl"></i>
    </div>
    <p class="text-gray-500 mb-4">
      {{#if search}}No clients match "{{search}}"{{else}}No clients yet{{/if}}
    </p>
    <button onclick="showModal('addModal')"
      class="px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700">
      Add First Client
    </button>
  </div>
  {{/if}}
</div>

{{!-- Pagination --}}
{{#if (gt pagination.totalPages 1)}}
<div class="flex items-center justify-center gap-2">
  {{#if pagination.hasPrev}}
  <a href="?page={{math pagination.currentPage '-' 1}}{{#if search}}&search={{search}}{{/if}}"
     class="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50">
    <i class="fas fa-chevron-left"></i>
  </a>
  {{/if}}
  <span class="px-4 py-2 text-sm text-gray-500">
    {{pagination.currentPage}} / {{pagination.totalPages}}
  </span>
  {{#if pagination.hasNext}}
  <a href="?page={{math pagination.currentPage '+' 1}}{{#if search}}&search={{search}}{{/if}}"
     class="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50">
    <i class="fas fa-chevron-right"></i>
  </a>
  {{/if}}
</div>
{{/if}}

{{!-- Add Client Modal --}}
<div id="addModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-lg font-semibold text-gray-900">Add Client</h3>
      <button onclick="hideModal('addModal')" class="text-gray-400 hover:text-gray-600">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="addClientForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Full Name</label>
        <input type="text" id="addName" placeholder="e.g. Tendai Moyo"
          class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Phone</label>
        <input type="tel" id="addPhone" placeholder="e.g. 0772 123 456"
          class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
      </div>
      <div id="addError" class="hidden text-sm text-red-600 bg-red-50 rounded-lg p-3"></div>
      <div class="flex gap-3 pt-2">
        <button type="submit"
          class="flex-1 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 disabled:opacity-50">
          Add Client
        </button>
        <button type="button" onclick="hideModal('addModal')"
          class="flex-1 py-2.5 border border-gray-200 text-sm text-gray-600 rounded-lg hover:bg-gray-50">
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

{{!-- Edit Client Modal --}}
<div id="editModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-lg font-semibold text-gray-900">Edit Client</h3>
      <button onclick="hideModal('editModal')" class="text-gray-400 hover:text-gray-600">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="editClientForm" class="space-y-4">
      <input type="hidden" id="editId">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Full Name</label>
        <input type="text" id="editName"
          class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Phone</label>
        <input type="tel" id="editPhone"
          class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
      </div>
      <div id="editError" class="hidden text-sm text-red-600 bg-red-50 rounded-lg p-3"></div>
      <div class="flex gap-3 pt-2">
        <button type="submit"
          class="flex-1 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700">
          Save Changes
        </button>
        <button type="button" onclick="hideModal('editModal')"
          class="flex-1 py-2.5 border border-gray-200 text-sm text-gray-600 rounded-lg hover:bg-gray-50">
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<script>
function showModal(id) {
  const el = document.getElementById(id);
  el.classList.remove('hidden');
  el.classList.add('flex');
}
function hideModal(id) {
  const el = document.getElementById(id);
  el.classList.add('hidden');
  el.classList.remove('flex');
}

function openEditClient(id, name, phone) {
  document.getElementById('editId').value = id;
  document.getElementById('editName').value = name;
  document.getElementById('editPhone').value = phone;
  showModal('editModal');
}

// Add Client
document.getElementById('addClientForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('[type=submit]');
  btn.disabled = true;
  const errEl = document.getElementById('addError');
  errEl.classList.add('hidden');

  try {
    const res = await fetch('/web/clients/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: document.getElementById('addName').value,
        phone: document.getElementById('addPhone').value
      })
    });
    const data = await res.json();
    if (data.success) {
      window.location.reload();
    } else {
      errEl.textContent = data.error || 'Failed to add client';
      errEl.classList.remove('hidden');
    }
  } catch (err) {
    errEl.textContent = 'Network error. Try again.';
    errEl.classList.remove('hidden');
  } finally {
    btn.disabled = false;
  }
});

// Edit Client
document.getElementById('editClientForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('editId').value;
  const btn = e.target.querySelector('[type=submit]');
  btn.disabled = true;
  const errEl = document.getElementById('editError');
  errEl.classList.add('hidden');

  try {
    const res = await fetch(`/web/clients/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: document.getElementById('editName').value,
        phone: document.getElementById('editPhone').value
      })
    });
    const data = await res.json();
    if (data.success) {
      window.location.reload();
    } else {
      errEl.textContent = data.error || 'Failed to update client';
      errEl.classList.remove('hidden');
    }
  } catch (err) {
    errEl.textContent = 'Network error. Try again.';
    errEl.classList.remove('hidden');
  } finally {
    btn.disabled = false;
  }
});
</script>
