<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify OTP - ZimQuote</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gradient-to-br from-blue-50 to-blue-100 min-h-screen flex items-center justify-center p-4">
  
  <div class="w-full max-w-md">
    
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-600 rounded-full mb-4">
        <i class="fas fa-shield-alt text-white text-2xl"></i>
      </div>
      <h1 class="text-3xl font-bold text-gray-800">Verify Your Number</h1>
      <p class="text-gray-600 mt-2">Enter the 6-digit code sent to your WhatsApp</p>
    </div>
    
    <!-- OTP Card -->
    <div class="bg-white rounded-2xl shadow-xl p-8">
      
      <!-- Phone Display -->
      <div class="mb-6 p-4 bg-gray-50 rounded-lg text-center">
        <p class="text-sm text-gray-600 mb-1">Code sent to</p>
        <p class="text-lg font-medium text-gray-800">
          <i class="fab fa-whatsapp text-green-500 mr-1"></i>
          {{phone}}
        </p>
      </div>
      
      {{#if error}}
        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm text-red-700">{{error}}</p>
        </div>
      {{/if}}
      
      <form id="otpForm">
        
        <!-- OTP Input -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-3 text-center">
            Enter 6-Digit Code
          </label>
          
          <div class="flex justify-center space-x-2">
            <input type="text" maxlength="1" class="otp-input w-12 h-14 text-center text-2xl font-bold border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200" data-index="0">
            <input type="text" maxlength="1" class="otp-input w-12 h-14 text-center text-2xl font-bold border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200" data-index="1">
            <input type="text" maxlength="1" class="otp-input w-12 h-14 text-center text-2xl font-bold border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200" data-index="2">
            <input type="text" maxlength="1" class="otp-input w-12 h-14 text-center text-2xl font-bold border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200" data-index="3">
            <input type="text" maxlength="1" class="otp-input w-12 h-14 text-center text-2xl font-bold border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200" data-index="4">
            <input type="text" maxlength="1" class="otp-input w-12 h-14 text-center text-2xl font-bold border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200" data-index="5">
          </div>
        </div>
        
        <!-- Submit Button -->
        <button 
          type="submit" 
          id="submitBtn"
          class="w-full bg-blue-600 text-white py-3 rounded-lg font-medium hover:bg-blue-700 active:scale-95 disabled:opacity-50"
        >
          <span id="btnText">
            <i class="fas fa-check mr-2"></i> Verify & Login
          </span>
          <span id="btnLoader" class="hidden">
            <i class="fas fa-spinner fa-spin mr-2"></i> Verifying...
          </span>
        </button>
        
      </form>
      
      <!-- Resend -->
      <div class="mt-6 text-center">
        <p class="text-sm text-gray-600">
          Didn't receive the code?
          <button id="resendBtn" class="text-blue-600 hover:underline font-medium">
            Resend OTP
          </button>
        </p>
        <p id="timer" class="text-xs text-gray-500 mt-2"></p>
      </div>
      
      <!-- Back -->
      <div class="mt-4 text-center">
        <a href="/web/login" class="text-sm text-gray-500 hover:text-gray-700">
          <i class="fas fa-arrow-left mr-1"></i> Back to login
        </a>
      </div>
      
    </div>
    
  </div>
  
  <script>
    const otpInputs = document.querySelectorAll('.otp-input');
    const form = document.getElementById('otpForm');
    const submitBtn = document.getElementById('submitBtn');
    const btnText = document.getElementById('btnText');
    const btnLoader = document.getElementById('btnLoader');
    const resendBtn = document.getElementById('resendBtn');
    const timerEl = document.getElementById('timer');
    
    const phone = '{{phone}}';
    
    // OTP input handling
    otpInputs.forEach((input, index) => {
      input.addEventListener('input', (e) => {
        const value = e.target.value;
        
        if (value && index < otpInputs.length - 1) {
          otpInputs[index + 1].focus();
        }
        
        // Auto-submit when all filled
        if (index === otpInputs.length - 1 && value) {
          const code = Array.from(otpInputs).map(i => i.value).join('');
          if (code.length === 6) {
            form.dispatchEvent(new Event('submit'));
          }
        }
      });
      
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && !e.target.value && index > 0) {
          otpInputs[index - 1].focus();
        }
      });
      
      // Paste handling
      input.addEventListener('paste', (e) => {
        e.preventDefault();
        const pastedData = e.clipboardData.getData('text').replace(/\D/g, '');
        
        pastedData.split('').forEach((char, i) => {
          if (i < otpInputs.length) {
            otpInputs[i].value = char;
          }
        });
        
        if (pastedData.length === 6) {
          form.dispatchEvent(new Event('submit'));
        }
      });
    });
    
    // Focus first input
    otpInputs[0].focus();
    
    // Form submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const code = Array.from(otpInputs).map(i => i.value).join('');
      
      if (code.length !== 6) {
        alert('Please enter the complete 6-digit code');
        return;
      }
      
      submitBtn.disabled = true;
      btnText.classList.add('hidden');
      btnLoader.classList.remove('hidden');
      
      try {
        const response = await fetch('/web/auth/verify-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone, code })
        });
        
        const data = await response.json();
        
        if (response.ok) {
          window.location.href = data.redirectUrl || '/web/dashboard';
        } else {
          alert(data.error || 'Invalid code. Please try again.');
          otpInputs.forEach(input => input.value = '');
          otpInputs[0].focus();
          submitBtn.disabled = false;
          btnText.classList.remove('hidden');
          btnLoader.classList.add('hidden');
        }
        
      } catch (error) {
        console.error('Error:', error);
        alert('Network error. Please try again.');
        submitBtn.disabled = false;
        btnText.classList.remove('hidden');
        btnLoader.classList.add('hidden');
      }
    });
    
    // Resend OTP
    let countdown = 60;
    const startTimer = () => {
      resendBtn.disabled = true;
      resendBtn.classList.add('opacity-50', 'cursor-not-allowed');
      
      const interval = setInterval(() => {
        countdown--;
        timerEl.textContent = `Resend available in ${countdown}s`;
        
        if (countdown <= 0) {
          clearInterval(interval);
          resendBtn.disabled = false;
          resendBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          timerEl.textContent = '';
          countdown = 60;
        }
      }, 1000);
    };
    
    startTimer();
    
    resendBtn.addEventListener('click', async () => {
      try {
        const response = await fetch('/web/auth/request-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone })
        });
        
        if (response.ok) {
          alert('New code sent!');
          startTimer();
        } else {
          alert('Failed to resend code. Please try again.');
        }
      } catch (error) {
        alert('Network error. Please try again.');
      }
    });
  </script>
</body>
</html>