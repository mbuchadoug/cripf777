<!-- Page Header -->
<div class="flex items-center mb-6">
  <a href="/web/clients" class="mr-4 text-gray-600 hover:text-gray-800">
    <i class="fas fa-arrow-left text-xl"></i>
  </a>
  <div>
    <h1 class="text-2xl font-bold text-gray-800">{{client.name}}</h1>
    <p class="text-sm text-gray-600">Client Profile</p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  
  <!-- Client Info -->
  <div class="space-y-6">
    
    <!-- Contact Card -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <div class="flex items-center space-x-4 mb-6">
        <div class="h-16 w-16 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
          <i class="fas fa-user text-blue-600 text-2xl"></i>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-800">{{client.name}}</h2>
          {{#if client.phone}}
            <p class="text-sm text-gray-600 mt-1">
              <i class="fas fa-phone mr-1"></i> {{client.phone}}
            </p>
          {{/if}}
        </div>
      </div>
      
      <div class="space-y-3 text-sm">
        <div class="flex justify-between py-2 border-b">
          <span class="text-gray-600">Client Since</span>
          <span class="font-medium">{{formatDate client.createdAt}}</span>
        </div>
      </div>
    </div>
    
    <!-- Financial Summary -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h3 class="font-semibold text-gray-800 mb-4">Financial Summary</h3>
      
      <div class="space-y-4">
        <div>
          <p class="text-sm text-gray-600 mb-1">Total Invoiced</p>
          <p class="text-2xl font-bold text-gray-800">{{user.currency}} {{totals.totalInvoiced}}</p>
        </div>
        
        <div>
          <p class="text-sm text-gray-600 mb-1">Total Paid</p>
          <p class="text-xl font-semibold text-green-600">{{user.currency}} {{totals.totalPaid}}</p>
        </div>
        
        <div class="pt-3 border-t">
          <p class="text-sm text-gray-600 mb-1">Outstanding Balance</p>
          <p class="text-xl font-semibold {{#if (gt totals.totalBalance 0)}}text-red-600{{else}}text-gray-800{{/if}}">
            {{user.currency}} {{totals.totalBalance}}
          </p>
        </div>
      </div>
    </div>
    
  </div>
  
  <!-- Invoice History -->
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h3 class="font-semibold text-gray-800 mb-4">Recent Invoices</h3>
      
      {{#if invoices.length}}
        <!-- Desktop Table -->
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Invoice #</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              {{#each invoices}}
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3">
                    <a href="/web/invoices/{{this._id}}" class="font-medium text-blue-600 hover:underline">
                      {{this.number}}
                    </a>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-600">{{formatDate this.createdAt}}</td>
                  <td class="px-4 py-3 text-sm font-medium text-gray-800 text-right">{{this.currency}} {{this.total}}</td>
                  <td class="px-4 py-3">
                    <span class="inline-block px-3 py-1 text-xs font-medium rounded-full {{#if (eq this.status 'paid')}}bg-green-100 text-green-800{{else if (eq this.status 'partial')}}bg-yellow-100 text-yellow-800{{else}}bg-red-100 text-red-800{{/if}}">
                      {{this.status}}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-right">
                    <a href="/web/invoices/{{this._id}}" class="text-blue-600 hover:text-blue-700">
                      <i class="fas fa-eye"></i>
                    </a>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        
        <!-- Mobile Cards -->
        <div class="md:hidden space-y-3">
          {{#each invoices}}
            <div class="border border-gray-200 rounded-lg p-4" onclick="window.location.href='/web/invoices/{{this._id}}'">
              <div class="flex items-center justify-between mb-2">
                <span class="font-medium text-blue-600">{{this.number}}</span>
                <span class="inline-block px-3 py-1 text-xs font-medium rounded-full {{#if (eq this.status 'paid')}}bg-green-100 text-green-800{{else if (eq this.status 'partial')}}bg-yellow-100 text-yellow-800{{else}}bg-red-100 text-red-800{{/if}}">
                  {{this.status}}
                </span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-600">{{formatDate this.createdAt}}</span>
                <span class="font-semibold">{{this.currency}} {{this.total}}</span>
              </div>
            </div>
          {{/each}}
        </div>
        
        <div class="mt-4 text-center">
          <a href="/web/invoices?client={{client._id}}" class="text-sm text-blue-600 hover:underline">
            View All Invoices <i class="fas fa-arrow-right ml-1"></i>
          </a>
        </div>
      {{else}}
        <div class="text-center py-12">
          <i class="fas fa-file-invoice text-4xl text-gray-300 mb-4"></i>
          <p class="text-gray-500 mb-4">No invoices yet</p>
          <a href="/web/invoices/create?client={{client._id}}" class="inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
            Create Invoice
          </a>
        </div>
      {{/if}}
    </div>
  </div>
  
</div>