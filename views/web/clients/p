<div class="page-header">
  <div>
    <div class="page-title">{{#if client.name}}{{client.name}}{{else}}{{client.phone}}{{/if}}</div>
    <div class="page-subtitle">Client profile and recent invoices</div>
  </div>
  <div class="page-actions">
    <a href="/web/clients" class="btn btn-ghost"><i class="fas fa-arrow-left"></i> Back</a>
    <a href="/web/invoices/create" class="btn btn-primary"><i class="fas fa-plus"></i> New Invoice</a>
  </div>
</div>

<div class="grid-3" style="margin-bottom:18px;">
  <div class="stat-card amber">
    <div class="stat-icon amber"><i class="fas fa-file-invoice"></i></div>
    <div class="stat-value">{{user.currency}} {{totals.totalInvoiced}}</div>
    <div class="stat-label">Total Invoiced</div>
  </div>

  <div class="stat-card green">
    <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
    <div class="stat-value">{{user.currency}} {{totals.totalPaid}}</div>
    <div class="stat-label">Total Paid</div>
  </div>

  <div class="stat-card red">
    <div class="stat-icon red"><i class="fas fa-exclamation-circle"></i></div>
    <div class="stat-value">{{user.currency}} {{totals.totalBalance}}</div>
    <div class="stat-label">Outstanding Balance</div>
  </div>
</div>

<div class="card" style="margin-bottom:18px;">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-id-card"></i> Details</div>
  </div>
  <div class="card-body">
    <div class="grid-2">
      <div>
        <div class="form-label" style="margin-bottom:6px;">Name</div>
        <div class="td-primary">{{#if client.name}}{{client.name}}{{else}}—{{/if}}</div>
      </div>
      <div>
        <div class="form-label" style="margin-bottom:6px;">Phone</div>
        <div class="td-primary td-mono">{{#if client.phone}}{{client.phone}}{{else}}—{{/if}}</div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-clock"></i> Recent Invoices</div>
    <a class="btn btn-ghost btn-sm" href="/web/invoices?search={{client.name}}">
      <i class="fas fa-external-link-alt"></i> View All
    </a>
  </div>

  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Invoice #</th>
          <th>Date</th>
          <th style="text-align:right">Total</th>
          <th style="text-align:right">Paid</th>
          <th style="text-align:right">Balance</th>
          <th>Status</th>
          <th style="text-align:right">Action</th>
        </tr>
      </thead>
      <tbody>
        {{#each invoices}}
          <tr onclick="window.location.href='/web/invoices/{{this._id}}'">
            <td><span class="td-primary td-mono">{{this.number}}</span></td>
            <td><span class="td-mono" style="font-size:12px">{{formatDate this.createdAt}}</span></td>
            <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.total}}</span></td>
            <td style="text-align:right"><span class="td-mono">{{../user.currency}} {{this.amountPaid}}</span></td>
            <td style="text-align:right"><span class="td-primary td-mono">{{../user.currency}} {{this.balance}}</span></td>
            <td>
              {{#if (eq this.status 'paid')}}<span class="badge badge-green">Paid</span>{{/if}}
              {{#if (eq this.status 'partial')}}<span class="badge badge-amber">Partial</span>{{/if}}
              {{#if (eq this.status 'unpaid')}}<span class="badge badge-red">Unpaid</span>{{/if}}
            </td>
            <td style="text-align:right" onclick="event.stopPropagation()">
              <a class="btn btn-ghost btn-icon btn-sm" href="/web/invoices/{{this._id}}" title="View">
                <i class="fas fa-eye"></i>
              </a>
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="7">
              <div class="empty-state">
                <i class="fas fa-file-invoice"></i>
                <h3>No invoices for this client yet</h3>
                <p>Create an invoice to start tracking payments.</p>
                <a href="/web/invoices/create" class="btn btn-primary"><i class="fas fa-plus"></i> New Invoice</a>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>