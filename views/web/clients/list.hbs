<!-- Page Header -->
<div class="page-header">
  <div>
    <div class="page-title">Clients</div>
    <div class="page-subtitle">Manage your customer list</div>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal('createClientModal')">
      <i class="fas fa-plus"></i> New Client
    </button>
  </div>
</div>

<!-- Filters -->
<div class="filters-bar no-print">
  <form method="GET" style="display:contents">
    <div class="filter-group">
      <label class="filter-label">Search</label>
      <input
        type="text"
        name="search"
        placeholder="Client name or phone…"
        class="form-input"
        style="padding:9px 12px;font-size:13px;"
        value="{{search}}"
      >
    </div>

    <div style="display:flex;gap:8px;align-items:flex-end;padding-bottom:1px">
      <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search"></i> Search</button>
      <a href="/web/clients" class="btn btn-ghost btn-sm"><i class="fas fa-redo"></i> Reset</a>
    </div>
  </form>
</div>

<!-- List -->
<div class="card">
  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Client</th>
          <th>Phone</th>
          <th style="text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each clients}}
          <tr onclick="window.location.href='/web/clients/{{this._id}}'">
            <td>
              <span class="td-primary">{{#if this.name}}{{this.name}}{{else}}Unknown{{/if}}</span>
            </td>
            <td>
              <span class="td-mono">{{#if this.phone}}{{this.phone}}{{else}}-{{/if}}</span>
            </td>
            <td style="text-align:right" onclick="event.stopPropagation()">
              <div class="td-actions" style="justify-content:flex-end">
                <a href="/web/clients/{{this._id}}" class="btn btn-ghost btn-icon btn-sm" title="View">
                  <i class="fas fa-eye"></i>
                </a>
              </div>
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="3">
              <div class="empty-state">
                <i class="fas fa-users"></i>
                <h3>No clients yet</h3>
                <p>Create your first client to start invoicing.</p>
                <button class="btn btn-primary" onclick="openModal('createClientModal')">
                  <i class="fas fa-plus"></i> New Client
                </button>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
{{#if (gt pagination.totalPages 1)}}
  <div class="pagination">
    {{#if pagination.hasPrev}}
      <a href="?page={{math pagination.currentPage '-' 1}}{{#if search}}&search={{search}}{{/if}}">
        <i class="fas fa-chevron-left"></i>
      </a>
    {{/if}}
    <span class="page-info">{{pagination.currentPage}} / {{pagination.totalPages}}</span>
    {{#if pagination.hasNext}}
      <a href="?page={{math pagination.currentPage '+' 1}}{{#if search}}&search={{search}}{{/if}}">
        <i class="fas fa-chevron-right"></i>
      </a>
    {{/if}}
  </div>
{{/if}}

<!-- Create Client Modal -->
<div class="modal-backdrop" id="createClientModal">
  <div class="modal" style="max-width:520px">
    <div class="modal-header">
      <div class="modal-title"><i class="fas fa-user-plus"></i> New Client</div>
      <button class="modal-close" onclick="closeModal('createClientModal')"><i class="fas fa-times"></i></button>
    </div>

    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Name</label>
        <input id="cName" class="form-input" placeholder="Client name (optional)">
      </div>

      <div class="form-group">
        <label class="form-label">Phone</label>
        <input id="cPhone" class="form-input" placeholder="0772 123 456 (optional)">
        <div class="form-hint">You can save either a name, a phone, or both.</div>
      </div>
    </div>

    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('createClientModal')">Cancel</button>
      <button class="btn btn-primary" id="createClientBtn" onclick="createClient()">
        <i class="fas fa-save"></i> Save Client
      </button>
    </div>
  </div>
</div>

<script>
  async function createClient() {
    const name = document.getElementById('cName').value.trim();
    const phone = document.getElementById('cPhone').value.trim();

    if (!name && !phone) return showToast('Enter a name or phone number', 'error');

    const btn = document.getElementById('createClientBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Saving…';

    try {
      const r = await fetch('/web/clients/create', {
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ name, phone })
      });

      const d = await r.json();
      if (!r.ok) {
        showToast(d.error || 'Failed to create client', 'error');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Save Client';
        return;
      }

      showToast('Client created', 'success');
      closeModal('createClientModal');
      setTimeout(()=>window.location.reload(), 650);
    } catch {
      showToast('Network error', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save"></i> Save Client';
    }
  }
</script>