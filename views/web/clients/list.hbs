<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800 mb-2">Clients</h1>
    <p class="text-sm text-gray-600">Manage your customer database</p>
  </div>
  <button onclick="showAddClientModal()" class="mt-4 sm:mt-0 inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 active:scale-95">
    <i class="fas fa-plus mr-2"></i>
    Add Client
  </button>
</div>

<!-- Search Bar -->
<div class="bg-white rounded-xl shadow-sm p-4 mb-6">
  <form method="GET" class="flex items-center space-x-4">
    <div class="flex-1">
      <input 
        type="text" 
        name="search" 
        placeholder="Search by name or phone..."
        value="{{search}}"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
      >
    </div>
    <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
      <i class="fas fa-search"></i>
    </button>
    {{#if search}}
      <a href="/web/clients" class="px-4 py-2 text-gray-600 hover:text-gray-800">
        <i class="fas fa-times"></i>
      </a>
    {{/if}}
  </form>
</div>

<!-- Clients Grid (Desktop) -->
<div class="hidden md:grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {{#each clients}}
    <div class="bg-white rounded-xl shadow-sm p-6 hover:shadow-md transition-shadow cursor-pointer" onclick="window.location.href='/web/clients/{{this._id}}'">
      <div class="flex items-start space-x-4">
        <div class="h-12 w-12 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
          <i class="fas fa-user text-blue-600 text-xl"></i>
        </div>
        
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-gray-800 text-lg truncate">
            {{#if this.name}}{{this.name}}{{else}}{{this.phone}}{{/if}}
          </h3>
          
          {{#if this.phone}}
            <p class="text-sm text-gray-500 mt-1">
              <i class="fas fa-phone mr-1"></i> {{this.phone}}
            </p>
          {{/if}}
          
          <div class="flex items-center mt-3 text-xs text-gray-500">
            <i class="fas fa-calendar mr-1"></i>
            Added {{formatDate this.createdAt}}
          </div>
        </div>
      </div>
      
      <div class="mt-4 pt-4 border-t flex items-center justify-between">
        <span class="text-sm text-gray-600">View Profile</span>
        <i class="fas fa-arrow-right text-gray-400"></i>
      </div>
    </div>
  {{else}}
    <div class="col-span-full bg-white rounded-xl shadow-sm p-12 text-center">
      <i class="fas fa-users text-4xl text-gray-300 mb-4"></i>
      <p class="text-gray-500 mb-4">No clients found</p>
      <button onclick="showAddClientModal()" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        <i class="fas fa-plus mr-2"></i> Add Your First Client
      </button>
    </div>
  {{/each}}
</div>

<!-- Clients List (Mobile) -->
<div class="md:hidden space-y-4">
  {{#each clients}}
    <div class="bg-white rounded-xl shadow-sm p-4" onclick="window.location.href='/web/clients/{{this._id}}'">
      <div class="flex items-center space-x-3 mb-3">
        <div class="h-10 w-10 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
          <i class="fas fa-user text-blue-600"></i>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-gray-800 truncate">
            {{#if this.name}}{{this.name}}{{else}}{{this.phone}}{{/if}}
          </h3>
          {{#if this.phone}}
            <p class="text-xs text-gray-500">{{this.phone}}</p>
          {{/if}}
        </div>
      </div>
      
      <div class="flex items-center justify-between pt-3 border-t">
        <span class="text-xs text-gray-500">{{formatDate this.createdAt}}</span>
        <span class="text-sm text-blue-600">View Profile <i class="fas fa-arrow-right ml-1"></i></span>
      </div>
    </div>
  {{else}}
    <div class="bg-white rounded-xl shadow-sm p-12 text-center">
      <i class="fas fa-users text-4xl text-gray-300 mb-4"></i>
      <p class="text-gray-500 mb-4">No clients found</p>
      <button onclick="showAddClientModal()" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        Add Client
      </button>
    </div>
  {{/each}}
</div>

<!-- Pagination -->
{{#if (gt pagination.totalPages 1)}}
  <div class="flex items-center justify-center space-x-2 mt-6">
    {{#if pagination.hasPrev}}
      <a href="?page={{math pagination.currentPage '-' 1}}{{#if search}}&search={{search}}{{/if}}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
        <i class="fas fa-chevron-left"></i>
      </a>
    {{/if}}
    
    <span class="px-4 py-2 text-sm text-gray-600">
      Page {{pagination.currentPage}} of {{pagination.totalPages}}
    </span>
    
    {{#if pagination.hasNext}}
      <a href="?page={{math pagination.currentPage '+' 1}}{{#if search}}&search={{search}}{{/if}}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
        <i class="fas fa-chevron-right"></i>
      </a>
    {{/if}}
  </div>
{{/if}}

<!-- Add Client Modal -->
<div id="clientModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center p-4">
  <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-gray-800">Add Client</h3>
      <button onclick="hideClientModal()" class="text-gray-400 hover:text-gray-600">
        <i class="fas fa-times"></i>
      </button>
    </div>
    
    <form id="clientForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Client Name</label>
        <input type="text" id="clientName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
        <input type="tel" id="clientPhone" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
      </div>
      
      <div class="flex space-x-3 pt-4">
        <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
          <i class="fas fa-check mr-2"></i> Add Client
        </button>
        <button type="button" onclick="hideClientModal()" class="flex-1 border border-gray-300 py-2 rounded-lg hover:bg-gray-50">
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function showAddClientModal() {
    document.getElementById('clientModal').classList.remove('hidden');
    document.getElementById('clientModal').classList.add('flex');
  }
  
  function hideClientModal() {
    document.getElementById('clientModal').classList.add('hidden');
    document.getElementById('clientModal').classList.remove('flex');
    document.getElementById('clientForm').reset();
  }
  
  document.getElementById('clientForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const name = document.getElementById('clientName').value;
    const phone = document.getElementById('clientPhone').value;
    
    try {
      const response = await fetch('/web/clients/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone })
      });
      
      if (response.ok) {
        window.location.reload();
      } else {
        const data = await response.json();
        alert(data.error || 'Failed to add client');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Failed to add client');
    }
  });
</script>