<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In - ZimQuote</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy:#0d1117; --navy-2:#161b22; --navy-3:#1f2937;
      --amber:#f59e0b; --amber-d:#d97706; --amber-g:rgba(245,158,11,0.10);
      --white:#f8fafc; --muted:#8b949e; --muted-2:#6e7681;
      --border:rgba(255,255,255,0.07); --border-2:rgba(255,255,255,0.04);
      --red:#f85149; --green:#3fb950;
    }
    html,body { height:100%; background:var(--navy); color:var(--white); font-family:"Instrument Sans",sans-serif; -webkit-font-smoothing:antialiased; }
    .shell { display:grid; grid-template-columns:1fr 460px; min-height:100vh; }

    /* LEFT */
    .left { position:relative; display:flex; flex-direction:column; justify-content:space-between; padding:48px 56px; background:var(--navy-2); border-right:1px solid var(--border); overflow:hidden; }
    .left::before { content:""; position:absolute; top:-140px; left:-140px; width:500px; height:500px; border-radius:50%; background:radial-gradient(circle,rgba(245,158,11,.07) 0%,transparent 70%); pointer-events:none; }
    .left::after  { content:""; position:absolute; bottom:-100px; right:-100px; width:380px; height:380px; border-radius:50%; background:radial-gradient(circle,rgba(59,130,246,.05) 0%,transparent 70%); pointer-events:none; }
    .grid-lines { position:absolute; inset:0; background-image:linear-gradient(var(--border-2) 1px,transparent 1px),linear-gradient(90deg,var(--border-2) 1px,transparent 1px); background-size:56px 56px; pointer-events:none; z-index:0; }
    .brand-mark { display:flex; align-items:center; gap:12px; position:relative; z-index:1; }
    .brand-icon { width:38px; height:38px; background:var(--amber); border-radius:9px; display:flex; align-items:center; justify-content:center; }
    .brand-icon svg { width:18px; height:18px; color:var(--navy); }
    .brand-name { font-family:"Syne",sans-serif; font-size:18px; font-weight:800; letter-spacing:-0.3px; color:var(--white); }
    .hero-content { position:relative; z-index:1; }
    .hero-tag { display:inline-flex; align-items:center; gap:6px; background:var(--amber-g); border:1px solid rgba(245,158,11,.22); color:var(--amber); font-size:10px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; padding:5px 12px; border-radius:20px; margin-bottom:22px; }
    .hero-tag::before { content:""; width:5px; height:5px; background:var(--amber); border-radius:50%; animation:pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }
    .hero-title { font-family:"Syne",sans-serif; font-size:clamp(30px,3vw,46px); font-weight:800; line-height:1.1; letter-spacing:-1.5px; color:var(--white); margin-bottom:18px; }
    .hero-title span { color:var(--amber); }
    .hero-desc { font-size:14px; color:var(--muted); line-height:1.7; max-width:400px; margin-bottom:36px; }
    .stats-row { display:flex; gap:28px; }
    .stat-num { font-family:"DM Mono",monospace; font-size:20px; font-weight:500; color:var(--white); letter-spacing:-0.5px; }
    .stat-label { font-size:10px; color:var(--muted-2); margin-top:2px; text-transform:uppercase; letter-spacing:.8px; }
    .left-footer { position:relative; z-index:1; display:flex; align-items:center; gap:18px; }
    .left-footer a { font-size:11px; color:var(--muted-2); text-decoration:none; transition:color .2s; }
    .left-footer a:hover { color:var(--muted); }

    /* RIGHT */
    .right { display:flex; flex-direction:column; justify-content:center; padding:52px 44px; background:var(--navy); }
    .form-header { margin-bottom:32px; }
    .form-header h2 { font-family:"Syne",sans-serif; font-size:26px; font-weight:800; letter-spacing:-0.7px; color:var(--white); margin-bottom:6px; }
    .form-header p { font-size:13px; color:var(--muted); line-height:1.5; }

    /* STEPS */
    .steps { display:flex; align-items:center; margin-bottom:28px; }
    .step { display:flex; align-items:center; gap:8px; flex:1; }
    .step-dot { width:26px; height:26px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; font-family:"DM Mono",monospace; flex-shrink:0; transition:all .3s; }
    .step.active  .step-dot { background:var(--amber); color:var(--navy); }
    .step.inactive .step-dot { background:var(--navy-3); color:var(--muted-2); border:1px solid var(--border); }
    .step.done    .step-dot { background:var(--green); color:var(--navy); }
    .step-label { font-size:11px; font-weight:500; color:var(--muted-2); }
    .step.active .step-label { color:var(--white); }
    .step-line { height:1px; background:var(--border); flex:1; margin:0 10px; }

    /* ALERTS */
    .alert-err { display:flex; align-items:flex-start; gap:10px; background:rgba(248,81,73,.08); border:1px solid rgba(248,81,73,.2); border-radius:9px; padding:12px 14px; margin-bottom:20px; font-size:12px; color:#fca5a5; line-height:1.5; animation:slide .3s ease; }
    .alert-err::before { content:"\26A0"; font-size:13px; flex-shrink:0; margin-top:1px; }
    @keyframes slide { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }

    /* FORM */
    .form-group { margin-bottom:18px; }
    .form-label { display:block; font-size:11px; font-weight:700; color:var(--muted); letter-spacing:.7px; text-transform:uppercase; margin-bottom:7px; }
    .input-wrap { position:relative; }
    .input-prefix { position:absolute; left:14px; top:50%; transform:translateY(-50%); font-family:"DM Mono",monospace; font-size:13px; color:var(--amber); font-weight:500; pointer-events:none; user-select:none; }
    .form-input { width:100%; background:var(--navy-2); border:1px solid var(--border); border-radius:9px; padding:13px 14px 13px 50px; font-size:15px; font-family:"DM Mono",monospace; font-weight:500; color:var(--white); outline:none; transition:all .2s; letter-spacing:.5px; }
    .form-input::placeholder { color:var(--muted-2); letter-spacing:0; font-family:"Instrument Sans",sans-serif; }
    .form-input:focus { border-color:var(--amber); background:var(--navy-3); box-shadow:0 0 0 3px var(--amber-g); }
    .form-hint { font-size:11px; color:var(--muted-2); margin-top:5px; }

    /* BUTTONS */
    .btn-primary { width:100%; padding:14px 20px; background:var(--amber); color:var(--navy); border:none; border-radius:9px; font-family:"Syne",sans-serif; font-size:14px; font-weight:700; cursor:pointer; transition:all .2s; display:flex; align-items:center; justify-content:center; gap:8px; position:relative; overflow:hidden; }
    .btn-primary::before { content:""; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,255,255,.1) 0%,transparent 50%); }
    .btn-primary:hover { background:var(--amber-d); transform:translateY(-1px); box-shadow:0 6px 20px rgba(245,158,11,.3); }
    .btn-primary:active { transform:translateY(0); }
    .btn-primary:disabled { opacity:.5; cursor:not-allowed; transform:none; box-shadow:none; }
    .btn-ghost { width:100%; padding:12px 20px; background:transparent; color:var(--muted); border:1px solid var(--border); border-radius:9px; font-family:"Instrument Sans",sans-serif; font-size:13px; font-weight:500; cursor:pointer; transition:all .2s; margin-top:10px; }
    .btn-ghost:hover { border-color:rgba(255,255,255,.14); color:var(--white); }
    .spinner { width:16px; height:16px; border:2px solid rgba(13,17,23,.3); border-top-color:var(--navy); border-radius:50%; animation:spin .6s linear infinite; }
    @keyframes spin { to{transform:rotate(360deg)} }

    /* OTP BOXES - fixed compact height, no aspect-ratio */
    .otp-grid { display:flex; gap:8px; margin-bottom:8px; }
    .otp-box { flex:1; min-width:0; height:50px; background:var(--navy-2); border:1px solid var(--border); border-radius:9px; font-family:"DM Mono",monospace; font-size:18px; font-weight:500; color:var(--white); text-align:center; outline:none; transition:all .2s; caret-color:var(--amber); padding:0; }
    .otp-box:focus { border-color:var(--amber); background:var(--navy-3); box-shadow:0 0 0 3px var(--amber-g); }
    .otp-box.filled { border-color:rgba(245,158,11,.35); color:var(--amber); }

    /* PHONE DISPLAY */
    .phone-display { display:flex; align-items:center; justify-content:space-between; background:var(--navy-2); border:1px solid var(--border); border-radius:9px; padding:12px 14px; margin-bottom:20px; }
    .phone-display .num { font-family:"DM Mono",monospace; font-size:14px; font-weight:500; color:var(--white); letter-spacing:.8px; }
    .phone-display button { background:none; border:none; color:var(--amber); font-size:12px; font-weight:600; cursor:pointer; font-family:"Instrument Sans",sans-serif; }
    .phone-display button:hover { text-decoration:underline; }
    .resend-row { display:flex; align-items:center; justify-content:space-between; margin-top:12px; }
    .timer-label { font-size:11px; color:var(--muted-2); font-family:"DM Mono",monospace; }
    .resend-btn { background:none; border:none; font-size:12px; font-weight:600; cursor:pointer; font-family:"Instrument Sans",sans-serif; color:var(--muted-2); transition:color .2s; }
    .resend-btn.active { color:var(--amber); }
    .resend-btn.active:hover { text-decoration:underline; }
    .success-badge { display:flex; align-items:center; gap:8px; background:rgba(63,185,80,.07); border:1px solid rgba(63,185,80,.18); border-radius:8px; padding:10px 14px; font-size:12px; color:#7ee787; margin-bottom:16px; animation:slide .3s ease; }
    .divider { display:flex; align-items:center; gap:10px; margin:20px 0; }
    .divider::before,.divider::after { content:""; flex:1; height:1px; background:var(--border); }
    .divider span { font-size:10px; color:var(--muted-2); text-transform:uppercase; letter-spacing:1px; white-space:nowrap; }
    .form-footer { margin-top:24px; text-align:center; }
    .form-footer p { font-size:12px; color:var(--muted-2); }
    .form-footer a { color:var(--amber); text-decoration:none; font-weight:600; }

    #panelPhone { display:block; }
    #panelOtp   { display:none; }

    @media (max-width:900px) { .shell{grid-template-columns:1fr} .left{display:none} .right{padding:36px 28px} }
    @media (max-width:480px) { .right{padding:28px 18px} .otp-grid{gap:6px} .otp-box{height:44px;font-size:16px} }
  </style>
</head>
<body>
<div class="shell">
  <div class="left">
    <div class="grid-lines"></div>
    <div class="brand-mark">
      <div class="brand-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      </div>
      <span class="brand-name">ZimQuote</span>
    </div>
    <div class="hero-content">
      <div class="hero-tag">Business Management Platform</div>
      <h1 class="hero-title">Run your business<br><span>with precision.</span></h1>
      <p class="hero-desc">Create invoices, track payments, manage branches, and generate professional reports — built for Zimbabwean businesses.</p>
      <div class="stats-row">
        <div><div class="stat-num">3.2k+</div><div class="stat-label">Invoices Sent</div></div>
        <div><div class="stat-num">$1.4M</div><div class="stat-label">Revenue Tracked</div></div>
        <div><div class="stat-num">99.9%</div><div class="stat-label">Uptime</div></div>
      </div>
    </div>
    <div class="left-footer"><a href="#">Privacy</a><a href="#">Terms</a><a href="#">Support</a></div>
  </div>

  <div class="right">
    <div class="form-header">
      <h2>Welcome back</h2>
      <p>Sign in with your registered WhatsApp number to continue.</p>
    </div>
    <div class="steps">
      <div class="step active" id="step1"><div class="step-dot">01</div><span class="step-label">Phone</span></div>
      <div class="step-line"></div>
      <div class="step inactive" id="step2"><div class="step-dot">02</div><span class="step-label">Verify</span></div>
    </div>
    {{#if error}}
    <div class="alert-err">
      {{#if (eq error "auth_required")}}Please sign in to continue.
      {{else if (eq error "session_expired")}}Your session expired. Please sign in again.
      {{else if (eq error "account_not_found")}}No account found for this number.
      {{else}}Something went wrong. Please try again.
      {{/if}}
    </div>
    {{/if}}
    <div id="errorAlert" class="alert-err" style="display:none;"></div>

    <div id="panelPhone">
      <div class="form-group">
        <label class="form-label">WhatsApp Number</label>
        <div class="input-wrap">
          <span class="input-prefix">+263</span>
          <input type="tel" id="phoneInput" class="form-input" placeholder="77 123 4567" maxlength="13" inputmode="numeric" autocomplete="tel">
        </div>
        <div class="form-hint">Enter the number registered on your WhatsApp account.</div>
      </div>
      <button class="btn-primary" id="sendOtpBtn" onclick="sendOtp()">
        <span id="sendBtnText">Send Verification Code</span>
        <div class="spinner" id="sendSpinner" style="display:none;"></div>
      </button>
      <div class="divider"><span>New to ZimQuote?</span></div>
      <p style="text-align:center;font-size:12px;color:var(--muted-2);line-height:1.6;">Message <strong style="color:var(--white);">JOIN</strong> to our WhatsApp number to create an account.</p>
    </div>

    <div id="panelOtp">
      <div class="success-badge" id="otpSentBadge" style="display:none;">&#10003; Code sent — check your WhatsApp messages</div>
      <div class="phone-display">
        <span class="num" id="displayPhone">+263 —</span>
        <button onclick="goBack()">Change</button>
      </div>
      <div class="form-group">
        <label class="form-label">6-Digit Verification Code</label>
        <div class="otp-grid" id="otpGrid">
          <input class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
          <input class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
          <input class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
          <input class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
          <input class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
          <input class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
        </div>
        <div class="resend-row">
          <span class="timer-label" id="timerLabel">Resend in 01:00</span>
          <button class="resend-btn" id="resendBtn" onclick="resendOtp()" disabled>Resend code</button>
        </div>
      </div>
      <button class="btn-primary" id="verifyBtn" onclick="verifyOtp()">
        <span id="verifyBtnText">Verify &amp; Sign In</span>
        <div class="spinner" id="verifySpinner" style="display:none;"></div>
      </button>
      <button class="btn-ghost" onclick="goBack()">&#8592; Back to phone number</button>
    </div>

    <div class="form-footer"><p>Having trouble? <a href="mailto:support@zimquote.co.zw">Contact support</a></p></div>
  </div>
</div>
<script>
  let _phone="",_timer=null,_secs=60;
  function showError(m){const e=document.getElementById("errorAlert");e.textContent=m;e.style.display="flex";setTimeout(()=>e.style.display="none",6000);}
  function setLoad(b,s,t,on){document.getElementById(b).disabled=on;document.getElementById(s).style.display=on?"block":"none";document.getElementById(t).style.display=on?"none":"inline";}
  function fmtPhone(r){const d=r.replace(/\D/g,"");if(d.startsWith("263")){const l=d.slice(3);return"+263 "+l.slice(0,2)+" "+l.slice(2,5)+" "+l.slice(5);}return"+263 "+r;}
  document.getElementById("phoneInput").addEventListener("input",function(e){let v=e.target.value.replace(/\D/g,"").slice(0,10);let f=v;if(v.length>2)f=v.slice(0,2)+" "+v.slice(2);if(v.length>5)f=v.slice(0,2)+" "+v.slice(2,5)+" "+v.slice(5);e.target.value=f;});
  document.getElementById("phoneInput").addEventListener("keydown",e=>{if(e.key==="Enter")sendOtp();});
  async function sendOtp(){const raw=document.getElementById("phoneInput").value.replace(/\s/g,"");if(!raw||raw.length<9){showError("Please enter a valid Zimbabwean mobile number.");return;}let phone=raw;if(phone.startsWith("0"))phone="263"+phone.slice(1);_phone=phone;setLoad("sendOtpBtn","sendSpinner","sendBtnText",true);try{const r=await fetch("/web/auth/request-otp",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({phone})});const d=await r.json();if(r.ok)switchToOtp();else showError(d.error||"Failed to send code.");}catch{showError("Network error. Check your connection.");}setLoad("sendOtpBtn","sendSpinner","sendBtnText",false);}
  function switchToOtp(){document.getElementById("panelPhone").style.display="none";document.getElementById("panelOtp").style.display="block";document.getElementById("displayPhone").textContent=fmtPhone(_phone);document.getElementById("otpSentBadge").style.display="flex";document.getElementById("step1").className="step done";document.getElementById("step2").className="step active";document.querySelectorAll(".otp-box").forEach(b=>{b.value="";b.classList.remove("filled");});document.querySelectorAll(".otp-box")[0].focus();startTimer();}
  function goBack(){document.getElementById("panelPhone").style.display="block";document.getElementById("panelOtp").style.display="none";document.getElementById("step1").className="step active";document.getElementById("step2").className="step inactive";clearInterval(_timer);}
  const boxes=document.querySelectorAll(".otp-box");
  boxes.forEach((box,i)=>{
    box.addEventListener("input",function(){this.value=this.value.replace(/\D/g,"").slice(-1);this.classList.toggle("filled",this.value!=="");if(this.value&&i<boxes.length-1)boxes[i+1].focus();if(Array.from(boxes).every(b=>b.value))verifyOtp();});
    box.addEventListener("keydown",function(e){if(e.key==="Backspace"&&!this.value&&i>0){boxes[i-1].focus();boxes[i-1].value="";boxes[i-1].classList.remove("filled");}if(e.key==="ArrowLeft"&&i>0)boxes[i-1].focus();if(e.key==="ArrowRight"&&i<boxes.length-1)boxes[i+1].focus();});
    box.addEventListener("paste",function(e){e.preventDefault();const p=e.clipboardData.getData("text").replace(/\D/g,"").slice(0,6);p.split("").forEach((c,j)=>{if(boxes[j]){boxes[j].value=c;boxes[j].classList.add("filled");}});if(p.length>0)boxes[Math.min(p.length,boxes.length-1)].focus();if(p.length===6)verifyOtp();});
  });
  async function verifyOtp(){const code=Array.from(boxes).map(b=>b.value).join("");if(code.length!==6){showError("Please enter the complete 6-digit code.");return;}setLoad("verifyBtn","verifySpinner","verifyBtnText",true);try{const r=await fetch("/web/auth/verify-otp",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({phone:_phone,code})});const d=await r.json();if(r.ok&&d.success)window.location.href=d.redirectUrl||"/web/dashboard";else{showError(d.error||"Invalid code.");boxes.forEach(b=>{b.value="";b.classList.remove("filled");});boxes[0].focus();}}catch{showError("Network error.");}setLoad("verifyBtn","verifySpinner","verifyBtnText",false);}
  function startTimer(){_secs=60;const b=document.getElementById("resendBtn");b.disabled=true;b.classList.remove("active");clearInterval(_timer);_timer=setInterval(()=>{_secs--;const m=String(Math.floor(_secs/60)).padStart(2,"0");const s=String(_secs%60).padStart(2,"0");document.getElementById("timerLabel").textContent="Resend in "+m+":"+s;if(_secs<=0){clearInterval(_timer);document.getElementById("timerLabel").textContent="";b.disabled=false;b.classList.add("active");}},1000);}
  async function resendOtp(){document.getElementById("resendBtn").disabled=true;document.getElementById("resendBtn").classList.remove("active");try{await fetch("/web/auth/request-otp",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({phone:_phone})});document.getElementById("otpSentBadge").style.display="flex";startTimer();}catch{showError("Failed to resend.");}}
</script>
</body>
</html>