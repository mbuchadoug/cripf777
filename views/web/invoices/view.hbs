{{!-- views/web/invoices/view.hbs --}}
<style>
  .inv-header { display:flex; align-items:flex-start; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-bottom:24px; }
  .inv-header-left h1 { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; letter-spacing:-0.5px; color:var(--white); margin-bottom:4px; }
  .inv-header-left p { font-size:13px; color:var(--muted); }
  .hdr-actions { display:flex; gap:10px; flex-wrap:wrap; }

  .inv-layout { display:grid; grid-template-columns:1fr 268px; gap:20px; align-items:start; }

  .doc-card { background:var(--navy-2); border:1px solid var(--border); border-radius:14px; overflow:hidden; }
  .doc-top { padding:28px 28px 24px; border-bottom:1px solid var(--border); display:flex; justify-content:space-between; align-items:flex-start; gap:20px; flex-wrap:wrap; }
  .doc-biz-name { font-family:'Syne',sans-serif; font-size:18px; font-weight:800; color:var(--white); letter-spacing:-0.4px; margin-bottom:3px; }
  .doc-biz-sub { font-size:12px; color:var(--muted-2); }
  .doc-type { font-family:'Syne',sans-serif; font-size:26px; font-weight:800; letter-spacing:-1px; color:var(--amber); text-transform:uppercase; line-height:1; }
  .doc-num-label { font-family:'DM Mono',monospace; font-size:12px; color:var(--muted-2); margin-top:5px; text-align:right; }

  .doc-meta { display:grid; grid-template-columns:1fr 1fr; }
  .meta-cell { padding:16px 28px; border-bottom:1px solid var(--border); }
  .meta-cell:nth-child(odd) { border-right:1px solid var(--border); }
  .meta-lbl { font-size:10px; font-weight:700; color:var(--muted-2); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:5px; }
  .meta-val { font-size:13px; color:var(--white); font-weight:500; }
  .meta-sub { font-size:11px; color:var(--muted-2); margin-top:2px; font-family:'DM Mono',monospace; }

  .items-table { width:100%; border-collapse:collapse; }
  .items-table thead tr { background:rgba(255,255,255,0.02); }
  .items-table th { padding:11px 20px; text-align:left; font-size:10px; font-weight:700; color:var(--muted-2); text-transform:uppercase; letter-spacing:0.8px; border-bottom:1px solid var(--border); }
  .items-table th:last-child,.items-table td:last-child { text-align:right; padding-right:28px; }
  .items-table td { padding:13px 20px; font-size:13px; color:var(--white); border-bottom:1px solid rgba(255,255,255,0.03); }
  .items-table tbody tr:last-child td { border-bottom:none; }
  .item-num { font-family:'DM Mono',monospace; color:var(--muted-2); font-size:12px; }
  .item-name { font-weight:500; }
  .item-mono { font-family:'DM Mono',monospace; color:var(--muted); }
  .item-total { font-family:'DM Mono',monospace; color:var(--white); font-weight:500; }

  .totals-row-wrap { padding:20px 28px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; }
  .totals-block { width:220px; }
  .t-row { display:flex; justify-content:space-between; align-items:center; padding:5px 0; font-size:13px; }
  .t-lbl { color:var(--muted-2); }
  .t-val { font-family:'DM Mono',monospace; }
  .t-row.final { border-top:1px solid var(--border); margin-top:8px; padding-top:12px; }
  .t-row.final .t-lbl { font-family:'Syne',sans-serif; font-weight:700; font-size:14px; color:var(--white); }
  .t-row.final .t-val { font-size:17px; color:var(--amber); font-weight:700; }
  .t-val.green { color:var(--green); }
  .t-val.blue { color:#58a6ff; }
  .t-val.red { color:var(--red); }

  /* Side panel */
  .side-col { display:flex; flex-direction:column; gap:14px; }
  .sc { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; overflow:hidden; }
  .sc-head { padding:14px 18px; border-bottom:1px solid var(--border); }
  .sc-head h3 { font-family:'Syne',sans-serif; font-size:13px; font-weight:700; color:var(--white); }
  .sc-body { padding:14px 18px; }
  .side-btn { display:flex; align-items:center; gap:10px; width:100%; padding:10px 12px; border-radius:8px; border:1px solid var(--border); background:transparent; color:var(--muted); font-size:13px; font-weight:500; cursor:pointer; transition:all 0.15s; text-decoration:none; margin-bottom:8px; font-family:'Instrument Sans',sans-serif; text-align:left; }
  .side-btn:last-child { margin-bottom:0; }
  .side-btn:hover { border-color:rgba(255,255,255,0.14); color:var(--white); background:rgba(255,255,255,0.02); }
  .side-btn.sb-amber { background:var(--amber); border-color:var(--amber); color:#0d1117; font-weight:700; }
  .side-btn.sb-amber:hover { background:#d97706; border-color:#d97706; }
  .side-btn.sb-danger { border-color:rgba(248,81,73,0.2); color:#f85149; }
  .side-btn.sb-danger:hover { background:rgba(248,81,73,0.06); border-color:rgba(248,81,73,0.3); }
  .side-btn svg { width:14px; height:14px; flex-shrink:0; }

  .status-area { padding:16px 18px; }
  .s-icon { width:34px; height:34px; border-radius:9px; display:flex; align-items:center; justify-content:center; margin-bottom:10px; }
  .s-icon svg { width:16px; height:16px; }
  .s-title { font-size:13px; font-weight:700; color:var(--white); margin-bottom:4px; }
  .s-desc { font-size:12px; color:var(--muted-2); line-height:1.5; }
  .s-paid .s-icon { background:rgba(63,185,80,0.1); color:#3fb950; }
  .s-partial .s-icon { background:rgba(245,158,11,0.1); color:#f59e0b; }
  .s-unpaid .s-icon { background:rgba(248,81,73,0.08); color:#f85149; }

  @media (max-width:900px) {
    .inv-layout { grid-template-columns:1fr; }
    .side-col { flex-direction:row; flex-wrap:wrap; }
    .side-col .sc { flex:1; min-width:240px; }
    .doc-meta { grid-template-columns:1fr; }
    .meta-cell:nth-child(odd) { border-right:none; }
  }
  @media print {
    .side-col,.hdr-actions { display:none!important; }
    .inv-layout { grid-template-columns:1fr; }
    .doc-card { border:none; box-shadow:none; }
    body { background:#fff; color:#000; }
    .doc-biz-name,.meta-val,.item-name,.t-row.final .t-lbl { color:#000; }
    .doc-type,.t-row.final .t-val { color:#000; font-weight:900; }
    .items-table th,.meta-lbl,.t-lbl,.item-mono,.item-num,.doc-num-label { color:#555; }
    .items-table td { color:#111; border-bottom:1px solid #eee; }
    .items-table thead tr { background:#f5f5f5; }
  }
</style>

<div class="inv-header">
  <div class="inv-header-left">
    <h1>{{invoice.number}}</h1>
    <p>Created {{formatDate invoice.createdAt}}</p>
  </div>
  <div class="hdr-actions no-print">
    <a href="/web/invoices" class="btn btn-outline">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <span>Back</span>
    </a>
    <button onclick="window.print()" class="btn btn-outline">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      <span>Print</span>
    </button>
    <button onclick="downloadPDF()" class="btn btn-amber">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download PDF
    </button>
  </div>
</div>

<div class="inv-layout">

  <!-- Document -->
  <div class="doc-card">
    <div class="doc-top">
      <div>
        {{#if user.logoUrl}}<img src="{{user.logoUrl}}" alt="Logo" style="height:38px;margin-bottom:10px;border-radius:6px;display:block;">{{/if}}
        <div class="doc-biz-name">{{user.businessName}}</div>
        {{#if user.address}}<div class="doc-biz-sub">{{user.address}}</div>{{/if}}
      </div>
      <div style="text-align:right;">
        <div class="doc-type">{{invoice.type}}</div>
        <div class="doc-num-label">{{invoice.number}}</div>
      </div>
    </div>

    <div class="doc-meta">
      <div class="meta-cell">
        <div class="meta-lbl">Bill To</div>
        <div class="meta-val">{{invoice.clientName}}</div>
        {{#if invoice.clientPhone}}<div class="meta-sub">{{invoice.clientPhone}}</div>{{/if}}
      </div>
      <div class="meta-cell">
        <div class="meta-lbl">Issue Date</div>
        <div class="meta-val">{{formatDate invoice.createdAt}}</div>
      </div>
      <div class="meta-cell">
        <div class="meta-lbl">Status</div>
        <div style="margin-top:4px;">
          <span class="pill {{#if (eq invoice.status 'paid')}}pill-paid{{else if (eq invoice.status 'partial')}}pill-partial{{else}}pill-unpaid{{/if}}">{{invoice.status}}</span>
        </div>
      </div>
      <div class="meta-cell">
        <div class="meta-lbl">Branch</div>
        <div class="meta-val">{{invoice.branchName}}</div>
      </div>
    </div>

    <table class="items-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Description</th>
          <th>Qty</th>
          <th>Unit Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each invoice.items}}
        <tr>
          <td class="item-num">{{inc @index}}</td>
          <td class="item-name">{{this.item}}</td>
          <td class="item-mono">{{this.qty}}</td>
          <td class="item-mono">{{../invoice.currency}} {{this.unit}}</td>
          <td class="item-total">{{../invoice.currency}} {{this.total}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="totals-row-wrap">
      <div class="totals-block">
        <div class="t-row"><span class="t-lbl">Subtotal</span><span class="t-val">{{invoice.currency}} {{invoice.subtotal}}</span></div>
        {{#if (gt invoice.discountAmount 0)}}
        <div class="t-row"><span class="t-lbl">Discount ({{invoice.discountPercent}}%)</span><span class="t-val green">−{{invoice.currency}} {{invoice.discountAmount}}</span></div>
        {{/if}}
        {{#if (gt invoice.vatAmount 0)}}
        <div class="t-row"><span class="t-lbl">VAT ({{invoice.vatPercent}}%)</span><span class="t-val blue">+{{invoice.currency}} {{invoice.vatAmount}}</span></div>
        {{/if}}
        <div class="t-row final"><span class="t-lbl">Total</span><span class="t-val">{{invoice.currency}} {{invoice.total}}</span></div>
        {{#if (gt invoice.amountPaid 0)}}
        <div class="t-row" style="margin-top:10px;"><span class="t-lbl">Paid</span><span class="t-val green">{{invoice.currency}} {{invoice.amountPaid}}</span></div>
        <div class="t-row"><span class="t-lbl">Balance Due</span><span class="t-val red">{{invoice.currency}} {{invoice.balance}}</span></div>
        {{/if}}
      </div>
    </div>
  </div>

  <!-- Side panel -->
  <div class="side-col no-print">

    <div class="sc">
      <div class="status-area {{#if (eq invoice.status 'paid')}}s-paid{{else if (eq invoice.status 'partial')}}s-partial{{else}}s-unpaid{{/if}}">
        <div class="s-icon">
          {{#if (eq invoice.status 'paid')}}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          {{else if (eq invoice.status 'partial')}}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {{else}}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          {{/if}}
        </div>
        <div class="s-title">{{#if (eq invoice.status 'paid')}}Paid in Full{{else if (eq invoice.status 'partial')}}Partially Paid{{else}}Awaiting Payment{{/if}}</div>
        <div class="s-desc">{{#if (eq invoice.status 'paid')}}This invoice has been fully settled.{{else if (eq invoice.status 'partial')}}{{invoice.currency}} {{invoice.amountPaid}} received · {{invoice.currency}} {{invoice.balance}} due.{{else}}{{invoice.currency}} {{invoice.total}} is outstanding.{{/if}}</div>
      </div>
    </div>

    <div class="sc">
      <div class="sc-head"><h3>Actions</h3></div>
      <div class="sc-body">
        <button onclick="downloadPDF()" class="side-btn sb-amber">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download PDF
        </button>
        <button onclick="shareInvoice()" class="side-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Share Link
        </button>
        <button onclick="window.print()" class="side-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print
        </button>
        {{#if (or (eq user.role 'owner') (eq user.role 'manager'))}}
        {{#if (ne invoice.status 'paid')}}
        <button onclick="deleteInvoice()" class="side-btn sb-danger" style="border-top:1px solid var(--border);margin-top:8px;padding-top:18px;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
          Delete Invoice
        </button>
        {{/if}}
        {{/if}}
      </div>
    </div>

  </div>
</div>

<script>
  async function downloadPDF() {
    try {
      const r = await fetch('/web/invoices/{{invoice._id}}/pdf');
      const d = await r.json();
      if (d.url) window.open(d.url, '_blank');
      else showToast('Failed to generate PDF', 'error');
    } catch { showToast('Download failed', 'error'); }
  }
  async function deleteInvoice() {
    if (!confirm('Delete this invoice? This cannot be undone.')) return;
    try {
      const r = await fetch('/web/invoices/{{invoice._id}}', { method:'DELETE' });
      if (r.ok) { showToast('Invoice deleted'); setTimeout(() => window.location.href='/web/invoices', 900); }
      else { const d = await r.json(); showToast(d.error || 'Delete failed', 'error'); }
    } catch { showToast('Delete failed', 'error'); }
  }
  function shareInvoice() {
    if (navigator.share) navigator.share({ title:'Invoice {{invoice.number}}', url:location.href });
    else navigator.clipboard.writeText(location.href).then(() => showToast('Link copied'));
  }
</script>
