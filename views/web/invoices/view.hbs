<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800 mb-2">Invoice {{invoice.number}}</h1>
    <p class="text-sm text-gray-600">Created on {{formatDate invoice.createdAt}}</p>
  </div>
  <div class="mt-4 sm:mt-0 flex items-center space-x-3">
    <button onclick="downloadPDF()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 active:scale-95">
      <i class="fas fa-download mr-2"></i> Download PDF
    </button>
    <button onclick="window.print()" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 no-print">
      <i class="fas fa-print mr-2"></i> Print
    </button>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  
  <!-- Main Invoice -->
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl shadow-sm p-6 sm:p-8">
      
      <!-- Header -->
      <div class="flex items-start justify-between mb-8 pb-6 border-b">
        <div>
          {{#if user.logoUrl}}
            <img src="{{user.logoUrl}}" alt="Logo" class="h-16 mb-3">
          {{/if}}
          <h2 class="text-2xl font-bold text-gray-800">{{user.businessName}}</h2>
          {{#if user.address}}
            <p class="text-sm text-gray-600 mt-1">{{user.address}}</p>
          {{/if}}
        </div>
        
        <div class="text-right">
          <h3 class="text-3xl font-bold text-blue-600">INVOICE</h3>
          <p class="text-lg font-semibold text-gray-800 mt-1">{{invoice.number}}</p>
        </div>
      </div>
      
      <!-- Client & Date Info -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
        <div>
          <h4 class="text-sm font-semibold text-gray-600 mb-2">BILL TO</h4>
          <p class="font-semibold text-gray-800">{{invoice.clientName}}</p>
          {{#if invoice.clientId.phone}}
            <p class="text-sm text-gray-600">{{invoice.clientId.phone}}</p>
          {{/if}}
        </div>
        
        <div class="sm:text-right">
          <div class="mb-3">
            <span class="text-sm text-gray-600">Invoice Date:</span>
            <span class="ml-2 font-medium">{{formatDate invoice.createdAt}}</span>
          </div>
          <div>
            <span class="text-sm text-gray-600">Status:</span>
            <span class="ml-2 inline-block px-3 py-1 text-xs font-medium rounded-full {{#if (eq invoice.status 'paid')}}bg-green-100 text-green-800{{else if (eq invoice.status 'partial')}}bg-yellow-100 text-yellow-800{{else}}bg-red-100 text-red-800{{/if}}">
              {{invoice.status}}
            </span>
          </div>
        </div>
      </div>
      
      <!-- Items Table -->
      <div class="mb-8 overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b-2 border-gray-200">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">#</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Item</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">Qty</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">Unit Price</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            {{#each invoice.items}}
              <tr>
                <td class="px-4 py-3 text-sm text-gray-600">{{inc @index}}</td>
                <td class="px-4 py-3 text-sm text-gray-800">{{this.item}}</td>
                <td class="px-4 py-3 text-sm text-gray-600 text-right">{{this.qty}}</td>
                <td class="px-4 py-3 text-sm text-gray-600 text-right">{{../invoice.currency}} {{this.unit}}</td>
                <td class="px-4 py-3 text-sm font-medium text-gray-800 text-right">{{../invoice.currency}} {{this.total}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      
      <!-- Totals -->
      <div class="flex justify-end">
        <div class="w-full sm:w-64 space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Subtotal</span>
            <span class="font-medium">{{invoice.currency}} {{invoice.subtotal}}</span>
          </div>
          
          {{#if (gt invoice.discountAmount 0)}}
            <div class="flex justify-between text-sm text-green-600">
              <span>Discount ({{invoice.discountPercent}}%)</span>
              <span>- {{invoice.currency}} {{invoice.discountAmount}}</span>
            </div>
          {{/if}}
          
          {{#if (gt invoice.vatAmount 0)}}
            <div class="flex justify-between text-sm text-blue-600">
              <span>VAT ({{invoice.vatPercent}}%)</span>
              <span>+ {{invoice.currency}} {{invoice.vatAmount}}</span>
            </div>
          {{/if}}
          
          <div class="flex justify-between pt-3 border-t-2 text-lg font-bold">
            <span>Total</span>
            <span>{{invoice.currency}} {{invoice.total}}</span>
          </div>
          
          {{#if (gt invoice.amountPaid 0)}}
            <div class="flex justify-between text-sm text-green-600">
              <span>Amount Paid</span>
              <span>{{invoice.currency}} {{invoice.amountPaid}}</span>
            </div>
            
            <div class="flex justify-between text-sm font-semibold text-red-600">
              <span>Balance Due</span>
              <span>{{invoice.currency}} {{invoice.balance}}</span>
            </div>
          {{/if}}
        </div>
      </div>
      
    </div>
  </div>
  
  <!-- Sidebar: Actions & Info -->
  <div class="space-y-6">
    
    <!-- Quick Actions -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h3 class="font-semibold text-gray-800 mb-4">Actions</h3>
      
      <div class="space-y-3">
        <button onclick="downloadPDF()" class="w-full px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-left">
          <i class="fas fa-download mr-2"></i> Download PDF
        </button>
        
        <button onclick="window.print()" class="w-full px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 text-left no-print">
          <i class="fas fa-print mr-2"></i> Print Invoice
        </button>
        
        <button onclick="shareInvoice()" class="w-full px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 text-left no-print">
          <i class="fas fa-share-alt mr-2"></i> Share
        </button>
        
        {{#if (or (eq user.role 'owner') (eq user.role 'manager'))}}
          {{#if (ne invoice.status 'paid')}}
            <button onclick="deleteInvoice()" class="w-full px-4 py-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 text-left no-print">
              <i class="fas fa-trash mr-2"></i> Delete Invoice
            </button>
          {{/if}}
        {{/if}}
      </div>
    </div>
    
    <!-- Payment Status -->
    {{#if (eq invoice.status 'unpaid')}}
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6">
        <div class="flex items-center mb-2">
          <i class="fas fa-exclamation-triangle text-yellow-600 mr-2"></i>
          <h4 class="font-semibold text-yellow-800">Payment Pending</h4>
        </div>
        <p class="text-sm text-yellow-700">This invoice has not been paid yet.</p>
      </div>
    {{else if (eq invoice.status 'partial')}}
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-6">
        <div class="flex items-center mb-2">
          <i class="fas fa-info-circle text-blue-600 mr-2"></i>
          <h4 class="font-semibold text-blue-800">Partially Paid</h4>
        </div>
        <p class="text-sm text-blue-700 mb-3">
          Paid: {{invoice.currency}} {{invoice.amountPaid}}<br>
          Balance: {{invoice.currency}} {{invoice.balance}}
        </p>
      </div>
    {{else}}
      <div class="bg-green-50 border border-green-200 rounded-xl p-6">
        <div class="flex items-center mb-2">
          <i class="fas fa-check-circle text-green-600 mr-2"></i>
          <h4 class="font-semibold text-green-800">Paid in Full</h4>
        </div>
        <p class="text-sm text-green-700">This invoice has been fully paid.</p>
      </div>
    {{/if}}
    
    <!-- Back to List -->
    <a href="/web/invoices" class="block w-full px-4 py-2 text-center border border-gray-300 rounded-lg hover:bg-gray-50 no-print">
      <i class="fas fa-arrow-left mr-2"></i> Back to Invoices
    </a>
    
  </div>
  
</div>

<script>
  async function downloadPDF() {
    try {
      const response = await fetch('/web/invoices/{{invoice._id}}/pdf');
      const data = await response.json();
      
      if (data.url) {
        window.open(data.url, '_blank');
      } else {
        alert('Failed to generate PDF');
      }
    } catch (error) {
      console.error('Download error:', error);
      alert('Failed to download PDF');
    }
  }
  
  async function deleteInvoice() {
    if (!confirm('Are you sure you want to delete this invoice? This action cannot be undone.')) {
      return;
    }
    
    try {
      const response = await fetch('/web/invoices/{{invoice._id}}', {
        method: 'DELETE'
      });
      
      if (response.ok) {
        window.location.href = '/web/invoices';
      } else {
        const data = await response.json();
        alert(data.error || 'Failed to delete invoice');
      }
    } catch (error) {
      console.error('Delete error:', error);
      alert('Failed to delete invoice');
    }
  }
  
  function shareInvoice() {
    const url = window.location.href;
    
    if (navigator.share) {
      navigator.share({
        title: 'Invoice {{invoice.number}}',
        text: 'View invoice {{invoice.number}} for {{invoice.clientName}}',
        url: url
      });
    } else {
      // Fallback: copy to clipboard
      navigator.clipboard.writeText(url).then(() => {
        alert('Link copied to clipboard!');
      });
    }
  }
</script>