<div class="page-header">
  <div>
    <div class="page-title">{{invoice.number}}</div>
    <div class="page-subtitle">Created {{formatDate invoice.createdAt}}</div>
  </div>
  <div class="page-actions">
    <button onclick="downloadPDF()" class="btn btn-ghost">
      <i class="fas fa-download"></i> Download PDF
    </button>
    <button onclick="window.print()" class="btn btn-ghost no-print">
      <i class="fas fa-print"></i> Print
    </button>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 340px;gap:22px;align-items:start" id="invoiceGrid">

  <!-- ── MAIN INVOICE ────────────────────────── -->
  <div class="card" style="padding:0">
    
    <!-- Invoice Header -->
    <div style="padding:32px 40px;border-bottom:1px solid var(--border)">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:24px">
        <div>
          {{#if user.logoUrl}}
            <img src="{{user.logoUrl}}" alt="Logo" style="height:56px;margin-bottom:14px;border-radius:8px">
          {{/if}}
          <h2 style="font-family:'Syne',sans-serif;font-size:24px;font-weight:800;color:var(--white);margin:0 0 6px 0">
            {{user.businessName}}
          </h2>
          {{#if user.address}}
            <p style="font-size:13px;color:var(--muted);margin:0;max-width:280px;line-height:1.6">
              {{user.address}}
            </p>
          {{/if}}
        </div>
        
        <div style="text-align:right">
          <div style="font-family:'Syne',sans-serif;font-size:32px;font-weight:800;color:var(--amber);letter-spacing:-0.5px;margin-bottom:8px">
            INVOICE
          </div>
          <div style="font-family:'DM Mono',monospace;font-size:16px;font-weight:500;color:var(--white);margin-bottom:8px">
            {{invoice.number}}
          </div>
          {{#if invoice.branchName}}
          <div style="display:inline-flex;align-items:center;gap:6px;padding:4px 10px;background:var(--surface-2);border:1px solid var(--border);border-radius:6px;font-size:12px;color:var(--muted)">
            <i class="fas fa-building"></i>
            <span>{{invoice.branchName}}</span>
          </div>
          {{/if}}
        </div>
      </div>
    </div>
    
    <!-- Client & Date Info -->
    <div style="padding:32px 40px;border-bottom:1px solid var(--border)">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px">
        <div>
          <div style="font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px">
            Bill To
          </div>
          <div style="font-family:'Syne',sans-serif;font-size:17px;font-weight:700;color:var(--white);margin-bottom:6px">
            {{invoice.clientName}}
          </div>
          {{#if invoice.clientId.phone}}
            <div style="font-size:13px;color:var(--muted);display:flex;align-items:center;gap:6px">
              <i class="fas fa-phone" style="font-size:11px"></i>
              <span>{{invoice.clientId.phone}}</span>
            </div>
          {{/if}}
        </div>
        
        <div>
          <div style="display:flex;flex-direction:column;gap:10px">
            <div style="display:flex;justify-content:space-between;align-items:center">
              <span style="font-size:13px;color:var(--muted-2)">Invoice Date</span>
              <span style="font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:var(--white)">
                {{formatDate invoice.createdAt}}
              </span>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center">
              <span style="font-size:13px;color:var(--muted-2)">Status</span>
              <span>
                {{#if (eq invoice.status 'paid')}}
                  <span class="badge badge-green">Paid</span>
                {{else if (eq invoice.status 'partial')}}
                  <span class="badge badge-amber">Partial</span>
                {{else}}
                  <span class="badge badge-red">Unpaid</span>
                {{/if}}
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Items Table -->
    <div style="padding:32px 40px;border-bottom:1px solid var(--border)">
      <table style="width:100%;border-collapse:collapse">
        <thead>
          <tr style="border-bottom:2px solid var(--border)">
            <th style="padding:12px 0;text-align:left;font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:1px;width:40px">#</th>
            <th style="padding:12px 0;text-align:left;font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:1px">Item</th>
            <th style="padding:12px 0;text-align:right;font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:1px;width:80px">Qty</th>
            <th style="padding:12px 0;text-align:right;font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:1px;width:120px">Unit Price</th>
            <th style="padding:12px 0;text-align:right;font-size:11px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:1px;width:130px">Total</th>
          </tr>
        </thead>
        <tbody>
          {{#each invoice.items}}
            <tr style="border-bottom:1px solid var(--border-subtle)">
              <td style="padding:16px 0;font-size:13px;color:var(--muted)">{{inc @index}}</td>
              <td style="padding:16px 0;font-size:14px;color:var(--white)">{{this.item}}</td>
              <td style="padding:16px 0;font-family:'DM Mono',monospace;font-size:13px;color:var(--muted);text-align:right">{{this.qty}}</td>
              <td style="padding:16px 0;font-family:'DM Mono',monospace;font-size:13px;color:var(--muted);text-align:right">
                {{../invoice.currency}} {{this.unit}}
              </td>
              <td style="padding:16px 0;font-family:'DM Mono',monospace;font-size:14px;font-weight:500;color:var(--white);text-align:right">
                {{../invoice.currency}} {{this.total}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    
    <!-- Totals -->
    <div style="padding:32px 40px">
      <div style="display:flex;justify-content:flex-end">
        <div style="width:100%;max-width:340px">
          <div style="display:flex;flex-direction:column;gap:12px">
            
            <div style="display:flex;justify-content:space-between;align-items:center">
              <span style="font-size:14px;color:var(--muted)">Subtotal</span>
              <span style="font-family:'DM Mono',monospace;font-size:15px;font-weight:500;color:var(--white)">
                {{invoice.currency}} {{invoice.subtotal}}
              </span>
            </div>
            
            {{#if (gt invoice.discountAmount 0)}}
              <div style="display:flex;justify-content:space-between;align-items:center">
                <span style="font-size:14px;color:var(--green)">
                  Discount ({{invoice.discountPercent}}%)
                </span>
                <span style="font-family:'DM Mono',monospace;font-size:15px;font-weight:500;color:var(--green)">
                  − {{invoice.currency}} {{invoice.discountAmount}}
                </span>
              </div>
            {{/if}}
            
            {{#if (gt invoice.vatAmount 0)}}
              <div style="display:flex;justify-content:space-between;align-items:center">
                <span style="font-size:14px;color:var(--blue)">
                  VAT ({{invoice.vatPercent}}%)
                </span>
                <span style="font-family:'DM Mono',monospace;font-size:15px;font-weight:500;color:var(--blue)">
                  + {{invoice.currency}} {{invoice.vatAmount}}
                </span>
              </div>
            {{/if}}
            
            <div style="height:1px;background:var(--border);margin:8px 0"></div>
            
            <div style="display:flex;justify-content:space-between;align-items:center">
              <span style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:var(--white)">
                Total
              </span>
              <span style="font-family:'DM Mono',monospace;font-size:22px;font-weight:500;color:var(--amber)">
                {{invoice.currency}} {{invoice.total}}
              </span>
            </div>
            
            {{#if (gt invoice.amountPaid 0)}}
              <div style="height:1px;background:var(--border);margin:4px 0"></div>
              
              <div style="display:flex;justify-content:space-between;align-items:center">
                <span style="font-size:14px;color:var(--green)">Amount Paid</span>
                <span style="font-family:'DM Mono',monospace;font-size:15px;font-weight:500;color:var(--green)">
                  {{invoice.currency}} {{invoice.amountPaid}}
                </span>
              </div>
              
              <div style="display:flex;justify-content:space-between;align-items:center">
                <span style="font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--red)">
                  Balance Due
                </span>
                <span style="font-family:'DM Mono',monospace;font-size:18px;font-weight:500;color:var(--red)">
                  {{invoice.currency}} {{invoice.balance}}
                </span>
              </div>
            {{/if}}
            
          </div>
        </div>
      </div>
    </div>
    
  </div>

  <!-- ── SIDEBAR ─────────────────────────────── -->
  <div style="position:sticky;top:72px;display:flex;flex-direction:column;gap:14px">
    
    <!-- Actions -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-bolt"></i> Quick Actions</div>
      </div>
      <div class="card-body">
        <div style="display:flex;flex-direction:column;gap:8px">
          <button onclick="downloadPDF()" class="btn btn-primary" style="width:100%;justify-content:center">
            <i class="fas fa-download"></i> Download PDF
          </button>
          <button onclick="window.print()" class="btn btn-ghost no-print" style="width:100%;justify-content:center">
            <i class="fas fa-print"></i> Print Invoice
          </button>
          <button onclick="shareInvoice()" class="btn btn-ghost no-print" style="width:100%;justify-content:center">
            <i class="fas fa-share-alt"></i> Share
          </button>
          
          {{#if (or (eq user.role 'owner') (eq user.role 'manager'))}}
            {{#if (ne invoice.status 'paid')}}
              <div style="height:1px;background:var(--border);margin:4px 0"></div>
              <button onclick="deleteInvoice()" class="btn btn-danger no-print" style="width:100%;justify-content:center">
                <i class="fas fa-trash"></i> Delete Invoice
              </button>
            {{/if}}
          {{/if}}
        </div>
      </div>
    </div>
    
    <!-- Branch Info -->
    {{#if invoice.branchName}}
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-building"></i> Branch</div>
      </div>
      <div class="card-body">
        <div style="font-size:15px;font-weight:600;color:var(--white)">
          {{invoice.branchName}}
        </div>
      </div>
    </div>
    {{/if}}
    
    <!-- Payment Status -->
    {{#if (eq invoice.status 'unpaid')}}
      <div style="background:var(--red-g);border:1px solid var(--red-b);border-radius:12px;padding:16px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <i class="fas fa-exclamation-triangle" style="color:var(--red);font-size:18px"></i>
          <div style="font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--red)">
            Payment Pending
          </div>
        </div>
        <p style="font-size:13px;color:var(--muted);margin:0;line-height:1.6">
          This invoice has not been paid yet.
        </p>
      </div>
    {{else if (eq invoice.status 'partial')}}
      <div style="background:var(--amber-g);border:1px solid var(--amber-b);border-radius:12px;padding:16px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <i class="fas fa-info-circle" style="color:var(--amber);font-size:18px"></i>
          <div style="font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--amber)">
            Partially Paid
          </div>
        </div>
        <div style="font-size:13px;color:var(--muted);line-height:1.7">
          <div style="margin-bottom:4px">
            <strong style="color:var(--white)">Paid:</strong> {{invoice.currency}} {{invoice.amountPaid}}
          </div>
          <div>
            <strong style="color:var(--white)">Balance:</strong> {{invoice.currency}} {{invoice.balance}}
          </div>
        </div>
      </div>
    {{else}}
      <div style="background:var(--green-g);border:1px solid var(--green-b);border-radius:12px;padding:16px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <i class="fas fa-check-circle" style="color:var(--green);font-size:18px"></i>
          <div style="font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--green)">
            Paid in Full
          </div>
        </div>
        <p style="font-size:13px;color:var(--muted);margin:0;line-height:1.6">
          This invoice has been fully paid.
        </p>
      </div>
    {{/if}}
    
    <!-- Back -->
    <a href="/web/invoices" class="btn btn-ghost no-print" style="width:100%;justify-content:center">
      <i class="fas fa-arrow-left"></i> Back to Invoices
    </a>
    
  </div>
  
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-backdrop" id="deleteModal">
  <div class="modal" style="max-width:420px">
    <div class="modal-header">
      <div class="modal-title">
        <i class="fas fa-exclamation-triangle" style="color:var(--red)"></i>
        Delete Invoice
      </div>
      <button class="modal-close" onclick="closeModal('deleteModal')">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <p style="font-size:14px;color:var(--muted);line-height:1.7;margin:0">
        Are you sure you want to delete invoice <strong style="color:var(--white)">{{invoice.number}}</strong>? 
        This action cannot be undone and all associated payment records will be permanently removed.
      </p>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('deleteModal')">Cancel</button>
      <button class="btn btn-danger" id="confirmDeleteBtn" onclick="executeDelete()">
        <span id="deleteText"><i class="fas fa-trash"></i> Delete Invoice</span>
        <span class="spinner" id="deleteSpinner" style="display:none"></span>
      </button>
    </div>
  </div>
</div>

<script>
  // Responsive grid
  function adjustGrid() {
    const g = document.getElementById('invoiceGrid');
    g.style.gridTemplateColumns = window.innerWidth < 1024 ? '1fr' : '1fr 340px';
  }
  adjustGrid();
  window.addEventListener('resize', adjustGrid);

  async function downloadPDF() {
    try {
      const response = await fetch('/web/invoices/{{invoice._id}}/pdf');
      const data = await response.json();
      
      if (data.url) {
        window.open(data.url, '_blank');
        showToast('PDF generated successfully', 'success');
      } else {
        showToast('Failed to generate PDF', 'error');
      }
    } catch (error) {
      console.error('Download error:', error);
      showToast('Failed to download PDF', 'error');
    }
  }
  
  function deleteInvoice() {
    openModal('deleteModal');
  }

  async function executeDelete() {
    const btn = document.getElementById('confirmDeleteBtn');
    const text = document.getElementById('deleteText');
    const spinner = document.getElementById('deleteSpinner');
    
    btn.disabled = true;
    text.style.display = 'none';
    spinner.style.display = 'inline-block';
    
    try {
      const response = await fetch('/web/invoices/{{invoice._id}}', {
        method: 'DELETE'
      });
      
      if (response.ok) {
        showToast('Invoice deleted successfully', 'success');
        setTimeout(() => window.location.href = '/web/invoices', 800);
      } else {
        const data = await response.json();
        showToast(data.error || 'Failed to delete invoice', 'error');
        btn.disabled = false;
        text.style.display = 'inline';
        spinner.style.display = 'none';
      }
    } catch (error) {
      console.error('Delete error:', error);
      showToast('Failed to delete invoice', 'error');
      btn.disabled = false;
      text.style.display = 'inline';
      spinner.style.display = 'none';
    }
  }
  
  function shareInvoice() {
    const url = window.location.href;
    
    if (navigator.share) {
      navigator.share({
        title: 'Invoice {{invoice.number}}',
        text: 'View invoice {{invoice.number}} for {{invoice.clientName}}',
        url: url
      }).then(() => {
        showToast('Shared successfully', 'success');
      }).catch(() => {});
    } else {
      navigator.clipboard.writeText(url).then(() => {
        showToast('Link copied to clipboard', 'success');
      }).catch(() => {
        showToast('Failed to copy link', 'error');
      });
    }
  }
</script>