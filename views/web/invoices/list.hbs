{{!-- views/web/invoices/list.hbs --}}
<style>
  .pg-head { display:flex; align-items:flex-start; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-bottom:22px; }
  .pg-head h1 { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; letter-spacing:-0.5px; color:var(--white); margin-bottom:4px; }
  .pg-head p { font-size:13px; color:var(--muted); }

  .filter-bar { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; padding:16px 20px; margin-bottom:18px; display:flex; gap:14px; flex-wrap:wrap; align-items:flex-end; }
  .fg { display:flex; flex-direction:column; gap:6px; flex:1; min-width:140px; }
  .filter-go { padding:10px 20px; background:var(--amber); color:#0d1117; border:none; border-radius:8px; font-family:'Instrument Sans',sans-serif; font-size:13px; font-weight:700; cursor:pointer; transition:all 0.15s; white-space:nowrap; align-self:flex-end; height:40px; }
  .filter-go:hover { background:#d97706; }
  .filter-reset { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--muted-2); text-decoration:none; padding:0 14px; border:1px solid var(--border); border-radius:8px; transition:all 0.15s; white-space:nowrap; height:40px; align-self:flex-end; }
  .filter-reset:hover { border-color:rgba(255,255,255,0.14); color:var(--white); }
  .filter-reset svg { width:12px; height:12px; }

  .tbl-wrap { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; overflow:hidden; }
  .tbl-hd { display:flex; align-items:center; justify-content:space-between; padding:14px 20px; border-bottom:1px solid var(--border); }
  .tbl-hd-title { font-family:'Syne',sans-serif; font-size:13px; font-weight:700; color:var(--white); }
  .tbl-count { font-family:'DM Mono',monospace; font-size:11px; color:var(--muted-2); background:rgba(255,255,255,0.04); padding:3px 10px; border-radius:20px; border:1px solid var(--border); }

  .dt { width:100%; border-collapse:collapse; }
  .dt thead tr { background:transparent; }
  .dt th { padding:10px 16px; text-align:left; font-size:10px; font-weight:700; color:var(--muted-2); text-transform:uppercase; letter-spacing:0.8px; border-bottom:1px solid var(--border); }
  .dt td { padding:13px 16px; font-size:13px; border-bottom:1px solid rgba(255,255,255,0.025); vertical-align:middle; }
  .dt tbody tr { cursor:pointer; transition:background 0.12s; }
  .dt tbody tr:hover { background:rgba(255,255,255,0.02); }
  .dt tbody tr:last-child td { border-bottom:none; }

  .inv-num { font-family:'DM Mono',monospace; font-size:12px; color:var(--amber); font-weight:500; }
  .inv-client { font-weight:500; color:var(--white); font-size:13px; }
  .inv-amt { font-family:'DM Mono',monospace; font-size:13px; color:var(--white); font-weight:500; }
  .inv-sub { font-family:'DM Mono',monospace; font-size:11px; color:var(--muted-2); margin-top:2px; }
  .inv-date { font-family:'DM Mono',monospace; font-size:11px; color:var(--muted-2); }

  .row-acts { display:flex; align-items:center; gap:6px; opacity:0; transition:opacity 0.12s; justify-content:flex-end; }
  .dt tbody tr:hover .row-acts { opacity:1; }
  .ra { width:28px; height:28px; border-radius:7px; border:1px solid var(--border); background:transparent; color:var(--muted); display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.12s; text-decoration:none; flex-shrink:0; }
  .ra:hover { border-color:rgba(255,255,255,0.14); color:var(--white); background:rgba(255,255,255,0.03); }
  .ra.red:hover { border-color:rgba(248,81,73,0.3); color:#f85149; background:rgba(248,81,73,0.05); }
  .ra svg { width:13px; height:13px; }

  /* Mobile cards */
  .mob-cards { display:none; flex-direction:column; gap:10px; }
  .mob-card { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; overflow:hidden; cursor:pointer; transition:border-color 0.15s; }
  .mob-card:hover { border-color:rgba(255,255,255,0.12); }
  .mob-card-body { padding:14px 16px; display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
  .mob-card-foot { padding:10px 16px; border-top:1px solid var(--border); display:flex; gap:8px; background:rgba(255,255,255,0.01); }
  .mob-card-foot .ra { flex:1; height:32px; width:auto; justify-content:center; gap:6px; font-size:12px; font-family:'Instrument Sans',sans-serif; color:var(--muted); opacity:1; }

  .empty-st { padding:56px 24px; text-align:center; }
  .empty-st svg { width:36px; height:36px; opacity:0.15; display:block; margin:0 auto 14px; }
  .empty-st p { font-size:13px; color:var(--muted-2); margin-bottom:16px; }

  .pag { display:flex; align-items:center; justify-content:center; gap:8px; margin-top:18px; }
  .pag a { display:flex; align-items:center; justify-content:center; width:34px; height:34px; border:1px solid var(--border); border-radius:8px; background:transparent; color:var(--muted); text-decoration:none; font-size:14px; transition:all 0.12s; }
  .pag a:hover { border-color:rgba(255,255,255,0.14); color:var(--white); }
  .pag-info { font-family:'DM Mono',monospace; font-size:11px; color:var(--muted-2); padding:0 10px; }

  @media(max-width:760px) { .tbl-wrap { display:none; } .mob-cards { display:flex; } }
  @media(max-width:500px) { .filter-bar { padding:14px 14px; } .fg { min-width:100%; } }
</style>

<div class="pg-head">
  <div>
    <h1>Invoices</h1>
    <p>Track and manage all your documents</p>
  </div>
  <div style="display:flex;gap:10px;flex-wrap:wrap;">
    <a href="/web/invoices/create?type=quote" class="btn btn-outline">New Quote</a>
    <a href="/web/invoices/create?type=invoice" class="btn btn-amber">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Invoice
    </a>
  </div>
</div>

<form method="GET" action="/web/invoices">
  <div class="filter-bar">
    <div class="fg">
      <label class="field-label">Status</label>
      <select name="status" class="field-input">
        <option value="">All statuses</option>
        <option value="unpaid"  {{#if (eq filters.status 'unpaid')}}selected{{/if}}>Unpaid</option>
        <option value="partial" {{#if (eq filters.status 'partial')}}selected{{/if}}>Partial</option>
        <option value="paid"    {{#if (eq filters.status 'paid')}}selected{{/if}}>Paid</option>
      </select>
    </div>
    <div class="fg">
      <label class="field-label">Type</label>
      <select name="type" class="field-input">
        <option value="invoice" {{#if (eq filters.type 'invoice')}}selected{{/if}}>Invoice</option>
        <option value="quote"   {{#if (eq filters.type 'quote')}}selected{{/if}}>Quote</option>
        <option value="receipt" {{#if (eq filters.type 'receipt')}}selected{{/if}}>Receipt</option>
      </select>
    </div>
    <div class="fg">
      <label class="field-label">Search</label>
      <input type="text" name="search" class="field-input" placeholder="Number or client..." value="{{filters.search}}" style="height:40px;">
    </div>
    {{#if isOwner}}
    <div class="fg">
      <label class="field-label">Branch</label>
      <select name="branchFilter" class="field-input">
        <option value="">All branches</option>
        {{#each branches}}
        <option value="{{this._id}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
    <button type="submit" class="filter-go">Filter</button>
    <a href="/web/invoices" class="filter-reset">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
      Reset
    </a>
  </div>
</form>

<!-- Desktop table -->
<div class="tbl-wrap">
  <div class="tbl-hd">
    <span class="tbl-hd-title">Results</span>
    <span class="tbl-count">{{pagination.total}} total</span>
  </div>
  {{#if invoices.length}}
  <table class="dt">
    <thead>
      <tr>
        <th>Number</th>
        <th>Client</th>
        <th>Amount</th>
        <th>Status</th>
        {{#if isOwner}}<th>Branch</th>{{/if}}
        <th>Date</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each invoices}}
      <tr onclick="window.location='/web/invoices/{{this._id}}'">
        <td><span class="inv-num">{{this.number}}</span></td>
        <td><div class="inv-client">{{this.clientName}}</div></td>
        <td>
          <div class="inv-amt">{{this.currency}} {{this.total}}</div>
          {{#if (gt this.amountPaid 0)}}<div class="inv-sub">Paid: {{this.currency}} {{this.amountPaid}}</div>{{/if}}
        </td>
        <td><span class="pill {{#if (eq this.status 'paid')}}pill-paid{{else if (eq this.status 'partial')}}pill-partial{{else}}pill-unpaid{{/if}}">{{this.status}}</span></td>
        {{#if ../isOwner}}<td><span style="font-size:12px;color:var(--muted-2);">{{this.branchName}}</span></td>{{/if}}
        <td><span class="inv-date">{{formatDate this.createdAt}}</span></td>
        <td onclick="event.stopPropagation()">
          <div class="row-acts">
            <a href="/web/invoices/{{this._id}}" class="ra" title="View">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </a>
            <button class="ra" onclick="downloadPDF('{{this._id}}')" title="PDF">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </button>
            {{#if (and (or (eq ../user.role 'owner') (eq ../user.role 'manager')) (ne this.status 'paid'))}}
            <button class="ra red" onclick="deleteInvoice('{{this._id}}')" title="Delete">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
            </button>
            {{/if}}
          </div>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-st">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    <p>No invoices found</p>
    <a href="/web/invoices/create" class="btn btn-amber">Create first invoice</a>
  </div>
  {{/if}}
</div>

<!-- Mobile cards -->
<div class="mob-cards">
  {{#each invoices}}
  <div class="mob-card">
    <div class="mob-card-body" onclick="window.location='/web/invoices/{{this._id}}'">
      <div>
        <div class="inv-num" style="margin-bottom:5px;">{{this.number}}</div>
        <div class="inv-client">{{this.clientName}}</div>
        <div class="inv-date" style="margin-top:4px;">{{formatDate this.createdAt}}</div>
      </div>
      <div style="text-align:right;flex-shrink:0;">
        <div class="inv-amt" style="margin-bottom:6px;">{{this.currency}} {{this.total}}</div>
        <span class="pill {{#if (eq this.status 'paid')}}pill-paid{{else if (eq this.status 'partial')}}pill-partial{{else}}pill-unpaid{{/if}}">{{this.status}}</span>
      </div>
    </div>
    <div class="mob-card-foot">
      <a href="/web/invoices/{{this._id}}" class="ra">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        View
      </a>
      <button class="ra" onclick="downloadPDF('{{this._id}}')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        PDF
      </button>
      {{#if (ne this.status 'paid')}}
      <button class="ra red" onclick="deleteInvoice('{{this._id}}')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
        Delete
      </button>
      {{/if}}
    </div>
  </div>
  {{else}}
  <div class="empty-st">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
    <p>No invoices found</p>
    <a href="/web/invoices/create" class="btn btn-amber">Create first invoice</a>
  </div>
  {{/each}}
</div>

{{#if (gt pagination.totalPages 1)}}
<div class="pag">
  {{#if pagination.hasPrev}}<a href="?page={{math pagination.currentPage '-' 1}}&status={{filters.status}}">‹</a>{{/if}}
  <span class="pag-info">{{pagination.currentPage}} / {{pagination.totalPages}}</span>
  {{#if pagination.hasNext}}<a href="?page={{math pagination.currentPage '+' 1}}&status={{filters.status}}">›</a>{{/if}}
</div>
{{/if}}

<script>
  async function downloadPDF(id) {
    try {
      const r = await fetch(`/web/invoices/${id}/pdf`);
      const d = await r.json();
      if (d.url) window.open(d.url, '_blank');
      else showToast('Failed to generate PDF', 'error');
    } catch { showToast('PDF failed', 'error'); }
  }
  async function deleteInvoice(id) {
    if (!confirm('Delete this invoice? Cannot be undone.')) return;
    try {
      const r = await fetch(`/web/invoices/${id}`, { method:'DELETE' });
      if (r.ok) { showToast('Invoice deleted'); setTimeout(() => location.reload(), 900); }
      else { const d = await r.json(); showToast(d.error || 'Failed', 'error'); }
    } catch { showToast('Delete failed', 'error'); }
  }
</script>
