<!-- Page Header -->
<div class="page-header">
  <div>
    <div class="page-title">Invoices</div>
    <div class="page-subtitle">Manage and track all your invoices</div>
  </div>
  <div class="page-actions">
    <a href="/web/invoices/create" class="btn btn-primary">
      <i class="fas fa-plus"></i> New Invoice
    </a>
  </div>
</div>

<!-- Filters -->
<div class="filters-bar no-print">
  <form method="GET" style="display:contents">
    <div class="filter-group">
      <label class="filter-label">Status</label>
      <select name="status" class="form-select" onchange="this.form.submit()" style="padding:9px 12px;font-size:13px;">
        <option value="">All Statuses</option>
        <option value="unpaid"  {{#if (eq filters.status 'unpaid')}}selected{{/if}}>Unpaid</option>
        <option value="partial" {{#if (eq filters.status 'partial')}}selected{{/if}}>Partially Paid</option>
        <option value="paid"    {{#if (eq filters.status 'paid')}}selected{{/if}}>Paid</option>
      </select>
    </div>
    <div class="filter-group">
      <label class="filter-label">Search</label>
      <input type="text" name="search" placeholder="Invoice # or client name…" class="form-input" style="padding:9px 12px;font-size:13px;" value="{{filters.search}}">
    </div>
    <div style="display:flex;gap:8px;align-items:flex-end;padding-bottom:1px">
      <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search"></i> Search</button>
      <a href="/web/invoices" class="btn btn-ghost btn-sm"><i class="fas fa-redo"></i> Reset</a>
    </div>
  </form>
</div>

<!-- Desktop Table -->
<div class="card" style="display:none;" id="desktopTable">
  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Invoice #</th>
          <th>Client</th>
          <th>Date</th>
          <th>Amount</th>
          <th>Status</th>
          <th style="text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each invoices}}
          <tr onclick="window.location.href='/web/invoices/{{this._id}}'">
            <td>
              <span class="td-primary td-mono">{{this.number}}</span>
            </td>
            <td>
              <span class="td-primary">{{this.clientName}}</span>
            </td>
            <td>
              <span class="td-mono" style="font-size:12px">{{formatDate this.createdAt}}</span>
            </td>
            <td>
              <span class="td-primary td-mono">{{this.currency}} {{this.total}}</span>
              {{#if (gt this.amountPaid 0)}}
                <div class="td-sub">Paid: {{this.currency}} {{this.amountPaid}}</div>
              {{/if}}
            </td>
            <td>
              {{#if (eq this.status 'paid')}}
                <span class="badge badge-green">Paid</span>
              {{else if (eq this.status 'partial')}}
                <span class="badge badge-amber">Partial</span>
              {{else}}
                <span class="badge badge-red">Unpaid</span>
              {{/if}}
            </td>
            <td style="text-align:right" onclick="event.stopPropagation()">
              <div class="td-actions" style="justify-content:flex-end">
                <a href="/web/invoices/{{this._id}}" class="btn btn-ghost btn-icon btn-sm" title="View">
                  <i class="fas fa-eye"></i>
                </a>
                <button onclick="downloadPDF('{{this._id}}')" class="btn btn-ghost btn-icon btn-sm" title="Download PDF">
                  <i class="fas fa-download" style="color:var(--green)"></i>
                </button>
                {{#if (or (eq ../user.role 'owner') (eq ../user.role 'manager'))}}
                  {{#if (ne this.status 'paid')}}
                    <button onclick="confirmDelete('{{this._id}}')" class="btn btn-icon btn-sm btn-danger" title="Delete">
                      <i class="fas fa-trash"></i>
                    </button>
                  {{/if}}
                {{/if}}
              </div>
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="6">
              <div class="empty-state">
                <i class="fas fa-file-invoice"></i>
                <h3>No invoices yet</h3>
                <p>Create your first invoice to start tracking payments.</p>
                <a href="/web/invoices/create" class="btn btn-primary"><i class="fas fa-plus"></i> Create Invoice</a>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<!-- Mobile Cards -->
<div id="mobileCards" style="display:none">
  {{#each invoices}}
    <div class="card" style="margin-bottom:12px;padding:16px;cursor:pointer" onclick="window.location.href='/web/invoices/{{this._id}}'">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px">
        <div>
          <div class="td-primary td-mono" style="font-size:14px">{{this.number}}</div>
          <div style="font-size:13px;color:var(--muted);margin-top:3px">{{this.clientName}}</div>
        </div>
        {{#if (eq this.status 'paid')}}
          <span class="badge badge-green">Paid</span>
        {{else if (eq this.status 'partial')}}
          <span class="badge badge-amber">Partial</span>
        {{else}}
          <span class="badge badge-red">Unpaid</span>
        {{/if}}
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <span class="td-mono" style="font-size:12px;color:var(--muted-2)">{{formatDate this.createdAt}}</span>
        <span class="td-primary td-mono">{{this.currency}} {{this.total}}</span>
      </div>
      {{#if (gt this.amountPaid 0)}}
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--muted-2);padding-bottom:10px;border-bottom:1px solid var(--border);margin-bottom:10px">
          <span>Paid: {{this.currency}} {{this.amountPaid}}</span>
          <span>Balance: {{this.currency}} {{this.balance}}</span>
        </div>
      {{/if}}
      <div style="display:flex;gap:8px" onclick="event.stopPropagation()">
        <a href="/web/invoices/{{this._id}}" class="btn btn-ghost btn-sm" style="flex:1;justify-content:center"><i class="fas fa-eye"></i> View</a>
        <button onclick="downloadPDF('{{this._id}}')" class="btn btn-ghost btn-sm" style="flex:1;justify-content:center;color:var(--green)"><i class="fas fa-download"></i> PDF</button>
        {{#if (or (eq ../user.role 'owner') (eq ../user.role 'manager'))}}
          {{#if (ne this.status 'paid')}}
            <button onclick="confirmDelete('{{this._id}}')" class="btn btn-danger btn-sm" style="flex:1;justify-content:center"><i class="fas fa-trash"></i> Delete</button>
          {{/if}}
        {{/if}}
      </div>
    </div>
  {{else}}
    <div class="card">
      <div class="empty-state">
        <i class="fas fa-file-invoice"></i>
        <h3>No invoices yet</h3>
        <p>Create your first invoice to start tracking payments.</p>
        <a href="/web/invoices/create" class="btn btn-primary"><i class="fas fa-plus"></i> Create Invoice</a>
      </div>
    </div>
  {{/each}}
</div>

<!-- Pagination -->
{{#if (gt pagination.totalPages 1)}}
  <div class="pagination">
    {{#if pagination.hasPrev}}
      <a href="?page={{math pagination.currentPage '-' 1}}{{#if filters.status}}&status={{filters.status}}{{/if}}{{#if filters.search}}&search={{filters.search}}{{/if}}">
        <i class="fas fa-chevron-left"></i>
      </a>
    {{/if}}
    <span class="page-info">{{pagination.currentPage}} / {{pagination.totalPages}}</span>
    {{#if pagination.hasNext}}
      <a href="?page={{math pagination.currentPage '+' 1}}{{#if filters.status}}&status={{filters.status}}{{/if}}{{#if filters.search}}&search={{filters.search}}{{/if}}">
        <i class="fas fa-chevron-right"></i>
      </a>
    {{/if}}
  </div>
{{/if}}

<!-- Delete Confirm Modal -->
<div class="modal-backdrop" id="deleteModal">
  <div class="modal" style="max-width:400px">
    <div class="modal-header">
      <div class="modal-title"><i class="fas fa-exclamation-triangle" style="color:var(--red)"></i> Delete Invoice</div>
      <button class="modal-close" onclick="closeModal('deleteModal')"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <p style="font-size:14px;color:var(--muted);line-height:1.6">This action cannot be undone. The invoice and all associated payment records will be permanently removed.</p>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('deleteModal')">Cancel</button>
      <button class="btn btn-danger" id="confirmDeleteBtn" onclick="executeDelete()">
        <i class="fas fa-trash"></i> Delete Invoice
      </button>
    </div>
  </div>
</div>

<script>
  // Responsive table/card toggle
  function layoutToggle() {
    const isMobile = window.innerWidth < 768;
    document.getElementById('desktopTable').style.display = isMobile ? 'none' : 'block';
    document.getElementById('mobileCards').style.display = isMobile ? 'block' : 'none';
  }
  layoutToggle();
  window.addEventListener('resize', layoutToggle);

  // PDF Download
  async function downloadPDF(id) {
    try {
      const r = await fetch(`/web/invoices/${id}/pdf`);
      const d = await r.json();
      if (d.url) window.open(d.url, '_blank');
      else showToast('Failed to generate PDF', 'error');
    } catch { showToast('Failed to download PDF', 'error'); }
  }

  // Delete
  let _deleteId = null;
  function confirmDelete(id) {
    _deleteId = id;
    openModal('deleteModal');
  }

  async function executeDelete() {
    if (!_deleteId) return;
    const btn = document.getElementById('confirmDeleteBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Deleting…';
    try {
      const r = await fetch(`/web/invoices/${_deleteId}`, { method:'DELETE' });
      if (r.ok) { showToast('Invoice deleted', 'success'); setTimeout(()=>window.location.reload(), 800); }
      else { const d=await r.json(); showToast(d.error||'Failed to delete', 'error'); btn.disabled=false; btn.innerHTML='<i class="fas fa-trash"></i> Delete Invoice'; }
    } catch { showToast('Failed to delete invoice', 'error'); btn.disabled=false; btn.innerHTML='<i class="fas fa-trash"></i> Delete Invoice'; }
  }
</script>