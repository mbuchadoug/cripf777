{{!-- views/web/dashboard.hbs --}}

{{!-- Page header --}}
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-sm text-gray-500 mt-1">Welcome back · {{user.phone}}</p>
  </div>
  <div class="mt-4 sm:mt-0 flex items-center gap-3">
    <a href="/web/invoices/create?type=invoice"
       class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
      <i class="fas fa-plus"></i> New Invoice
    </a>
    {{#if isOwner}}
    <a href="/web/branches"
       class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
      <i class="fas fa-code-branch"></i> Branches
    </a>
    {{/if}}
  </div>
</div>

{{!-- KPI Cards --}}
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Today</span>
      <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center">
        <i class="fas fa-calendar-day text-blue-600 text-sm"></i>
      </div>
    </div>
    <p class="text-2xl font-bold text-gray-900">{{user.currency}} {{stats.todayRevenue}}</p>
    <p class="text-xs text-gray-500 mt-1">Revenue today</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">This Month</span>
      <div class="w-9 h-9 bg-green-50 rounded-lg flex items-center justify-center">
        <i class="fas fa-chart-line text-green-600 text-sm"></i>
      </div>
    </div>
    <p class="text-2xl font-bold text-gray-900">{{user.currency}} {{stats.monthRevenue}}</p>
    <p class="text-xs mt-1 {{#if (gt stats.growth 0)}}text-green-600{{else}}text-red-500{{/if}}">
      <i class="fas fa-arrow-{{#if (gt stats.growth 0)}}up{{else}}down{{/if}} mr-1"></i>{{stats.growth}}% vs last month
    </p>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Outstanding</span>
      <div class="w-9 h-9 bg-amber-50 rounded-lg flex items-center justify-center">
        <i class="fas fa-file-invoice-dollar text-amber-600 text-sm"></i>
      </div>
    </div>
    <p class="text-2xl font-bold text-gray-900">{{stats.unpaidInvoices}}</p>
    <p class="text-xs text-gray-500 mt-1">{{stats.paidInvoices}} paid this month</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Clients</span>
      <div class="w-9 h-9 bg-purple-50 rounded-lg flex items-center justify-center">
        <i class="fas fa-users text-purple-600 text-sm"></i>
      </div>
    </div>
    <p class="text-2xl font-bold text-gray-900">{{stats.totalClients}}</p>
    <p class="text-xs text-gray-500 mt-1">{{stats.totalProducts}} active products</p>
  </div>

</div>

{{!-- Revenue Chart + Recent Invoices --}}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

  <div class="lg:col-span-2 bg-white rounded-xl border border-gray-100 shadow-sm p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-semibold text-gray-800">Revenue - Last 30 Days</h2>
      {{#if isOwner}}
      <select id="chartBranchFilter" onchange="loadChart(this.value)"
              class="text-xs border border-gray-200 rounded-lg px-3 py-1.5 text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
        <option value="">All Branches</option>
        {{#each branchPerformance}}
          <option value="{{this._id}}">{{this.name}}</option>
        {{/each}}
      </select>
      {{/if}}
    </div>
    <div style="height:280px; position:relative;">
      <canvas id="revenueChart"></canvas>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-semibold text-gray-800">Recent Invoices</h2>
      <a href="/web/invoices" class="text-xs text-blue-600 hover:underline">View all</a>
    </div>
    <div class="space-y-3">
      {{#each recentInvoices}}
        <a href="/web/invoices/{{this._id}}"
           class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 transition-colors group">
          <div class="min-w-0">
            <p class="text-sm font-medium text-gray-800 truncate">{{this.number}}</p>
            <p class="text-xs text-gray-500 truncate">{{this.clientName}}</p>
          </div>
          <div class="text-right ml-3 flex-shrink-0">
            <p class="text-sm font-semibold text-gray-900">{{this.total}}</p>
            <span class="inline-block px-2 py-0.5 text-xs rounded-full font-medium
              {{#if (eq this.status 'paid')}}bg-green-100 text-green-700
              {{else if (eq this.status 'partial')}}bg-amber-100 text-amber-700
              {{else}}bg-red-100 text-red-700{{/if}}">
              {{this.status}}
            </span>
          </div>
        </a>
      {{else}}
        <div class="text-center py-10 text-gray-400">
          <i class="fas fa-file-invoice text-3xl mb-3"></i>
          <p class="text-sm">No invoices yet</p>
        </div>
      {{/each}}
    </div>
  </div>

</div>

{{!-- Branch Performance (owners only) --}}
{{#if isOwner}}
{{#if branchPerformance.length}}
<div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 mb-8">
  <div class="flex items-center justify-between mb-5">
    <h2 class="font-semibold text-gray-800">Branch Performance — This Month</h2>
    <a href="/web/branches" class="text-xs text-blue-600 hover:underline">Full details</a>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-100">
          <th class="text-left pb-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Branch</th>
          <th class="text-right pb-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Revenue</th>
          <th class="text-right pb-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Collected</th>
          <th class="text-right pb-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Expenses</th>
          <th class="text-right pb-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Unpaid</th>
          <th class="text-right pb-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Staff</th>
          <th class="pb-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        {{#each branchPerformance}}
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="py-3 font-medium text-gray-800">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-blue-400"></div>
              {{this.name}}
            </div>
          </td>
          <td class="py-3 text-right text-gray-700">{{../user.currency}} {{this.revenue}}</td>
          <td class="py-3 text-right text-green-600 font-medium">{{../user.currency}} {{this.collected}}</td>
          <td class="py-3 text-right text-red-500">{{../user.currency}} {{this.expenses}}</td>
          <td class="py-3 text-right">
            {{#if this.unpaidCount}}
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                {{this.unpaidCount}}
              </span>
            {{else}}
              <span class="text-gray-400">0</span>
            {{/if}}
          </td>
          <td class="py-3 text-right text-gray-500">{{this.userCount}}</td>
          <td class="py-3 text-right">
            <a href="/web/branches/{{this._id}}"
               class="text-xs text-blue-600 hover:underline">View</a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
{{/if}}
{{/if}}

{{!-- Quick Actions --}}
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
  <a href="/web/invoices/create?type=invoice"
     class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow text-center group">
    <div class="w-11 h-11 bg-blue-50 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:bg-blue-100 transition-colors">
      <i class="fas fa-file-invoice text-blue-600"></i>
    </div>
    <p class="text-sm font-medium text-gray-700">New Invoice</p>
  </a>
  <a href="/web/clients"
     class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow text-center group">
    <div class="w-11 h-11 bg-purple-50 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:bg-purple-100 transition-colors">
      <i class="fas fa-users text-purple-600"></i>
    </div>
    <p class="text-sm font-medium text-gray-700">Clients</p>
  </a>
  <a href="/web/reports"
     class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow text-center group">
    <div class="w-11 h-11 bg-amber-50 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:bg-amber-100 transition-colors">
      <i class="fas fa-chart-bar text-amber-600"></i>
    </div>
    <p class="text-sm font-medium text-gray-700">Reports</p>
  </a>
  {{#if isOwner}}
  <a href="/web/users"
     class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow text-center group">
    <div class="w-11 h-11 bg-emerald-50 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:bg-emerald-100 transition-colors">
      <i class="fas fa-user-plus text-emerald-600"></i>
    </div>
    <p class="text-sm font-medium text-gray-700">Team</p>
  </a>
  {{else}}
  <a href="/web/files"
     class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow text-center group">
    <div class="w-11 h-11 bg-emerald-50 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:bg-emerald-100 transition-colors">
      <i class="fas fa-folder-open text-emerald-600"></i>
    </div>
    <p class="text-sm font-medium text-gray-700">Files</p>
  </a>
  {{/if}}
</div>

<script>
const currency = '{{user.currency}}';

function loadChart(branchId) {
  const url = branchId
    ? `/web/api/revenue-chart?branchId=${branchId}`
    : '/web/api/revenue-chart';

  fetch(url)
    .then(r => r.json())
    .then(data => {
      if (window._chart) window._chart.destroy();
      const ctx = document.getElementById('revenueChart').getContext('2d');
      window._chart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: data.map(d => {
            const dt = new Date(d.date);
            return dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
          }),
          datasets: [{
            label: 'Revenue',
            data: data.map(d => d.revenue),
            borderColor: '#3b82f6',
            backgroundColor: 'rgba(59,130,246,0.07)',
            borderWidth: 2,
            pointRadius: 3,
            pointHoverRadius: 5,
            tension: 0.4,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false }, tooltip: {
            callbacks: { label: ctx => `${currency} ${ctx.parsed.y.toLocaleString()}` }
          }},
          scales: {
            y: {
              beginAtZero: true,
              grid: { color: 'rgba(0,0,0,0.04)' },
              ticks: { callback: v => `${currency} ${v.toLocaleString()}`, font: { size: 11 } }
            },
            x: { grid: { display: false }, ticks: { font: { size: 11 } } }
          }
        }
      });
    })
    .catch(err => console.error('Chart error:', err));
}

loadChart('');
</script>
