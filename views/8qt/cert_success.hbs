{{!-- views/8qt/cert_success.hbs (Post-Stripe success page) --}}
{{!-- Rendered inside main.hbs layout — no DOCTYPE/html/head/body tags here --}}

<style>
  .cert-success-wrap{min-height:70vh;display:flex;align-items:center;justify-content:center;padding:40px 20px}
  .cert-success-card{background:#fff;border-radius:16px;padding:56px 48px;max-width:520px;width:100%;text-align:center;box-shadow:0 8px 32px rgba(30,58,95,.1);border:1px solid #E9ECEF}
  .cert-success-check{width:72px;height:72px;background:#ecfdf5;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 24px}
  .cert-success-card h1{font-family:'Crimson Pro',serif;font-size:2rem;color:#1E3A5F;margin-bottom:12px}
  .cert-success-card p{font-size:.9rem;color:#495057;line-height:1.7;margin-bottom:16px}
  .cert-detail-box{background:#F8F9FA;border-radius:8px;padding:16px;margin:24px 0;font-size:.85rem;color:#495057;text-align:left;line-height:1.8;border:1px solid #E9ECEF}
  .cert-detail-box strong{color:#1E3A5F}
  .cert-success-btn{display:inline-block;padding:.8rem 1.8rem;background:#1E3A5F;color:#fff;border-radius:8px;font-weight:600;text-decoration:none;margin:4px;font-size:.9rem;transition:background .2s}
  .cert-success-btn:hover{background:#0F1C2E;color:#fff}
  .cert-success-btn-outline{background:transparent;color:#1E3A5F;border:2px solid #1E3A5F}
  .cert-success-btn-outline:hover{background:#F8F9FA;color:#1E3A5F}
</style>

<div class="cert-success-wrap">
  <div class="cert-success-card">
    <div class="cert-success-check">✅</div>
    <h1>Payment Confirmed</h1>
    <p>{{message}}</p>

    <div class="cert-detail-box">
      <strong>What happens next:</strong><br>
      1. Your certificate is being generated now<br>
      2. It will be emailed to <strong>{{attempt.certificateEmail}}</strong><br>
      3. You will receive a PDF and a unique verification link<br>
      4. Delivery typically takes 2–5 minutes
    </div>

    <p style="font-size:.8rem;color:#495057;opacity:.7">
      If you don't receive your email within 15 minutes, check your spam folder.
      Your archetype was: <strong>{{attempt.archetypeName}}</strong>
    </p>

    <a href="/8qt/results/{{attempt._id}}" class="cert-success-btn">View My Results</a>
    <a href="/8qt" class="cert-success-btn cert-success-btn-outline">Back to 8QT Home</a>
  </div>
</div>
