{{!-- views/8qt/cert_success.hbs (Post-Stripe success page) --}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Payment Confirmed - CRIPFCnt 8QT</title>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root{--navy:#1E3A5F;--gold:#C9A961;--white:#fff;--light:#F8F9FA;--border:#E9ECEF;--dark:#495057;--green:#059669}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:var(--light);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
    .card{background:var(--white);border-radius:16px;padding:56px 48px;max-width:520px;width:100%;text-align:center;box-shadow:0 8px 32px rgba(30,58,95,.1)}
    .check{width:72px;height:72px;background:#ecfdf5;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 24px}
    h1{font-family:'Crimson Pro',serif;font-size:2rem;color:var(--navy);margin-bottom:12px}
    p{font-size:.9rem;color:var(--dark);line-height:1.7;margin-bottom:16px}
    .detail-box{background:var(--light);border-radius:8px;padding:16px;margin:24px 0;font-size:.85rem;color:var(--dark);text-align:left;line-height:1.8}
    .detail-box strong{color:var(--navy)}
    .btn{display:inline-block;padding:.8rem 1.8rem;background:var(--navy);color:var(--white);border-radius:8px;font-weight:600;text-decoration:none;margin:4px;font-size:.9rem;transition:background .2s}
    .btn:hover{background:#0F1C2E}
    .btn-outline{background:transparent;color:var(--navy);border:2px solid var(--navy)}
    .btn-outline:hover{background:var(--light)}
  </style>
</head>
<body>
<div class="card">
  <div class="check">✅</div>
  <h1>Payment Confirmed</h1>
  <p>{{message}}</p>
  <div class="detail-box">
    <strong>What happens next:</strong><br>
    1. Your certificate is being generated now<br>
    2. It will be emailed to <strong>{{attempt.certificateEmail}}</strong><br>
    3. You will receive a PDF and a unique verification link<br>
    4. Delivery typically takes 2–5 minutes
  </div>
  <p style="font-size:.8rem;color:var(--dark);opacity:.7">
    If you don't receive your email within 15 minutes, check your spam folder.
    Your archetype was: <strong>{{attempt.archetypeName}}</strong>
  </p>
  <a href="/8qt/results/{{attempt._id}}" class="btn">View My Results</a>
  <a href="/8qt" class="btn btn-outline">Back to 8QT Home</a>
</div>
</body>
</html>

