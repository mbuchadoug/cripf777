{{!-- views/8qt/cert_request.hbs (STEP 7 - Certificate Request) --}}
{{!-- Rendered inside main.hbs layout - no DOCTYPE/html/head/body tags here --}}

<style>
  .cert-req-wrap{max-width:620px;margin:0 auto;padding:40px 20px 80px}
  .cert-req-back{display:inline-flex;align-items:center;gap:6px;color:#1E3A5F;text-decoration:none;font-size:.85rem;font-weight:500;margin-bottom:24px}
  .cert-req-card{background:#fff;border-radius:16px;padding:40px;box-shadow:0 8px 32px rgba(30,58,95,.08);border:1px solid #E9ECEF}
  .cert-preview-block{background:linear-gradient(135deg,#1E3A5F,#0F1C2E);border-radius:10px;padding:24px;text-align:center;margin-bottom:32px;color:#fff}
  .cert-preview-block .cp-label{font-size:.65rem;letter-spacing:3px;text-transform:uppercase;color:#C9A961;font-weight:600;margin-bottom:8px}
  .cert-preview-block .cp-arch{font-family:'Crimson Pro',serif;font-size:1.4rem;font-weight:700;margin-bottom:4px}
  .cert-preview-block .cp-sub{font-size:.8rem;color:#E5D4A6;opacity:.8}
  .cert-req-card h2{font-family:'Crimson Pro',serif;font-size:1.8rem;color:#1E3A5F;margin-bottom:8px}
  .cert-req-subtitle{font-size:.9rem;color:#495057;margin-bottom:28px;line-height:1.6}
  .cert-req-fg{margin-bottom:18px}
  .cert-req-fg label{display:block;font-size:.8rem;font-weight:600;color:#1E3A5F;margin-bottom:6px}
  .cert-req-fg .req{color:#dc2626}
  .cert-req-fg input[type=text],
  .cert-req-fg input[type=email],
  .cert-req-fg input[type=password]{width:100%;padding:.7rem .9rem;border:1.5px solid #E9ECEF;border-radius:8px;font-family:'Inter',sans-serif;font-size:.9rem;color:#212529;transition:border-color .2s;outline:none}
  .cert-req-fg input:focus{border-color:#1E3A5F}
  .tier-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
  .tier-card{border:2px solid #E9ECEF;border-radius:10px;padding:16px;cursor:pointer;transition:all .15s;text-align:center;background:#fff}
  .tier-card:hover{border-color:#1E3A5F}
  .tier-card.selected{border-color:#C9A961;background:#fdf8ef}
  .tier-card input[type=radio]{display:none}
  .tier-price{font-size:1.4rem;font-weight:700;color:#1E3A5F;margin-bottom:4px}
  .tier-name{font-size:.8rem;font-weight:600;color:#495057;margin-bottom:6px;text-transform:uppercase;letter-spacing:1px}
  .tier-features{font-size:.75rem;color:#495057;line-height:1.6}
  .cert-divider{border:none;border-top:1px solid #E9ECEF;margin:24px 0}
  .checkbox-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:16px}
  .checkbox-row input{margin-top:3px;flex-shrink:0}
  .checkbox-row label{font-size:.85rem;color:#495057;font-weight:400;margin-bottom:0}
  .convert-section{background:#F8F9FA;border-radius:8px;padding:16px;margin-bottom:20px}
  .convert-section h4{font-size:.85rem;font-weight:600;color:#1E3A5F;margin-bottom:4px}
  .convert-section p{font-size:.78rem;color:#495057;margin-bottom:12px}
  .cert-submit-btn{width:100%;padding:.9rem;background:#1E3A5F;color:#fff;border:none;border-radius:8px;font-family:'Inter',sans-serif;font-size:1rem;font-weight:600;cursor:pointer;transition:background .2s;margin-top:8px}
  .cert-submit-btn:hover{background:#0F1C2E}
  .cert-security-note{text-align:center;font-size:.75rem;color:#495057;margin-top:12px;opacity:.7}
  .cert-error{background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:10px 14px;color:#dc2626;font-size:.85rem;margin-bottom:16px}
</style>

<div class="cert-req-wrap">
  <a href="/8qt/results/{{attempt._id}}" class="cert-req-back">← Back to Results</a>

  <div class="cert-req-card">

    <div class="cert-preview-block">
      <div class="cp-label">Official Certificate</div>
      <div class="cp-arch">{{attempt.archetypeName}}</div>
      <div class="cp-sub">CRIPFCnt 8 Quotients Assessment · {{attempt.dominantQuotient}} Dominant</div>
    </div>

    <h2>Request Your Certificate</h2>
    <p class="cert-req-subtitle">
      Your certificate will include your full quotient scores, archetype profile, and a unique
      verification code. It will be emailed to you as a high-quality PDF.
    </p>

    {{#if error}}<div class="cert-error">{{error}}</div>{{/if}}

    <div style="margin-bottom:8px">
      <label style="display:block;font-size:.8rem;font-weight:600;color:#1E3A5F;margin-bottom:6px">
        Choose your certificate tier
      </label>
    </div>
    <div class="tier-grid">
      <div class="tier-card selected" id="tier-standard" onclick="selectTier('standard')">
        <input type="radio" name="tier" value="standard" checked>
        <div class="tier-price">${{prices.standard}}</div>
        <div class="tier-name">Standard</div>
        <div class="tier-features">PDF certificate<br>All 8 scores<br>Verification code<br>Public verify link</div>
      </div>
      <div class="tier-card" id="tier-premium" onclick="selectTier('premium')">
        <input type="radio" name="tier" value="premium">
        <div class="tier-price">${{prices.premium}}</div>
        <div class="tier-name">Premium</div>
        <div class="tier-features">Everything in Standard<br>Embossed design<br>QR verification code<br>Priority email</div>
      </div>
    </div>

    <hr class="cert-divider">

    <div class="cert-req-fg">
      <label for="crFullName">Full name as it should appear on certificate <span class="req">*</span></label>
      <input type="text" id="crFullName" placeholder="e.g. Tendai Moyo"
             value="{{#if attempt.profile.firstName}}{{attempt.profile.firstName}}{{/if}}">
    </div>
    <div class="cert-req-fg">
      <label for="crEmail">Email address for delivery <span class="req">*</span></label>
      <input type="email" id="crEmail" placeholder="your@email.com"
             value="{{#if attempt.certificateEmail}}{{attempt.certificateEmail}}{{/if}}">
    </div>
    <div class="cert-req-fg">
      <label for="crOrg">Organisation or institution (optional)</label>
      <input type="text" id="crOrg" placeholder="e.g. Ministry of Education, Harare">
    </div>

    <div class="checkbox-row">
      <input type="checkbox" id="crPublic">
      <label for="crPublic">
        Allow my full quotient scores to be visible on the public verification page
        (name and archetype are always shown)
      </label>
    </div>

    {{#unless user}}
    <div class="convert-section">
      <h4>Save your results permanently (optional)</h4>
      <p>Set a password to convert your anonymous session into a registered account. You can skip this.</p>
      <div class="cert-req-fg" style="margin-bottom:0">
        <label>Password (min 8 characters) - leave blank to stay anonymous</label>
        <input type="password" id="crPassword" placeholder="Optional - create account to save results">
      </div>
    </div>
    {{/unless}}

    <button class="cert-submit-btn" onclick="submitCertRequest()">Proceed to Payment →</button>
    <p class="cert-security-note">🔒 Secured by Stripe - your payment details never touch our servers</p>

  </div>
</div>

<script>
let selectedTier = 'standard';

function selectTier(tier) {
  selectedTier = tier;
  document.querySelectorAll('.tier-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('tier-' + tier).classList.add('selected');
}

async function submitCertRequest() {
  const fullName  = document.getElementById('crFullName').value.trim();
  const email     = document.getElementById('crEmail').value.trim();
  const orgName   = document.getElementById('crOrg')?.value.trim() || '';
  const makePublic = document.getElementById('crPublic')?.checked || false;
  const password  = document.getElementById('crPassword')?.value || '';

  if (!fullName) { alert('Please enter your full name as it should appear on the certificate.'); return; }
  if (!email || !email.includes('@')) { alert('Please enter a valid email address.'); return; }

  const btn = document.querySelector('.cert-submit-btn');
  btn.textContent = 'Processing…';
  btn.disabled = true;

  try {
    const r = await fetch('/8qt/certificate/{{attempt._id}}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ fullName, email, orgName, tier: selectedTier, makePublic, password })
    });
    const d = await r.json();
    if (d.ok && d.redirect) {
      window.location.href = d.redirect;
    } else {
      alert(d.error || 'Something went wrong. Please try again.');
      btn.textContent = 'Proceed to Payment →';
      btn.disabled = false;
    }
  } catch (e) {
    alert('Network error. Please try again.');
    btn.textContent = 'Proceed to Payment →';
    btn.disabled = false;
  }
}
</script>
