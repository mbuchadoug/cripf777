  <meta property="og:site_name" content="CRIPFCnt" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="CRIPFCnt | Recalibrating Intelligence &amp; Society" />
  <meta property="og:description" content="CRIPFCnt: an eight-pillar framework and life manual redefining consciousness, responsibility and interpretation for the data age." />
  <meta property="og:url" content="{{siteUrl}}{{canonicalPath}}" />
  <meta property="og:image" content="{{siteUrl}}/static/img/logo.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="CRIPFCnt | Recalibrating Intelligence &amp; Society" />
  <meta name="twitter:description" content="CRIPFCnt | an eight-pillar framework and life manual for society, leadership." />
  <meta name="twitter:image" content="{{siteUrl}}/static/img/logo.png" />

  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"CRIPFCnt","url":"{{siteUrl}}","logo":"{{siteUrl}}/static/img/logo.png"}</script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    /* ── DESIGN TOKENS ───────────────────────────────────────────── */
    :root {
      --navy:         #1E3A5F;
      --navy-dark:    #0F1C2E;
      --gold:         #C9A961;
      --gold-light:   #E5D4A6;
      --white:        #FFFFFF;
      --light-gray:   #F8F9FA;
      --medium-gray:  #E9ECEF;
      --dark-gray:    #495057;
      --text-primary: #212529;
      --font-serif:   'Crimson Pro', serif;
      --font-sans:    'Inter', sans-serif;
      --shadow-sm:    0 2px 8px rgba(30,58,95,0.08);
      --shadow-md:    0 4px 16px rgba(30,58,95,0.12);
      --shadow-lg:    0 8px 32px rgba(30,58,95,0.16);
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { overflow-x:hidden; scroll-behavior:smooth; }
    body { font-family:var(--font-sans); color:var(--text-primary); line-height:1.7; background:var(--white); -webkit-font-smoothing:antialiased; overflow-x:hidden; }

    /* ── NAVBAR ─────────────────────────────────────────────────── */
    .navbar { background:var(--white); border-bottom:1px solid var(--medium-gray); padding:1.5rem 5%; position:sticky; top:0; z-index:1000; box-shadow:var(--shadow-sm); }
    .nav-container { max-width:1400px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; }
    .logo { display:flex; align-items:center; gap:1rem; text-decoration:none; z-index:1001; }
    .logo-icon { width:48px; height:48px; background:var(--navy); display:flex; align-items:center; justify-content:center; font-family:var(--font-serif); font-weight:700; font-size:1.4rem; color:var(--gold); border:2px solid var(--gold); flex-shrink:0; }
    .logo-text { font-family:var(--font-serif); font-size:1.8rem; font-weight:700; color:var(--navy); letter-spacing:-0.5px; }
    .nav-links { display:flex; gap:2.5rem; list-style:none; align-items:center; }
    .nav-links a { font-size:0.95rem; font-weight:500; color:var(--text-primary); text-decoration:none; transition:color 0.3s; letter-spacing:0.3px; }
    .nav-links a:hover { color:var(--navy); }
    .nav-cta { background:var(--navy); color:var(--white) !important; padding:0.75rem 1.75rem; border-radius:4px; font-weight:600; transition:all 0.3s; }
    .nav-cta:hover { background:var(--navy-dark) !important; }

    /* user pill */
    .user-pill { display:inline-flex; align-items:center; gap:0.6rem; padding:0.45rem 0.75rem; border:1px solid var(--medium-gray); background:var(--light-gray); border-radius:999px; font-size:0.9rem; max-width:260px; }
    .user-pill .user-email { max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .user-pill .user-photo { width:28px; height:28px; border-radius:50%; object-fit:cover; border:1px solid var(--medium-gray); flex-shrink:0; }
    .nav-signout { background:transparent; border:1px solid var(--medium-gray); padding:0.55rem 0.9rem; border-radius:8px; font-weight:600; text-decoration:none; white-space:nowrap; color:var(--text-primary); transition:background 0.2s; }
    .nav-signout:hover { background:var(--light-gray); }
    .nav-auth { display:inline-flex; align-items:center; gap:0.75rem; }

    /* LMS dropdown */
    .nav-item.dropdown { position:relative; }
    .dropdown-toggle { display:inline-flex; align-items:center; gap:0.35rem; cursor:pointer; }
    .caret { font-size:0.75rem; opacity:0.8; transition:transform 0.2s; }
    .nav-item.dropdown.open .caret { transform:rotate(180deg); }
    .dropdown-menu { position:absolute; top:calc(100% + 8px); left:0; min-width:320px; background:var(--white); border:1px solid var(--medium-gray); box-shadow:var(--shadow-md); padding:0.6rem; border-radius:10px; opacity:0; visibility:hidden; transform:translateY(-10px); transition:all 0.2s ease; z-index:2000; pointer-events:none; }
    .nav-item.dropdown::after { content:''; position:absolute; top:100%; left:0; right:0; height:12px; display:none; }
    .nav-item.dropdown:hover::after, .nav-item.dropdown:focus-within::after { display:block; }
    .nav-item.dropdown:hover .dropdown-menu, .nav-item.dropdown:focus-within .dropdown-menu { opacity:1; visibility:visible; transform:translateY(0); pointer-events:auto; }
    .dropdown-link { display:block; text-decoration:none; padding:0.85rem 0.9rem; border-radius:8px; transition:background 0.2s, transform 0.2s; color:var(--text-primary); }
    .dropdown-link:hover { background:var(--light-gray); transform:translateY(-1px); }
    .dd-title { font-weight:700; color:var(--navy); font-size:0.95rem; line-height:1.25; }
    .dd-sub { margin-top:0.25rem; font-size:0.82rem; color:#6b7280; line-height:1.3; }

    /* mobile toggle */
    .mobile-menu-toggle { display:none; flex-direction:column; gap:5px; background:none; border:none; cursor:pointer; padding:0.5rem; z-index:1001; }
    .mobile-menu-toggle span { width:28px; height:3px; background:var(--navy); transition:all 0.3s; border-radius:2px; display:block; }
    .mobile-menu-toggle.active span:nth-child(1) { transform:rotate(45deg) translate(8px,8px); }
    .mobile-menu-toggle.active span:nth-child(2) { opacity:0; }
    .mobile-menu-toggle.active span:nth-child(3) { transform:rotate(-45deg) translate(7px,-7px); }

    /* ── HERO ────────────────────────────────────────────────────── */
    .hero { background:linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%); padding:8rem 5% 6rem; position:relative; overflow:hidden; }
    .hero::before { content:''; position:absolute; top:0; right:0; width:50%; height:100%; background:linear-gradient(90deg, transparent, rgba(201,169,97,0.05)); }
    .hero-container { max-width:1400px; margin:0 auto; position:relative; z-index:1; }
    .hero-badge { display:inline-block; background:rgba(201,169,97,0.15); color:var(--gold-light); padding:0.5rem 1.25rem; border-radius:30px; font-size:0.85rem; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:2rem; border:1px solid rgba(201,169,97,0.3); }
    .hero h1 { font-family:var(--font-serif); font-size:clamp(2.5rem,5vw,4.5rem); font-weight:700; color:var(--white); line-height:1.15; margin-bottom:1.5rem; max-width:900px; }
    .hero h1 em { font-style:italic; color:var(--gold); }
    .hero-subtitle { font-size:1.2rem; color:rgba(255,255,255,0.85); max-width:680px; margin-bottom:2.5rem; line-height:1.7; }
    .hero-actions { display:flex; gap:1.25rem; flex-wrap:wrap; margin-bottom:4rem; }
    .btn { display:inline-block; padding:1rem 2.5rem; font-family:var(--font-sans); font-size:1rem; font-weight:600; border-radius:4px; text-decoration:none; transition:all 0.3s; letter-spacing:0.3px; cursor:pointer; border:none; }
    .btn-gold { background:var(--gold); color:var(--navy-dark); border:2px solid var(--gold); }
    .btn-gold:hover { background:var(--gold-light); border-color:var(--gold-light); }
    .btn-outline { background:transparent; color:var(--white); border:2px solid rgba(255,255,255,0.6); }
    .btn-outline:hover { background:rgba(255,255,255,0.1); border-color:var(--white); }
    .hero-stats { display:flex; gap:4rem; flex-wrap:wrap; padding-top:3rem; border-top:1px solid rgba(255,255,255,0.1); }
    .stat-item { display:flex; flex-direction:column; }
    .stat-number { font-family:var(--font-serif); font-size:2.5rem; font-weight:700; color:var(--gold); margin-bottom:0.25rem; }
    .stat-label { font-size:0.85rem; color:rgba(255,255,255,0.65); text-transform:uppercase; letter-spacing:1px; }

    /* ── TRUST BAR ───────────────────────────────────────────────── */
    .trust-bar { background:var(--light-gray); padding:2.5rem 5%; border-bottom:1px solid var(--medium-gray); }
    .trust-container { max-width:1400px; margin:0 auto; text-align:center; }
    .trust-title { font-size:0.8rem; font-weight:700; color:var(--dark-gray); text-transform:uppercase; letter-spacing:2px; margin-bottom:1.5rem; }
    .trust-logos { display:flex; justify-content:center; align-items:center; gap:1.5rem; flex-wrap:wrap; }
    .trust-logo { font-size:0.875rem; font-weight:600; color:var(--dark-gray); padding:0.75rem 1.5rem; background:var(--white); border:1px solid var(--medium-gray); border-radius:4px; }

    /* ── SECTIONS SHARED ─────────────────────────────────────────── */
    .section-container { max-width:1400px; margin:0 auto; }
    .section-header { text-align:center; margin-bottom:4rem; }
    .section-label { font-size:0.85rem; font-weight:700; color:var(--navy); text-transform:uppercase; letter-spacing:2px; margin-bottom:1rem; }
    .section-title { font-family:var(--font-serif); font-size:clamp(2rem,4vw,3rem); font-weight:700; color:var(--navy-dark); margin-bottom:1.25rem; line-height:1.3; }
    .section-description { font-size:1.1rem; color:var(--dark-gray); max-width:700px; margin:0 auto; line-height:1.7; }

    /* ── FRAMEWORK / PILLARS ─────────────────────────────────────── */
    .framework-section { padding:7rem 5%; background:var(--white); }
    .pillars-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; }
    .pillar-card { background:var(--white); border:1px solid var(--medium-gray); padding:2rem 1.75rem; transition:all 0.3s; position:relative; overflow:hidden; }
    .pillar-card::before { content:''; position:absolute; top:0; left:0; width:4px; height:0; background:var(--gold); transition:height 0.3s; }
    .pillar-card:hover { box-shadow:var(--shadow-md); transform:translateY(-4px); }
    .pillar-card:hover::before { height:100%; }
    .pillar-number { font-family:var(--font-serif); font-size:2.5rem; font-weight:700; color:var(--gold); opacity:0.3; margin-bottom:0.75rem; }
    .pillar-name { font-family:var(--font-serif); font-size:1.35rem; font-weight:700; color:var(--navy); margin-bottom:0.6rem; }
    .pillar-description { font-size:0.9rem; color:var(--dark-gray); line-height:1.6; }

    /* ── VIDEO SECTION ───────────────────────────────────────────── */
    .videos-section { padding:7rem 5%; background:var(--light-gray); }
    .videos-header { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:end; margin-bottom:3.5rem; }
    .videos-header .section-title { text-align:left; }
    .videos-intro { font-size:1.05rem; color:var(--dark-gray); line-height:1.75; }
    .videos-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; }
    .video-card { background:var(--white); border:1px solid var(--medium-gray); overflow:hidden; transition:all 0.3s; box-shadow:var(--shadow-sm); }
    .video-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
    .video-wrapper { position:relative; aspect-ratio:16/9; background:var(--navy-dark); overflow:hidden; }
    .video-wrapper video { width:100%; height:100%; object-fit:cover; }
    .video-episode { position:absolute; bottom:1rem; left:1rem; font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--gold-light); background:rgba(15,28,46,0.75); padding:0.25rem 0.6rem; border-radius:3px; }
    .video-body { padding:1.75rem 2rem; }
    .video-tag { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:var(--navy); margin-bottom:0.6rem; }
    .video-title { font-family:var(--font-serif); font-size:1.35rem; font-weight:700; color:var(--navy-dark); line-height:1.3; margin-bottom:0.9rem; }
    .video-desc { font-size:0.92rem; color:var(--dark-gray); line-height:1.65; margin-bottom:1.25rem; }
    .video-tags { display:flex; flex-wrap:wrap; gap:0.4rem; }
    .video-tag-pill { font-size:0.75rem; padding:0.2rem 0.65rem; border:1px solid var(--medium-gray); color:var(--dark-gray); border-radius:2px; }

    /* ── EQUATION / SCOI ─────────────────────────────────────────── */
    .equation-section { background:linear-gradient(135deg, var(--navy-dark), var(--navy)); color:var(--white); padding:7rem 5%; position:relative; overflow:hidden; }
    .equation-section::before { content:'SCOI'; position:absolute; right:-2rem; top:50%; transform:translateY(-50%); font-family:var(--font-serif); font-size:18rem; font-weight:700; color:rgba(201,169,97,0.05); pointer-events:none; line-height:1; }
    .equation-inner { display:grid; grid-template-columns:1fr 1fr; gap:6rem; align-items:center; }
    .eq-box { border:1px solid rgba(201,169,97,0.35); padding:3rem; background:rgba(255,255,255,0.03); }
    .eq-label { font-size:0.72rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:var(--gold); margin-bottom:1.75rem; }
    .eq-lines { font-family:'Inter', monospace; font-size:0.85rem; line-height:2.8; color:rgba(255,255,255,0.7); }
    .eq-lines .hl { color:var(--gold); font-size:1rem; font-weight:600; }
    .eq-lines .result { color:var(--white); font-size:1rem; font-weight:700; border-top:1px solid rgba(201,169,97,0.3); padding-top:1rem; margin-top:0.5rem; line-height:1.6; display:block; }
    .eq-vars { margin-top:2rem; display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; }
    .eq-var { padding:0.75rem; border:1px solid rgba(255,255,255,0.07); }
    .eq-var-name { font-size:0.68rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:var(--gold-light); margin-bottom:0.25rem; }
    .eq-var-def { font-size:0.8rem; color:rgba(255,255,255,0.6); }
    .eq-content .section-label { color:var(--gold); }
    .eq-content .section-title { color:var(--white); text-align:left; }
    .eq-content p { color:rgba(255,255,255,0.75); line-height:1.75; margin-bottom:1.25rem; font-size:1rem; }

    /* ── REDISTRIBUTION ──────────────────────────────────────────── */
    .redist-section { padding:7rem 5%; background:var(--white); }
    .redist-inner { display:grid; grid-template-columns:1fr 1fr; gap:5rem; }
    .redist-inner .section-title { text-align:left; }
    .redist-body { font-size:1rem; color:var(--dark-gray); line-height:1.75; margin-bottom:2rem; }
    .action-box { background:var(--navy-dark); color:var(--white); padding:2rem; }
    .action-box-title { font-family:var(--font-serif); font-size:1.2rem; margin-bottom:1.25rem; font-style:italic; color:var(--gold-light); }
    .action-list { list-style:none; display:flex; flex-direction:column; gap:0.75rem; }
    .action-list li { display:flex; align-items:flex-start; gap:0.75rem; font-size:0.95rem; color:rgba(255,255,255,0.8); }
    .action-list li::before { content:'→'; color:var(--gold); font-weight:700; flex-shrink:0; }
    .questions-list { display:flex; flex-direction:column; gap:1px; }
    .question-item { display:flex; align-items:flex-start; gap:1rem; padding:1.25rem 1.5rem; background:var(--light-gray); border-left:3px solid transparent; transition:border-color 0.2s, transform 0.2s; }
    .question-item:hover { border-left-color:var(--gold); transform:translateX(4px); }
    .q-num { font-size:0.7rem; font-weight:700; color:var(--gold); font-family:var(--font-sans); padding-top:0.2rem; flex-shrink:0; letter-spacing:0.05em; }
    .q-text { font-size:0.95rem; line-height:1.55; color:var(--text-primary); }


    /* ── VALUE PROPOSITION ───────────────────────────────────────── */
    .value-section { background:var(--light-gray); padding:7rem 5%; }
    .value-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2.5rem; margin-top:0; }
    .value-card { background:var(--white); padding:2.5rem 2rem; border-left:3px solid var(--gold); box-shadow:var(--shadow-sm); }
    .value-icon { width:56px; height:56px; background:var(--navy); border-radius:4px; display:flex; align-items:center; justify-content:center; font-size:1.6rem; margin-bottom:1.25rem; }
    .value-title { font-family:var(--font-serif); font-size:1.4rem; font-weight:700; color:var(--navy); margin-bottom:0.75rem; }
    .value-text { color:var(--dark-gray); line-height:1.7; font-size:0.95rem; }

    /* ── CTA ─────────────────────────────────────────────────────── */
    .cta-section { background:var(--navy); padding:6rem 5%; text-align:center; }
    .cta-container { max-width:800px; margin:0 auto; }
    .cta-section h2 { font-family:var(--font-serif); font-size:clamp(2rem,4vw,3rem); font-weight:700; color:var(--white); margin-bottom:1.25rem; }
    .cta-section p { font-size:1.1rem; color:rgba(255,255,255,0.85); margin-bottom:2.5rem; line-height:1.7; }
    .cta-buttons { display:flex; gap:1.25rem; justify-content:center; flex-wrap:wrap; }
    .btn-primary { background:var(--gold); color:var(--navy-dark); border:2px solid var(--gold); }
    .btn-primary:hover { background:var(--gold-light); border-color:var(--gold-light); }
    .btn-secondary { background:transparent; color:var(--white); border:2px solid var(--white); }
    .btn-secondary:hover { background:var(--white); color:var(--navy); }

    /* ── BOOK BANNER ─────────────────────────────────────────────── */
    .book-banner { background:var(--white); border-top:3px solid var(--gold); padding:3.5rem 5%; }
    .book-inner { max-width:1400px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:2rem; flex-wrap:wrap; }
    .book-text h3 { font-family:var(--font-serif); font-size:1.75rem; font-weight:700; color:var(--navy-dark); margin-bottom:0.35rem; }
    .book-text p { font-size:0.95rem; color:var(--dark-gray); }

    /* ── FOOTER ──────────────────────────────────────────────────── */
    footer { background:var(--navy-dark); color:rgba(255,255,255,0.8); padding:5rem 5% 3rem; }
    .footer-container { max-width:1400px; margin:0 auto; }
    .footer-grid { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:4rem; margin-bottom:4rem; }
    .footer-brand { font-family:var(--font-serif); font-size:2rem; font-weight:700; color:var(--gold); margin-bottom:1.25rem; }
    .footer-description { color:rgba(255,255,255,0.65); line-height:1.7; margin-bottom:1.25rem; font-size:0.95rem; }
    .footer-title { font-family:var(--font-serif); font-size:1.05rem; font-weight:700; color:var(--white); margin-bottom:1.25rem; }
    .footer-links { list-style:none; }
    .footer-links li { margin-bottom:0.6rem; font-size:0.9rem; color:rgba(255,255,255,0.6); }
    .footer-links a { color:rgba(255,255,255,0.65); text-decoration:none; transition:color 0.3s; }
    .footer-links a:hover { color:var(--gold); }
    .footer-bottom { border-top:1px solid rgba(255,255,255,0.1); padding-top:2rem; text-align:center; color:rgba(255,255,255,0.5); font-size:0.875rem; }
    .footer-bottom a { color:rgba(255,255,255,0.6); text-decoration:none; }
    .footer-bottom a:hover { color:var(--gold); }

    /* ── MOBILE ──────────────────────────────────────────────────── */
    @media (max-width:768px) {
      html, body { overflow-x:hidden; width:100%; }
      .mobile-menu-toggle { display:flex; }
      .nav-links { position:fixed; top:0; right:-85%; width:85%; max-width:320px; height:100vh; background:var(--white); flex-direction:column; align-items:flex-start; padding:5rem 1.5rem 2rem; gap:0; box-shadow:-4px 0 20px rgba(0,0,0,0.1); transition:right 0.3s ease; overflow-y:auto; overflow-x:hidden; z-index:1000; box-sizing:border-box; }
      .nav-links.active { right:0; }
      body.menu-open { overflow:hidden; position:fixed; width:100%; }
      body::after { content:''; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); opacity:0; visibility:hidden; transition:all 0.3s; z-index:999; }
      body.menu-open::after { opacity:1; visibility:visible; }
      .nav-links li { width:100%; border-bottom:1px solid var(--medium-gray); box-sizing:border-box; }
      .nav-links li:last-child { border-bottom:none; }
      .nav-links a { display:block; padding:1.1rem 0; width:100%; font-size:1rem; box-sizing:border-box; }
      .nav-cta { margin-top:1rem; text-align:center; width:100%; box-sizing:border-box; }
      .nav-item.dropdown { width:100%; }
      .nav-item.dropdown::after { display:none !important; }
      .dropdown-toggle { width:100%; justify-content:space-between; padding:1.1rem 0; display:flex; }
      .dropdown-menu { position:static; opacity:1; visibility:visible; transform:none; display:none; width:100%; min-width:0; box-shadow:none; border:none; padding:0.5rem 0 1rem; margin-top:0; pointer-events:auto; background:var(--light-gray); border-radius:0; }
