                gap: 0;
                padding: 6rem 2rem 2rem;
                box-shadow: -5px 0 15px rgba(0,0,0,0.1);
                transition: right 0.3s;
                align-items: flex-start;
                z-index: 1000;
            }
            
            .nav-links.active {
