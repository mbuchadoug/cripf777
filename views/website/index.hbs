    <!-- Hero -->
    <section class="hero">
        <div class="hero-container">
            <div class="hero-badge">Intelligence Structuring Framework</div>
            <h1>Restructuring Human Intelligence</h1>
<p class="hero-subtitle">
  The first Learning Management System teaching responsibility as structural placement.
  Supporting Junior (Primary), High School, and Professional learners through structured
  quizzes, subject training, and accountability development.
</p>


            
            <div class="hero-stats">
                <div class="stat-item">
                    <div class="stat-number">8</div>
                    <div class="stat-label">Core Pillars</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">2025</div>
                    <div class="stat-label">Framework Launch</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">Global</div>
                    <div class="stat-label">Reach & Impact</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Trust Bar -->
    <section class="trust-bar">
        <div class="trust-container">
            <div class="trust-title">Designed for Global Institutions</div>
            <div class="trust-logos">
                <div class="trust-logo">Government Agencies</div>
                <div class="trust-logo">NGOs & Foundations</div>
                <div class="trust-logo">Think Tanks</div>
                <div class="trust-logo">Public Companies</div>
                <div class="trust-logo">International Organizations</div>
            </div>
        </div>
    </section>

    <!-- Framework Section -->
    <section class="framework-section" id="framework">
        <div class="section-container">
            <div class="section-header">
                <div class="section-label">The CRIPFCnt Framework</div>
                <h2 class="section-title">Eight Pillars of Intelligence & Governance Transformation</h2>
                <p class="section-description">
                    A systematic approach to restructuring institutional intelligence, enhancing decision-making capabilities, and implementing governance reform at scale.
                </p>
            </div>
            
            <div class="pillars-grid">
                <div class="pillar-card">
                    <div class="pillar-number">01</div>
                    <h3 class="pillar-name">Consciousness</h3>
                    <p class="pillar-description">Institutional awareness and strategic foresight as fundamental organizational assets.</p>
                </div>
                
                <div class="pillar-card">
                    <div class="pillar-number">02</div>
                    <h3 class="pillar-name">Responsibility</h3>
                    <p class="pillar-description">Accountability frameworks and performance measurement systems driving organizational evolution.</p>
                </div>
                
                <div class="pillar-card">
                    <div class="pillar-number">03</div>
                    <h3 class="pillar-name">Interpretation</h3>
                    <p class="pillar-description">Evidence-based analysis frameworks for complex decision-making environments.</p>
                </div>
                
                <div class="pillar-card">
                    <div class="pillar-number">04</div>
                    <h3 class="pillar-name">Purpose</h3>
                    <p class="pillar-description">Mission clarity and strategic alignment across organizational hierarchies.</p>
                </div>
                
                <div class="pillar-card">
                    <div class="pillar-number">05</div>
                    <h3 class="pillar-name">Frequencies</h3>
                    <p class="pillar-description">Communication protocols and stakeholder engagement optimization.</p>
                </div>
                
                <div class="pillar-card">
                    <div class="pillar-number">06</div>
                    <h3 class="pillar-name">Civilization</h3>
                    <p class="pillar-description">Societal infrastructure and institutional frameworks for sustainable development.</p>
                </div>
                
                <div class="pillar-card">
                    <div class="pillar-number">07</div>
                    <h3 class="pillar-name">Negotiation</h3>
                    <p class="pillar-description">Strategic dialogue and consensus-building methodologies for multi-stakeholder environments.</p>
                </div>
                
                <div class="pillar-card">
                    <div class="pillar-number">08</div>
                    <h3 class="pillar-name">Technology</h3>
                    <p class="pillar-description">AI-age tools and digital transformation strategies for institutional advancement.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Value Proposition -->
    <section class="value-section">
        <div class="section-container">
            <div class="section-header">
                <div class="section-label">Value Proposition</div>
                <h2 class="section-title">Why Global Institutions Choose CRIPFCnt</h2>
            </div>
            
            <div class="value-grid">
