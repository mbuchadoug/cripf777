}
        /* ============================================
           MOBILE BREAKPOINT (@media 768px)
        ============================================ */
      @media (max-width: 768px) {
            /* ✅ PREVENT HORIZONTAL SCROLL ON BODY */
            html, body {
                overflow-x: hidden;
                width: 100%;
                position: relative;
            }

            /* Show hamburger menu */
            .mobile-menu-toggle {
                display: flex;
            }

            /* Hide nav links by default on mobile */
            .nav-links {
                position: fixed;
                top: 0;
                right: -85%; /* ✅ CHANGED: Match width for perfect slide */
                width: 85%; /* ✅ CHANGED: Reduced from 80% */
                max-width: 320px; /* ✅ CHANGED: Reduced from 400px */
                height: 100vh;
                background: var(--white);
                flex-direction: column;
                align-items: flex-start;
                padding: 5rem 1.5rem 2rem; /* ✅ CHANGED: Reduced padding */
                gap: 0;
                box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
                transition: right 0.3s ease;
                overflow-y: auto;
                overflow-x: hidden; /* ✅ ADDED: Prevent horizontal scroll */
                z-index: 1000;
                box-sizing: border-box; /* ✅ ADDED: Ensure padding included in width */
            }

            /* Show nav when active */
            .nav-links.active {
                right: 0;
            }

            /* ✅ ADDED: Prevent body scroll when menu open */
            body.menu-open {
                overflow: hidden;
                position: fixed; /* ✅ CRITICAL: Prevents background scroll */
                width: 100%;
            }

            /* Show nav when active */
            .nav-links.active {
                right: 0;
            }

            /* Stack nav items vertically */
            .nav-links li {
                width: 100%;
                border-bottom: 1px solid var(--medium-gray);
            }

            .nav-links li:last-child {
                border-bottom: none;
            }

            .nav-links a {
                display: block;
                padding: 1.25rem 0;
                width: 100%;
                font-size: 1.05rem;
            }

            /* Mobile: LMS dropdown positioning */
            .nav-item.dropdown {
                width: 100%;
            }

            /* Remove desktop hover bridge on mobile */
            .nav-item.dropdown::after {
                display: none !important;
            }

            /* Make LMS toggle full-width */
            .dropdown-toggle {
                width: 100%;
                justify-content: space-between;
                padding: 1.25rem 0;
                display: flex;
            }

            /* Mobile dropdown menu styling */
            .dropdown-menu {
                position: static;
                opacity: 1;
                visibility: visible;
                transform: none;
                display: none; /* Hidden by default */
                width: 100%;
                min-width: 0;
                box-shadow: none;
                border: none;
                padding: 0.5rem 0 1rem;
                margin-top: 0;
                pointer-events: auto;
                background: var(--light-gray);
                border-radius: 0;
            }

            /* Show dropdown when JS adds .open */
            .nav-item.dropdown.open .dropdown-menu {
                display: block;
            }

            /* Mobile dropdown links */
            .dropdown-link {
                padding: 1rem 1rem;
                border-radius: 0;
                background: transparent;
            }

            .dropdown-link:hover {
                background: rgba(201, 169, 97, 0.1);
                transform: none;
            }

            .dd-title {
                font-size: 1rem;
            }

            .dd-sub {
                font-size: 0.85rem;
            }

            /* Mobile CTA button */
          /* Mobile CTA button */
            .nav-cta {
                margin-top: 1rem;
                text-align: center;
                width: 100%; /* ✅ ADDED: Full width */
                box-sizing: border-box; /* ✅ ADDED */
                padding: 0.75rem 1rem !important; /* ✅ CHANGED: Reduce padding */
            }

            /* ✅ ADDED: Fix all nav link widths */
            .nav-links li {
                width: 100%;
                border-bottom: 1px solid var(--medium-gray);
                box-sizing: border-box; /* ✅ CRITICAL */
            }

            .nav-links a {
                display: block;
                padding: 1.1rem 0; /* ✅ CHANGED: Reduced from 1.25rem */
                width: 100%;
                font-size: 1rem; /* ✅ CHANGED: Reduced from 1.05rem */
                box-sizing: border-box; /* ✅ CRITICAL */
            }

            /* ✅ Logged-in user pill */

            /* Overlay backdrop when menu is open */
            body::after {
                content: '';
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.5);
                opacity: 0;
                visibility: hidden;
                transition: all 0.3s;
                z-index: 999;
            }

            body.menu-open::after {
                opacity: 1;
                visibility: visible;
            }

            /* Prevent body scroll when menu is open */
            body.menu-open {
                overflow: hidden;
            }

            /* Adjust hero padding for mobile */
            .hero {
                padding: 5rem 5% 4rem;
            }

            .hero h1 {
                font-size: 2rem;
            }

            .hero-subtitle {
                font-size: 1.1rem;
