<script>
  /* ── Mobile menu ────────────────────────────────────────────── */
  /* ── Mobile nav (matches CSS breakpoint 1024px) ─────────────── */
  const toggle   = document.getElementById('mobileMenuToggle');
  const navLinks = document.getElementById('navLinks');
  const NAV_BP   = 1024;

  function closeMenu() {
    toggle?.classList.remove('active');
    navLinks?.classList.remove('active');
    document.body.classList.remove('menu-open');
  }

  toggle?.addEventListener('click', e => {
    e.stopPropagation();
    toggle.classList.toggle('active');
    navLinks.classList.toggle('active');
    document.body.classList.toggle('menu-open');
  });

  navLinks?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

  document.addEventListener('click', e => {
    if (window.innerWidth <= NAV_BP &&
        !navLinks?.contains(e.target) &&
        !toggle?.contains(e.target) &&
        navLinks?.classList.contains('active')) closeMenu();
  });

  window.addEventListener('resize', () => { if (window.innerWidth > NAV_BP) closeMenu(); });

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMenu(); });

  /* LMS dropdown on tablet/mobile */
  document.getElementById('lmsDropdown')?.addEventListener('click', function(e) {
    if (window.innerWidth <= NAV_BP) { e.preventDefault(); this.classList.toggle('open'); }
  });

  /* ── Dynamic video content expand/collapse ─────────────────── */
  function toggleContent(btn) {
    const body    = btn.nextElementSibling;
    const isOpen  = body.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  }

  /* ── Scroll reveal ──────────────────────────────────────────── */
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
