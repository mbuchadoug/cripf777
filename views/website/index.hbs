.nav-item.dropdown {
  position: relative;
}

/* clickable trigger */
.dropdown-toggle {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  cursor: pointer;
}

.caret {
  font-size: 0.75rem;
  opacity: 0.8;
  transition: transform 0.2s;
}

/* rotate caret when open */
.nav-item.dropdown.open .caret {
  transform: rotate(180deg);
}

/* menu container */
.dropdown-menu {
  position: absolute;
  top: calc(100% + 8px); /* ✅ REDUCED GAP */
  left: 0;
  min-width: 320px;
  background: var(--white);
  border: 1px solid var(--medium-gray);
  box-shadow: var(--shadow-md);
  padding: 0.6rem;
  border-radius: 10px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10px);
  transition: all 0.2s ease;
  z-index: 2000;
  pointer-events: none; /* ✅ PREVENT MOUSE INTERFERENCE WHEN HIDDEN */
}

/* ✅ CRITICAL FIX: Add padding zone to bridge the gap */
.nav-item.dropdown::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  height: 12px; /* ✅ INVISIBLE BRIDGE */
  display: none;
}

/* show dropdown on desktop hover */
.nav-item.dropdown:hover::after,
.nav-item.dropdown:focus-within::after {
  display: block;
}

.nav-item.dropdown:hover .dropdown-menu,
.nav-item.dropdown:focus-within .dropdown-menu {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  pointer-events: auto; /* ✅ ENABLE CLICKING WHEN VISIBLE */
}

/* dropdown link styling */
.dropdown-link {
  display: block;
  text-decoration: none;
  padding: 0.85rem 0.9rem;
  border-radius: 8px;
  transition: background 0.2s, transform 0.2s;
  color: var(--text-primary);
}

.dropdown-link:hover {
  background: var(--light-gray);
  transform: translateY(-1px);
}

.dd-title {
  font-weight: 700;
  color: var(--navy);
  font-size: 0.95rem;
  line-height: 1.25;
}

.dd-sub {
  margin-top: 0.25rem;
  font-size: 0.82rem;
  color: #6b7280;
  line-height: 1.3;
}

/* prevent menu going off screen */
.nav-item.dropdown .dropdown-menu {
  max-width: min(420px, 90vw);
}

