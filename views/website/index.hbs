  <meta property="og:title" content="CRIPFCnt | Recalibrating Intelligence &amp; Society" />
  <meta property="og:description" content="CRIPFCnt: an eight-pillar framework and life manual redefining consciousness, responsibility and interpretation for the data age." />
  <meta property="og:url" content="{{siteUrl}}{{canonicalPath}}" />
  <meta property="og:image" content="{{siteUrl}}/static/img/logo.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="CRIPFCnt | Recalibrating Intelligence &amp; Society" />
  <meta name="twitter:description" content="CRIPFCnt | an eight-pillar framework and life manual for society, leadership." />
  <meta name="twitter:image" content="{{siteUrl}}/static/img/logo.png" />

  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"CRIPFCnt","url":"{{siteUrl}}","logo":"{{siteUrl}}/static/img/logo.png"}</script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    /* ── DESIGN TOKENS ───────────────────────────────────────────── */
    :root {
      --navy:         #1E3A5F;
      --navy-dark:    #0F1C2E;
      --gold:         #C9A961;
      --gold-light:   #E5D4A6;
      --white:        #FFFFFF;
      --light-gray:   #F8F9FA;
      --medium-gray:  #E9ECEF;
      --dark-gray:    #495057;
      --text-primary: #212529;
      --font-serif:   'Crimson Pro', serif;
      --font-sans:    'Inter', sans-serif;
      --shadow-sm:    0 2px 8px rgba(30,58,95,0.08);
      --shadow-md:    0 4px 16px rgba(30,58,95,0.12);
      --shadow-lg:    0 8px 32px rgba(30,58,95,0.16);
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { overflow-x:hidden; scroll-behavior:smooth; }
    body { font-family:var(--font-sans); color:var(--text-primary); line-height:1.7; background:var(--white); -webkit-font-smoothing:antialiased; overflow-x:hidden; }

    /* ── NAVBAR ─────────────────────────────────────────────────── */
    .navbar { background:var(--white); border-bottom:1px solid var(--medium-gray); padding:0.875rem 2.5%; position:sticky; top:0; z-index:1000; box-shadow:var(--shadow-sm); }
    .nav-container { max-width:1400px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:1rem; }
    .logo { display:flex; align-items:center; gap:0.65rem; text-decoration:none; z-index:1001; flex-shrink:0; }
    .logo-icon { width:42px; height:42px; background:var(--navy); display:flex; align-items:center; justify-content:center; font-family:var(--font-serif); font-weight:700; font-size:1.25rem; color:var(--gold); border:2px solid var(--gold); flex-shrink:0; }
    .logo-text { font-family:var(--font-serif); font-size:clamp(1.35rem,2vw,1.75rem); font-weight:700; color:var(--navy); letter-spacing:-0.5px; }
    /* fluid gap: 0.9rem at 900px → 2rem at 1400px */
    .nav-links { display:flex; gap:clamp(0.85rem,1.5vw,2rem); list-style:none; align-items:center; flex-wrap:nowrap; }
    .nav-links a { font-size:clamp(0.78rem,0.95vw,0.92rem); font-weight:500; color:var(--text-primary); text-decoration:none; transition:color 0.3s; letter-spacing:0.2px; white-space:nowrap; }
    .nav-links a:hover { color:var(--navy); }
    .nav-cta { background:var(--navy); color:var(--white) !important; padding:0.55rem 1.1rem; border-radius:4px; font-weight:600; transition:all 0.3s; font-size:clamp(0.75rem,0.9vw,0.88rem) !important; white-space:nowrap; }
    .nav-cta:hover { background:var(--navy-dark) !important; }

    /* user pill */
    .user-pill { display:inline-flex; align-items:center; gap:0.6rem; padding:0.45rem 0.75rem; border:1px solid var(--medium-gray); background:var(--light-gray); border-radius:999px; font-size:0.9rem; max-width:260px; }
    .user-pill .user-email { max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .user-pill .user-photo { width:28px; height:28px; border-radius:50%; object-fit:cover; border:1px solid var(--medium-gray); flex-shrink:0; }
    .nav-signout { background:transparent; border:1px solid var(--medium-gray); padding:0.55rem 0.9rem; border-radius:8px; font-weight:600; text-decoration:none; white-space:nowrap; color:var(--text-primary); transition:background 0.2s; }
    .nav-signout:hover { background:var(--light-gray); }
    .nav-auth { display:inline-flex; align-items:center; gap:0.75rem; }

    /* LMS dropdown */
    .nav-item.dropdown { position:relative; }
    .dropdown-toggle { display:inline-flex; align-items:center; gap:0.35rem; cursor:pointer; }
    .caret { font-size:0.75rem; opacity:0.8; transition:transform 0.2s; }
    .nav-item.dropdown.open .caret { transform:rotate(180deg); }
    .dropdown-menu { position:absolute; top:calc(100% + 8px); left:0; min-width:320px; background:var(--white); border:1px solid var(--medium-gray); box-shadow:var(--shadow-md); padding:0.6rem; border-radius:10px; opacity:0; visibility:hidden; transform:translateY(-10px); transition:all 0.2s ease; z-index:2000; pointer-events:none; }
    .nav-item.dropdown::after { content:''; position:absolute; top:100%; left:0; right:0; height:12px; display:none; }
    .nav-item.dropdown:hover::after, .nav-item.dropdown:focus-within::after { display:block; }
    .nav-item.dropdown:hover .dropdown-menu, .nav-item.dropdown:focus-within .dropdown-menu { opacity:1; visibility:visible; transform:translateY(0); pointer-events:auto; }
    .dropdown-link { display:block; text-decoration:none; padding:0.85rem 0.9rem; border-radius:8px; transition:background 0.2s, transform 0.2s; color:var(--text-primary); }
    .dropdown-link:hover { background:var(--light-gray); transform:translateY(-1px); }
    .dd-title { font-weight:700; color:var(--navy); font-size:0.95rem; line-height:1.25; }
    .dd-sub { margin-top:0.25rem; font-size:0.82rem; color:#6b7280; line-height:1.3; }

    /* mobile toggle */
    .mobile-menu-toggle { display:none; flex-direction:column; gap:5px; background:none; border:none; cursor:pointer; padding:0.5rem; z-index:1001; }
    .mobile-menu-toggle span { width:28px; height:3px; background:var(--navy); transition:all 0.3s; border-radius:2px; display:block; }
    .mobile-menu-toggle.active span:nth-child(1) { transform:rotate(45deg) translate(8px,8px); }
    .mobile-menu-toggle.active span:nth-child(2) { opacity:0; }
    .mobile-menu-toggle.active span:nth-child(3) { transform:rotate(-45deg) translate(7px,-7px); }

    /* ── HERO ────────────────────────────────────────────────────── */
    .hero { background:linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%); padding:8rem 5% 6rem; position:relative; overflow:hidden; }
    .hero::before { content:''; position:absolute; top:0; right:0; width:50%; height:100%; background:linear-gradient(90deg, transparent, rgba(201,169,97,0.05)); }
    .hero-container { max-width:1400px; margin:0 auto; position:relative; z-index:1; }
    .hero-badge { display:inline-block; background:rgba(201,169,97,0.15); color:var(--gold-light); padding:0.5rem 1.25rem; border-radius:30px; font-size:0.85rem; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:2rem; border:1px solid rgba(201,169,97,0.3); }
    .hero h1 { font-family:var(--font-serif); font-size:clamp(2.5rem,5vw,4.5rem); font-weight:700; color:var(--white); line-height:1.15; margin-bottom:1.5rem; max-width:900px; }
    .hero h1 em { font-style:italic; color:var(--gold); }
    .hero-subtitle { font-size:1.2rem; color:rgba(255,255,255,0.85); max-width:680px; margin-bottom:2.5rem; line-height:1.7; }
    .hero-actions { display:flex; gap:1.25rem; flex-wrap:wrap; margin-bottom:4rem; }
    .btn { display:inline-block; padding:1rem 2.5rem; font-family:var(--font-sans); font-size:1rem; font-weight:600; border-radius:4px; text-decoration:none; transition:all 0.3s; letter-spacing:0.3px; cursor:pointer; border:none; }
    .btn-gold { background:var(--gold); color:var(--navy-dark); border:2px solid var(--gold); }
    .btn-gold:hover { background:var(--gold-light); border-color:var(--gold-light); }
    .btn-outline { background:transparent; color:var(--white); border:2px solid rgba(255,255,255,0.6); }
    .btn-outline:hover { background:rgba(255,255,255,0.1); border-color:var(--white); }
    .hero-stats { display:flex; gap:4rem; flex-wrap:wrap; padding-top:3rem; border-top:1px solid rgba(255,255,255,0.1); }
    .stat-item { display:flex; flex-direction:column; }
    .stat-number { font-family:var(--font-serif); font-size:2.5rem; font-weight:700; color:var(--gold); margin-bottom:0.25rem; }
    .stat-label { font-size:0.85rem; color:rgba(255,255,255,0.65); text-transform:uppercase; letter-spacing:1px; }

    /* ── TRUST BAR ───────────────────────────────────────────────── */
    .trust-bar { background:var(--light-gray); padding:2.5rem 5%; border-bottom:1px solid var(--medium-gray); }
    .trust-container { max-width:1400px; margin:0 auto; text-align:center; }
    .trust-title { font-size:0.8rem; font-weight:700; color:var(--dark-gray); text-transform:uppercase; letter-spacing:2px; margin-bottom:1.5rem; }
    .trust-logos { display:flex; justify-content:center; align-items:center; gap:1.5rem; flex-wrap:wrap; }
    .trust-logo { font-size:0.875rem; font-weight:600; color:var(--dark-gray); padding:0.75rem 1.5rem; background:var(--white); border:1px solid var(--medium-gray); border-radius:4px; }

    /* ── SECTIONS SHARED ─────────────────────────────────────────── */
    .section-container { max-width:1400px; margin:0 auto; }
    .section-header { text-align:center; margin-bottom:4rem; }
    .section-label { font-size:0.85rem; font-weight:700; color:var(--navy); text-transform:uppercase; letter-spacing:2px; margin-bottom:1rem; }
    .section-title { font-family:var(--font-serif); font-size:clamp(2rem,4vw,3rem); font-weight:700; color:var(--navy-dark); margin-bottom:1.25rem; line-height:1.3; }
    .section-description { font-size:1.1rem; color:var(--dark-gray); max-width:700px; margin:0 auto; line-height:1.7; }

    /* ── FRAMEWORK / PILLARS ─────────────────────────────────────── */
    .framework-section { padding:7rem 5%; background:var(--white); }
    .pillars-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; }
    .pillar-card { background:var(--white); border:1px solid var(--medium-gray); padding:2rem 1.75rem; transition:all 0.3s; position:relative; overflow:hidden; }
    .pillar-card::before { content:''; position:absolute; top:0; left:0; width:4px; height:0; background:var(--gold); transition:height 0.3s; }
    .pillar-card:hover { box-shadow:var(--shadow-md); transform:translateY(-4px); }
    .pillar-card:hover::before { height:100%; }
    .pillar-number { font-family:var(--font-serif); font-size:2.5rem; font-weight:700; color:var(--gold); opacity:0.3; margin-bottom:0.75rem; }
    .pillar-name { font-family:var(--font-serif); font-size:1.35rem; font-weight:700; color:var(--navy); margin-bottom:0.6rem; }
    .pillar-description { font-size:0.9rem; color:var(--dark-gray); line-height:1.6; }

    /* ── VIDEO SECTION ───────────────────────────────────────────── */
    .videos-section { padding:7rem 5%; background:var(--light-gray); }
    .videos-header { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:end; margin-bottom:3.5rem; }
    .videos-header .section-title { text-align:left; }
    .videos-intro { font-size:1.05rem; color:var(--dark-gray); line-height:1.75; }
    .videos-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; }
    .video-card { background:var(--white); border:1px solid var(--medium-gray); overflow:hidden; transition:all 0.3s; box-shadow:var(--shadow-sm); }
    .video-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
    .video-wrapper { position:relative; aspect-ratio:16/9; background:var(--navy-dark); overflow:hidden; }
    .video-wrapper video { width:100%; height:100%; object-fit:cover; }
    .video-episode { position:absolute; bottom:1rem; left:1rem; font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--gold-light); background:rgba(15,28,46,0.75); padding:0.25rem 0.6rem; border-radius:3px; }
    .video-body { padding:1.75rem 2rem; }
    .video-tag { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:var(--navy); margin-bottom:0.6rem; }
    .video-title { font-family:var(--font-serif); font-size:1.35rem; font-weight:700; color:var(--navy-dark); line-height:1.3; margin-bottom:0.9rem; }
    .video-desc { font-size:0.92rem; color:var(--dark-gray); line-height:1.65; margin-bottom:1.25rem; }
    .video-tags { display:flex; flex-wrap:wrap; gap:0.4rem; }
    .video-tag-pill { font-size:0.75rem; padding:0.2rem 0.65rem; border:1px solid var(--medium-gray); color:var(--dark-gray); border-radius:2px; }

    /* Dynamic video content (uploaded via admin) */
    .video-content-wrap { border-top:1px solid var(--medium-gray); margin-top:1.25rem; padding-top:1.25rem; }
    .video-content-toggle {
      display:inline-flex; align-items:center; gap:0.5rem;
      background:none; border:none; cursor:pointer; padding:0;
      font-family:var(--font-sans); font-size:0.82rem; font-weight:700;
      color:var(--navy); letter-spacing:0.5px; text-transform:uppercase;
      transition:color 0.2s;
    }
    .video-content-toggle:hover { color:var(--gold); }
    .video-content-toggle .toggle-arrow { font-size:0.75rem; transition:transform 0.25s; display:inline-block; }
    .video-content-toggle.open .toggle-arrow { transform:rotate(180deg); }
    .video-content-body {
      display:none; margin-top:1.25rem;
      font-family:var(--font-serif); font-size:1rem;
      color:var(--text-primary); line-height:1.85;
      max-height:520px; overflow-y:auto;
      border-left:3px solid var(--gold);
      padding-left:1.25rem;
    }
    .video-content-body.open { display:block; }
    .video-content-body p { margin-bottom:0.75rem; }
    .video-content-body p:last-child { margin-bottom:0; }

    /* ── EQUATION / SCOI ─────────────────────────────────────────── */
    .equation-section { background:linear-gradient(135deg, var(--navy-dark), var(--navy)); color:var(--white); padding:7rem 5%; position:relative; overflow:hidden; }
    .equation-section::before { content:'SCOI'; position:absolute; right:-2rem; top:50%; transform:translateY(-50%); font-family:var(--font-serif); font-size:18rem; font-weight:700; color:rgba(201,169,97,0.05); pointer-events:none; line-height:1; }
    .equation-inner { display:grid; grid-template-columns:1fr 1fr; gap:6rem; align-items:center; }
    .eq-box { border:1px solid rgba(201,169,97,0.35); padding:3rem; background:rgba(255,255,255,0.03); }
    .eq-label { font-size:0.72rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:var(--gold); margin-bottom:1.75rem; }
    .eq-lines { font-family:'Inter', monospace; font-size:0.85rem; line-height:2.8; color:rgba(255,255,255,0.7); }
    .eq-lines .hl { color:var(--gold); font-size:1rem; font-weight:600; }
    .eq-lines .result { color:var(--white); font-size:1rem; font-weight:700; border-top:1px solid rgba(201,169,97,0.3); padding-top:1rem; margin-top:0.5rem; line-height:1.6; display:block; }
    .eq-vars { margin-top:2rem; display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; }
    .eq-var { padding:0.75rem; border:1px solid rgba(255,255,255,0.07); }
    .eq-var-name { font-size:0.68rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:var(--gold-light); margin-bottom:0.25rem; }
    .eq-var-def { font-size:0.8rem; color:rgba(255,255,255,0.6); }
    .eq-content .section-label { color:var(--gold); }
    .eq-content .section-title { color:var(--white); text-align:left; }
    .eq-content p { color:rgba(255,255,255,0.75); line-height:1.75; margin-bottom:1.25rem; font-size:1rem; }

    /* ── REDISTRIBUTION ──────────────────────────────────────────── */
    .redist-section { padding:7rem 5%; background:var(--white); }
    .redist-inner { display:grid; grid-template-columns:1fr 1fr; gap:5rem; }
    .redist-inner .section-title { text-align:left; }
    .redist-body { font-size:1rem; color:var(--dark-gray); line-height:1.75; margin-bottom:2rem; }
    .action-box { background:var(--navy-dark); color:var(--white); padding:2rem; }
    .action-box-title { font-family:var(--font-serif); font-size:1.2rem; margin-bottom:1.25rem; font-style:italic; color:var(--gold-light); }
    .action-list { list-style:none; display:flex; flex-direction:column; gap:0.75rem; }
    .action-list li { display:flex; align-items:flex-start; gap:0.75rem; font-size:0.95rem; color:rgba(255,255,255,0.8); }
    .action-list li::before { content:'→'; color:var(--gold); font-weight:700; flex-shrink:0; }
    .questions-list { display:flex; flex-direction:column; gap:1px; }
    .question-item { display:flex; align-items:flex-start; gap:1rem; padding:1.25rem 1.5rem; background:var(--light-gray); border-left:3px solid transparent; transition:border-color 0.2s, transform 0.2s; }
    .question-item:hover { border-left-color:var(--gold); transform:translateX(4px); }
    .q-num { font-size:0.7rem; font-weight:700; color:var(--gold); font-family:var(--font-sans); padding-top:0.2rem; flex-shrink:0; letter-spacing:0.05em; }
    .q-text { font-size:0.95rem; line-height:1.55; color:var(--text-primary); }

    /* ── LMS SECTION ────────────────────────────────────────────── */
    .lms-section { background:var(--navy-dark); padding:7rem 5%; }
    .lms-inner { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; max-width:1400px; margin:0 auto; }
    .lms-label { font-size:0.85rem; font-weight:700; color:var(--gold); text-transform:uppercase; letter-spacing:2px; margin-bottom:1rem; }
    .lms-title { font-family:var(--font-serif); font-size:clamp(1.8rem,3.5vw,2.75rem); font-weight:700; color:var(--white); line-height:1.25; margin-bottom:1.5rem; }
    .lms-body { font-size:1rem; color:rgba(255,255,255,0.75); line-height:1.8; margin-bottom:2rem; }
    .lms-tracks { display:flex; flex-direction:column; gap:1px; }
    .lms-track { display:flex; align-items:flex-start; gap:1.25rem; padding:1.25rem 1.5rem; background:rgba(255,255,255,0.04); border-left:3px solid transparent; transition:border-color 0.2s, background 0.2s; text-decoration:none; }
    .lms-track:hover { border-left-color:var(--gold); background:rgba(255,255,255,0.07); }
    .lms-track-icon { font-size:1.5rem; flex-shrink:0; margin-top:0.1rem; }
    .lms-track-title { font-family:var(--font-serif); font-size:1.1rem; font-weight:700; color:var(--white); margin-bottom:0.2rem; }
    .lms-track-desc { font-size:0.875rem; color:rgba(255,255,255,0.55); line-height:1.5; }
    .lms-cta { display:inline-block; margin-top:2rem; background:var(--gold); color:var(--navy-dark); padding:0.9rem 2rem; font-weight:700; font-size:0.95rem; text-decoration:none; border-radius:4px; transition:background 0.2s; }
    .lms-cta:hover { background:var(--gold-light); }

    /* ── VALUE PROPOSITION ───────────────────────────────────────── */
    .value-section { background:var(--light-gray); padding:7rem 5%; }
    .value-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2.5rem; margin-top:0; }
    .value-card { background:var(--white); padding:2.5rem 2rem; border-left:3px solid var(--gold); box-shadow:var(--shadow-sm); }
    .value-icon { width:56px; height:56px; background:var(--navy); border-radius:4px; display:flex; align-items:center; justify-content:center; font-size:1.6rem; margin-bottom:1.25rem; }
    .value-title { font-family:var(--font-serif); font-size:1.4rem; font-weight:700; color:var(--navy); margin-bottom:0.75rem; }
    .value-text { color:var(--dark-gray); line-height:1.7; font-size:0.95rem; }

    /* ── FEATURED AUDITS ─────────────────────────────────────────── */
    .audits-section { padding:7rem 5%; background:var(--white); }
    .audits-section-header { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:3rem; flex-wrap:wrap; gap:1.5rem; }
    .audits-section-header .header-left { max-width:600px; }
    .view-all-link { display:inline-flex; align-items:center; gap:0.5rem; font-weight:700; font-size:0.9rem; color:var(--navy); text-decoration:none; border-bottom:2px solid var(--gold); padding-bottom:0.2rem; transition:color 0.2s, border-color 0.2s; white-space:nowrap; }
    .view-all-link:hover { color:var(--gold); }

    /* Horizontal scroll carousel for audits on homepage */
    .audits-carousel-wrap { position:relative; }
    .audits-carousel { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
    .audit-card { background:var(--white); border:1px solid var(--medium-gray); border-radius:2px; padding:0; overflow:hidden; transition:all 0.3s; display:flex; flex-direction:column; }
    .audit-card:hover { box-shadow:var(--shadow-md); transform:translateY(-4px); }
    .audit-card-header { background:linear-gradient(135deg, var(--navy-dark), var(--navy)); padding:1.5rem; position:relative; }
    .audit-kind-badge { display:inline-block; font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; padding:0.3rem 0.75rem; border-radius:2px; margin-bottom:0.75rem; }
    .audit-kind-badge.special { background:rgba(201,169,97,0.25); color:var(--gold-light); border:1px solid rgba(201,169,97,0.4); }
    .audit-kind-badge.placement { background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.8); border:1px solid rgba(255,255,255,0.15); }
    .audit-card-title { font-family:var(--font-serif); font-size:1.2rem; font-weight:700; color:var(--white); line-height:1.35; }
    .audit-card-window { font-size:0.78rem; color:rgba(255,255,255,0.55); margin-top:0.5rem; }
    .audit-card-body { padding:1.5rem; flex:1; display:flex; flex-direction:column; }
    .audit-features { list-style:none; margin-bottom:1.25rem; flex:1; }
    .audit-features li { font-size:0.85rem; color:var(--dark-gray); padding:0.35rem 0; border-bottom:1px solid var(--medium-gray); display:flex; align-items:flex-start; gap:0.5rem; line-height:1.4; }
    .audit-features li:last-child { border-bottom:none; }
    .audit-features li::before { content:'✓'; color:var(--gold); font-weight:700; font-size:0.75rem; flex-shrink:0; margin-top:0.15rem; }
    .audit-card-footer { padding:1.25rem 1.5rem; border-top:1px solid var(--medium-gray); display:flex; justify-content:space-between; align-items:center; background:var(--light-gray); }
    .audit-price { font-family:var(--font-serif); font-size:1.6rem; font-weight:700; color:var(--navy); }
    .audit-price-label { font-size:0.72rem; color:var(--dark-gray); display:block; }
    .btn-audit-buy { background:var(--navy); color:var(--white); padding:0.65rem 1.25rem; border-radius:4px; font-size:0.85rem; font-weight:700; text-decoration:none; transition:all 0.2s; border:none; cursor:pointer; white-space:nowrap; }
    .btn-audit-buy:hover { background:var(--navy-dark); }

    /* Audit section count badge */
    .audits-count-badge { display:inline-flex; align-items:center; gap:0.4rem; background:rgba(201,169,97,0.12); color:var(--navy); border:1px solid rgba(201,169,97,0.4); padding:0.35rem 0.9rem; border-radius:30px; font-size:0.8rem; font-weight:700; letter-spacing:0.5px; }

    /* ── CTA ─────────────────────────────────────────────────────── */
    .cta-section { background:var(--navy); padding:6rem 5%; text-align:center; }
    .cta-container { max-width:800px; margin:0 auto; }
    .cta-section h2 { font-family:var(--font-serif); font-size:clamp(2rem,4vw,3rem); font-weight:700; color:var(--white); margin-bottom:1.25rem; }
    .cta-section p { font-size:1.1rem; color:rgba(255,255,255,0.85); margin-bottom:2.5rem; line-height:1.7; }
    .cta-buttons { display:flex; gap:1.25rem; justify-content:center; flex-wrap:wrap; }
    .btn-primary { background:var(--gold); color:var(--navy-dark); border:2px solid var(--gold); }
    .btn-primary:hover { background:var(--gold-light); border-color:var(--gold-light); }
    .btn-secondary { background:transparent; color:var(--white); border:2px solid var(--white); }
    .btn-secondary:hover { background:var(--white); color:var(--navy); }

    /* ── BOOK BANNER ─────────────────────────────────────────────── */
    .book-banner { background:var(--white); border-top:3px solid var(--gold); padding:3.5rem 5%; }
    .book-inner { max-width:1400px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:2rem; flex-wrap:wrap; }
    .book-text h3 { font-family:var(--font-serif); font-size:1.75rem; font-weight:700; color:var(--navy-dark); margin-bottom:0.35rem; }
    .book-text p { font-size:0.95rem; color:var(--dark-gray); }

    /* ── FOOTER ──────────────────────────────────────────────────── */
    footer { background:var(--navy-dark); color:rgba(255,255,255,0.8); padding:5rem 5% 3rem; }
    .footer-container { max-width:1400px; margin:0 auto; }
    .footer-grid { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:4rem; margin-bottom:4rem; }
    .footer-brand { font-family:var(--font-serif); font-size:2rem; font-weight:700; color:var(--gold); margin-bottom:1.25rem; }
    .footer-description { color:rgba(255,255,255,0.65); line-height:1.7; margin-bottom:1.25rem; font-size:0.95rem; }
    .footer-title { font-family:var(--font-serif); font-size:1.05rem; font-weight:700; color:var(--white); margin-bottom:1.25rem; }
    .footer-links { list-style:none; }
    .footer-links li { margin-bottom:0.6rem; font-size:0.9rem; color:rgba(255,255,255,0.6); }
    .footer-links a { color:rgba(255,255,255,0.65); text-decoration:none; transition:color 0.3s; }
    .footer-links a:hover { color:var(--gold); }
    .footer-bottom { border-top:1px solid rgba(255,255,255,0.1); padding-top:2rem; font-size:0.85rem; color:rgba(255,255,255,0.45); }
    .footer-bottom a { color:rgba(255,255,255,0.55); text-decoration:none; }
    .footer-bottom a:hover { color:var(--gold); }

    /* scroll reveal */
    .reveal { opacity:0; transform:translateY(24px); transition:opacity 0.6s ease, transform 0.6s ease; }
    .reveal.visible { opacity:1; transform:translateY(0); }

    /* ── RESPONSIVE ─────────────────────────────────────────────── */

    /* ─ Hamburger active for anything ≤ 1024px (tablets + phones) ─ */
    @media (max-width:1024px) {
      /* Show hamburger button */
      .mobile-menu-toggle { display:flex; }

      /* Nav slides in as full-screen overlay */
      .nav-links { display:none; flex-direction:column; position:fixed; top:0; left:0; width:100%; height:100vh; background:var(--white); padding:5.5rem 2rem 3rem; gap:0; overflow-y:auto; z-index:999; }
      .nav-links.active { display:flex; }
      body.menu-open { overflow:hidden; }

      /* Each nav item full width with separator */
      .nav-links > li { border-bottom:1px solid var(--medium-gray); width:100%; }
      .nav-links > li > a { display:block; padding:1rem 0; font-size:1rem !important; font-weight:600 !important; }

      /* LMS dropdown → flat list on mobile */
      .nav-item.dropdown { width:100%; }
      .nav-item.dropdown::after { display:none !important; }
      .dropdown-toggle { width:100%; justify-content:space-between; padding:1rem 0; display:flex; }
      .dropdown-menu { position:static; opacity:1; visibility:visible; transform:none; display:none; width:100%; min-width:0; box-shadow:none; border:none; padding:0.5rem 0 1rem; margin-top:0; pointer-events:auto; background:var(--light-gray); border-radius:0; }
      .nav-item.dropdown.open .dropdown-menu { display:block !important; }

      /* Auth section stacks */
      .nav-links li.nav-auth { flex-direction:column; align-items:stretch; gap:0.6rem; border-bottom:none; padding-top:1.25rem; }
      .nav-links li.nav-auth .user-pill { width:100%; max-width:100%; }
      .nav-links li.nav-auth .nav-signout { width:100%; display:block; text-align:center; padding:0.8rem; }
      .nav-links li.nav-auth .nav-cta { display:block; text-align:center; padding:0.8rem !important; }

      /* Show/hide helpers */
      .mobile-only { display:block !important; }
      .desktop-only { display:none !important; }

      /* LMS mobile section */
      .mobile-lms-section { width:100%; padding:0; border:none; }
      .mobile-section-header { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:var(--dark-gray); padding:1.25rem 0 0.75rem; border-top:2px solid var(--medium-gray); margin-top:0.5rem; }
      .mobile-lms-links { list-style:none; padding:0; margin:0; width:100%; }
      .mobile-lms-links li { border-bottom:none; width:100%; }
      .mobile-lms-links a { display:block; padding:0.85rem 0.75rem; font-size:0.9rem; color:var(--text-primary); background:var(--light-gray); margin:0.2rem 0; border-radius:6px; transition:background 0.2s; }
      .mobile-lms-links a:hover { background:rgba(201,169,97,0.15); }

      /* Page sections at tablet */
      .pillars-grid { grid-template-columns:repeat(2,1fr); }
      .value-grid { grid-template-columns:1fr 1fr; }
      .audits-carousel { grid-template-columns:1fr 1fr; }
      .equation-inner { grid-template-columns:1fr; gap:3rem; }
      .equation-section::before { display:none; }
      .redist-inner { grid-template-columns:1fr; gap:3rem; }
      .lms-inner { grid-template-columns:1fr; gap:3rem; }
      .videos-header { grid-template-columns:1fr; gap:1.5rem; }
      .videos-grid { grid-template-columns:1fr 1fr; }
      .footer-grid { grid-template-columns:1fr 1fr; gap:2.5rem; }
    }

    /* ─ Small phones ≤ 600px ─ */
    @media (max-width:600px) {
      .hero { padding:4.5rem 5% 3.5rem; }
      .hero h1 { font-size:2rem; }
      .hero-stats { gap:2rem; }
      .pillars-grid { grid-template-columns:1fr 1fr; gap:0.75rem; }
      .value-grid { grid-template-columns:1fr; gap:1.25rem; }
      .audits-carousel { grid-template-columns:1fr; }
      .audits-section-header { flex-direction:column; align-items:flex-start; gap:1rem; }
      .videos-grid { grid-template-columns:1fr; }
      .footer-grid { grid-template-columns:1fr; gap:2rem; }
      .book-inner { flex-direction:column; text-align:center; }
    }

    /* ─ Desktop ≥ 1025px - full nav, hamburger hidden ─ */
    @media (min-width:1025px) {
      .mobile-menu-toggle { display:none; }
      .mobile-only { display:none !important; }
      .desktop-only { display:block !important; }
    }
  /* ── 8QT PLACEMENT INTELLIGENCE SECTION ──────────────────────── */
  .piq-section { padding:7rem 5%; background:linear-gradient(135deg,var(--navy-dark) 0%,var(--navy) 100%); color:var(--white); position:relative; overflow:hidden; }
  .piq-section::before { content:'8QT'; position:absolute; right:-1rem; top:50%; transform:translateY(-50%); font-family:var(--font-serif); font-size:16rem; font-weight:700; color:rgba(201,169,97,0.04); pointer-events:none; line-height:1; }
  .piq-inner { max-width:1400px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
  .piq-label { font-size:0.75rem; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:var(--gold); margin-bottom:1rem; }
  .piq-title { font-family:var(--font-serif); font-size:clamp(2rem,4vw,3rem); font-weight:700; color:var(--white); line-height:1.2; margin-bottom:1.25rem; }
  .piq-title em { color:var(--gold); font-style:normal; }
  .piq-desc { font-size:1.05rem; color:rgba(255,255,255,0.82); line-height:1.75; margin-bottom:2rem; }
  .piq-meta { display:flex; gap:1.5rem; flex-wrap:wrap; margin-bottom:2.5rem; }
  .piq-meta-item { display:flex; align-items:center; gap:0.5rem; font-size:0.85rem; color:var(--gold-light); }
  .piq-meta-item::before { content:'✓'; color:var(--gold); font-weight:700; }
  .piq-btn { display:inline-block; background:var(--gold); color:var(--navy-dark); padding:0.9rem 2rem; border-radius:4px; font-weight:700; font-size:1rem; text-decoration:none; transition:all 0.25s; }
  .piq-btn:hover { background:var(--gold-light); transform:translateY(-2px); box-shadow:0 8px 24px rgba(201,169,97,0.3); }
  .piq-btn-outline { display:inline-block; background:transparent; color:var(--white); border:1.5px solid rgba(255,255,255,0.4); padding:0.88rem 1.75rem; border-radius:4px; font-weight:600; font-size:0.9rem; text-decoration:none; transition:all 0.25s; margin-left:1rem; }
  .piq-btn-outline:hover { border-color:var(--white); background:rgba(255,255,255,0.08); }
  .piq-quotients { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
  .piq-q { background:rgba(255,255,255,0.06); border:1px solid rgba(201,169,97,0.2); border-radius:8px; padding:14px 10px; text-align:center; transition:all 0.2s; }
  .piq-q:hover { background:rgba(201,169,97,0.1); border-color:var(--gold); transform:translateY(-2px); }
  .piq-q-code { font-size:0.65rem; font-weight:800; letter-spacing:2px; text-transform:uppercase; color:var(--gold); margin-bottom:6px; font-family:var(--font-sans); }
  .piq-q-name { font-size:0.8rem; color:rgba(255,255,255,0.8); font-weight:500; line-height:1.3; }
  .piq-q-bar { height:3px; border-radius:99px; background:rgba(201,169,97,0.3); margin:8px auto 0; width:60%; overflow:hidden; }
  .piq-q-fill { height:100%; background:var(--gold); border-radius:99px; }
  .piq-badge { display:inline-flex; align-items:center; gap:6px; background:rgba(201,169,97,0.12); border:1px solid rgba(201,169,97,0.3); color:var(--gold); padding:0.3rem 0.8rem; border-radius:20px; font-size:0.72rem; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:1.5rem; }
  @media(max-width:900px) {
    .piq-inner { grid-template-columns:1fr; gap:3rem; }
    .piq-section::before { display:none; }
    .piq-quotients { grid-template-columns:repeat(4,1fr); gap:8px; }
    .piq-btn-outline { margin-left:0; margin-top:0.75rem; }
  }
  @media(max-width:480px) { .piq-quotients { grid-template-columns:repeat(2,1fr); } }
  </style>
</head>
<body>

<!-- ── NAVBAR ─────────────────────────────────────────────────────────── -->

<!-- ── HERO ───────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-container">
    <div class="hero-badge">Taking Psychology to the People</div>
    <h1>Structure shapes what<br><em>effort cannot explain.</em></h1>
    <p class="hero-subtitle">
      Two people. Same effort. One gets seen. One doesn't.
      CRIPFCnt names what's actually happening - the invisible structure that decides
      who rises, who is overlooked, and why. Then it shows you what to do about it.
    </p>
    <div class="hero-actions">
      <a href="/8qt" class="btn btn-gold">Discover Your 8 Quotients ✦</a>
      <a href="/scoi" class="btn btn-outline">Browse Intelligence Reports →</a>
    </div>
    <div class="hero-stats">
      <div class="stat-item">
        <div class="stat-number">8</div>
        <div class="stat-label">Core Pillars</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">8QT</div>
        <div class="stat-label">Free Assessment</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">SCOI</div>
        <div class="stat-label">Audit System</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">ERF</div>
        <div class="stat-label">Resilience Factor</div>
      </div>
    </div>
  </div>
</section>

<!-- ── TRUST BAR ──────────────────────────────────────────────────────── -->
<section class="trust-bar">
  <div class="trust-container">
    <div class="trust-title">Designed for Global Institutions</div>
    <div class="trust-logos">
      <div class="trust-logo">Government Agencies</div>
      <div class="trust-logo">NGOs &amp; Foundations</div>
      <div class="trust-logo">Think Tanks</div>
      <div class="trust-logo">Public Companies</div>
      <div class="trust-logo">International Organizations</div>
    </div>
  </div>
</section>

<!-- ── FEATURED AUDITS ─────────────────────────────────────────────────
     Shows up to 6 featured audits. The server should pass `featuredAudits`
     (an array of up to 6 items, newest special first, then placement).
     The full catalogue lives at /scoi.
-->
{{#if featuredAudits.length}}
<section class="audits-section" id="audits">
  <div class="section-container">
    <div class="audits-section-header">
      <div class="header-left">
        <div class="section-label">Intelligence Marketplace</div>
        <h2 class="section-title" style="margin-bottom:0.75rem;">Latest SCOI Reports</h2>
        <p style="color:var(--dark-gray); font-size:1rem; line-height:1.65; max-width:560px;">
          Civilization-grade structural audits authored by Donald Mataranyika. 
          Immutable reference intelligence for organisations and systems operating at scale.
        </p>
        <div style="margin-top:1rem;">
          <span class="audits-count-badge">📊 {{totalAuditCount}} reports available</span>
        </div>
      </div>
      <a href="/scoi" class="view-all-link">Browse all reports →</a>
    </div>

    <div class="audits-carousel">
      {{#each featuredAudits}}
      <article class="audit-card reveal">
        <div class="audit-card-header">
          <div class="audit-kind-badge {{this.auditKind}}">
            {{#if (eq this.auditKind 'special')}}Premium Special Report{{else}}Placement Audit{{/if}}
          </div>
          <h3 class="audit-card-title">{{this.subject.name}}</h3>
          <div class="audit-card-window">📅 {{this.assessmentWindow.label}}</div>
        </div>
        <div class="audit-card-body">
          <ul class="audit-features">
            {{#if (eq this.auditKind 'special')}}
              <li>Non-placement structural analysis</li>
              <li>Civilization risk signals</li>
              <li>Counterfactual responsibility framework</li>
            {{else}}
              <li>Archived placement audit (immutable)</li>
              <li>Dual-matrix SCOI calculation</li>
              <li>Structural diagnosis &amp; interpretation</li>
            {{/if}}
          </ul>
        </div>
        <div class="audit-card-footer">
          <div>
            <span class="audit-price">${{this.displayPrice}}</span>
            <span class="audit-price-label">one-time purchase</span>
          </div>
          <form method="POST" action="/scoi/checkout" style="margin:0;">
            <input type="hidden" name="auditId" value="{{this._id}}">
            <button type="submit" class="btn-audit-buy">Buy Report →</button>
          </form>
        </div>
      </article>
      {{/each}}
    </div>

    <div style="text-align:center; margin-top:3rem;">
      <a href="/scoi" class="btn btn-gold" style="display:inline-block;">View All {{totalAuditCount}} Reports →</a>
    </div>
  </div>
</section>
{{/if}}

<!-- ── FRAMEWORK / PILLARS ────────────────────────────────────────────── -->
<section class="framework-section" id="framework">
  <div class="section-container">
    <div class="section-header reveal">
      <div class="section-label">The CRIPFCnt Framework</div>
      <h2 class="section-title">Eight pillars. One map.</h2>
      <p class="section-description">Most systems fail not because people lack intelligence - but because intelligence isn't connected to responsibility, purpose, or action. CRIPFCnt gives you the map that connects all eight. It works for individuals, institutions, and governments.</p>
    </div>
    <div class="pillars-grid">
      <div class="pillar-card reveal"><div class="pillar-number">01</div><h3 class="pillar-name">Consciousness</h3><p class="pillar-description">Knowing what is actually happening - not just what you're told. The foundation of every good decision.</p></div>
      <div class="pillar-card reveal"><div class="pillar-number">02</div><h3 class="pillar-name">Responsibility</h3><p class="pillar-description">Owning outcomes, not just intentions. Real accountability means measuring what you actually produce, not just effort.</p></div>
      <div class="pillar-card reveal"><div class="pillar-number">03</div><h3 class="pillar-name">Interpretation</h3><p class="pillar-description">The same data means different things to different people. CRIPFCnt trains you to read what others miss.</p></div>
      <div class="pillar-card reveal"><div class="pillar-number">04</div><h3 class="pillar-name">Purpose</h3><p class="pillar-description">Activity without direction is noise. This pillar asks: what are you actually here to build?</p></div>
      <div class="pillar-card reveal"><div class="pillar-number">05</div><h3 class="pillar-name">Frequencies</h3><p class="pillar-description">How you communicate determines who hears you - and who doesn't. This pillar adjusts the signal.</p></div>
      <div class="pillar-card reveal"><div class="pillar-number">06</div><h3 class="pillar-name">Civilization</h3><p class="pillar-description">Individual progress that doesn't contribute to collective advancement is incomplete. This pillar connects the two.</p></div>
      <div class="pillar-card reveal"><div class="pillar-number">07</div><h3 class="pillar-name">Negotiation</h3><p class="pillar-description">Every outcome is negotiated - in meetings, in silences, in who gets mentioned and who gets left out.</p></div>
      <div class="pillar-card reveal"><div class="pillar-number">08</div><h3 class="pillar-name">Technology</h3><p class="pillar-description">AI is reorganising who gets seen, hired, funded, and trusted. This pillar ensures you understand the new rules.</p></div>
    </div>
  </div>
</section>

<!-- ── 8 QUOTIENTS TEST (PLACEMENT INTELLIGENCE) ──────────────────────── -->
<section class="piq-section" id="8qt">
  <div class="piq-inner">

    <!-- LEFT: Copy -->
    <div>
      <span class="piq-badge">✦ New - Free Assessment</span>
      <div class="piq-label">CRIPFCnt Placement Intelligence</div>
      <h2 class="piq-title">Where do you actually<br><em>sit in the structure?</em></h2>
      <p class="piq-desc">
        The 8 Quotients Test maps your orientation across eight dimensions of how you
        process the world - from Consciousness to Civilization. It is not an IQ test.
        It does not ask what you know. It asks how you are placed - and why.
      </p>
      <div class="piq-meta">
        <span class="piq-meta-item">Completely free to take</span>
        <span class="piq-meta-item">No CRIPFCnt knowledge needed</span>
        <span class="piq-meta-item">~20 minutes</span>
        <span class="piq-meta-item">Instant radar chart results</span>
      </div>
      <a href="/8qt" class="piq-btn">Begin the Assessment →</a>
      <a href="/8qt#framework" class="piq-btn-outline">See the 8 dimensions</a>
    </div>

    <!-- RIGHT: Quotient grid -->
    <div>
      <div class="piq-quotients">
        <div class="piq-q">
          <div class="piq-q-code">CsQ</div>
          <div class="piq-q-name">Consciousness</div>
          <div class="piq-q-bar"><div class="piq-q-fill" style="width:82%"></div></div>
        </div>
        <div class="piq-q">
          <div class="piq-q-code">RQ</div>
          <div class="piq-q-name">Responsibility</div>
          <div class="piq-q-bar"><div class="piq-q-fill" style="width:70%"></div></div>
        </div>
        <div class="piq-q">
          <div class="piq-q-code">IQ</div>
          <div class="piq-q-name">Interpretation</div>
          <div class="piq-q-bar"><div class="piq-q-fill" style="width:65%"></div></div>
        </div>
        <div class="piq-q">
          <div class="piq-q-code">PQ</div>
