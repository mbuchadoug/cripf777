<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CRIPFCnt - Taking Psychology to the People</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --ink: #0d0d0d;
      --cream: #f7f3ec;
      --gold: #c9a84c;
      --gold-light: #e8d08a;
      --rust: #b94a2c;
      --slate: #2c3e50;
      --muted: #6b7280;
      --card-bg: #ffffff;
      --border: rgba(201,168,76,0.25);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--ink);
      overflow-x: hidden;
    }

    /* ─── NOISE TEXTURE OVERLAY ─── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1000;
      opacity: 0.6;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 3rem;
      background: rgba(247,243,236,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--ink);
      letter-spacing: -0.02em;
    }

    .nav-logo span { color: var(--gold); }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--ink); }

    .nav-cta {
      background: var(--ink);
      color: var(--cream) !important;
      padding: 0.5rem 1.25rem;
      border-radius: 2px;
    }

    .nav-cta:hover { background: var(--gold); color: var(--ink) !important; }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      padding-top: 5rem;
      position: relative;
      overflow: hidden;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 3rem 5rem 4rem;
      position: relative;
      z-index: 2;
    }

    .hero-eyebrow {
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--gold);
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 5vw, 4.5rem);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin-bottom: 1.75rem;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--rust);
    }

    .hero-sub {
      font-size: 1.1rem;
      line-height: 1.7;
      color: #444;
      max-width: 480px;
      margin-bottom: 2.5rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--ink);
      color: var(--cream);
      padding: 0.9rem 2rem;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      font-size: 0.95rem;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.25s;
      letter-spacing: 0.02em;
    }

    .btn-primary:hover {
      background: var(--gold);
      color: var(--ink);
      transform: translateY(-2px);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: transparent;
      color: var(--ink);
      padding: 0.9rem 2rem;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      font-size: 0.95rem;
      text-decoration: none;
      border: 1.5px solid var(--ink);
      cursor: pointer;
      transition: all 0.25s;
    }

    .btn-secondary:hover {
      background: var(--ink);
      color: var(--cream);
    }

    .hero-right {
      position: relative;
      background: var(--ink);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .hero-visual {
      position: absolute;
      inset: 0;
      background: 
        radial-gradient(ellipse at 30% 50%, rgba(201,168,76,0.15) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 20%, rgba(185,74,44,0.1) 0%, transparent 50%),
        var(--ink);
    }

    .hero-formula {
      position: relative;
      z-index: 2;
      padding: 3rem;
      text-align: center;
    }

    .formula-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 2rem;
    }

    .formula-box {
      border: 1px solid rgba(201,168,76,0.4);
      padding: 2.5rem 2rem;
      margin-bottom: 2rem;
    }

    .formula-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      color: var(--cream);
      margin-bottom: 1.5rem;
      font-style: italic;
    }

    .formula-eq {
      font-family: 'Space Mono', monospace;
      font-size: 0.85rem;
      color: var(--gold-light);
      line-height: 2;
    }

    .formula-eq .operator { color: var(--rust); font-size: 1rem; }

    .hero-stat-row {
      display: flex;
      gap: 2rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-stat {
      text-align: center;
    }

    .hero-stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      color: var(--gold);
    }

    .hero-stat-label {
      font-size: 0.75rem;
      color: #888;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-top: 0.25rem;
    }

    /* ─── SECTION BASE ─── */
    section {
      padding: 6rem 0;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .section-tag {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .section-tag::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
      max-width: 3rem;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 1.25rem;
    }

    .section-body {
      font-size: 1.05rem;
      line-height: 1.75;
      color: #444;
      max-width: 600px;
    }

    /* ─── CONCEPT STRIP ─── */
    .concept-strip {
      background: var(--ink);
      color: var(--cream);
      padding: 5rem 0;
    }

    .concept-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }

    .concept-item {
      padding: 3rem 2.5rem;
      border-right: 1px solid rgba(255,255,255,0.08);
      position: relative;
      transition: background 0.3s;
    }

    .concept-item:last-child { border-right: none; }
    .concept-item:hover { background: rgba(201,168,76,0.05); }

    .concept-num {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      color: var(--gold);
      letter-spacing: 0.15em;
      margin-bottom: 1.5rem;
    }

    .concept-icon {
      width: 3rem;
      height: 3rem;
      border: 1px solid rgba(201,168,76,0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .concept-h {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
      color: var(--cream);
    }

    .concept-p {
      font-size: 0.95rem;
      line-height: 1.7;
      color: #aaa;
    }

    /* ─── VIDEO SECTION ─── */
    .videos-section {
      background: var(--cream);
      padding: 6rem 0;
    }

    .videos-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: end;
      margin-bottom: 4rem;
    }

    .videos-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .video-card {
      background: white;
      border: 1px solid rgba(0,0,0,0.06);
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .video-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.12);
    }

    .video-wrapper {
      position: relative;
      aspect-ratio: 16/9;
      background: var(--ink);
      overflow: hidden;
    }

    .video-wrapper video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .video-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%);
      display: flex;
      align-items: flex-end;
      padding: 1.25rem;
      pointer-events: none;
    }

    .video-duration {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      color: rgba(255,255,255,0.8);
      background: rgba(0,0,0,0.4);
      padding: 0.2rem 0.5rem;
    }

    .video-body {
      padding: 1.75rem;
    }

    .video-tag {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    .video-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 1rem;
    }

    .video-desc {
      font-size: 0.9rem;
      line-height: 1.65;
      color: #555;
      margin-bottom: 1.25rem;
    }

    .video-concepts {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .video-concept-tag {
      font-size: 0.75rem;
      font-family: 'Space Mono', monospace;
      padding: 0.25rem 0.6rem;
      border: 1px solid var(--border);
      color: var(--muted);
    }

    /* ─── EQUATION SECTION ─── */
    .equation-section {
      background: linear-gradient(135deg, #0d0d0d 0%, #1a1a1a 100%);
      color: var(--cream);
      padding: 6rem 0;
      position: relative;
      overflow: hidden;
    }

    .equation-section::before {
      content: 'SCOI';
      position: absolute;
      right: -2rem;
      top: 50%;
      transform: translateY(-50%);
      font-family: 'Playfair Display', serif;
      font-size: 20rem;
      font-weight: 900;
      color: rgba(201,168,76,0.04);
      pointer-events: none;
      line-height: 1;
    }

    .equation-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }

    .eq-display {
      border: 1px solid rgba(201,168,76,0.3);
      padding: 3rem;
    }

    .eq-main {
      font-family: 'Space Mono', monospace;
      font-size: 0.85rem;
      line-height: 2.5;
      color: #ccc;
    }

    .eq-main .eq-highlight {
      color: var(--gold);
      font-size: 1rem;
    }

    .eq-main .eq-result {
      color: var(--cream);
      font-size: 1.1rem;
      font-weight: 700;
      border-top: 1px solid rgba(201,168,76,0.3);
      padding-top: 1rem;
      margin-top: 0.5rem;
    }

    .eq-vars {
      margin-top: 2rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .eq-var {
      padding: 0.75rem;
      border: 1px solid rgba(255,255,255,0.06);
      font-size: 0.8rem;
    }

    .eq-var-name {
      font-family: 'Space Mono', monospace;
      color: var(--gold-light);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      margin-bottom: 0.25rem;
    }

    .eq-var-def { color: #999; font-size: 0.8rem; }

    .eq-content .section-tag { color: var(--gold); }
    .eq-content .section-tag::after { background: rgba(201,168,76,0.3); }
    .eq-content .section-title { color: var(--cream); }
    .eq-content .section-body { color: #aaa; max-width: 100%; }

    /* ─── REDISTRIBUTION SECTION ─── */
    .redist-section {
      padding: 6rem 0;
      background: var(--cream);
    }

    .redist-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .questions-list {
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .question-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem 1.5rem;
      background: white;
      border-left: 3px solid transparent;
      transition: border-color 0.2s, transform 0.2s;
      cursor: default;
    }

    .question-item:hover {
      border-left-color: var(--gold);
      transform: translateX(4px);
    }

    .q-num {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      color: var(--gold);
      padding-top: 0.2rem;
      flex-shrink: 0;
    }

    .q-text {
      font-size: 1rem;
      line-height: 1.5;
      color: var(--ink);
    }

    .redist-actions {
      margin-top: 2rem;
      padding: 2rem;
      background: var(--ink);
      color: var(--cream);
    }

    .redist-actions-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      margin-bottom: 1.25rem;
      font-style: italic;
    }

    .action-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .action-list li {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.95rem;
      color: #ccc;
    }

    .action-list li::before {
      content: '→';
      color: var(--gold);
      font-family: 'Space Mono', monospace;
      flex-shrink: 0;
    }

    /* ─── AUDIT CTA ─── */
    .audit-cta {
      background: var(--rust);
      color: var(--cream);
      padding: 5rem 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .audit-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background: 
        radial-gradient(ellipse at 20% 50%, rgba(255,255,255,0.06) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 50%, rgba(0,0,0,0.15) 0%, transparent 60%);
    }

    .audit-cta .container { position: relative; z-index: 2; }

    .audit-cta-tag {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.6);
      margin-bottom: 1.5rem;
    }

    .audit-cta h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 900;
      margin-bottom: 1.25rem;
      line-height: 1.1;
    }

    .audit-cta p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.8);
      max-width: 560px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .audit-cta .btn-primary {
      background: var(--cream);
      color: var(--rust);
    }

    .audit-cta .btn-primary:hover {
      background: var(--ink);
      color: var(--cream);
    }

    /* ─── INPUT SECTION (old tool) ─── */
    .tool-section {
      padding: 6rem 0;
      background: #f0ece4;
    }

    .tool-inner {
      max-width: 700px;
      margin: 0 auto;
      text-align: center;
    }

    .tool-inner .section-title { margin-bottom: 0.75rem; }
    .tool-inner .section-body { margin: 0 auto 2.5rem; text-align: center; }

    .input-row {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .input-row input {
      flex: 1;
      padding: 0.9rem 1.25rem;
      border: 1.5px solid rgba(0,0,0,0.15);
      background: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s;
    }

    .input-row input:focus { border-color: var(--gold); }
    .input-row input::placeholder { color: #aaa; }

    .output {
      background: white;
      border: 1.5px solid rgba(0,0,0,0.08);
      padding: 1.5rem 2rem;
      white-space: pre-wrap;
      font-family: 'Space Mono', monospace;
      font-size: 0.82rem;
      line-height: 1.7;
      text-align: left;
      color: var(--ink);
      min-height: 120px;
    }

    /* ─── BOOK BANNER ─── */
    .book-banner {
      background: var(--ink);
      color: var(--cream);
      padding: 4rem 0;
      border-top: 3px solid var(--gold);
    }

    .book-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
      flex-wrap: wrap;
    }

    .book-text h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .book-text p {
      color: #aaa;
      font-size: 0.95rem;
    }

    /* ─── FOOTER ─── */
    footer {
      background: #080808;
      color: #666;
      padding: 3rem 0;
      text-align: center;
      font-size: 0.85rem;
      font-family: 'Space Mono', monospace;
      letter-spacing: 0.05em;
    }

    footer a { color: var(--gold); text-decoration: none; }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .fade-up {
      opacity: 0;
      animation: fadeUp 0.7s ease forwards;
    }

    .fade-up:nth-child(1) { animation-delay: 0.1s; }
    .fade-up:nth-child(2) { animation-delay: 0.25s; }
    .fade-up:nth-child(3) { animation-delay: 0.4s; }
    .fade-up:nth-child(4) { animation-delay: 0.55s; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      .hero { grid-template-columns: 1fr; }
      .hero-right { min-height: 340px; }
      .hero-left { padding: 4rem 1.5rem 3rem; }
      .concept-grid { grid-template-columns: 1fr; }
      .concept-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); }
      .videos-header { grid-template-columns: 1fr; gap: 2rem; }
      .videos-grid { grid-template-columns: 1fr; }
      .equation-inner { grid-template-columns: 1fr; gap: 3rem; }
      .redist-inner { grid-template-columns: 1fr; gap: 3rem; }
      .book-inner { flex-direction: column; text-align: center; }
      .input-row { flex-direction: column; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-logo">CRIP<span>F</span>Cnt</div>
    <ul class="nav-links">
      <li><a href="#concepts">Framework</a></li>
      <li><a href="#videos">Insights</a></li>
      <li><a href="#equation">The Equation</a></li>
      <li><a href="#audit" class="nav-cta">Run Audit →</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-eyebrow fade-up">Taking Psychology to the People</div>
      <h1 class="fade-up">
        Structure shapes<br>
        what effort<br>
        <em>cannot explain.</em>
      </h1>
      <p class="hero-sub fade-up">
        Two people work equally hard. One advances. One remains unseen. 
        CRIPFCnt is the framework that names what happens in the space between effort and outcome - 
        and what you can do about it.
      </p>
      <div class="hero-actions fade-up">
        <a href="#audit" class="btn-primary">Run a Live SCOI Audit →</a>
        <a href="#videos" class="btn-secondary">Watch the Insights</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-visual"></div>
