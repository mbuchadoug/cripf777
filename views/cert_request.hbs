{{!-- views/8qt/cert_request.hbs (STEP 7 — Certificate Request) --}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Request Certificate — CRIPFCnt 8QT</title>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root{--navy:#1E3A5F;--gold:#C9A961;--white:#fff;--light:#F8F9FA;--border:#E9ECEF;--text:#212529;--dark:#495057;--red:#dc2626}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:var(--light);min-height:100vh;display:flex;align-items:flex-start;justify-content:center;padding:40px 20px 80px}
    .wrap{max-width:600px;width:100%}
    .back-link{display:inline-flex;align-items:center;gap:6px;color:var(--navy);text-decoration:none;font-size:.85rem;font-weight:500;margin-bottom:24px}
    .card{background:var(--white);border-radius:16px;padding:40px;box-shadow:0 8px 32px rgba(30,58,95,.08);border:1px solid var(--border)}
    .cert-preview{background:linear-gradient(135deg,var(--navy),#0F1C2E);border-radius:10px;padding:24px;text-align:center;margin-bottom:32px;color:var(--white)}
    .cert-preview .label{font-size:.65rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:8px}
    .cert-preview .arch{font-family:'Crimson Pro',serif;font-size:1.4rem;font-weight:700;margin-bottom:4px}
    .cert-preview .sub{font-size:.8rem;color:#E5D4A6;opacity:.8}
    h2{font-family:'Crimson Pro',serif;font-size:1.8rem;color:var(--navy);margin-bottom:8px}
    .subtitle{font-size:.9rem;color:var(--dark);margin-bottom:28px;line-height:1.6}
    .form-group{margin-bottom:18px}
    label{display:block;font-size:.8rem;font-weight:600;color:var(--navy);margin-bottom:6px}
    label .req{color:var(--red)}
    input[type=text],input[type=email],input[type=password]{width:100%;padding:.7rem .9rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Inter',sans-serif;font-size:.9rem;color:var(--text);transition:border-color .2s}
    input:focus{outline:none;border-color:var(--navy)}
    .tier-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
    .tier-card{border:2px solid var(--border);border-radius:10px;padding:16px;cursor:pointer;transition:all .15s;text-align:center}
    .tier-card:hover{border-color:var(--navy)}
    .tier-card.selected{border-color:var(--gold);background:#fdf8ef}
    .tier-card input[type=radio]{display:none}
    .tier-price{font-size:1.4rem;font-weight:700;color:var(--navy);margin-bottom:4px}
    .tier-name{font-size:.8rem;font-weight:600;color:var(--dark);margin-bottom:6px;text-transform:uppercase;letter-spacing:1px}
    .tier-features{font-size:.75rem;color:var(--dark);line-height:1.6}
    .checkbox-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:16px}
    .checkbox-row input{margin-top:3px;flex-shrink:0}
    .checkbox-row label{font-size:.85rem;color:var(--dark);font-weight:400;margin-bottom:0}
    .divider{border:none;border-top:1px solid var(--border);margin:24px 0}
    .convert-section{background:var(--light);border-radius:8px;padding:16px;margin-bottom:20px}
    .convert-section h4{font-size:.85rem;font-weight:600;color:var(--navy);margin-bottom:4px}
    .convert-section p{font-size:.78rem;color:var(--dark);margin-bottom:12px}
    .btn-primary{width:100%;padding:.9rem;background:var(--navy);color:var(--white);border:none;border-radius:8px;font-family:'Inter',sans-serif;font-size:1rem;font-weight:600;cursor:pointer;transition:background .2s;margin-top:8px}
    .btn-primary:hover{background:#0F1C2E}
    .security-note{text-align:center;font-size:.75rem;color:var(--dark);margin-top:12px;opacity:.7}
    .error{background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:10px 14px;color:#dc2626;font-size:.85rem;margin-bottom:16px}
  </style>
</head>
<body>
<div class="wrap">
  <a href="/8qt/results/{{attempt._id}}" class="back-link">← Back to Results</a>

  <div class="card">
    <!-- Certificate preview -->
    <div class="cert-preview">
      <div class="label">Official Certificate</div>
      <div class="arch">{{attempt.archetypeName}}</div>
      <div class="sub">CRIPFCnt 8 Quotients Assessment · {{attempt.dominantQuotient}} Dominant</div>
    </div>

    <h2>Request Your Certificate</h2>
    <p class="subtitle">
      Your certificate will include your full quotient scores, archetype profile, and a unique
      verification code. It will be emailed to you as a high-quality PDF.
    </p>

    {{#if error}}<div class="error">{{error}}</div>{{/if}}

    <!-- Tier selection -->
    <div style="margin-bottom:8px"><label>Choose your certificate tier</label></div>
    <div class="tier-grid">
      <div class="tier-card selected" id="tier-standard" onclick="selectTier('standard')">
        <input type="radio" name="tier" value="standard" checked>
        <div class="tier-price">${{prices.standard}}</div>
        <div class="tier-name">Standard</div>
        <div class="tier-features">PDF certificate<br>All 8 scores<br>Verification code<br>Public verify link</div>
      </div>
      <div class="tier-card" id="tier-premium" onclick="selectTier('premium')">
        <input type="radio" name="tier" value="premium">
        <div class="tier-price">${{prices.premium}}</div>
        <div class="tier-name">Premium</div>
        <div class="tier-features">Everything in Standard<br>Embossed design<br>QR verification code<br>Priority email</div>
      </div>
    </div>

    <hr class="divider">

    <!-- Personal details -->
    <div class="form-group">
      <label for="fullName">Full name as it should appear on certificate <span class="req">*</span></label>
      <input type="text" id="fullName" placeholder="e.g. Tendai Moyo" required
             value="{{#if attempt.profile.firstName}}{{attempt.profile.firstName}}{{/if}}">
    </div>
    <div class="form-group">
      <label for="email">Email address for delivery <span class="req">*</span></label>
      <input type="email" id="email" placeholder="your@email.com" required
             value="{{#if attempt.certificateEmail}}{{attempt.certificateEmail}}{{/if}}">
    </div>
    <div class="form-group">
      <label for="orgName">Organisation or institution (optional)</label>
      <input type="text" id="orgName" placeholder="e.g. Ministry of Education, Harare">
    </div>

    <!-- Make profile public -->
    <div class="checkbox-row">
      <input type="checkbox" id="makePublic" name="makePublic">
      <label for="makePublic">Allow my full quotient scores to be visible on the public verification page (name and archetype are always shown)</label>
    </div>

    <!-- Account creation for anonymous users -->
    {{#unless user}}
    <div class="convert-section">
      <h4>Save your results permanently (optional)</h4>
      <p>Set a password to convert your anonymous session into a registered account. You can skip this.</p>
      <div class="form-group" style="margin-bottom:0">
        <label>Password (min 8 characters) — leave blank to stay anonymous</label>
        <input type="password" id="password" placeholder="Optional — create account to save results">
      </div>
    </div>
    {{/unless}}

    <button class="btn-primary" onclick="submitRequest()">Proceed to Payment →</button>
    <p class="security-note">🔒 Secured by Stripe — your payment details never touch our servers</p>
  </div>
</div>

<script>
let selectedTier = 'standard';

function selectTier(tier) {
  selectedTier = tier;
  document.querySelectorAll('.tier-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('tier-' + tier).classList.add('selected');
}

async function submitRequest() {
  const fullName = document.getElementById('fullName').value.trim();
  const email = document.getElementById('email').value.trim();
  const orgName = document.getElementById('orgName')?.value.trim() || '';
  const makePublic = document.getElementById('makePublic')?.checked || false;
  const password = document.getElementById('password')?.value || '';

  if (!fullName) { alert('Please enter your full name as it should appear on the certificate.'); return; }
  if (!email || !email.includes('@')) { alert('Please enter a valid email address.'); return; }

  try {
    const r = await fetch('/8qt/certificate/{{attempt._id}}', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ fullName, email, orgName, tier: selectedTier, makePublic, password })
    });
    const d = await r.json();
    if (d.ok && d.redirect) {
      window.location.href = d.redirect;
    } else {
      alert(d.error || 'Something went wrong. Please try again.');
    }
  } catch (e) {
    alert('Network error. Please try again.');
  }
}
</script>
</body>
</html>
