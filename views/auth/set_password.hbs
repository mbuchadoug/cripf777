{{!-- views/auth/set_password.hbs --}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{#if isFirstTime}}Create Your Password{{else}}Change Password{{/if}} | CRIPFCnt</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --ink:    #0f1117;
      --muted:  #6b7280;
      --border: #e5e7eb;
      --bg:     #f9fafb;
      --surface:#ffffff;
      --blue:   #2563eb;
      --blue-lt:#dbeafe;
      --green:  #16a34a;
      --green-lt:#dcfce7;
      --red:    #dc2626;
      --red-lt: #fee2e2;
      --gold:   #ca8a04;
      --r:      12px;
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      color: var(--ink);
    }

    .card {
      width: 100%;
      max-width: 480px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,.06);
    }

    /* ── Header strip ── */
    .card-head {
      background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
      padding: 36px 36px 30px;
      color: #fff;
    }

    .logo {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -.5px;
      margin-bottom: 20px;
      opacity: .95;
    }

    .logo em { color: #fde68a; font-style: normal; }

    .card-head h1 {
      font-size: 26px;
      font-weight: 800;
      margin-bottom: 6px;
    }

    .card-head p {
      font-size: 14px;
      opacity: .85;
      line-height: 1.5;
    }

    /* ── Username callout ── */
    .username-badge {
      margin: 0 36px;
      margin-top: -16px;
      background: var(--surface);
      border: 2px solid var(--blue-lt);
      border-radius: var(--r);
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .username-badge .icon {
      font-size: 28px;
      flex-shrink: 0;
    }

    .username-badge .label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .6px;
      color: var(--muted);
    }

    .username-badge .value {
      font-size: 19px;
      font-weight: 800;
      color: var(--blue);
      font-family: 'DM Mono', 'Courier New', monospace;
      letter-spacing: .5px;
    }

    /* ── Body ── */
    .card-body {
      padding: 28px 36px 36px;
    }

    /* ── Alerts ── */
    .alert {
      border-radius: var(--r);
      padding: 12px 16px;
      font-size: 13.5px;
      font-weight: 500;
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 22px;
    }

    .alert-error   { background: var(--red-lt);   color: var(--red);   border: 1px solid #fca5a5; }
    .alert-success { background: var(--green-lt); color: var(--green); border: 1px solid #86efac; }

    /* ── Form ── */
    .form-group {
      margin-bottom: 18px;
    }

    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 7px;
    }

    .input-wrap {
      position: relative;
    }

    .form-input {
      width: 100%;
      padding: 12px 44px 12px 14px;
      border: 1.5px solid var(--border);
      border-radius: var(--r);
      font-size: 15px;
      font-family: inherit;
      color: var(--ink);
      background: #fff;
      outline: none;
      transition: border-color .15s;
    }

    .form-input:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(37,99,235,.1);
    }

    .eye-btn {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      font-size: 17px;
      color: var(--muted);
      padding: 4px;
    }

    /* ── Strength meter ── */
    .strength-bar {
      height: 4px;
      border-radius: 2px;
      background: var(--border);
      margin-top: 7px;
      overflow: hidden;
    }

    .strength-fill {
      height: 100%;
      border-radius: 2px;
      transition: width .25s, background .25s;
    }

    .strength-label {
      font-size: 11.5px;
      color: var(--muted);
      margin-top: 4px;
    }

    /* ── Submit button ── */
    .btn {
      width: 100%;
      padding: 14px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: var(--r);
      font-size: 15px;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: background .15s, transform .1s;
      margin-top: 6px;
    }

    .btn:hover    { background: #1d4ed8; }
    .btn:active   { transform: scale(.99); }
    .btn:disabled { opacity: .6; cursor: not-allowed; }

    /* ── Login link ── */
    .login-link {
      text-align: center;
      margin-top: 20px;
      font-size: 13.5px;
      color: var(--muted);
    }

    .login-link a {
      color: var(--blue);
      font-weight: 600;
      text-decoration: none;
    }

    .login-link a:hover { text-decoration: underline; }

    /* ── What you can do with it ── */
    .info-box {
      background: #f0f9ff;
      border: 1px solid #bae6fd;
      border-radius: var(--r);
      padding: 14px 16px;
      margin-bottom: 22px;
      font-size: 13px;
      color: #0369a1;
      line-height: 1.6;
    }

    .info-box strong { font-weight: 700; }

    @media (max-width: 520px) {
      body { padding: 0; align-items: flex-start; }
      .card { border-radius: 0; min-height: 100vh; }
      .card-head { padding: 28px 24px 24px; }
      .card-body { padding: 24px 24px 32px; }
      .username-badge { margin: 0 24px; margin-top: -14px; }
    }
  </style>
</head>
<body>

<div class="card">

  <div class="card-head">
    <div class="logo">CRIPF<em>Cnt</em></div>
    <h1>{{#if isFirstTime}}Create Your Password{{else}}Change Password{{/if}}</h1>
    <p>
      {{#if isFirstTime}}
        Set a password so you can log in directly — no Google required.
      {{else}}
        Update your account password.
      {{/if}}
    </p>
  </div>

  {{#if user.username}}
  <div class="username-badge">
    <span class="icon">🔑</span>
    <div>
      <div class="label">Your Login Username</div>
      <div class="value">{{user.username}}</div>
    </div>
  </div>
  {{/if}}

  <div class="card-body">

    {{#if error}}
    <div class="alert alert-error">
      <span>⚠️</span>
      <span>{{error}}</span>
    </div>
    {{/if}}

    {{#if success}}
    <div class="alert alert-success">
      <span>✅</span>
      <div>
        <strong>Done!</strong> {{success}}
      </div>
    </div>
    {{/if}}

    {{#unless success}}

    <div class="info-box">
      <strong>Once set, you can sign in at
        <a href="/auth/school" style="color:#0369a1">/auth/school</a>
      </strong> using your username <strong>{{#if user.username}}{{user.username}}{{else}}(will be assigned){{/if}}</strong>
      and your new password — even without Google.
    </div>

    <form method="POST" action="/auth/set-password" id="pwForm">

      <div class="form-group">
        <label for="newPassword">New Password</label>
        <div class="input-wrap">
          <input
            type="password"
            id="newPassword"
            name="newPassword"
            class="form-input"
            placeholder="At least 8 characters"
            autocomplete="new-password"
            required
            minlength="8"
            oninput="checkStrength(this.value)"
          />
          <button type="button" class="eye-btn" onclick="toggleVis('newPassword',this)">👁️</button>
        </div>
        <div class="strength-bar"><div class="strength-fill" id="strengthFill" style="width:0"></div></div>
        <div class="strength-label" id="strengthLabel"></div>
      </div>

      <div class="form-group">
        <label for="confirmPassword">Confirm Password</label>
        <div class="input-wrap">
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            class="form-input"
            placeholder="Repeat your password"
            autocomplete="new-password"
            required
          />
          <button type="button" class="eye-btn" onclick="toggleVis('confirmPassword',this)">👁️</button>
        </div>
      </div>

      <button type="submit" class="btn" id="submitBtn">
        {{#if isFirstTime}}Create Password{{else}}Save New Password{{/if}}
      </button>

    </form>

    {{/unless}}

    <div class="login-link">
      {{#if success}}
        <a href="/auth/school">← Sign in with your username &amp; password</a>
      {{else}}
        Already have a password? <a href="/auth/school">Sign in here →</a>
      {{/if}}
    </div>

  </div>
</div>

<script>
function toggleVis(id, btn) {
  const inp = document.getElementById(id);
  if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
  else { inp.type = 'password'; btn.textContent = '👁️'; }
}

function checkStrength(val) {
  const fill  = document.getElementById('strengthFill');
  const label = document.getElementById('strengthLabel');
  let score = 0;
  if (val.length >= 8)  score++;
  if (val.length >= 12) score++;
  if (/[A-Z]/.test(val))  score++;
  if (/[0-9]/.test(val))  score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;

  const levels = [
    { pct: '0%',   col: '#e5e7eb', text: '' },
    { pct: '20%',  col: '#ef4444', text: 'Very weak' },
    { pct: '40%',  col: '#f97316', text: 'Weak' },
    { pct: '60%',  col: '#eab308', text: 'Fair' },
    { pct: '80%',  col: '#22c55e', text: 'Strong' },
    { pct: '100%', col: '#16a34a', text: 'Very strong' },
  ];
  const l = levels[score] || levels[0];
  fill.style.width      = l.pct;
  fill.style.background = l.col;
  label.textContent     = l.text;
  label.style.color     = l.col;
}

document.getElementById('pwForm')?.addEventListener('submit', function (e) {
  const pw  = document.getElementById('newPassword').value;
  const cpw = document.getElementById('confirmPassword').value;
  if (pw !== cpw) {
    e.preventDefault();
    alert('Passwords do not match. Please try again.');
    return;
  }
  document.getElementById('submitBtn').disabled = true;
  document.getElementById('submitBtn').textContent = 'Saving…';
});
</script>

</body>
</html>
