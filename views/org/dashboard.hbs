                  data-topics="{{#each topics}}{{this}} {{/each}}">
                  <div class="qrow-n">{{inc @index}}</div>
                  <div class="qrow-info">
                    <div class="qrow-t">{{quizTitle}}</div>
                    <div class="qrow-m">
                      <span>📝 {{questionCount}}q</span>
                      {{#if category}}<span>· {{capitalize (replace category "-" " ")}}</span>{{/if}}
                      {{#unless isAdminQuiz}}<span>· {{status}}</span>{{/unless}}
                    </div>
                  </div>
                  <div class="qrow-a">
                    {{#if isTrial}}<span class="badge b-blue">Trial</span>{{/if}}
                    {{#if isAdminQuiz}}<span class="badge b-emerald">Cat.</span>{{/if}}
                    <a href="{{openUrl}}" class="btn btn-p btn-xs">
                      {{#if isAdminQuiz}}Take{{else if (eq status "completed")}}Review{{else}}Start{{/if}}
                    </a>
                    {{#if ../../isAdmin}}{{#unless isAdminQuiz}}
                    <form method="POST" action="/admin/orgs/{{../../org.slug}}/quizzes/{{assignmentId}}/delete"
                      style="display:inline" onsubmit="return confirm('Delete?');">
                      <button class="btn btn-d btn-xs">Del</button>
                    </form>
                    {{/unless}}{{/if}}
