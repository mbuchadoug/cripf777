  </main>
</div>

{{!-- MOBILE SIDEBAR DRAWER --}}
{{#if isCripfcntSchool}}
<div class="mob-drawer" id="mob-drawer" onclick="closeMobSidebar(event)">
  <div class="mob-panel" id="mob-panel">
    <div class="mob-header">
      <span>Browse Categories</span>
      <button class="mob-close" onclick="closeMobSidebar(null,true)">✕</button>
    </div>
    <button class="sbi {{#unless categoryFilter}}active{{/unless}}" onclick="clearCategoryFilter()">
      <span class="sbi-em">🌐</span>
      <span class="sbi-txt"><div class="sbi-t">All Assessments</div><div class="sbi-s">{{totalQuizCount}} available</div></span>
    </button>
    {{#if categoryMeta.length}}
    <div class="sb-div">Professional Areas</div>
    {{#each categoryMeta}}
    {{#if (gt this.count 0)}}
    <button class="sbi sb-cat {{#if (eq this.slug ../categoryFilter)}}active{{/if}}"
      onclick="setCategoryFilter('{{this.slug}}')">
      <span class="sbi-em">{{this.icon}}</span>
      <span class="sbi-txt">
        <div class="sbi-t">{{this.label}}</div>
        <div class="sbi-s">{{this.count}} assessment{{#if (gt this.count 1)}}s{{/if}}</div>
      </span>
      <span class="sbi-n">{{this.count}}</span>
    </button>
    {{#if (eq this.slug ../categoryFilter)}}
    {{#each ../../allSeriesMeta}}
    {{#if (eq this.category ../../../../../categoryFilter)}}
    {{#if (gt this.count 0)}}
    <button class="sbi sb-series {{#if (eq this.slug ../../../../seriesFilter)}}active{{/if}}"
      onclick="setSeriesFilter('{{this.slug}}')">
      <span class="sbi-em">▸</span>
      <span class="sbi-txt"><div class="sbi-t">{{this.label}}</div><div class="sbi-s">{{this.count}} assessments</div></span>
      <span class="sbi-n">{{this.count}}</span>
    </button>
    {{/if}}
    {{/if}}
    {{/each}}
    {{/if}}
    {{/if}}
    {{/each}}
    {{/if}}
  </div>
  <div class="mob-back"></div>
</div>
{{/if}}

<script>
function switchTab(id,btn){
  ['assessments','history','admin'].forEach(function(t){var el=document.getElementById('tab-'+t);if(el)el.classList.add('jh');});
  document.querySelectorAll('.ntab').forEach(function(t){t.classList.remove('active');});
  var target=document.getElementById('tab-'+id);if(target)target.classList.remove('jh');
  if(btn)btn.classList.add('active');
}
function setView(mode){
  var mc=document.getElementById('main-content');if(mc)mc.dataset.view=mode;
  document.getElementById('vb-grid').classList.toggle('active',mode==='grid');
  document.getElementById('vb-list').classList.toggle('active',mode==='list');
  try{localStorage.setItem('dv',mode);}catch(e){}
}
function toggleSeries(slug){
  var b=document.getElementById('sbody-'+slug),c=document.getElementById('chev-'+slug);
  if(!b)return;var h=b.classList.toggle('jh');if(c)c.classList.toggle('open',!h);
}
function setCategoryFilter(slug){
  closeMobSidebar(null,true);
  var url=new URL(window.location.href);
  url.searchParams.set('category',slug);
  url.searchParams.delete('series');
  window.location.href=url.toString();
}
function clearCategoryFilter(){
  closeMobSidebar(null,true);
  var mc=document.getElementById('main-content'),slug=mc&&mc.dataset.org;
  window.location.href=slug?'/org/'+slug+'/dashboard':window.location.pathname;
}
function setSeriesFilter(slug){
  closeMobSidebar(null,true);
  var url=new URL(window.location.href);
  url.searchParams.set('series',slug);
  window.location.href=url.toString();
}
function toggleFPanel(btn){
  var p=document.getElementById('fpanel');if(!p)return;var h=p.classList.toggle('jh');btn.classList.toggle('on',!h);
}
var _st;
function liveSearch(q){
  clearTimeout(_st);
  _st=setTimeout(function(){
    var term=q.toLowerCase().trim();
    var blocks=document.querySelectorAll('.series-block'),total=0;
    blocks.forEach(function(block){
      var cnt=0;
      block.querySelectorAll('.qcard,.qrow').forEach(function(card){
        var hay=[card.dataset.title||'',card.dataset.topics||'',card.dataset.pillar||'',card.dataset.category||'',card.dataset.series||''].join(' ').toLowerCase();
        var match=!term||hay.includes(term);
        card.style.display=match?'':'none';
        if(match)cnt++;
      });
      if(term&&cnt===0){block.style.display='none';}
      else{
        block.style.display='';
        if(term&&cnt>0){var sl=block.dataset.series;if(sl){var sb=document.getElementById('sbody-'+sl),cv=document.getElementById('chev-'+sl);if(sb&&sb.classList.contains('jh')){sb.classList.remove('jh');if(cv)cv.classList.add('open');}}}
        total+=cnt;
      }
    });
    var vc=document.getElementById('vis-cnt');
    if(vc)vc.textContent=term?' - '+total+' result'+(total!==1?'s':''):'';
    var nr=document.getElementById('no-results'),lib=document.getElementById('quiz-lib');
    if(nr&&lib){var any=Array.from(blocks).some(function(b){return b.style.display!=='none';});nr.classList.toggle('jh',!term||any);}
  },150);
}
function openMobSidebar(){var d=document.getElementById('mob-drawer');if(d)d.classList.add('open');document.body.style.overflow='hidden';}
function closeMobSidebar(e,force){
  if(!force&&e){var t=e.target;if(!t.classList.contains('mob-back')&&t!==e.currentTarget)return;}
  var d=document.getElementById('mob-drawer');if(d)d.classList.remove('open');document.body.style.overflow='';
}

/* ── Category carousel: arrow scroll + mouse drag + fade state ─────────── */
(function(){
  var scroll = null, wrap = null, prevBtn = null, nextBtn = null;

  function initCatScroll() {
    scroll  = document.getElementById('cat-scroll');
    wrap    = document.getElementById('cat-scroll-wrap');
    prevBtn = document.getElementById('cat-prev');
    nextBtn = document.getElementById('cat-next');
    if (!scroll) return;
    scroll.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
    initDrag();
  }

  function updateArrows() {
    if (!scroll || !wrap) return;
    var atStart = scroll.scrollLeft <= 4;
    var atEnd   = scroll.scrollLeft >= (scroll.scrollWidth - scroll.clientWidth - 4);
    wrap.classList.toggle('at-start', atStart);
    wrap.classList.toggle('at-end',   atEnd);
    if (prevBtn) prevBtn.disabled = atStart;
    if (nextBtn) nextBtn.disabled = atEnd;
  }

  window.scrollCats = function(dir) {
    if (!scroll) return;
    /* scroll by ~3 card widths (approx 520px) */
    scroll.scrollBy({ left: dir * 520, behavior: 'smooth' });
  };

  function initDrag() {
    if (!scroll) return;
    var isDown = false, startX = 0, scrollStart = 0, moved = false;

    scroll.addEventListener('mousedown', function(e) {
      if (e.button !== 0) return;
      isDown = true; moved = false;
      startX = e.pageX - scroll.offsetLeft;
      scrollStart = scroll.scrollLeft;
      scroll.classList.add('is-dragging');
      e.preventDefault();
    });

    document.addEventListener('mousemove', function(e) {
      if (!isDown) return;
      var x    = e.pageX - scroll.offsetLeft;
      var dist = x - startX;
      if (Math.abs(dist) > 4) moved = true;
      scroll.scrollLeft = scrollStart - dist;
    });

    document.addEventListener('mouseup', function(e) {
      if (!isDown) return;
      isDown = false;
      scroll.classList.remove('is-dragging');
      /* if the mouse barely moved, treat as a click - do nothing extra */
      /* if it moved, prevent the click event on child buttons */
      if (moved) {
        var stop = function(ev) { ev.stopPropagation(); ev.preventDefault(); };
        scroll.addEventListener('click', stop, { once: true, capture: true });
      }
    });

    /* prevent text selection while dragging */
    scroll.addEventListener('dragstart', function(e){ e.preventDefault(); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCatScroll);
  } else {
    initCatScroll();
  }
})();

(function(){
  try{var sv=localStorage.getItem('dv');if(sv==='list')setView('list');}catch(e){}
  var p=new URLSearchParams(window.location.search);
  if(p.get('series')){
    var fp=document.getElementById('fpanel'),fb=document.getElementById('fbtn-toggle');
    if(fp)fp.classList.remove('jh');if(fb)fb.classList.add('on');
  }
})();
</script>
</body>
</html>
