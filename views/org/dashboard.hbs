        </div>

        {{else}}
        <div class="empty">
          <div class="empty-ic">📚</div>
          <h3>No Assessments Available</h3>
          <p>{{#if categoryFilter}}No assessments found in this area - try another category{{else if searchQuery}}Try different search terms{{else}}Check back soon for new content{{/if}}</p>
        </div>
        {{/if}}

      {{else}}
        {{!-- Non-cripfcnt-school orgs --}}
        {{#if hasAssignedQuizzes}}
          {{#each quizzesByModule}}
          <div class="series-block">
            <button class="series-hdr" onclick="toggleSeries('mod-{{@key}}')">
              <div class="s-stripe"></div>
              <div class="s-info"><div class="s-title">
                {{#if (eq @key "consciousness")}}🧠 {{/if}}
                {{#if (eq @key "responsibility")}}🤝 {{/if}}
                {{#if (eq @key "purpose")}}🎯 {{/if}}
                {{#if (eq @key "technology")}}💻 {{/if}}
                {{#if (eq @key "frequencies")}}📡 {{/if}}
                {{#if (eq @key "civilization")}}🏛 {{/if}}
                {{#if (eq @key "interpretation")}}🔍 {{/if}}
                {{#if (eq @key "negotiation")}}🤝 {{/if}}
                {{capitalize @key}}</div></div>
              <div class="s-right"><span class="s-count">{{this.length}} assessment{{#if (gt this.length 1)}}s{{/if}}</span><span class="s-chev open" id="chev-mod-{{@key}}">▼</span></div>
            </button>
            <div class="series-body" id="sbody-mod-{{@key}}">
              <div class="qgrid">
                {{#each this}}
                <div class="qcard">
                  <div class="qcard-top"><h3 class="qtitle">{{quizTitle}}</h3><div class="qbdgs">{{#if isTrial}}<span class="badge b-blue">Trial</span>{{/if}}{{#if isAdminQuiz}}<span class="badge b-emerald">Catalog</span>{{/if}}</div></div>
                  <div class="qmeta">📝 {{questionCount}} questions{{#unless isAdminQuiz}}<span class="qsep">·</span>{{status}}{{/unless}}</div>
                  {{#if topics}}<div class="qtags">{{#each topics}}<span class="qtag">{{this}}</span>{{/each}}</div>{{/if}}
                  <div class="qfoot">
                    <a href="{{openUrl}}" class="btn btn-p btn-sm" style="flex:1">{{#if isAdminQuiz}}Take Assessment{{else}}Continue{{/if}}</a>
                    {{#if ../../isAdmin}}{{#unless isAdminQuiz}}<form method="POST" action="/admin/orgs/{{../../org.slug}}/quizzes/{{assignmentId}}/delete" style="display:inline" onsubmit="return confirm('Delete?');"><button class="btn btn-d btn-xs">Delete</button></form>{{/unless}}{{/if}}
                  </div>
                </div>
                {{/each}}
              </div>
            </div>
          </div>
          {{/each}}
        {{else}}
        <div class="empty"><div class="empty-ic">📚</div><h3>No Assessments Available</h3><p>Check back soon.</p></div>
        {{/if}}
      {{/if}}

    </div>{{!-- /tab-assessments --}}

    <div id="tab-history" class="jh">
      {{#if attemptRows.length}}
      <div class="sec-title">📋 Assessment History</div>
      <div class="tw">
        <table class="ht">
          <thead><tr><th>Assessment</th><th>Score</th><th>Result</th><th>Date</th><th>Action</th></tr></thead>
          <tbody>
            {{#each attemptRows}}
            <tr>
              <td><strong>{{quizTitle}}</strong></td>
              <td><span class="spill {{#if (gte percentage 80)}}sh{{else if (gte percentage 60)}}smd{{else}}sl{{/if}}">{{percentage}}%</span></td>
              <td>{{#if passed}}<span style="color:var(--emerald);font-weight:700">✓ Passed</span>{{else}}<span style="color:var(--rose);font-weight:700">✗ Failed</span>{{/if}}</td>
              <td style="color:var(--ink-muted)">{{formatDate finishedAt}}</td>
              <td><a href="/org/{{../org.slug}}/my-attempts/{{_id}}" class="btn btn-o btn-xs">Review</a></td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{else}}
      <div class="empty"><div class="empty-ic">📋</div><h3>No History Yet</h3><p>Complete an assessment and your results will appear here.</p></div>
      {{/if}}
    </div>

    {{#if isAdmin}}
    <div id="tab-admin" class="jh">
      <div class="sec-title">🔧 Admin Tools</div>
      <div class="atgrid">
        <a href="/admin/orgs/{{org.slug}}/manage" class="atcard"><div class="ati" style="background:var(--blue-bg)">⚙️</div><div><div class="atl">Manage Org</div><div class="atd">Members, roles &amp; settings</div></div></a>
        <a href="/admin/orgs/{{org.slug}}/attempts" class="atcard"><div class="ati" style="background:var(--emerald-bg)">📊</div><div><div class="atl">All Attempts</div><div class="atd">View every result</div></div></a>
        <a href="/admin/orgs/{{org.slug}}/reports/attempts.csv" class="atcard"><div class="ati" style="background:var(--teal-bg)">⬇️</div><div><div class="atl">Export CSV</div><div class="atd">Download raw data</div></div></a>
        <a href="/org/{{org.slug}}/certificates" class="atcard"><div class="ati" style="background:var(--amber-bg)">🏆</div><div><div class="atl">Certificates</div><div class="atd">Browse awarded certs</div></div></a>
        <a href="/admin/orgs/{{org.slug}}/classification-review" class="atcard"><div class="ati" style="background:var(--violet-bg)">🏷️</div><div><div class="atl">Classification Review</div><div class="atd">Review low-confidence AI categories</div></div></a>
        <a href="/admin/orgs/{{org.slug}}/manage#classify" class="atcard" onclick="event.preventDefault();window.location='/admin/orgs/{{org.slug}}/manage';setTimeout(()=>document.querySelector('[data-page=classify]')?.click(),400)"><div class="ati" style="background:var(--blue-bg)">📂</div><div><div class="atl">Reclassify Quizzes</div><div class="atd">Manually assign pillars and categories</div></div></a>
      </div>
