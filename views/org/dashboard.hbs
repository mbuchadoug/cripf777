                    </form>
                    {{/unless}}{{/if}}
                  </div>
                </div>
                {{/each}}
              </div>
              <div class="qlist">
                {{#each this.quizzes}}
                <div class="qrow"
                  data-title="{{quizTitle}}" data-pillar="{{pillar}}"
