{{!-- views/consumer/start.hbs - REDESIGNED: Clear Teacher vs Parent distinction --}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Junior Academy | CRIPFCnt for Parents, Guardians & Private Teachers</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@600;700&family=General+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --gold:#FFB800;--gold-light:#FFC933;--gold-dark:#E6A600;
      --navy:#0F172A;--navy-light:#1E293B;--navy-dark:#020617;
      --slate:#64748B;--slate-light:#94A3B8;
      --white:#FFFFFF;--cream:#FEFCE8;
      --blue:#3B82F6;--green:#10B981;--purple:#8B5CF6;
      --indigo:#6366f1;--indigo-light:#818cf8;
      --radius:20px;
      --shadow:0 10px 40px rgba(0,0,0,0.08);
      --shadow-lg:0 20px 60px rgba(0,0,0,0.12);
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'General Sans',system-ui,sans-serif;background:linear-gradient(180deg,#FEFCE8 0%,#FEF3C7 100%);color:var(--navy);line-height:1.6;overflow-x:hidden;}

    /* NAVBAR */
    .navbar{background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border-bottom:1px solid rgba(15,23,42,0.08);padding:16px 0;position:sticky;top:0;z-index:100;}
    .nav-container{max-width:1300px;margin:0 auto;padding:0 32px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
    .brand{font-family:'Clash Display',sans-serif;font-weight:700;font-size:26px;color:var(--navy);text-decoration:none;letter-spacing:-0.5px;}
    .brand span{color:var(--gold);}
    .nav-right{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
    .nav-link{color:var(--navy);text-decoration:none;font-weight:500;font-size:14px;transition:color 0.2s;}
    .nav-link:hover{color:var(--gold);}

    /* NAV BUTTONS - Teacher vs Parent */
    .btn-nav{padding:11px 22px;border-radius:12px;font-weight:700;font-size:13px;text-decoration:none;transition:all 0.3s;display:inline-flex;align-items:center;gap:6px;border:2px solid transparent;}
    .btn-nav-teacher{background:var(--indigo);color:white;box-shadow:0 4px 12px rgba(99,102,241,0.3);}
    .btn-nav-teacher:hover{background:var(--indigo-light);transform:translateY(-2px);box-shadow:0 6px 16px rgba(99,102,241,0.4);}
    .btn-nav-parent{background:var(--gold);color:var(--navy-dark);box-shadow:0 4px 12px rgba(255,184,0,0.3);}
    .btn-nav-parent:hover{background:var(--gold-light);transform:translateY(-2px);box-shadow:0 6px 16px rgba(255,184,0,0.4);}

    /* ROLE PICKER BANNER */
    .role-picker{max-width:1300px;margin:0 auto;padding:32px 32px 0;}
    .role-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
    .role-card{border-radius:20px;padding:32px;position:relative;overflow:hidden;transition:all 0.3s;cursor:pointer;text-decoration:none;display:block;}
    .role-card:hover{transform:translateY(-4px);}
    .role-card-parent{background:linear-gradient(135deg,#FEF3C7,#FEFCE8);border:2px solid var(--gold);box-shadow:0 8px 24px rgba(255,184,0,0.15);}
    .role-card-parent:hover{box-shadow:0 12px 32px rgba(255,184,0,0.25);}
    .role-card-teacher{background:linear-gradient(135deg,#eef2ff,#e0e7ff);border:2px solid var(--indigo);box-shadow:0 8px 24px rgba(99,102,241,0.15);}
    .role-card-teacher:hover{box-shadow:0 12px 32px rgba(99,102,241,0.25);}
    .role-badge{display:inline-block;padding:5px 12px;border-radius:999px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;}
    .role-card-parent .role-badge{background:var(--gold);color:var(--navy-dark);}
    .role-card-teacher .role-badge{background:var(--indigo);color:white;}
    .role-card .role-icon{font-size:42px;margin-bottom:12px;}
    .role-card h3{font-family:'Clash Display',sans-serif;font-size:24px;font-weight:700;margin-bottom:8px;}
    .role-card-parent h3{color:var(--navy);}
    .role-card-teacher h3{color:var(--navy);}
    .role-card p{font-size:14px;line-height:1.6;margin-bottom:16px;}
    .role-card-parent p{color:var(--slate);}
    .role-card-teacher p{color:var(--slate);}
    .role-card .role-features{list-style:none;display:grid;gap:6px;margin-bottom:20px;}
    .role-card .role-features li{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:500;color:var(--navy);}
    .role-card-parent .role-features li::before{content:'✓';color:var(--gold-dark);font-weight:800;}
    .role-card-teacher .role-features li::before{content:'✓';color:var(--indigo);font-weight:800;}
    .role-cta{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:14px;font-weight:700;font-size:15px;text-decoration:none;transition:all 0.2s;}
    .role-card-parent .role-cta{background:var(--gold);color:var(--navy-dark);}
    .role-card-parent .role-cta:hover{background:var(--gold-light);}
    .role-card-teacher .role-cta{background:var(--indigo);color:white;}
    .role-card-teacher .role-cta:hover{background:var(--indigo-light);}
    .role-card .role-arrow{font-size:18px;transition:transform 0.2s;}
    .role-card:hover .role-arrow{transform:translateX(4px);}

    /* HERO */
    .hero{max-width:1300px;margin:0 auto;padding:60px 32px 80px;display:grid;grid-template-columns:1.1fr 0.9fr;gap:80px;align-items:center;}
    .hero-content{animation:fadeInLeft 0.8s ease 0.2s backwards;}
    @keyframes fadeInLeft{from{opacity:0;transform:translateX(-40px)}to{opacity:1;transform:translateX(0)}}
    .hero-badge{display:inline-flex;align-items:center;gap:8px;background:white;padding:10px 18px;border-radius:999px;font-size:13px;font-weight:700;color:var(--navy);border:1px solid rgba(15,23,42,0.1);margin-bottom:24px;box-shadow:var(--shadow);}
    .hero-badge::before{content:'🎓';font-size:18px;}
    .hero h1{font-family:'Clash Display',sans-serif;font-size:58px;font-weight:700;line-height:1.1;color:var(--navy);margin-bottom:24px;letter-spacing:-1.5px;}
    .hero h1 .highlight{color:var(--gold);}
    .hero-subtitle{font-size:19px;color:var(--slate);margin-bottom:16px;line-height:1.6;font-weight:500;}
    .hero-description{font-size:16px;color:var(--slate);margin-bottom:40px;line-height:1.7;max-width:580px;}

    .hero-visual{position:relative;animation:fadeInRight 0.8s ease 0.4s backwards;}
    @keyframes fadeInRight{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}
    .info-card{background:white;border-radius:24px;padding:36px;box-shadow:var(--shadow-lg);border:1px solid rgba(15,23,42,0.06);position:relative;overflow:hidden;}
    .info-card::before{content:'';position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(90deg,var(--gold),var(--indigo));}
    .info-card h3{font-family:'Clash Display',sans-serif;font-size:24px;font-weight:700;color:var(--navy);margin-bottom:6px;}
    .info-card .tagline{color:var(--slate);font-size:14px;margin-bottom:24px;}
    .info-list{list-style:none;display:grid;gap:14px;}
    .info-list li{display:flex;align-items:flex-start;gap:12px;padding:12px;background:rgba(255,184,0,0.05);border-radius:12px;border:1px solid rgba(255,184,0,0.1);}
    .info-list li .icon{width:32px;height:32px;background:var(--gold);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:16px;}
    .info-list li strong{display:block;color:var(--navy);font-weight:700;margin-bottom:2px;font-size:14px;}
    .info-list li span{color:var(--slate);font-size:12px;line-height:1.5;}

    /* AUDIENCE */
    .audience-section{background:white;padding:80px 0;border-top:1px solid rgba(15,23,42,0.08);}
    .audience-container{max-width:1300px;margin:0 auto;padding:0 32px;}
    .section-header{text-align:center;margin-bottom:60px;}
    .section-tag{font-size:14px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;}
    .section-title{font-family:'Clash Display',sans-serif;font-size:42px;font-weight:700;color:var(--navy);margin-bottom:16px;line-height:1.2;}
    .section-subtitle{font-size:17px;color:var(--slate);max-width:700px;margin:0 auto;line-height:1.6;}
    .audience-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;}
    .audience-card{background:linear-gradient(180deg,#FEFCE8,#FFFFFF);border-radius:20px;padding:32px;border:1px solid rgba(15,23,42,0.08);transition:all 0.3s;position:relative;overflow:hidden;}
    .audience-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:4px;transform:scaleX(0);transition:transform 0.3s;}
    .audience-card:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg);}
    .audience-card:hover::before{transform:scaleX(1);}
    .audience-card:nth-child(1)::before,.audience-card:nth-child(2)::before{background:var(--gold);}
    .audience-card:nth-child(3)::before{background:var(--indigo);}
    .audience-icon{width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:28px;margin-bottom:16px;}
    .audience-card:nth-child(1) .audience-icon,.audience-card:nth-child(2) .audience-icon{background:var(--gold);}
    .audience-card:nth-child(3) .audience-icon{background:var(--indigo);color:white;}
    .audience-card h3{font-family:'Clash Display',sans-serif;font-size:22px;font-weight:700;color:var(--navy);margin-bottom:10px;}
    .audience-card p{color:var(--slate);font-size:14px;line-height:1.6;margin-bottom:16px;}
    .audience-features{list-style:none;display:grid;gap:6px;}
    .audience-features li{display:flex;align-items:center;gap:8px;color:var(--navy);font-size:13px;font-weight:500;}
    .audience-features li::before{content:'✓';color:var(--gold-dark);font-weight:800;font-size:12px;}
    .audience-card:nth-child(3) .audience-features li::before{color:var(--indigo);}
    .audience-card .card-cta{display:inline-flex;align-items:center;gap:6px;padding:12px 24px;border-radius:12px;font-weight:700;font-size:14px;text-decoration:none;margin-top:16px;transition:all 0.2s;}
    .card-cta-parent{background:var(--gold);color:var(--navy-dark);}
    .card-cta-parent:hover{background:var(--gold-light);transform:translateY(-2px);}
    .card-cta-teacher{background:var(--indigo);color:white;}
    .card-cta-teacher:hover{background:var(--indigo-light);transform:translateY(-2px);}

    /* FEATURES */
    .features-section{padding:80px 0;background:linear-gradient(180deg,#FFFFFF,#FEFCE8);}
    .features-container{max-width:1300px;margin:0 auto;padding:0 32px;}
    .features-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:28px;}
    .feature-card{background:white;border-radius:20px;padding:28px;box-shadow:var(--shadow);border:1px solid rgba(15,23,42,0.06);display:flex;gap:20px;transition:all 0.3s;}
    .feature-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);}
    .feature-icon{width:52px;height:52px;background:linear-gradient(135deg,var(--gold),var(--gold-light));border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
    .feature-content h3{font-family:'Clash Display',sans-serif;font-size:18px;font-weight:700;color:var(--navy);margin-bottom:6px;}
    .feature-content p{color:var(--slate);font-size:14px;line-height:1.6;}

    /* HOW IT WORKS */
    .how-it-works{background:var(--navy);padding:100px 0;position:relative;overflow:hidden;}
    .how-it-works::before{content:'';position:absolute;top:-50%;right:-25%;width:150%;height:200%;background:radial-gradient(circle,rgba(255,184,0,0.08),transparent 60%);}
    .how-container{max-width:1300px;margin:0 auto;padding:0 32px;position:relative;z-index:1;}
    .how-header{text-align:center;margin-bottom:60px;}
    .how-header h2{font-family:'Clash Display',sans-serif;font-size:42px;font-weight:700;color:white;margin-bottom:16px;}
    .how-header p{font-size:17px;color:rgba(255,255,255,0.7);max-width:600px;margin:0 auto;}
    .steps-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}
    .step{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:20px;padding:28px;position:relative;}
    .step-number{position:absolute;top:-14px;left:20px;width:36px;height:36px;background:var(--gold);border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px;color:var(--navy-dark);}
    .step-icon{width:48px;height:48px;background:rgba(255,184,0,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:16px;}
    .step h3{font-family:'Clash Display',sans-serif;font-size:18px;font-weight:700;color:white;margin-bottom:8px;}
    .step p{color:rgba(255,255,255,0.7);font-size:13px;line-height:1.6;}

    /* PRICING */
    .pricing-section{padding:80px 0;background:white;}
    .pricing-container{max-width:900px;margin:0 auto;padding:0 32px;}
    .pricing-card{background:linear-gradient(135deg,#FEFCE8,#FEF3C7);border-radius:24px;padding:44px;text-align:center;border:2px solid var(--gold);box-shadow:var(--shadow-lg);}
    .pricing-badge{display:inline-block;background:var(--gold);color:var(--navy-dark);padding:8px 18px;border-radius:999px;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:20px;}
    .pricing-card h2{font-family:'Clash Display',sans-serif;font-size:38px;font-weight:700;color:var(--navy);margin-bottom:12px;}
    .pricing-card .description{font-size:17px;color:var(--slate);margin-bottom:32px;line-height:1.6;}
    .pricing-features{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:36px;text-align:left;list-style:none;}
    .pricing-features li{display:flex;align-items:center;gap:10px;color:var(--navy);font-size:14px;font-weight:500;}
    .pricing-features li::before{content:'✓';width:22px;height:22px;background:var(--gold);color:var(--navy-dark);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0;}
    .pricing-note{font-size:14px;color:var(--slate);margin-top:24px;}
    .btn-hero{padding:16px 32px;border-radius:14px;font-weight:700;font-size:15px;text-decoration:none;transition:all 0.3s;display:inline-flex;align-items:center;gap:8px;border:none;cursor:pointer;}
    .btn-hero-primary{background:var(--gold);color:var(--navy-dark);box-shadow:0 8px 24px rgba(255,184,0,0.3);}
    .btn-hero-primary:hover{background:var(--gold-light);transform:translateY(-4px);}
    .btn-hero-secondary{background:white;color:var(--navy);box-shadow:0 4px 16px rgba(0,0,0,0.08);border:2px solid rgba(15,23,42,0.1);}
    .btn-hero-secondary:hover{background:var(--cream);transform:translateY(-2px);}
    .btn-hero-teacher{background:var(--indigo);color:white;box-shadow:0 8px 24px rgba(99,102,241,0.3);}
    .btn-hero-teacher:hover{background:var(--indigo-light);transform:translateY(-4px);}

    /* CTA */
    .cta-section{padding:100px 0;background:linear-gradient(180deg,#FEFCE8,#FEF3C7);}
    .cta-container{max-width:1000px;margin:0 auto;padding:0 32px;text-align:center;}
    .cta-container h2{font-family:'Clash Display',sans-serif;font-size:46px;font-weight:700;color:var(--navy);margin-bottom:20px;line-height:1.2;}
    .cta-container p{font-size:18px;color:var(--slate);margin-bottom:40px;max-width:700px;margin-left:auto;margin-right:auto;line-height:1.6;}
    .cta-buttons{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}

    /* FOOTER */
    .footer{background:var(--navy-dark);padding:60px 32px 32px;color:rgba(255,255,255,0.6);}
    .footer-container{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:60px;margin-bottom:40px;}
    .footer-brand{font-family:'Clash Display',sans-serif;font-size:28px;font-weight:700;color:white;margin-bottom:12px;}
    .footer-brand span{color:var(--gold);}
    .footer-tagline{font-size:14px;line-height:1.6;margin-bottom:20px;}
    .footer h4{font-family:'Clash Display',sans-serif;font-weight:700;color:white;margin-bottom:16px;font-size:16px;}
    .footer ul{list-style:none;}
    .footer ul li{margin-bottom:10px;}
    .footer ul li a{color:rgba(255,255,255,0.6);text-decoration:none;font-size:14px;transition:color 0.2s;}
    .footer ul li a:hover{color:var(--gold);}
    .footer-bottom{max-width:1300px;margin:0 auto;padding-top:30px;border-top:1px solid rgba(255,255,255,0.1);text-align:center;font-size:13px;}

    /* RESPONSIVE */
    @media(max-width:1100px){
      .hero{grid-template-columns:1fr;gap:50px;}
      .audience-grid,.features-grid{grid-template-columns:1fr;}
      .steps-grid{grid-template-columns:repeat(2,1fr);}
      .pricing-features{grid-template-columns:1fr;}
      .footer-container{grid-template-columns:1fr 1fr;}
      .role-grid{grid-template-columns:1fr;}
    }
    @media(max-width:768px){
      .hero h1{font-size:38px;}
      .section-title{font-size:32px;}
      .how-header h2{font-size:32px;}
      .cta-container h2{font-size:34px;}
      .steps-grid{grid-template-columns:1fr;}
      .footer-container{grid-template-columns:1fr;gap:40px;}
      .nav-right{gap:8px;}
      .role-card{padding:24px;}
      .role-card h3{font-size:20px;}
    }
  </style>
</head>

<body>

<!-- ================= NAVBAR ================= -->
<nav class="navbar">
  <div class="nav-container">
    <a href="/lms" class="brand">CRIPF<span>Cnt</span></a>
    <div class="nav-right">
      {{#if user}}
        {{#if (eq user.role "private_teacher")}}
          <a href="/teacher/dashboard" class="nav-link">Dashboard</a>
        {{else}}
          <a href="/parent/dashboard" class="nav-link">Dashboard</a>
        {{/if}}
        <a href="/auth/logout" class="btn-nav btn-nav-parent">Sign Out</a>
      {{else}}
        <a href="/lms" class="nav-link">Home</a>
        <a href="/auth/teacher" class="btn-nav btn-nav-teacher">👨‍🏫 Teacher Sign Up</a>
        <a href="/auth/parent" class="btn-nav btn-nav-parent">👨‍👩‍👧 Parent Sign Up</a>
      {{/if}}
    </div>
  </div>
</nav>

<!-- ================= ROLE PICKER ================= -->
{{#unless user}}
<section class="role-picker">
  <div class="role-grid">
    <a href="/auth/parent" class="role-card role-card-parent">
      <span class="role-badge">For Parents & Guardians</span>
      <div class="role-icon">👨‍👩‍👧</div>
      <h3>I'm a Parent / Guardian</h3>
      <p>Monitor your child's education with structured quizzes, progress tracking, and achievement certificates.</p>
      <ul class="role-features">
        <li>Manage 1–5 children</li>
        <li>Auto-assigned quizzes by grade</li>
        <li>Track scores & completion</li>
        <li>Download certificates</li>
      </ul>
      <span class="role-cta">Start Free Trial <span class="role-arrow">→</span></span>
    </a>

    <a href="/auth/teacher" class="role-card role-card-teacher">
      <span class="role-badge">For Private Teachers & Tutors</span>
      <div class="role-icon">👨‍🏫</div>
      <h3>I'm a Private Teacher</h3>
      <p>Manage up to 40 students with AI quiz generation, a full quiz library, bulk assignment, and assessment reports.</p>
      <ul class="role-features">
        <li>Manage 15–40 students</li>
        <li>AI-powered quiz generation</li>
        <li>Access full quiz library</li>
        <li>Generate assessment reports</li>
      </ul>
      <span class="role-cta">Sign Up as Teacher <span class="role-arrow">→</span></span>
    </a>
  </div>
</section>
{{/unless}}

<!-- ================= HERO ================= -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">Junior Academy Platform</div>
    <h1>Empower Your Child's<br><span class="highlight">Learning Journey</span></h1>
    <p class="hero-subtitle">Built for <strong>parents</strong>, <strong>guardians</strong>, and <strong>private teachers</strong> supporting primary school learners.</p>
    <p class="hero-description">Take control of your child's education with structured quizzes across Math, English, Science, and Responsibility. Track progress, assign work, monitor completion, and celebrate achievements.</p>
  </div>

  <div class="hero-visual">
    <div class="info-card">
      <h3>What You Get</h3>
      <p class="tagline">Complete learning visibility and control</p>
      <ul class="info-list">
        <li><div class="icon">👨‍👩‍👧</div><div class="text"><strong>Multi-Child Management</strong><span>Create profiles for multiple children</span></div></li>
        <li><div class="icon">📊</div><div class="text"><strong>Real-Time Progress</strong><span>View scores, completion rates, and knowledge gaps</span></div></li>
        <li><div class="icon">📚</div><div class="text"><strong>4 Subject Areas</strong><span>Math, English, Science, Responsibility (Grades 1-7)</span></div></li>
        <li><div class="icon">🧠</div><div class="text"><strong>AI Quiz Generation</strong><span>Teachers: generate custom quizzes instantly</span></div></li>
        <li><div class="icon">🏆</div><div class="text"><strong>Certificates</strong><span>Downloadable completion certificates per subject</span></div></li>
      </ul>
    </div>
  </div>
</section>

