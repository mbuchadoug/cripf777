<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Add Child | Parent Setup</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    :root{
      --gold:#D4AF37;
      --bg:#0b0b0b;
      --panel:#141414;
      --border:#222;
      --muted:#9aa3ad;
      --radius:14px;
    }

    body{
      margin:0;
      font-family:system-ui,-apple-system,"Segoe UI",Arial;
      background:var(--bg);
      color:#fff;
    }

    main{
      max-width:520px;
      margin:60px auto;
      padding:0 20px;
    }

    h1{ font-size:28px; margin-bottom:8px; }

    .subtitle{
      color:var(--muted);
      font-size:15px;
      margin-bottom:24px;
      line-height:1.5;
    }

    .panel{
      background:var(--panel);
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:22px;
    }

    form{ display:grid; gap:18px; }

    label{
      display:flex;
      flex-direction:column;
      font-size:14px;
      font-weight:600;
    }

    label span{
      margin-bottom:6px;
      color:#ddd;
    }

    input, select{
      background:#0e0e0e;
      border:1px solid var(--border);
      border-radius:10px;
      padding:12px;
      font-size:15px;
      color:#fff;
      outline:none;
    }

    input::placeholder{ color:#666; }
    input:focus, select:focus{ border-color:var(--gold); }

    button{
      margin-top:10px;
      padding:14px;
      border-radius:12px;
      border:none;
      background:var(--gold);
      color:#000;
      font-weight:800;
      font-size:16px;
      cursor:pointer;
    }

    button:hover{ opacity:0.9; }
    button:disabled{ opacity:0.5; cursor:not-allowed; }

    .note{
      margin-top:14px;
      font-size:13px;
      color:var(--muted);
      line-height:1.4;
    }

    .back{
      display:inline-block;
      margin-bottom:18px;
      color:var(--gold);
      text-decoration:none;
      font-weight:700;
      font-size:14px;
    }

    .slots{
      background:#0e0e0e;
      border:1px solid var(--border);
      border-radius:10px;
      padding:12px 16px;
      margin-bottom:8px;
      font-size:14px;
      text-align:center;
    }

    .slots strong{ color:var(--gold); }

    /* ✅ PROGRESS BAR */
    .progress-overlay{
      position:fixed;
      top:0;
      left:0;
      width:100%;
      height:100%;
      background:rgba(0,0,0,0.85);
      display:none;
      align-items:center;
      justify-content:center;
      z-index:9999;
    }

    .progress-overlay.active{ display:flex; }

    .progress-box{
      background:var(--panel);
      border:2px solid var(--gold);
      border-radius:var(--radius);
      padding:32px 40px;
      text-align:center;
      max-width:400px;
    }

    .progress-title{
      font-size:20px;
      font-weight:800;
      margin-bottom:20px;
    }

    .progress-bar{
      width:100%;
      height:12px;
      background:#0e0e0e;
      border-radius:8px;
      overflow:hidden;
      margin-bottom:12px;
    }

    .progress-fill{
      height:100%;
      background:linear-gradient(90deg, var(--gold), #ffd700);
      width:0%;
      transition:width 0.3s ease;
    }

    .progress-text{
      font-size:14px;
      color:var(--muted);
      margin-bottom:8px;
    }

    .progress-spinner{
      width:40px;
      height:40px;
      border:4px solid #333;
      border-top-color:var(--gold);
      border-radius:50%;
      animation:spin 0.8s linear infinite;
      margin:20px auto 0;
    }

    @keyframes spin{
      to{ transform:rotate(360deg); }
    }
  </style>
</head>

<body>

<main>

 <a href="{{dashboardUrl}}" class="back">← Back to Dashboard</a>

  <h1>Add Your Child</h1>
  <p class="subtitle">
    Enter your child's details to start tracking quizzes,
    progress and certificates.
  </p>

  <div class="panel">

    <div class="slots">
      Child slots: <strong>{{childCount}}</strong> / <strong>{{childLimit}}</strong> used
    </div>

    <form method="POST" action="/parent/children" id="childForm">

      <label>
        <span>First name *</span>
        <input
          name="firstName"
          placeholder="e.g. Tendai"
          required
        >
      </label>

      <label>
        <span>Last name</span>
        <input
          name="lastName"
          placeholder="e.g. Moyo"
        >
      </label>

      <label>
        <span>Grade *</span>
        <select name="grade" required>
          <option value="">Select grade</option>
          <option value="0">Grade 0</option>
          <option value="1">Grade 1</option>
          <option value="2">Grade 2</option>
          <option value="3">Grade 3</option>
          <option value="4">Grade 4</option>
          <option value="5">Grade 5</option>
          <option value="6">Grade 6</option>
          <option value="7">Grade 7</option>
           <option value="8">Form 1</option>
            <option value="9">Form 2</option>
             <option value="10">Form 3</option>
              <option value="11">Form 4</option>
               <option value="12">Form 5</option>
                <option value="13">Form 6 </option>
        </select>
      </label>

      <button type="submit" id="submitBtn">
        ➕ Add Child
      </button>

    </form>

    <div class="note">
      ⏱️ Account creation takes 10-15 seconds as we set up personalized quizzes for your child.
    </div>
  </div>

</main>

<!-- ✅ PROGRESS OVERLAY -->
<div class="progress-overlay" id="progressOverlay">
  <div class="progress-box">
    <div class="progress-title">Creating Child Account...</div>
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>
    <div class="progress-text" id="progressText">Setting up account...</div>
    <div class="progress-spinner"></div>
  </div>
</div>

<script>
const form = document.getElementById('childForm');
const overlay = document.getElementById('progressOverlay');
const fill = document.getElementById('progressFill');
const text = document.getElementById('progressText');
const btn = document.getElementById('submitBtn');

const steps = [
  { pct: 20, msg: 'Creating student account...' },
  { pct: 40, msg: 'Generating login credentials...' },
  { pct: 60, msg: 'Assigning trial quizzes...' },
  { pct: 80, msg: 'Loading paid quiz library...' },
  { pct: 95, msg: 'Finalizing setup...' }
];

let currentStep = 0;

form.addEventListener('submit', (e) => {
  overlay.classList.add('active');
  btn.disabled = true;

  // Simulate progress (since backend is async)
  const interval = setInterval(() => {
    if (currentStep < steps.length) {
      fill.style.width = steps[currentStep].pct + '%';
      text.textContent = steps[currentStep].msg;
      currentStep++;
    } else {
      clearInterval(interval);
    }
  }, 2500); // 2.5s per step = ~12.5s total

  // Let form submit naturally
});
</script>

</body>
</html>