<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Battle Payment</title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <style>
    body{font-family:system-ui;background:#0b0b0b;color:#fff;margin:0}
    .wrap{max-width:720px;margin:40px auto;padding:0 18px}
    .card{background:#141414;border:1px solid #222;border-radius:14px;padding:18px}
    .btn{display:inline-block;background:#FFB800;color:#000;padding:12px 18px;border-radius:12px;font-weight:900;border:none;cursor:pointer}
    .muted{color:#9aa3ad}
  </style>
</head>
<body>
  <div class="wrap">
    <a href="/arena" style="color:#FFB800;text-decoration:none;font-weight:800;">← Back to Arena</a>
    <div class="card" style="margin-top:14px;">
      <h2 style="margin:0 0 10px;">Pay to Enter Battle</h2>
      <div class="muted" style="margin-bottom:14px;">
        Battle: <strong>{{battle.title}}</strong><br/>
        Entry Fee: <strong>${{entryUsd}}</strong>
      </div>

      <form method="POST" action="/battles/{{battle._id}}/paynow/init">
        <button class="btn" type="submit">Pay Now</button>
      </form>

      <div class="muted" style="margin-top:12px;">
        After payment, you’ll be returned to Arena and your entry will be unlocked.
      </div>
    </div>
  </div>
</body>
</html>