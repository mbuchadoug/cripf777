{{!-- views/8qt/profile.hbs (STEP 3 — Optional pre-test profile) --}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Before You Begin — CRIPFCnt 8QT</title>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root{--navy:#1E3A5F;--gold:#C9A961;--white:#fff;--light:#F8F9FA;--border:#E9ECEF;--text:#212529;--dark:#495057}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:var(--light);min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px}
    .card{background:var(--white);border-radius:16px;padding:48px 40px;max-width:500px;width:100%;box-shadow:0 8px 32px rgba(30,58,95,.1);text-align:center}
    .step-label{font-size:.7rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:12px}
    h1{font-family:'Crimson Pro',serif;font-size:2rem;color:var(--navy);margin-bottom:8px}
    .subtitle{color:var(--dark);font-size:.9rem;margin-bottom:32px;line-height:1.6}
    .optional-badge{display:inline-block;background:#e8f5e9;color:#2e7d32;font-size:.7rem;padding:.2rem .6rem;border-radius:20px;font-weight:600;letter-spacing:1px;margin-bottom:28px}
    .form-group{text-align:left;margin-bottom:16px}
    label{display:block;font-size:.8rem;font-weight:600;color:var(--navy);margin-bottom:6px}
    input,select{width:100%;padding:.7rem .9rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Inter',sans-serif;font-size:.9rem;color:var(--text);background:var(--white);transition:border-color .2s}
    input:focus,select:focus{outline:none;border-color:var(--navy)}
    .btn-primary{display:block;width:100%;margin-top:24px;padding:.9rem;background:var(--navy);color:var(--white);border:none;border-radius:8px;font-family:'Inter',sans-serif;font-size:1rem;font-weight:600;cursor:pointer;transition:background .2s}
    .btn-primary:hover{background:#0F1C2E}
    .btn-skip{display:block;text-align:center;margin-top:12px;color:var(--dark);font-size:.85rem;cursor:pointer;text-decoration:underline;background:none;border:none;width:100%}
    .code-display{background:var(--light);border:1px dashed var(--border);border-radius:8px;padding:12px;margin-bottom:24px;font-family:monospace;font-size:1.1rem;letter-spacing:2px;color:var(--navy)}
    .code-note{font-size:.75rem;color:var(--dark);margin-top:4px}
  </style>
</head>
<body>
<div class="card">
  <div class="step-label">Step 1 of 2 — Before You Begin</div>
  <h1>A few quick details</h1>
  <p class="subtitle">All fields are optional. They help us personalise your experience and build the CRIPFCnt quotient database.</p>

  {{#if code}}
  <div class="code-display">
    {{code}}
    <div class="code-note">Save this code — you'll need it to retrieve your results later</div>
  </div>
  {{/if}}

  <span class="optional-badge">ALL FIELDS OPTIONAL — SKIP FREELY</span>

  <div class="form-group">
    <label for="firstName">First name (for your certificate)</label>
    <input type="text" id="firstName" name="firstName" placeholder="e.g. Tendai">
  </div>
  <div class="form-group">
    <label for="country">Country</label>
    <select id="country" name="country">
      <option value="">— Select country —</option>
      <option value="Zimbabwe">Zimbabwe</option>
      <option value="South Africa">South Africa</option>
      <option value="Nigeria">Nigeria</option>
      <option value="Kenya">Kenya</option>
      <option value="Ghana">Ghana</option>
      <option value="United Kingdom">United Kingdom</option>
      <option value="United States">United States</option>
      <option value="Other">Other</option>
    </select>
  </div>
  <div class="form-group">
    <label for="sector">Field / sector</label>
    <select id="sector" name="sector">
      <option value="">— Select sector —</option>
      <option value="Education">Education</option>
      <option value="Business">Business</option>
      <option value="Government">Government</option>
      <option value="Health">Health</option>
      <option value="Technology">Technology</option>
      <option value="Agriculture">Agriculture</option>
      <option value="NGO / Charity">NGO / Charity</option>
      <option value="Student">Student</option>
      <option value="Other">Other</option>
    </select>
  </div>

  <button class="btn-primary" onclick="submitProfile()">Continue to Test →</button>
  <button class="btn-skip" onclick="skipProfile()">Skip and start immediately</button>
</div>

<script>
const CODE = '{{code}}' || null;

async function submitProfile() {
  const body = {
    firstName: document.getElementById('firstName').value,
    country: document.getElementById('country').value,
    sector: document.getElementById('sector').value,
    code: CODE
  };
  await doSubmit(body);
}

async function skipProfile() {
  await doSubmit({ code: CODE });
}

async function doSubmit(body) {
  try {
    const r = await fetch('/8qt/profile', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(body)
    });
    const d = await r.json();
    if (d.ok && d.redirect) {
      window.location.href = d.redirect;
    } else {
      alert(d.error || 'Something went wrong. Please try again.');
    }
  } catch (e) {
    alert('Network error. Please try again.');
  }
}
</script>
</body>
</html>
