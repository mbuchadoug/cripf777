{{!-- views/8qt/test.hbs (STEP 4 — One question at a time) --}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>CRIPFCnt 8QT — Question {{add currentIndex 1}}</title>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root{--navy:#1E3A5F;--navy-dark:#0F1C2E;--gold:#C9A961;--white:#fff;--light:#F8F9FA;--border:#E9ECEF;--text:#212529;--dark:#495057;--green:#059669}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:var(--light);min-height:100vh;display:flex;flex-direction:column}

    /* HEADER */
    .header{background:var(--navy);padding:0;position:sticky;top:0;z-index:100}
    .header-in{max-width:800px;margin:0 auto;padding:0 20px}
    .progress-row{display:flex;justify-content:space-between;align-items:center;padding:12px 0 6px}
    .q-counter{color:var(--gold-light,#E5D4A6);font-size:.8rem;font-weight:600}
    .q-counter span{color:var(--gold)}
    .progress-bar-wrap{height:4px;background:rgba(255,255,255,.15);border-radius:99px;margin-bottom:0}
    .progress-bar-fill{height:4px;background:var(--gold);border-radius:99px;transition:width .5s ease}

    /* MAIN */
    .main{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:48px 20px 80px}
    .card{background:var(--white);border-radius:16px;padding:40px 36px;max-width:720px;width:100%;box-shadow:0 8px 32px rgba(30,58,95,.1)}

    .q-label{font-size:.7rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:16px}
    .q-text{font-family:'Crimson Pro',serif;font-size:1.6rem;font-weight:600;color:var(--navy);line-height:1.45;margin-bottom:32px}

    /* OPTIONS */
    .options{display:flex;flex-direction:column;gap:12px}
    .option{display:flex;align-items:flex-start;gap:14px;padding:16px 18px;border:2px solid var(--border);border-radius:10px;cursor:pointer;transition:all .15s;background:var(--white)}
    .option:hover{border-color:var(--navy);background:#f8f9fb}
    .option.selected{border-color:var(--navy);background:#eef2ff}
    .option.correct{border-color:var(--green);background:#ecfdf5}
    .opt-letter{width:32px;height:32px;border-radius:50%;background:var(--light);border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;color:var(--dark);flex-shrink:0;transition:all .15s}
    .option.selected .opt-letter{background:var(--navy);border-color:var(--navy);color:var(--white)}
    .opt-text{font-size:.95rem;color:var(--text);line-height:1.55;padding-top:4px}

    /* SUBMIT */
    .submit-row{margin-top:28px;text-align:right}
    .btn-next{padding:.8rem 2rem;background:var(--navy);color:var(--white);border:none;border-radius:8px;font-family:'Inter',sans-serif;font-size:.95rem;font-weight:600;cursor:pointer;transition:all .2s;opacity:.4;pointer-events:none}
    .btn-next.active{opacity:1;pointer-events:auto}
    .btn-next.active:hover{background:var(--navy-dark);transform:translateX(2px)}

    /* NOTE: no timer shown intentionally */
    .no-pressure{text-align:center;margin-top:20px;font-size:.78rem;color:var(--dark);opacity:.7}
  </style>
</head>
<body>

<div class="header">
  <div class="header-in">
    <div class="progress-row">
      <span class="q-counter">Question <span>{{add currentIndex 1}}</span> of {{totalQuestions}}</span>
      <span class="q-counter">{{progress}}% complete</span>
    </div>
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" style="width:{{progress}}%"></div>
    </div>
  </div>
</div>

<div class="main">
  <div class="card">
    <div class="q-label">8 Quotients Assessment</div>
    <p class="q-text">{{question.text}}</p>

    <div class="options" id="optionsContainer">
      {{#each question.options}}
      <div class="option" onclick="selectOption(this, {{@index}}, {{this.originalIndex}})"
           data-index="{{@index}}" data-original="{{this.originalIndex}}">
        <div class="opt-letter">{{letterFromIndex @index}}</div>
        <div class="opt-text">{{this.text}}</div>
      </div>
      {{/each}}
    </div>

    <div class="submit-row">
      <button class="btn-next" id="nextBtn" onclick="submitAnswer()">
        {{#if isLast}}Submit Test{{else}}Next Question →{{/if}}
      </button>
    </div>
    <p class="no-pressure">Take your time — there is no time limit</p>
  </div>
</div>

<script>
const ATTEMPT_ID = '{{attempt._id}}';
const QUESTION_ID = '{{question._id}}';
let selectedIndex = null;

function selectOption(el, shownIndex, originalIndex) {
  // Deselect all
  document.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  selectedIndex = shownIndex;
  document.getElementById('nextBtn').classList.add('active');
}

async function submitAnswer() {
  if (selectedIndex === null) return;
  const btn = document.getElementById('nextBtn');
  btn.textContent = 'Saving…';
  btn.classList.remove('active');

  try {
    const r = await fetch(`/8qt/test/${ATTEMPT_ID}/answer`, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        questionId: QUESTION_ID,
        selectedIndex
      })
    });
    const d = await r.json();
    if (d.ok && d.redirect) {
      window.location.href = d.redirect;
    } else {
      alert(d.error || 'Error saving answer. Please try again.');
      btn.textContent = 'Next Question →';
      btn.classList.add('active');
    }
  } catch (e) {
    alert('Network error. Please try again.');
    btn.textContent = 'Next Question →';
    btn.classList.add('active');
  }
}

// Keyboard navigation
document.addEventListener('keydown', e => {
  const keys = {'1':0,'2':1,'3':2,'4':3,'a':0,'b':1,'c':2,'d':3};
  const idx = keys[e.key.toLowerCase()];
  if (idx !== undefined) {
    const opts = document.querySelectorAll('.option');
    if (opts[idx]) opts[idx].click();
  }
  if ((e.key === 'Enter' || e.key === ' ') && selectedIndex !== null) submitAnswer();
});
</script>
</body>
</html>
