<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}} — ZimQuote</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy:#0d1117; --navy-2:#161b22; --navy-3:#1f2937; --navy-4:#111827;
      --amber:#f59e0b; --amber-d:#d97706;
      --amber-g:rgba(245,158,11,0.10); --amber-b:rgba(245,158,11,0.22);
      --white:#f8fafc; --muted:#8b949e; --muted-2:#6e7681;
      --border:rgba(255,255,255,0.07); --border-2:rgba(255,255,255,0.04);
      --green:#3fb950; --green-g:rgba(63,185,80,0.10);
      --red:#f85149; --red-g:rgba(248,81,73,0.10);
      --blue:#58a6ff; --blue-g:rgba(88,166,255,0.10);
      --sidebar-w:256px;
    }
    html,body { height:100%; background:var(--navy); color:var(--white); font-family:"Instrument Sans",sans-serif; -webkit-font-smoothing:antialiased; }

    /* scrollbar */
    ::-webkit-scrollbar { width:6px; height:6px; }
    ::-webkit-scrollbar-track { background:var(--navy-2); }
    ::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.12); border-radius:3px; }
    ::-webkit-scrollbar-thumb:hover { background:rgba(255,255,255,0.2); }

    /* layout */
    .shell { display:flex; min-height:100vh; }

    /* ── SIDEBAR ───────────────────────────────── */
    .sidebar {
      width:var(--sidebar-w);
      background:var(--navy-2);
      border-right:1px solid var(--border);
      display:flex; flex-direction:column;
      position:fixed; top:0; left:0; bottom:0;
      z-index:50; overflow:hidden;
      transition:transform 0.3s ease;
    }

    .sidebar-logo {
      display:flex; align-items:center; gap:11px;
      padding:20px 22px;
      border-bottom:1px solid var(--border);
      flex-shrink:0;
    }
    .logo-icon {
      width:34px; height:34px; background:var(--amber);
      border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;
    }
    .logo-icon svg { width:16px; height:16px; color:var(--navy); }
    .logo-name { font-family:"Syne",sans-serif; font-size:17px; font-weight:800; letter-spacing:-0.3px; color:var(--white); }

    .sidebar-user { padding:14px 22px; border-bottom:1px solid var(--border); flex-shrink:0; }
    .user-row { display:flex; align-items:center; gap:10px; }
    .user-avatar {
      width:36px; height:36px;
      background:linear-gradient(135deg,var(--amber),var(--amber-d));
      border-radius:50%; display:flex; align-items:center; justify-content:center;
      font-family:"Syne",sans-serif; font-size:14px; font-weight:800; color:var(--navy); flex-shrink:0;
    }
    .user-info { flex:1; min-width:0; }
    .user-name { font-size:13px; font-weight:600; color:var(--white); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .user-role { font-size:11px; color:var(--muted-2); margin-top:2px; text-transform:capitalize; }
    .user-branch { font-size:11px; color:var(--amber); margin-top:1px; }
    .pkg-pill {
      display:inline-flex; align-items:center; gap:5px;
      background:var(--amber-g); border:1px solid var(--amber-b);
      color:var(--amber); font-size:9px; font-weight:700;
      letter-spacing:0.8px; text-transform:uppercase;
      padding:3px 9px; border-radius:20px; margin-top:8px;
    }

    .sidebar-nav { flex:1; overflow-y:auto; padding:8px 0; }

    .nav-section {
      padding:10px 22px 4px;
      font-size:9px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase;
      color:var(--muted-2);
    }

    .nav-link {
      display:flex; align-items:center; gap:11px;
      padding:10px 22px;
      color:var(--muted); text-decoration:none;
      font-size:13px; font-weight:500;
      border-left:2px solid transparent;
      transition:all 0.18s;
    }
    .nav-link i { width:16px; text-align:center; font-size:13px; flex-shrink:0; }
    .nav-link:hover { color:var(--white); background:rgba(255,255,255,0.04); border-left-color:rgba(245,158,11,0.3); }
    .nav-link.active { color:var(--amber); background:var(--amber-g); border-left-color:var(--amber); font-weight:600; }
    .nav-divider { height:1px; background:var(--border); margin:8px 22px; }

    .sidebar-bottom { border-top:1px solid var(--border); padding:12px 0; flex-shrink:0; }
    .nav-link.logout { color:var(--red); }
    .nav-link.logout:hover { background:var(--red-g); border-left-color:var(--red); }

    /* ── MAIN ──────────────────────────────────── */
    .main-wrap { flex:1; margin-left:var(--sidebar-w); display:flex; flex-direction:column; min-height:100vh; }

    /* ── TOPBAR ─────────────────────────────────── */
    .topbar {
      height:56px; background:var(--navy-2);
      border-bottom:1px solid var(--border);
      display:flex; align-items:center; padding:0 28px; gap:14px;
      position:sticky; top:0; z-index:30; flex-shrink:0;
    }
    .topbar-hamburger { display:none; background:none; border:none; color:var(--muted); cursor:pointer; font-size:18px; }
    .topbar-breadcrumb { display:flex; align-items:center; gap:7px; flex:1; }
    .bc-app { font-family:"Syne",sans-serif; font-size:12px; font-weight:700; color:var(--muted-2); }
    .bc-sep { color:var(--muted-2); font-size:10px; }
    .bc-page { font-family:"Syne",sans-serif; font-size:14px; font-weight:800; color:var(--white); }
    .topbar-right { display:flex; align-items:center; gap:12px; }
    .topbar-currency {
      display:flex; align-items:center; gap:6px;
      font-family:"DM Mono",monospace; font-size:12px; color:var(--muted);
      background:rgba(255,255,255,0.04); border:1px solid var(--border);
      padding:4px 10px; border-radius:6px;
    }
    .topbar-phone { font-family:"DM Mono",monospace; font-size:12px; color:var(--muted-2); }

    /* ── PAGE ───────────────────────────────────── */
    .page-content { flex:1; padding:28px; }

    /* ── FOOTER ─────────────────────────────────── */
    .footer {
      border-top:1px solid var(--border);
      padding:14px 28px;
      font-size:11px; color:var(--muted-2);
      display:flex; align-items:center; justify-content:space-between;
    }
    .footer a { color:var(--muted-2); text-decoration:none; }
    .footer a:hover { color:var(--muted); }
    .footer-links { display:flex; gap:14px; }

    /* ── OVERLAY ────────────────────────────────── */
    .sidebar-overlay {
      display:none; position:fixed; inset:0;
      background:rgba(0,0,0,0.65);
      backdrop-filter:blur(2px);
      z-index:40;
    }
    .sidebar-overlay.open { display:block; }

    /* ── SHARED COMPONENTS ─────────────────────── */

    /* Page header */
    .page-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:24px; gap:16px; flex-wrap:wrap; }
    .page-title { font-family:"Syne",sans-serif; font-size:24px; font-weight:800; letter-spacing:-0.6px; color:var(--white); margin-bottom:4px; }
    .page-subtitle { font-size:13px; color:var(--muted); }
    .page-actions { display:flex; gap:10px; flex-wrap:wrap; }

    /* Cards */
    .card { background:var(--navy-2); border:1px solid var(--border); border-radius:14px; }
    .card-header { padding:18px 22px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
    .card-title { font-family:"Syne",sans-serif; font-size:14px; font-weight:800; color:var(--white); display:flex; align-items:center; gap:8px; }
    .card-title i { color:var(--amber); }
    .card-body { padding:22px; }

    /* Stat cards */
    .stat-card { background:var(--navy-2); border:1px solid var(--border); border-radius:14px; padding:20px 22px; position:relative; overflow:hidden; }
    .stat-card::after { content:""; position:absolute; top:-28px; right:-28px; width:80px; height:80px; border-radius:50%; opacity:0.07; }
    .stat-card.amber::after { background:var(--amber); }
    .stat-card.green::after { background:var(--green); }
    .stat-card.red::after { background:var(--red); }
    .stat-card.blue::after { background:var(--blue); }
    .stat-icon { width:36px; height:36px; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:14px; margin-bottom:14px; }
    .stat-icon.amber { background:var(--amber-g); border:1px solid var(--amber-b); color:var(--amber); }
    .stat-icon.green { background:var(--green-g); border:1px solid rgba(63,185,80,0.2); color:var(--green); }
    .stat-icon.red   { background:var(--red-g);   border:1px solid rgba(248,81,73,0.2); color:var(--red); }
    .stat-icon.blue  { background:var(--blue-g);  border:1px solid rgba(88,166,255,0.2); color:var(--blue); }
    .stat-value { font-family:"DM Mono",monospace; font-size:22px; font-weight:500; color:var(--white); letter-spacing:-0.5px; margin-bottom:4px; }
    .stat-label { font-size:12px; color:var(--muted); }
    .stat-change { font-size:11px; margin-top:5px; }
    .stat-change.up { color:var(--green); }
    .stat-change.down { color:var(--red); }

    /* Buttons */
    .btn { display:inline-flex; align-items:center; gap:7px; padding:10px 16px; border-radius:9px; border:none; font-family:"Syne",sans-serif; font-size:13px; font-weight:700; cursor:pointer; text-decoration:none; transition:all 0.2s; white-space:nowrap; }
    .btn:disabled { opacity:0.5; cursor:not-allowed; transform:none !important; box-shadow:none !important; }
    .btn-primary { background:var(--amber); color:var(--navy); }
    .btn-primary:hover { background:var(--amber-d); transform:translateY(-1px); box-shadow:0 4px 16px rgba(245,158,11,0.25); }
    .btn-ghost { background:rgba(255,255,255,0.05); border:1px solid var(--border); color:var(--muted); }
    .btn-ghost:hover { border-color:rgba(255,255,255,0.15); color:var(--white); }
    .btn-danger { background:var(--red-g); border:1px solid rgba(248,81,73,0.25); color:var(--red); }
    .btn-danger:hover { background:rgba(248,81,73,0.18); }
    .btn-sm { padding:7px 12px; font-size:12px; }
    .btn-icon { width:34px; height:34px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:8px; }

    /* Forms */
    .form-group { margin-bottom:18px; }
    .form-label { display:block; font-size:11px; font-weight:700; color:var(--muted); letter-spacing:0.7px; text-transform:uppercase; margin-bottom:7px; }
    .form-input, .form-select, .form-textarea {
      width:100%; background:var(--navy-3); border:1px solid var(--border);
      border-radius:9px; padding:11px 14px;
      font-size:14px; font-family:"Instrument Sans",sans-serif;
      color:var(--white); outline:none; transition:all 0.2s;
    }
    .form-input::placeholder, .form-textarea::placeholder { color:var(--muted-2); }
    .form-input:focus, .form-select:focus, .form-textarea:focus {
      border-color:var(--amber); background:var(--navy-4); box-shadow:0 0 0 3px var(--amber-g);
    }
    .form-select option { background:var(--navy-3); }
    .form-textarea { resize:vertical; min-height:90px; line-height:1.6; }
    .form-hint { font-size:11px; color:var(--muted-2); margin-top:5px; line-height:1.5; }
    .form-prefix-wrap { position:relative; }
    .form-prefix { position:absolute; left:14px; top:50%; transform:translateY(-50%); font-family:"DM Mono",monospace; font-size:13px; color:var(--amber); font-weight:500; pointer-events:none; }
    .form-input-pl { padding-left:42px; }

    /* Grids */
    .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; }
    .grid-4 { display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:16px; }

    /* Table */
    .data-table { width:100%; border-collapse:collapse; }
    .data-table thead th { padding:11px 18px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; color:var(--muted-2); border-bottom:1px solid var(--border); text-align:left; }
    .data-table tbody tr { border-bottom:1px solid var(--border); transition:background 0.15s; cursor:pointer; }
    .data-table tbody tr:last-child { border-bottom:none; }
    .data-table tbody tr:hover { background:rgba(255,255,255,0.025); }
    .data-table td { padding:14px 18px; font-size:13px; color:var(--muted); vertical-align:middle; }
    .td-primary { color:var(--white) !important; font-weight:600; font-size:13px; }
    .td-mono { font-family:"DM Mono",monospace; font-size:12px; }
    .td-sub { color:var(--muted-2); font-size:11px; margin-top:2px; }
    .td-actions { display:flex; align-items:center; gap:6px; }

    /* Badges */
    .badge { display:inline-flex; align-items:center; gap:4px; padding:3px 9px; border-radius:20px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; }
    .badge::before { content:""; width:5px; height:5px; border-radius:50%; flex-shrink:0; }
    .badge-green { background:var(--green-g); border:1px solid rgba(63,185,80,0.2); color:var(--green); }
    .badge-green::before { background:var(--green); }
    .badge-amber { background:var(--amber-g); border:1px solid var(--amber-b); color:var(--amber); }
    .badge-amber::before { background:var(--amber); }
    .badge-red   { background:var(--red-g);   border:1px solid rgba(248,81,73,0.2); color:var(--red); }
    .badge-red::before { background:var(--red); }
    .badge-muted { background:rgba(255,255,255,0.05); border:1px solid var(--border); color:var(--muted); }
    .badge-muted::before { background:var(--muted-2); }
    .badge-blue  { background:var(--blue-g); border:1px solid rgba(88,166,255,0.2); color:var(--blue); }
    .badge-blue::before { background:var(--blue); }

    /* Modal */
    .modal-backdrop { position:fixed; inset:0; background:rgba(0,0,0,0.72); backdrop-filter:blur(3px); z-index:60; display:none; align-items:center; justify-content:center; padding:20px; }
    .modal-backdrop.open { display:flex; }
    .modal { background:var(--navy-2); border:1px solid var(--border); border-radius:16px; width:100%; max-width:480px; box-shadow:0 24px 64px rgba(0,0,0,0.5); animation:modalIn 0.25s ease; }
    @keyframes modalIn { from{opacity:0;transform:scale(0.96)} to{opacity:1;transform:scale(1)} }
    .modal-header { display:flex; align-items:center; justify-content:space-between; padding:20px 22px; border-bottom:1px solid var(--border); }
    .modal-title { font-family:"Syne",sans-serif; font-size:16px; font-weight:800; color:var(--white); display:flex; align-items:center; gap:8px; }
    .modal-title i { color:var(--amber); }
    .modal-close { background:none; border:none; color:var(--muted); cursor:pointer; font-size:16px; transition:color 0.2s; }
    .modal-close:hover { color:var(--white); }
    .modal-body { padding:22px; }
    .modal-footer { padding:16px 22px; border-top:1px solid var(--border); display:flex; align-items:center; justify-content:flex-end; gap:10px; }

    /* Alert */
    .alert { display:flex; align-items:flex-start; gap:10px; border-radius:9px; padding:12px 14px; font-size:13px; line-height:1.5; margin-bottom:18px; animation:slideIn 0.3s ease; }
    @keyframes slideIn { from{opacity:0;transform:translateY(-5px)} to{opacity:1;transform:translateY(0)} }
    .alert-error   { background:var(--red-g);   border:1px solid rgba(248,81,73,0.2); color:#fca5a5; }
    .alert-success { background:var(--green-g); border:1px solid rgba(63,185,80,0.2); color:#7ee787; }
    .alert-info    { background:var(--amber-g); border:1px solid var(--amber-b); color:#fcd34d; }

    /* Divider */
    .divider { height:1px; background:var(--border); margin:20px 0; }

    /* Empty state */
    .empty-state { text-align:center; padding:56px 20px; }
    .empty-state i { font-size:40px; color:var(--muted-2); margin-bottom:14px; display:block; }
    .empty-state h3 { font-family:"Syne",sans-serif; font-size:16px; font-weight:700; color:var(--muted); margin-bottom:6px; }
    .empty-state p { font-size:13px; color:var(--muted-2); margin-bottom:18px; line-height:1.6; }

    /* Pagination */
    .pagination { display:flex; align-items:center; justify-content:center; gap:6px; margin-top:22px; }
    .pagination a, .page-info { display:flex; align-items:center; justify-content:center; height:36px; border-radius:8px; font-size:12px; text-decoration:none; transition:all 0.2s; }
    .pagination a { padding:0 14px; background:var(--navy-2); border:1px solid var(--border); color:var(--muted); font-family:"DM Mono",monospace; }
    .pagination a:hover { border-color:var(--amber); color:var(--amber); }
    .page-info { padding:0 14px; background:var(--amber-g); border:1px solid var(--amber-b); color:var(--amber); font-family:"DM Mono",monospace; font-size:12px; }

    /* Filters bar */
    .filters-bar { background:var(--navy-2); border:1px solid var(--border); border-radius:14px; padding:16px 20px; margin-bottom:20px; display:flex; gap:14px; flex-wrap:wrap; align-items:flex-end; }
    .filter-group { display:flex; flex-direction:column; gap:6px; min-width:160px; flex:1; }
    .filter-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.7px; color:var(--muted-2); }

    /* Toast */
    .toast-container { position:fixed; bottom:20px; right:20px; z-index:100; display:flex; flex-direction:column; gap:8px; }
    .toast { display:flex; align-items:center; gap:10px; padding:12px 16px; background:var(--navy-2); border:1px solid var(--border); border-radius:10px; font-size:13px; color:var(--white); box-shadow:0 8px 30px rgba(0,0,0,0.4); animation:toastIn 0.3s ease; min-width:260px; max-width:380px; }
    .toast.success { border-left:3px solid var(--green); }
    .toast.error   { border-left:3px solid var(--red); }
    .toast.info    { border-left:3px solid var(--amber); }
    @keyframes toastIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

    /* Spinner */
    .spinner { width:14px; height:14px; border:2px solid rgba(255,255,255,0.15); border-top-color:var(--amber); border-radius:50%; animation:spin 0.6s linear infinite; display:inline-block; }
    @keyframes spin { to{transform:rotate(360deg)} }

    /* ── RESPONSIVE ─────────────────────────────── */
    @media (max-width:1023px) {
      .sidebar { transform:translateX(-100%); }
      .sidebar.open { transform:translateX(0); }
      .main-wrap { margin-left:0; }
      .topbar-hamburger { display:block; }
      .page-content { padding:20px 16px 32px; }
      .topbar { padding:0 16px; }
      .grid-4 { grid-template-columns:1fr 1fr; }
    }
    @media (max-width:768px) {
      .grid-2, .grid-3 { grid-template-columns:1fr; }
      .grid-4 { grid-template-columns:1fr 1fr; }
      .topbar-currency, .topbar-phone { display:none; }
    }
    @media (max-width:480px) {
      .grid-4 { grid-template-columns:1fr; }
    }

    /* Print */
    @media print {
      .sidebar, .topbar, .footer, .no-print { display:none !important; }
      .main-wrap { margin-left:0 !important; }
      body { background:white !important; color:black !important; }
    }
  </style>
</head>
<body>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- ══════════════════════════════════════
     SIDEBAR
══════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
    </div>
    <span class="logo-name">ZimQuote</span>
  </div>

  <div class="sidebar-user">
    <div class="user-row">
      <div class="user-avatar">{{substring user.businessName 0 1}}</div>
      <div class="user-info">
        <div class="user-name">{{user.businessName}}</div>
        <div class="user-role">{{user.role}}</div>
        {{#if user.branchName}}<div class="user-branch"><i class="fas fa-map-marker-alt" style="font-size:9px"></i> {{user.branchName}}</div>{{/if}}
      </div>
    </div>
    <div class="pkg-pill"><i class="fas fa-crown" style="font-size:8px"></i> {{user.package}}</div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section">Main</div>
    <a href="/web/dashboard" class="nav-link {{#if (eq pageKey 'dashboard')}}active{{/if}}"><i class="fas fa-home"></i> Dashboard</a>
    <a href="/web/invoices"  class="nav-link {{#if (eq pageKey 'invoices')}}active{{/if}}"><i class="fas fa-file-invoice"></i> Invoices</a>
    <a href="/web/products"  class="nav-link {{#if (eq pageKey 'products')}}active{{/if}}"><i class="fas fa-box"></i> Products</a>
