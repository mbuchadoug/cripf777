  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    /* ── TOKENS ──────────────────────────────────────────────────── */
    :root {
      --navy:       #1E3A5F;
      --navy-dark:  #0F1C2E;
      --gold:       #C9A961;
      --gold-lt:    #E5D4A6;
      --white:      #FFFFFF;
      --lg:         #F8F9FA;
      --mg:         #E9ECEF;
      --dg:         #495057;
      --text:       #212529;
      --serif:      'Crimson Pro', Georgia, serif;
      --sans:       'Inter', system-ui, sans-serif;
      --shad-sm:    0 2px 8px rgba(30,58,95,0.08);
      --shad-md:    0 4px 16px rgba(30,58,95,0.14);
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { overflow-x:hidden; }
    body { font-family:var(--sans); color:var(--text); overflow-x:hidden; -webkit-font-smoothing:antialiased; }

    /* ── NAVBAR ──────────────────────────────────────────────────── */
    .c-nav {
      background:var(--white);
      border-bottom:1px solid var(--mg);
      padding:0.875rem 2.5%;
      position:sticky; top:0; z-index:1000;
      box-shadow:var(--shad-sm);
    }
    .c-nav-inner {
      max-width:1400px; margin:0 auto;
      display:flex; align-items:center;
      justify-content:space-between; gap:1rem;
    }

    /* Logo */
    .c-logo {
      display:flex; align-items:center; gap:0.65rem;
      text-decoration:none; flex-shrink:0; z-index:1002;
    }
    .c-logo-icon {
      width:42px; height:42px;
      background:var(--navy);
      display:flex; align-items:center; justify-content:center;
      font-family:var(--serif); font-size:1.25rem; font-weight:700;
      color:var(--gold); border:2px solid var(--gold); flex-shrink:0;
    }
    .c-logo-name {
      font-family:var(--serif);
      font-size:clamp(1.3rem,2vw,1.7rem);
      font-weight:700; color:var(--navy); letter-spacing:-0.4px;
    }
    .c-logo-badge {
      font-family:var(--sans); font-size:0.58rem; font-weight:700;
      text-transform:uppercase; letter-spacing:1.5px;
      color:var(--navy); background:var(--gold-lt);
      border:1px solid var(--gold); padding:0.15rem 0.5rem;
      border-radius:30px; flex-shrink:0;
    }

    /* Links list */
    .c-links {
      display:flex; align-items:center;
      gap:clamp(0.75rem,1.4vw,1.75rem);
      list-style:none; flex-wrap:nowrap;
    }
    .c-links a {
      font-family:var(--sans);
      font-size:clamp(0.78rem,0.95vw,0.9rem);
      font-weight:500; color:var(--text);
      text-decoration:none; white-space:nowrap;
      transition:color 0.2s; letter-spacing:0.15px;
    }
    .c-links a:hover { color:var(--navy); }

    /* CTA button */
    .c-btn {
      background:var(--navy); color:var(--white) !important;
      padding:0.52rem 1rem; border-radius:4px; font-weight:600 !important;
      font-size:clamp(0.74rem,0.9vw,0.86rem) !important;
      white-space:nowrap; transition:background 0.2s; text-decoration:none;
      display:inline-block;
    }
    .c-btn:hover { background:var(--navy-dark) !important; }

    /* Outline button */
    .c-btn-outline {
      background:transparent; color:var(--navy) !important;
      border:1.5px solid var(--navy);
      padding:0.48rem 0.9rem; border-radius:4px; font-weight:600 !important;
      font-size:clamp(0.74rem,0.9vw,0.86rem) !important;
      white-space:nowrap; transition:all 0.2s; text-decoration:none;
      display:inline-block;
    }
    .c-btn-outline:hover { background:var(--navy); color:var(--white) !important; }

    /* User pill */
    .c-user {
      display:inline-flex; align-items:center; gap:0.5rem;
      padding:0.35rem 0.65rem;
      border:1px solid var(--mg); background:var(--lg);
      border-radius:999px; font-size:0.82rem; font-weight:500;
      color:var(--text); max-width:200px;
    }
    .c-user img {
      width:24px; height:24px; border-radius:50%;
      object-fit:cover; flex-shrink:0;
    }
    .c-user-email {
      max-width:130px; overflow:hidden;
      text-overflow:ellipsis; white-space:nowrap;
    }
    .c-auth { display:inline-flex; align-items:center; gap:0.6rem; }

    /* Sign-out link */
    .c-signout {
      font-size:0.82rem; font-weight:600; color:var(--dg) !important;
      text-decoration:none; white-space:nowrap;
      padding:0.42rem 0.7rem; border:1px solid var(--mg);
      border-radius:4px; transition:background 0.2s;
    }
    .c-signout:hover { background:var(--lg); }

    /* ── HAMBURGER ───────────────────────────────────────────────── */
    .c-toggle {
      display:none; flex-direction:column; gap:5px;
      background:none; border:none; cursor:pointer;
      padding:0.45rem; z-index:1002; flex-shrink:0;
    }
    .c-toggle span {
      display:block; width:25px; height:2.5px;
      background:var(--navy); border-radius:2px;
      transition:all 0.25s ease;
    }
    .c-toggle.open span:nth-child(1) { transform:rotate(45deg) translate(7px,7px); }
    .c-toggle.open span:nth-child(2) { opacity:0; transform:scaleX(0); }
    .c-toggle.open span:nth-child(3) { transform:rotate(-45deg) translate(6px,-6px); }

    /* ── MOBILE / TABLET ≤ 1024px ────────────────────────────────── */
    @media (max-width:1024px) {
      .c-toggle { display:flex; }

      .c-links {
        display:none; position:fixed;
        top:0; left:0; width:100%; height:100vh;
        background:var(--white);
        flex-direction:column; align-items:flex-start;
        padding:5rem 2rem 3rem; gap:0; overflow-y:auto;
        z-index:1001;
      }
      .c-links.open { display:flex; }
      body.c-menu-open { overflow:hidden; }

      .c-links > li { width:100%; border-bottom:1px solid var(--mg); }
      .c-links > li > a { display:block; padding:0.95rem 0; font-size:1rem !important; font-weight:600 !important; }

      /* Auth stretches full width */
      .c-links li.c-auth-item { border-bottom:none; padding-top:1.25rem; width:100%; }
      .c-auth { flex-direction:column; align-items:stretch; gap:0.6rem; width:100%; }
      .c-user { max-width:100%; width:100%; }
      .c-btn, .c-btn-outline, .c-signout {
        display:block; width:100%; text-align:center;
        padding:0.8rem; font-size:0.95rem !important;
      }
    }

    /* ── DESKTOP ≥ 1025px ────────────────────────────────────────── */
    @media (min-width:1025px) {
      .c-toggle { display:none; }
      .c-links { display:flex !important; }
    }
  </style>
</head>

<body>


<!-- ── NAVBAR ──────────────────────────────────────────────────────────── -->
