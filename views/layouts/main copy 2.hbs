        {{/if}}
      </li>
    </ul>

  </div>
</nav>

{{{body}}}
  
 
 	

<script>
  /* ── Navbar toggle (matches CSS breakpoint 1024px) ─── */
  (function() {
    var btn   = document.getElementById('cNavToggle');
    var menu  = document.getElementById('cNavLinks');
    var BP    = 1024;

    function close() {
      btn && btn.classList.remove('open');
      btn && btn.setAttribute('aria-expanded','false');
      menu && menu.classList.remove('open');
      document.body.classList.remove('c-menu-open');
    }

    btn && btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var isOpen = menu.classList.toggle('open');
      btn.classList.toggle('open', isOpen);
      btn.setAttribute('aria-expanded', String(isOpen));
      document.body.classList.toggle('c-menu-open', isOpen);
    });

    if (menu) {
      menu.querySelectorAll('a').forEach(function(a) {
        a.addEventListener('click', close);
      });
    }

    document.addEventListener('click', function(e) {
      if (window.innerWidth <= BP &&
          menu && !menu.contains(e.target) &&
          btn && !btn.contains(e.target) &&
          menu.classList.contains('open')) close();
    });

    window.addEventListener('resize', function() {
      if (window.innerWidth > BP) close();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') close();
    });
  })();
</script>
</body>
<script>
(function () {
  function getVisitorId() {
    const name = 'zimedufinder_vid';
    const cookie = document.cookie.split('; ').find(c => c.indexOf(name + '=') === 0);
    if (cookie) return cookie.split('=')[1];
    const id = 'v_' + (crypto && crypto.randomUUID ? crypto.randomUUID() : Date.now() + '-' + Math.random().toString(36).slice(2,8));
    document.cookie = name + '=' + id + ';path=/;max-age=' + (60*60*24*365) + ';SameSite=Lax';
    return id;
  }
  const visitorId = getVisitorId();

  function sendHit(path) {
    const payload = { visitorId, path: path || location.pathname + location.search, ts: new Date().toISOString(), ua: navigator.userAgent };
    const url = '/api/track';
    const body = JSON.stringify(payload);
    if (navigator.sendBeacon) {
      const blob = new Blob([body], { type: 'application/json' });
      navigator.sendBeacon(url, blob);
      return;
    }
    fetch(url, { method: 'POST', body, headers: { 'Content-Type': 'application/json' }, keepalive: true }).catch(()=>{});
  }

  // send on load and before unload
  sendHit(location.pathname + location.search);
  window.addEventListener('pagehide', function () { sendHit(location.pathname + location.search); }, { passive: true });
})();
</script>


